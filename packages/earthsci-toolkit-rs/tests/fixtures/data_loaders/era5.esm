{
  "esm": "0.1.0",
  "metadata": {
    "name": "ERA5_PressureLevels_Fixture",
    "description": "EarthSciData.jl ERA5 pressure-level loader expressed in the STAC-like DataLoader schema. Corresponds to EarthSciData.jl src/era5.jl — struct ERA5PressureLevelFileSet (lines 56-200+) and the ERA5_VARIABLES mapping (lines 16-33). Data can be pulled via the Copernicus Climate Data Store API or from pre-downloaded monthly files (file:// mirror). The CDS API request parameters (area box, variable list, pressure levels) are derived from the simulation domain at runtime and are not schema-expressible; this fixture captures the pre-downloaded monthly-file layout with {date:%Y} and {date:%m} substitutions.",
    "authors": ["ESM Rust binding acceptance suite"],
    "tags": ["fixture", "earthscidata", "gt-0c7"]
  },
  "data_loaders": {
    "ERA5_PressureLevels": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/era5/era5_pl_{date:%Y}_{date:%m}.nc",
        "mirrors": [
          "cds://reanalysis-era5-pressure-levels?year={date:%Y}&month={date:%m}"
        ]
      },
      "temporal": {
        "file_period": "P1M",
        "frequency": "PT1H",
        "records_per_file": "auto",
        "time_variable": "valid_time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "longitude": "center",
          "latitude": "center",
          "pressure_level": "center"
        },
        "resolution": {
          "longitude": 0.25,
          "latitude": 0.25
        }
      },
      "variables": {
        "t": {
          "file_variable": "t",
          "units": "K",
          "description": "Air temperature on pressure levels"
        },
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "Eastward wind component on pressure levels"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "Northward wind component on pressure levels"
        },
        "w": {
          "file_variable": "w",
          "units": "Pa/s",
          "description": "Vertical velocity (pressure) on pressure levels"
        },
        "q": {
          "file_variable": "q",
          "units": "kg/kg",
          "description": "Specific humidity on pressure levels"
        },
        "z": {
          "file_variable": "z",
          "units": "m^2/s^2",
          "description": "Geopotential on pressure levels"
        },
        "o3": {
          "file_variable": "o3",
          "units": "kg/kg",
          "description": "Ozone mass mixing ratio on pressure levels"
        }
      },
      "regridding": {
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Hersbach et al., 2020: The ERA5 global reanalysis. Q.J.R. Meteorol. Soc., 146, 1999-2049",
        "doi": "10.1002/qj.3803",
        "url": "https://cds.climate.copernicus.eu/cdsapp#!/dataset/reanalysis-era5-pressure-levels"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis", "pressure-levels"],
        "earthscidata_source": "src/era5.jl",
        "earthscidata_struct": "ERA5PressureLevelFileSet",
        "earthscidata_variable_map": {
          "temperature": "t",
          "u_component_of_wind": "u",
          "v_component_of_wind": "v",
          "vertical_velocity": "w",
          "specific_humidity": "q",
          "geopotential": "z",
          "ozone_mass_mixing_ratio": "o3"
        }
      }
    }
  },
  "models": {
    "fixture_stub": {
      "variables": {
        "x": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  }
}
