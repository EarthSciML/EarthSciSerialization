{
  "esm": "0.1.0",
  "metadata": {
    "name": "USGS3DEP_Fixture",
    "description": "EarthSciData.jl USGS3DEP elevation and slopes loaders expressed in the STAC-like DataLoader schema. Covers two structs from src/usgs3dep.jl: USGS3DEPFileSet (lines 21-27) with its constructor (lines 44-108) and exportImage URL builder (lines 115-129) for raw elevation; and USGS3DEPSlopeFileSet (lines 195-198) with its derivation machinery in loadslice! (lines 218-265) for dzdx/dzdy terrain slopes. Both are static datasets served by the USGS National Map ArcGIS ImageServer as GeoTIFF. bbox/width/height are derived from the simulation domain at runtime; the custom substitutions {bbox_w}/{bbox_s}/{bbox_e}/{bbox_n}/{width}/{height} encode that API contract. The slope loader fetches the same tile as USGS3DEP and applies a central-finite-difference derivative at load time — this derivation is runtime behavior (analogous to how CEDS sums over sectors at runtime) and is NOT schema-described.",
    "authors": ["ESM Rust binding acceptance suite"],
    "tags": ["fixture", "earthscidata", "gt-0c7"]
  },
  "data_loaders": {
    "USGS3DEP_Elevation": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_w},{bbox_s},{bbox_e},{bbox_n}&bboxSR=4326&imageSR=4326&size={width},{height}&format=tiff&pixelType=F32&interpolation=+RSP_BilinearInterpolation&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 9.25926e-5,
          "lat": 9.25926e-5
        }
      },
      "variables": {
        "elevation": {
          "file_variable": "elevation",
          "units": "m",
          "description": "Terrain elevation above sea level (1/3 arc-second ~ 10m)"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "US Geological Survey, 3D Elevation Program (3DEP), 1/3 arc-second DEM",
        "url": "https://elevation.nationalmap.gov/"
      },
      "metadata": {
        "tags": ["static", "elevation", "terrain", "us-only"],
        "earthscidata_source": "src/usgs3dep.jl",
        "earthscidata_struct": "USGS3DEPFileSet",
        "earthscidata_coverage": "CONUS, Alaska, Hawaii, US territories",
        "earthscidata_note": "Bounding box, width, and height are derived from the simulation domain at runtime (lines 44-108). Pixel count is capped at 4000x4000."
      }
    },
    "USGS3DEP_Slopes": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_w},{bbox_s},{bbox_e},{bbox_n}&bboxSR=4326&imageSR=4326&size={width},{height}&format=tiff&pixelType=F32&interpolation=+RSP_BilinearInterpolation&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 9.25926e-5,
          "lat": 9.25926e-5
        }
      },
      "variables": {
        "dzdx": {
          "file_variable": "elevation",
          "units": "1",
          "description": "Dimensionless terrain slope in the east (x) direction — runtime derives dzdx via central finite differences over elevation with metric scale factor _LON2M*cos(lat)."
        },
        "dzdy": {
          "file_variable": "elevation",
          "units": "1",
          "description": "Dimensionless terrain slope in the north (y) direction — runtime derives dzdy via central finite differences over elevation with metric scale factor _LAT2M."
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "US Geological Survey, 3D Elevation Program (3DEP), 1/3 arc-second DEM — terrain slopes derived via central finite differences",
        "url": "https://elevation.nationalmap.gov/"
      },
      "metadata": {
        "tags": ["static", "slope", "terrain", "derived", "us-only"],
        "earthscidata_source": "src/usgs3dep.jl",
        "earthscidata_struct": "USGS3DEPSlopeFileSet",
        "earthscidata_components": ["dzdx", "dzdy"],
        "earthscidata_note": "Derived wrapper over USGS3DEPFileSet: loadslice! (lines 218-265) reads elevation via the parent loader and applies central finite differences. The derivation is runtime behavior — the schema describes what the loader exposes (slope fields on the same grid) without encoding the finite-difference kernel."
      }
    }
  },
  "models": {
    "fixture_stub": {
      "variables": {
        "x": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  }
}
