{
  "esm": "0.1.0",
  "metadata": {
    "name": "LANDFIRE_Fixture",
    "description": "EarthSciData.jl LANDFIRE loader expressed in the STAC-like DataLoader schema. Corresponds to EarthSciData.jl src/landfire.jl — struct LANDFIREFileSet (lines 65-73), the constructor (lines 90-107), the exportImage URL builder (lines 114-129), and varnames/loadmetadata (lines 135-159). Additional static-field fixture covering the 'Slopes / static fields' category from the acceptance criteria. Like USGS3DEP, the bbox/width/height are derived from the simulation domain at runtime; the categorical fuel model codes are integer pixel values and the nearest-neighbour regridder is selected at runtime.",
    "authors": ["ESM Rust binding acceptance suite"],
    "tags": ["fixture", "earthscidata", "gt-0c7"]
  },
  "data_loaders": {
    "LANDFIRE_FBFM13": {
      "kind": "static",
      "source": {
        "url_template": "https://lfps.usgs.gov/arcgis/rest/services/Landfire_{version}/{version}_{product}_CONUS/ImageServer/exportImage?bbox={bbox_w},{bbox_s},{bbox_e},{bbox_n}&bboxSR=4326&imageSR=4326&size={width},{height}&format=tiff&pixelType=S16&interpolation=+RSP_NearestNeighbor&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.000277778,
          "lat": 0.000277778
        }
      },
      "variables": {
        "fuel_model": {
          "file_variable": "fuel_model",
          "units": "1",
          "description": "Anderson 13 fire behavior fuel model (integer codes 1-13, 91=urban, 92=snow/ice, 93=agriculture, 98=water, 99=barren)"
        }
      },
      "regridding": {
        "fill_value": 99.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "LANDFIRE: Landscape Fire and Resource Management Planning Tools",
        "url": "https://landfire.gov/"
      },
      "metadata": {
        "tags": ["static", "land-cover", "fuel-model", "categorical", "us-only"],
        "earthscidata_source": "src/landfire.jl",
        "earthscidata_struct": "LANDFIREFileSet",
        "earthscidata_products": ["FBFM13", "FBFM40"],
        "earthscidata_version_example": "LF2022",
        "earthscidata_note": "Categorical data — runtime uses nearest-neighbour interpolation (extrapolation 'clamp' reflects that boundary cells hold their value). {product}, {version}, {bbox_*}, {width}, {height} are custom substitutions resolved at runtime."
      }
    }
  },
  "models": {
    "fixture_stub": {
      "variables": {
        "x": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  }
}
