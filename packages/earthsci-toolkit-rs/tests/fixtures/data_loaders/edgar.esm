{
  "esm": "0.1.0",
  "metadata": {
    "name": "EDGARv81_Fixture",
    "description": "EarthSciData.jl EDGAR v8.1 monthly emissions loader expressed in the STAC-like DataLoader schema. Corresponds to EarthSciData.jl src/edgar_v81_monthly.jl — struct EDGARv81MonthlyEmisFileSet (lines 91-140) with relpath (lines 148-152) and the EDGAR_V81_SUBSTANCES table (lines 3-5). Upstream files are delivered as a per-substance, per-sector ZIP containing one .nc per year; the runtime unpacks the ZIP and opens the yearly files as a single multi-year dataset. That unpack step is runtime behavior, so the url_template below points at the per-year NC file after extraction (the runtime is free to substitute the ZIP path if it handles unpacking).",
    "authors": ["ESM Rust binding acceptance suite"],
    "tags": ["fixture", "earthscidata", "gt-0c7"]
  },
  "data_loaders": {
    "EDGARv81Monthly": {
      "kind": "grid",
      "source": {
        "url_template": "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81_FT2022_AP_new/monthly/{species}/bkl_{sector}/bkl_{sector}_flx_nc/v81_FT2022_AP_new_{species}_{date:%Y}_{sector}.nc",
        "mirrors": [
          "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81_FT2022_AP_new/monthly/{species}/bkl_{sector}/bkl_{sector}_flx_nc.zip"
        ]
      },
      "temporal": {
        "start": "2000-01-01T00:00:00Z",
        "end": "2022-12-31T23:59:59Z",
        "file_period": "P1Y",
        "frequency": "P1M",
        "records_per_file": "auto",
        "time_variable": "time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.1,
          "lat": 0.1
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "BC": {
          "file_variable": "emi_bc",
          "units": "kg/m^2/s",
          "description": "Black carbon flux"
        },
        "CO": {
          "file_variable": "emi_co",
          "units": "kg/m^2/s",
          "description": "CO flux"
        },
        "NH3": {
          "file_variable": "emi_nh3",
          "units": "kg/m^2/s",
          "description": "NH3 flux"
        },
        "NMVOC": {
          "file_variable": "emi_nmvoc",
          "units": "kg/m^2/s",
          "description": "NMVOC flux"
        },
        "NOx": {
          "file_variable": "emi_nox",
          "units": "kg/m^2/s",
          "description": "NOx flux (as NO2)"
        },
        "OC": {
          "file_variable": "emi_oc",
          "units": "kg/m^2/s",
          "description": "Organic carbon flux"
        },
        "PM10": {
          "file_variable": "emi_pm10",
          "units": "kg/m^2/s",
          "description": "PM10 flux"
        },
        "PM25": {
          "file_variable": "emi_pm2p5",
          "units": "kg/m^2/s",
          "description": "PM2.5 flux"
        },
        "SO2": {
          "file_variable": "emi_so2",
          "units": "kg/m^2/s",
          "description": "SO2 flux"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Crippa, M., et al., EDGAR v8.1 Monthly Air Pollutant Emissions (EDGARv8.1_AP), European Commission, JRC",
        "url": "https://edgar.jrc.ec.europa.eu/dataset_ap81"
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "monthly"],
        "earthscidata_source": "src/edgar_v81_monthly.jl",
        "earthscidata_struct": "EDGARv81MonthlyEmisFileSet",
        "earthscidata_substances": ["BC", "CO", "NH3", "NMVOC", "NOx", "OC", "PM10", "PM2.5", "SO2"],
        "earthscidata_note": "The runtime unpacks the per-sector ZIP mirror into yearly .nc files; the primary url_template is the extracted form."
      }
    }
  },
  "models": {
    "fixture_stub": {
      "variables": {
        "x": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  }
}
