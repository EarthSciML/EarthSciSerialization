{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_04_weno_wide_stencil",
    "description": "WENO-like wide stencil on u[1:20]. flux[i] = u[i-2] - 5u[i-1] + 10u[i] - 10u[i+1] + 5u[i+2] - u[i+3] for i in 3:17. D(u[i]) = -(flux[i] - flux[i-1]) for i in 4:17. Boundary cells [1,2,3,18,19,20] held at zero via scalar BCs. Mirrors MTK fork test #4. Smoke test: with zero initial condition the solution stays at zero and the solver integrates successfully — verifies the 6-point stencil compiles and links into the arrayop block-tearing path.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "wide_stencil", "flux"]
  },
  "models": {
    "WENO": {
      "variables": {
        "u": { "type": "state" },
        "flux": { "type": "state" }
      },
      "equations": [
        {
          "_comment": "flux[i] = u[i-2] - 5u[i-1] + 10u[i] - 10u[i+1] + 5u[i+2] - u[i+3], i in 3..17",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "index", "args": ["flux", "i"] },
            "ranges": { "i": [3, 17] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": {
              "op": "+",
              "args": [
                { "op": "index", "args": ["u", { "op": "-", "args": ["i", 2] }] },
                { "op": "*", "args": [-5, { "op": "index", "args": ["u", { "op": "-", "args": ["i", 1] }] }] },
                { "op": "*", "args": [10, { "op": "index", "args": ["u", "i"] }] },
                { "op": "*", "args": [-10, { "op": "index", "args": ["u", { "op": "+", "args": ["i", 1] }] }] },
                { "op": "*", "args": [5, { "op": "index", "args": ["u", { "op": "+", "args": ["i", 2] }] }] },
                { "op": "*", "args": [-1, { "op": "index", "args": ["u", { "op": "+", "args": ["i", 3] }] }] }
              ]
            },
            "ranges": { "i": [3, 17] }
          }
        },
        {
          "_comment": "D(u[i]) = -(flux[i] - flux[i-1]), i in 4..17",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "D", "args": [{ "op": "index", "args": ["u", "i"] }], "wrt": "t" },
            "ranges": { "i": [4, 17] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": {
              "op": "-",
              "args": [
                { "op": "-", "args": [
                  { "op": "index", "args": ["flux", "i"] },
                  { "op": "index", "args": ["flux", { "op": "-", "args": ["i", 1] }] }
                ]}
              ]
            },
            "ranges": { "i": [4, 17] }
          }
        },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 1] }],  "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 2] }],  "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 3] }],  "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 18] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 19] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 20] }], "wrt": "t" }, "rhs": 0.0 }
      ],
      "tolerance": { "abs": 1.0e-10 },
      "tests": [
        {
          "id": "zero_ic_stability",
          "description": "With u[i] = 0 everywhere the right-hand side is identically zero, so the solver must return Success and u[i] must remain at 0. Sanity check only — non-trivial numerical conformance for this stencil lives in the native Julia MTK-fork test.",
          "initial_conditions": {
            "u[1]": 0.0, "u[2]": 0.0, "u[3]": 0.0, "u[4]": 0.0, "u[5]": 0.0,
            "u[6]": 0.0, "u[7]": 0.0, "u[8]": 0.0, "u[9]": 0.0, "u[10]": 0.0,
            "u[11]": 0.0, "u[12]": 0.0, "u[13]": 0.0, "u[14]": 0.0, "u[15]": 0.0,
            "u[16]": 0.0, "u[17]": 0.0, "u[18]": 0.0, "u[19]": 0.0, "u[20]": 0.0
          },
          "time_span": { "start": 0.0, "end": 0.01 },
          "assertions": [
            { "variable": "u[1]",  "time": 0.01, "expected": 0.0 },
            { "variable": "u[10]", "time": 0.01, "expected": 0.0 },
            { "variable": "u[17]", "time": 0.01, "expected": 0.0 },
            { "variable": "u[20]", "time": 0.01, "expected": 0.0 }
          ]
        }
      ]
    }
  }
}
