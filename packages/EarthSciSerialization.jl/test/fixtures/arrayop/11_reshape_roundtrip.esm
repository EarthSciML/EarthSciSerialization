{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_11_reshape_roundtrip",
    "description": "Exercises `reshape`. u[1:6] is held constant (D(u[i]) = 0). A scalar probe variable `diff` integrates the difference between u[3] and the 3rd element of `reshape(reshape(u,[2,3]),[6])`, i.e. the round-trip through a 2x3 view and back to a 6-vector. If reshape is shape-preserving in column-major order (which both Julia's `Symbolics.reshape` and the downstream bindings must agree on), the difference is identically zero, diff stays at 0, and the analytical value at t=1 is exactly 0.0. A second scalar `col` directly samples `reshape(u,[2,3])[1,2]` which in column-major is element 3 of u — so col(t) integrates u[3] = 3.0 giving col(1) = 3.0.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "reshape"]
  },
  "models": {
    "ReshapeRoundTrip": {
      "variables": {
        "u":    { "type": "state" },
        "diff": { "type": "state" },
        "col":  { "type": "state" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 1] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 2] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 3] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 4] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 5] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 6] }], "wrt": "t" }, "rhs": 0.0 },
        {
          "_comment": "D(diff) = index(u, 3) - index(reshape(reshape(u, [2,3]), [6]), 3). Round-trip must preserve element order, so this evaluates to 0.",
          "lhs": { "op": "D", "args": ["diff"], "wrt": "t" },
          "rhs": {
            "op": "-",
            "args": [
              { "op": "index", "args": ["u", 3] },
              { "op": "index", "args": [
                { "op": "reshape", "args": [
                  { "op": "reshape", "args": ["u"], "shape": [2, 3] }
                ], "shape": [6] },
                3
              ]}
            ]
          }
        },
        {
          "_comment": "D(col) = index(reshape(u, [2,3]), 1, 2). In column-major this is u[3] = 3.0.",
          "lhs": { "op": "D", "args": ["col"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "reshape", "args": ["u"], "shape": [2, 3] },
              1, 2
            ]
          }
        }
      ],
      "tolerance": { "abs": 1.0e-9 },
      "tests": [
        {
          "id": "roundtrip_and_column_major",
          "description": "u held at [1,2,3,4,5,6]. diff stays 0 (roundtrip). col integrates 3.0 so col(1)=3.0.",
          "initial_conditions": {
            "u[1]": 1.0, "u[2]": 2.0, "u[3]": 3.0, "u[4]": 4.0, "u[5]": 5.0, "u[6]": 6.0,
            "diff": 0.0, "col": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "diff", "time": 1.0, "expected": 0.0 },
            { "variable": "col",  "time": 1.0, "expected": 3.0, "tolerance": { "rel": 1.0e-6 } }
          ]
        }
      ]
    }
  }
}
