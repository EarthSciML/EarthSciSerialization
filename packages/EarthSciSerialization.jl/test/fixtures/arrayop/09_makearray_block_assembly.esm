{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_09_makearray_block_assembly",
    "description": "Exercises the `makearray` op by assembling a 3x3 matrix from two overlapping constant-valued rectangular regions (region 1 = [1:3,1:3] at value 1.0, region 2 = [2:3,2:3] at value 2.0). Each cell u[i,j] runs the trivial linear-growth ODE D(u[i,j]) = C[i,j] starting from u[i,j]=0. After t=1 we check that the overlapping cells picked up the later region's value (2.0) and the non-overlapping border cells hold the first region's value (1.0).",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "makearray"]
  },
  "models": {
    "MakeArrayBlocks": {
      "variables": {
        "u": { "type": "state" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 1, 1] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     1, 1
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 1, 2] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     1, 2
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 1, 3] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     1, 3
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 2, 1] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     2, 1
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 2, 2] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     2, 2
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 2, 3] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     2, 3
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 3, 1] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     3, 1
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 3, 2] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     3, 2
                   ]}},
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["u", 3, 3] }], "wrt": "t" },
          "rhs": { "op": "index",
                   "args": [
                     { "op": "makearray", "args": [],
                       "regions": [[[1,3],[1,3]], [[2,3],[2,3]]],
                       "values": [1.0, 2.0] },
                     3, 3
                   ]}}
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "overlapping_blocks_at_t1",
          "description": "Starting from u[i,j] = 0, integrating D(u[i,j]) = C[i,j] to t=1 yields u[i,j](1) = C[i,j]. The outer border is 1.0 (region 1) and the 2x2 overlap region (rows 2..3, cols 2..3) is 2.0 (region 2, later in the sequence).",
          "initial_conditions": {
            "u[1,1]": 0.0, "u[1,2]": 0.0, "u[1,3]": 0.0,
            "u[2,1]": 0.0, "u[2,2]": 0.0, "u[2,3]": 0.0,
            "u[3,1]": 0.0, "u[3,2]": 0.0, "u[3,3]": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "u[1,1]", "time": 1.0, "expected": 1.0 },
            { "variable": "u[1,2]", "time": 1.0, "expected": 1.0 },
            { "variable": "u[1,3]", "time": 1.0, "expected": 1.0 },
            { "variable": "u[2,1]", "time": 1.0, "expected": 1.0 },
            { "variable": "u[2,2]", "time": 1.0, "expected": 2.0 },
            { "variable": "u[2,3]", "time": 1.0, "expected": 2.0 },
            { "variable": "u[3,1]", "time": 1.0, "expected": 1.0 },
            { "variable": "u[3,2]", "time": 1.0, "expected": 2.0 },
            { "variable": "u[3,3]", "time": 1.0, "expected": 2.0 }
          ]
        }
      ]
    }
  }
}
