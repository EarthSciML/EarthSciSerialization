{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_14_broadcast_elementwise",
    "description": "Exercises the `broadcast` op with operands of compatible but different shapes. a is a (3,) vector and b is reshaped to a (1, 3) row, so broadcast(+, a, reshape(b,[1,3])) produces a (3, 3) matrix where result[i, j] = a[i] + b[j]. Three scalar probes sample distinct positions of the result to verify both shape and element-wise semantics.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "broadcast"]
  },
  "models": {
    "BroadcastShapes": {
      "variables": {
        "a":    { "type": "state" },
        "b":    { "type": "state" },
        "corner": { "type": "state" },
        "middle": { "type": "state" },
        "far":    { "type": "state" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 1] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 2] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 3] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["b", 1] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["b", 2] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["b", 3] }], "wrt": "t" }, "rhs": 0.0 },
        {
          "_comment": "corner = broadcast(+, a, reshape(b,[1,3]))[1, 1] = a[1] + b[1] = 1 + 100 = 101.",
          "lhs": { "op": "D", "args": ["corner"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "broadcast", "args": [
                "a",
                { "op": "reshape", "args": ["b"], "shape": [1, 3] }
              ], "fn": "+" },
              1, 1
            ]
          }
        },
        {
          "_comment": "middle = broadcast(+, a, reshape(b,[1,3]))[2, 3] = a[2] + b[3] = 2 + 300 = 302.",
          "lhs": { "op": "D", "args": ["middle"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "broadcast", "args": [
                "a",
                { "op": "reshape", "args": ["b"], "shape": [1, 3] }
              ], "fn": "+" },
              2, 3
            ]
          }
        },
        {
          "_comment": "far = broadcast(+, a, reshape(b,[1,3]))[3, 2] = a[3] + b[2] = 3 + 200 = 203.",
          "lhs": { "op": "D", "args": ["far"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "broadcast", "args": [
                "a",
                { "op": "reshape", "args": ["b"], "shape": [1, 3] }
              ], "fn": "+" },
              3, 2
            ]
          }
        }
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "broadcast_shape_check",
          "description": "Three distinct output elements (corners and an interior cell) each equal a[i] + b[j] confirming the shape of the broadcast result and its element-wise values.",
          "initial_conditions": {
            "a[1]": 1.0, "a[2]": 2.0, "a[3]": 3.0,
            "b[1]": 100.0, "b[2]": 200.0, "b[3]": 300.0,
            "corner": 0.0, "middle": 0.0, "far": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "corner", "time": 1.0, "expected": 101.0 },
            { "variable": "middle", "time": 1.0, "expected": 302.0 },
            { "variable": "far",    "time": 1.0, "expected": 203.0 }
          ]
        }
      ]
    }
  }
}
