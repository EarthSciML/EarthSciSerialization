{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_02_mixed_ode_algebraic",
    "description": "Mixed ODE + algebraic equation on N=5 arrays. D(u[i]) = v[i], v[i] = -u[i]. The algebraic variable v must be eliminated during mtkcompile so the compiled system has N unknowns. Final u_i(1) = i*exp(-1). Mirrors MTK fork test #2.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "algebraic_elimination"]
  },
  "models": {
    "MixedODEAlg": {
      "variables": {
        "u": { "type": "state" },
        "v": { "type": "state" }
      },
      "equations": [
        {
          "_comment": "D(u[i]) = v[i]",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "D", "args": [{ "op": "index", "args": ["u", "i"] }], "wrt": "t" },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "index", "args": ["v", "i"] },
            "ranges": { "i": [1, 5] }
          }
        },
        {
          "_comment": "v[i] = -u[i]",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "index", "args": ["v", "i"] },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "-", "args": [{ "op": "index", "args": ["u", "i"] }] },
            "ranges": { "i": [1, 5] }
          }
        }
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "analytical_t1",
          "description": "u analytically i*exp(-t). Check u[i](1) for i in 1..5.",
          "initial_conditions": {
            "u[1]": 1.0, "u[2]": 2.0, "u[3]": 3.0, "u[4]": 4.0, "u[5]": 5.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "u[1]", "time": 1.0, "expected": 0.36787944117144233 },
            { "variable": "u[3]", "time": 1.0, "expected": 1.103638323514327 },
            { "variable": "u[5]", "time": 1.0, "expected": 1.8393972058572117 }
          ]
        }
      ]
    }
  }
}
