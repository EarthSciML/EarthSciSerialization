{
  "esm": "0.1.0",
  "metadata": {
    "name": "EDGAR_v81_SO2_ENE_example",
    "description": "Covers EarthSciData.jl/src/edgar_v81_monthly.jl EDGARv81MonthlyEmisFileSet. Files are bundled per substance+sector as zips (bkl_<sector>/bkl_<sector>_flx_nc.zip) of per-year netCDFs on a 0.1-degree global lat-lon grid. Each .nc has 12 monthly records per year. EDGAR v8.1 monthly SO2 emissions from the energy (ENE) sector.",
    "authors": ["ESM fixture"],
    "tags": ["data-loader", "emissions", "edgar", "anthropogenic"]
  },
  "models": {
    "Stub": { "variables": {}, "equations": [] }
  },
  "data_loaders": {
    "EDGAR_v81_SO2_ENE": {
      "kind": "grid",
      "source": {
        "url_template": "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81/{species}/bkl_ENE/v8.1_FT2022_{species}_{date:%Y}_ENE_bkl.nc"
      },
      "temporal": {
        "start": "1970-01-01T00:00:00Z",
        "end": "2022-12-31T23:59:59Z",
        "file_period": "P1Y",
        "frequency": "P1M",
        "records_per_file": 12,
        "time_variable": "time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.1,
          "lat": 0.1
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "SO2_emiss": {
          "file_variable": "fluxes",
          "units": "kg m^-2 s^-1",
          "description": "SO2 emission flux from the energy (ENE) sector"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Crippa, M., et al. (2024) EDGAR v8.1 global air pollutant emissions. European Commission — Joint Research Centre.",
        "url": "https://edgar.jrc.ec.europa.eu/"
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "monthly"],
        "version": "v8.1",
        "species": "SO2",
        "sector": "ENE"
      }
    }
  }
}
