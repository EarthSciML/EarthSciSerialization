{
  "esm": "0.1.0",
  "metadata": {
    "name": "GEOSFP_A3dyn_example",
    "description": "Covers EarthSciData.jl/src/geosfp.jl GEOSFPFileSet: mirror + domain + filetype + hourly/daily cadence (relpath yyyy/mm/yyyymmdd in GEOSFP.<date>.<filetype>.<domain>.nc). Default mirror: https://geos-chem.s3-us-west-2.amazonaws.com. Staggering from geosfp_staggering(); A3dyn is 3D dynamics on center/center/center. CRS is longitude/latitude WGS84. GEOS-FP A3dyn 3-hour average 3D dynamics for a 2x2.5 global domain.",
    "authors": ["ESM fixture"],
    "tags": ["data-loader", "meteorology", "reanalysis", "geosfp"]
  },
  "models": {
    "Stub": {
      "variables": {},
      "equations": []
    }
  },
  "data_loaders": {
    "GEOSFP_A3dyn_2x2_5": {
      "kind": "grid",
      "source": {
        "url_template": "https://geos-chem.s3-us-west-2.amazonaws.com/GEOS_2x2.5/GEOS_FP/{date:%Y}/{date:%m}/GEOSFP.{date:%Y%m%d}.A3dyn.2x2.5.nc",
        "mirrors": [
          "file:///data/GEOS_2x2.5/GEOS_FP/{date:%Y}/{date:%m}/GEOSFP.{date:%Y%m%d}.A3dyn.2x2.5.nc"
        ]
      },
      "temporal": {
        "file_period": "P1D",
        "frequency": "PT3H",
        "records_per_file": 8,
        "time_variable": "time"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center",
          "lev": "center"
        },
        "resolution": {
          "lon": 2.5,
          "lat": 2.0
        },
        "extent": {
          "lon": [-180.0, 177.5],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "U": {
          "file_variable": "U",
          "units": "m s^-1",
          "description": "Eastward wind component"
        },
        "V": {
          "file_variable": "V",
          "units": "m s^-1",
          "description": "Northward wind component"
        },
        "OMEGA": {
          "file_variable": "OMEGA",
          "units": "Pa s^-1",
          "description": "Vertical pressure velocity"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Global Modeling and Assimilation Office (GMAO), NASA GSFC — GEOS-FP assimilation",
        "url": "https://gmao.gsfc.nasa.gov/GEOS_systems/"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis"],
        "domain": "2x2.5",
        "filetype": "A3dyn"
      }
    }
  }
}
