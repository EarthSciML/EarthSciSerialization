{
  "_comment": "GEOS-FP (NASA Global Modeling and Assimilation Office) reanalysis fixture. Expresses an instantiation of EarthSciData.jl GEOSFPFileSet for domain='0.25x0.3125_NA', filetype='A3dyn'. Source: EarthSciData.jl src/geosfp.jl (struct GEOSFPFileSet at lines 50-89, relpath at lines 97-110). The url_template encodes the path grammar 'GEOS_{domain}/GEOS_FP/{year}/{month}/GEOSFP.{yyyymmdd}.{filetype}.{domain_no_underscore}.nc' via {date} substitutions.",
  "esm": "0.1.0",
  "metadata": {
    "name": "GEOSFPFixture",
    "description": "GEOS-FP reanalysis data (0.25x0.3125 NA grid, A3dyn filetype) expressed in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "geosfp", "reanalysis"]
  },
  "data_loaders": {
    "GEOSFP": {
      "kind": "grid",
      "source": {
        "url_template": "https://geos-chem.s3-us-west-2.amazonaws.com/GEOS_0.25x0.3125_NA/GEOS_FP/{date:%Y}/{date:%m}/GEOSFP.{date:%Y%m%d}.A3dyn.025x03125.NA.nc"
      },
      "temporal": {
        "file_period": "P1D",
        "frequency": "PT3H",
        "records_per_file": 8,
        "time_variable": "time"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.3125,
          "lat": 0.25
        },
        "extent": {
          "lon": [-140.0, -40.0],
          "lat": [10.0, 70.0]
        }
      },
      "variables": {
        "U": {
          "file_variable": "U",
          "units": "m/s",
          "description": "Eastward wind component"
        },
        "V": {
          "file_variable": "V",
          "units": "m/s",
          "description": "Northward wind component"
        },
        "OMEGA": {
          "file_variable": "OMEGA",
          "units": "Pa/s",
          "description": "Vertical pressure velocity"
        }
      },
      "regridding": {
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Global Modeling and Assimilation Office (GMAO), NASA GSFC. GEOS Forward Processing (GEOS-FP).",
        "url": "https://gmao.gsfc.nasa.gov/GEOS_systems/",
        "doi": "10.5067/A7S6XP56VZWS"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis", "geoschem"],
        "earthscidata_source": "src/geosfp.jl::GEOSFPFileSet",
        "domain": "0.25x0.3125_NA",
        "filetype": "A3dyn"
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
