      "kind": "grid",
      "source": {
        "url_template": "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81_AP/{species}/TOTALS/bkl_{sector}_flx_nc.zip"
      },
      "temporal": {
