      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": 3600,
            "spacing": "uniform"
          },
          "lat": {
            "n": 1800,
            "spacing": "uniform"
          }
        }
      },
      "variables": {
        "flx": {
          "file_variable": "flx",
          "units": "kg/m^2/s",
          "description": "NOx flux from road transport excluding residential heating (TRO_noRES sector)"
        }
      },
      "reference": {
        "citation": "Crippa, M. et al. (2023). EDGAR v8.1 Global Air Pollutant Emissions (1970-2022). EU Joint Research Centre.",
        "url": "https://edgar.jrc.ec.europa.eu/dataset_ap81"
      },
      "metadata": {
