{
  "_comment": "CEDS (Community Emissions Data System) fixture. Expresses an instantiation of EarthSciData.jl CEDSFileSet with species='SO2'. Source: EarthSciData.jl src/ceds.jl (struct CEDSFileSet at lines 59-151, relpath at lines 159-167). The url_template encodes the chunked path grammar 'input4MIPs/CMIP7/CMIP/PNNL-JGCRI/{version}/atmos/mon/{species}_em_anthro/gn/{data_version}/{species}-em-anthro_..._{Y1}01-{Y2}12.nc'. Sectors are aggregated at runtime (sum or filter) and per-species files are accessed by substituting {species}.",
  "esm": "0.1.0",
  "metadata": {
    "name": "CEDSFixture",
    "description": "CEDS CMIP anthropogenic emissions (0.5deg global, SO2 species, all sectors) in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "ceds", "emissions", "anthropogenic"]
  },
  "data_loaders": {
    "CEDS_SO2": {
      "kind": "grid",
      "source": {
        "url_template": "https://esgf-node.ornl.gov/thredds/fileServer/user_pub_work/input4MIPs/CMIP7/CMIP/PNNL-JGCRI/CEDS-CMIP-2025-04-18/atmos/mon/{species}_em_anthro/gn/v20250421/{species}-em-anthro_input4MIPs_emissions_CMIP_CEDS-CMIP-2025-04-18_gn_195001-{date:%Y}12.nc"
      },
      "temporal": {
        "start": "1750-01-01T00:00:00Z",
        "end": "2023-12-31T23:59:59Z",
        "file_period": "P50Y",
        "frequency": "P1M",
        "time_variable": "time"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.5,
          "lat": 0.5
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "SO2_em_anthro": {
          "file_variable": "SO2_em_anthro",
          "units": "kg/m^2/s",
          "description": "SO2 anthropogenic emissions summed across 8 sectors (AIR/ENE/IND/NRTR/RCO/SHP/SLV/WST). Runtime may filter by selected sector indices (0-7)."
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Hoesly, R. M. et al. (2018). Historical (1750-2014) anthropogenic emissions of reactive gases and aerosols from the Community Emissions Data System (CEDS). Geosci. Model Dev., 11, 369-408.",
        "url": "https://esgf-node.ornl.gov/search/input4mips/?project=input4MIPs&institution_id=PNNL-JGCRI",
        "doi": "10.5194/gmd-11-369-2018"
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "cmip"],
        "earthscidata_source": "src/ceds.jl::CEDSFileSet",
        "species": "SO2",
        "version": "CEDS-CMIP-2025-04-18",
        "data_version": "v20250421",
        "sectors": "all",
        "notes": "Each file contains one species and has dimensions (time, sector, lat, lon). Runtime permutes longitude from [0,360) to [-180,180)."
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
