{
  "_comment": "ERA5 pressure-level reanalysis fixture. Expresses an instantiation of EarthSciData.jl ERA5PressureLevelFileSet. Source: EarthSciData.jl src/era5.jl (struct ERA5PressureLevelFileSet at lines 56-211, relpath at lines 213-217). CDS API source is represented by the 'cds://' scheme in url_template; the file path pattern era5_pl_{YYYY}_{MM}.nc comes from relpath. Variables list mirrors ERA5_VARIABLES at lines 16-33.",
  "esm": "0.1.0",
  "metadata": {
    "name": "ERA5Fixture",
    "description": "ERA5 pressure-level reanalysis (CDS API) expressed in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "era5", "reanalysis", "pressure-level"]
  },
  "data_loaders": {
    "ERA5": {
      "kind": "grid",
      "source": {
        "url_template": "cds://reanalysis-era5-pressure-levels/era5_pl_{date:%Y}_{date:%m}.nc",
        "mirrors": [
          "file:///data/era5/era5_pl_{date:%Y}_{date:%m}.nc"
        ]
      },
      "temporal": {
        "file_period": "P1M",
        "frequency": "PT1H",
        "time_variable": "valid_time"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center",
          "pressure_level": "center"
        },
        "resolution": {
          "lon": 0.25,
          "lat": 0.25
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0],
          "pressure_level": [1.0, 1000.0]
        }
      },
      "variables": {
        "t": {
          "file_variable": "t",
          "units": "K",
          "description": "Air temperature (ERA5 variable 'temperature')"
        },
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "U component of wind (ERA5 variable 'u_component_of_wind')"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "V component of wind (ERA5 variable 'v_component_of_wind')"
        },
        "w": {
          "file_variable": "w",
          "units": "Pa/s",
          "description": "Vertical velocity (ERA5 variable 'vertical_velocity')"
        },
        "q": {
          "file_variable": "q",
          "units": "kg/kg",
          "description": "Specific humidity"
        },
        "z": {
          "file_variable": "z",
          "units": "m^2/s^2",
          "description": "Geopotential"
        },
        "o3": {
          "file_variable": "o3",
          "units": "kg/kg",
          "description": "Ozone mass mixing ratio"
        }
      },
      "regridding": {
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Hersbach, H. et al. (2020): The ERA5 global reanalysis. Quart. J. Roy. Meteorol. Soc. 146, 1999-2049.",
        "url": "https://cds.climate.copernicus.eu/cdsapp#!/dataset/reanalysis-era5-pressure-levels",
        "doi": "10.1002/qj.3803"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis", "pressure-level"],
        "earthscidata_source": "src/era5.jl::ERA5PressureLevelFileSet",
        "notes": "ERA5 latitude is stored in decreasing order (90..-90) and longitudes in [0,360); runtime reverses and shifts these to match [-180,180)."
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
