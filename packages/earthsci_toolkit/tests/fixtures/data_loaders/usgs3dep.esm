{
  "_comment": "USGS 3DEP elevation fixture. Expresses an instantiation of EarthSciData.jl USGS3DEPFileSet (static elevation at ~1/3 arc-second over a CONUS bounding box). Source: EarthSciData.jl src/usgs3dep.jl (struct USGS3DEPFileSet at lines 21-27, constructor at lines 44-108, relpath at lines 110-113, url at lines 115-130). This is a static (time-invariant) dataset served by a REST ImageServer API, so url_template uses the REST endpoint with bbox/size query parameters. No temporal block because kind='static'.",
  "esm": "0.1.0",
  "metadata": {
    "name": "USGS3DEPFixture",
    "description": "USGS 3D Elevation Program (3DEP) elevation data over a CONUS bounding box in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "usgs3dep", "elevation", "static"]
  },
  "data_loaders": {
    "USGS3DEP": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_west},{bbox_south},{bbox_east},{bbox_north}&size={width},{height}&format=tiff&bboxSR=4326&imageSR=4326&pixelType=F32&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.00009259,
          "lat": 0.00009259
        },
        "extent": {
          "lon": [-125.0, -66.0],
          "lat": [20.0, 50.0]
        }
      },
      "variables": {
        "elevation": {
          "file_variable": "elevation",
          "units": "m",
          "description": "Terrain elevation above WGS84 ellipsoid (no-data pixels outside US territory)"
        }
      },
      "regridding": {
        "extrapolation": "nan"
      },
      "reference": {
        "citation": "U.S. Geological Survey (USGS), 3D Elevation Program (3DEP). National Map Elevation Imagery.",
        "url": "https://elevation.nationalmap.gov/"
      },
      "metadata": {
        "tags": ["elevation", "static", "terrain"],
        "earthscidata_source": "src/usgs3dep.jl::USGS3DEPFileSet",
        "resolution_arc_seconds": 0.333,
        "coverage": "US only (CONUS + Alaska + Hawaii + territories)",
        "notes": "Static dataset served via REST ImageServer. bbox_{west,south,east,north} and {width,height} are custom substitutions the runtime must fill from the requested domain. Max request is 4000x4000 pixels."
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
