{
  "_comment": "USGS 3DEP derived-slopes fixture. Expresses an instantiation of EarthSciData.jl USGS3DEPSlopeFileSet, which wraps a USGS3DEPFileSet and computes slope (and aspect) at runtime from elevation. Source: EarthSciData.jl src/usgs3dep.jl (struct USGS3DEPSlopeFileSet at lines 195-202). We express this as a separate static data loader whose variables are slope_* fields. The underlying source is the same 3DEP elevation endpoint; slope computation is a runtime transform declared via metadata.",
  "esm": "0.1.0",
  "metadata": {
    "name": "USGS3DEPSlopesFixture",
    "description": "USGS 3DEP derived slope/aspect/grade over a CONUS bounding box (runtime-derived from elevation) in the STAC-like DataLoader schema.",
    "authors": [
      "EarthSciSerialization Test Suite"
    ],
    "created": "2026-04-14T00:00:00Z",
    "tags": [
      "earthscidata-coverage",
      "usgs3dep",
      "slopes",
      "static"
    ]
  },
  "data_loaders": {
    "USGS3DEP_Slopes": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_west},{bbox_south},{bbox_east},{bbox_north}&size={width},{height}&format=tiff&bboxSR=4326&imageSR=4326&pixelType=F32&f=image"
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": 637218,
            "spacing": "uniform"
          },
          "lat": {
            "n": 324009,
            "spacing": "uniform"
          }
        }
      },
      "variables": {
        "slope": {
          "file_variable": "elevation",
          "units": "rad",
          "description": "Terrain slope derived from 3DEP elevation (runtime: spatial gradient magnitude, arctangent)"
        },
        "aspect": {
          "file_variable": "elevation",
          "units": "rad",
          "description": "Terrain aspect derived from 3DEP elevation (runtime: direction of steepest descent)"
        }
      },
      "reference": {
        "citation": "U.S. Geological Survey (USGS), 3D Elevation Program (3DEP). Slope computed from elevation via first derivative.",
        "url": "https://elevation.nationalmap.gov/"
      },
      "metadata": {
        "tags": [
          "elevation",
          "slope",
          "static",
          "derived"
        ],
        "earthscidata_source": "src/usgs3dep.jl::USGS3DEPSlopeFileSet",
        "derivation": "runtime",
        "notes": "EarthSciData computes slope/aspect on the client side from the elevation grid. The file_variable points at the underlying elevation field; the runtime transform is not expressible in schema unit_conversion (which takes Expression only, not differential operators)."
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 0.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": 0
        }
      ]
    }
  }
}
