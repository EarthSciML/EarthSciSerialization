{
  "_comment": "NCEP-NCAR Reanalysis fixture. Expresses an instantiation of EarthSciData.jl NCEPNCARReanalysisFileSet. Source: EarthSciData.jl src/NCEP-NCAR_Reanalysis.jl (struct at lines 4-66, relpath at lines 72-79). The loader uses two filename templates — per-variable per-year files at 'pressure/{var}.{year}.nc' and static surface files at 'surface/{var}.sfc.nc'. Since the schema allows only one url_template per loader, we split this into two logical loaders: one for time-varying pressure-level variables and one for the static surface field.",
  "esm": "0.1.0",
  "metadata": {
    "name": "NCEPNCARReanalysisFixture",
    "description": "NCEP-NCAR Reanalysis 1 pressure-level variables and static surface geopotential in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "ncep-ncar", "reanalysis"]
  },
  "data_loaders": {
    "NCEPNCAR_Pressure": {
      "kind": "grid",
      "source": {
        "url_template": "https://downloads.psl.noaa.gov/Datasets/ncep.reanalysis/pressure/{var}.{date:%Y}.nc"
      },
      "temporal": {
        "start": "1948-01-01T00:00:00Z",
        "file_period": "P1Y",
        "frequency": "PT6H",
        "time_variable": "time"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center",
          "level": "center"
        },
        "resolution": {
          "lon": 2.5,
          "lat": 2.5
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0],
          "level": [10.0, 1000.0]
        }
      },
      "variables": {
        "air": {
          "file_variable": "air",
          "units": "K",
          "description": "Air temperature at pressure levels"
        },
        "hgt": {
          "file_variable": "hgt",
          "units": "m",
          "description": "Geopotential height"
        },
        "omega": {
          "file_variable": "omega",
          "units": "Pa/s",
          "description": "Lagrangian tendency of pressure (vertical velocity)"
        },
        "uwnd": {
          "file_variable": "uwnd",
          "units": "m/s",
          "description": "U-wind component"
        },
        "vwnd": {
          "file_variable": "vwnd",
          "units": "m/s",
          "description": "V-wind component"
        }
      },
      "reference": {
        "citation": "Kalnay, E. et al. (1996): The NCEP/NCAR 40-year reanalysis project. Bull. Amer. Meteor. Soc. 77, 437-471.",
        "url": "https://psl.noaa.gov/data/gridded/data.ncep.reanalysis.html",
        "doi": "10.1175/1520-0477(1996)077<0437:TNYRP>2.0.CO;2"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis", "pressure-level"],
        "earthscidata_source": "src/NCEP-NCAR_Reanalysis.jl::NCEPNCARReanalysisFileSet (pressure variables)"
      }
    },
    "NCEPNCAR_Surface": {
      "kind": "static",
      "source": {
        "url_template": "https://downloads.psl.noaa.gov/Datasets/ncep.reanalysis/surface/{var}.sfc.nc"
      },
      "spatial": {
        "crs": "+proj=longlat +datum=WGS84 +no_defs",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 2.5,
          "lat": 2.5
        }
      },
      "variables": {
        "hgt_sfc": {
          "file_variable": "hgt",
          "units": "m",
          "description": "Surface geopotential height (static)"
        }
      },
      "reference": {
        "citation": "Kalnay, E. et al. (1996): The NCEP/NCAR 40-year reanalysis project.",
        "url": "https://psl.noaa.gov/data/gridded/data.ncep.reanalysis.html"
      },
      "metadata": {
        "tags": ["meteorology", "static", "surface"],
        "earthscidata_source": "src/NCEP-NCAR_Reanalysis.jl::NCEPNCARReanalysisFileSet (surface variables)"
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
