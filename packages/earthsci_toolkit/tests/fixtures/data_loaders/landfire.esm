{
  "_comment": "LANDFIRE fuel model fixture. Expresses an instantiation of EarthSciData.jl LANDFIREFileSet for product='FBFM13' (Anderson 13 fuel models), version='LF2022'. Source: EarthSciData.jl src/landfire.jl (struct at lines 65-73, constructor at lines 90-107, url at lines 114+). Static (time-invariant) dataset served by an ArcGIS ImageServer REST API. Pixel values are integer fuel model codes.",
  "esm": "0.1.0",
  "metadata": {
    "name": "LANDFIREFixture",
    "description": "LANDFIRE Anderson 13 fuel models over CONUS in the STAC-like DataLoader schema.",
    "authors": ["EarthSciSerialization Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["earthscidata-coverage", "landfire", "fuel-model", "static"]
  },
  "data_loaders": {
    "LANDFIRE_FBFM13": {
      "kind": "static",
      "source": {
        "url_template": "https://landfire.cr.usgs.gov/arcgis/rest/services/Landfire_{version}/{version}_{product}_CONUS/ImageServer/exportImage?bbox={bbox_west},{bbox_south},{bbox_east},{bbox_north}&size={width},{height}&format=tiff&bboxSR=4326&imageSR=4326&pixelType=U8&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.000278,
          "lat": 0.000278
        },
        "extent": {
          "lon": [-125.0, -66.0],
          "lat": [20.0, 50.0]
        }
      },
      "variables": {
        "fbfm13": {
          "file_variable": "fbfm13",
          "units": "1",
          "description": "Anderson 13 fuel model code (1-13 for fuel classes; 91=urban, 92=snow/ice, 93=agriculture, 98=water, 99=barren)"
        }
      },
      "regridding": {
        "fill_value": 99.0,
        "extrapolation": "nan"
      },
      "reference": {
        "citation": "U.S. Geological Survey (USGS) LANDFIRE Program. Fire Behavior Fuel Model 13.",
        "url": "https://landfire.gov/"
      },
      "metadata": {
        "tags": ["fuel-model", "wildfire", "static"],
        "earthscidata_source": "src/landfire.jl::LANDFIREFileSet",
        "product": "FBFM13",
        "version": "LF2022",
        "notes": "Custom substitutions bbox_{west,south,east,north}, {width}, {height}, {version}, {product} are runtime-filled from the requested domain and constructor arguments."
      }
    }
  },
  "models": {
    "placeholder": {
      "variables": {
        "x": {"type": "state", "units": "1", "default": 0.0}
      },
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
