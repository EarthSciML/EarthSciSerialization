{
  "esm": "0.1.0",
  "metadata": {
    "name": "EDGAR_v81_Monthly_NOx_ENE",
    "description": "Source: EarthSciData/src/edgar_v81_monthly.jl — EDGARv81MonthlyEmisFileSet / EDGARv81MonthlyEmis(). Parameter footprint: mirror (JRC jeodpp FTP), substance (one of EDGAR_V81_SUBSTANCES), sector, starttime, endtime. Data is distributed as per-sector zip archives containing yearly NC files, one per year (2000-2022). Monthly records. Global 0.1 deg grid. This fixture represents the ENE (energy) sector NOx emissions.",
    "authors": [
      "EarthSciSerialization gt-mos"
    ],
    "tags": [
      "emissions",
      "anthropogenic",
      "earthscidata.jl"
    ]
  },
  "data_loaders": {
    "EDGAR_v81_Monthly_NOx_ENE": {
      "kind": "grid",
      "source": {
        "url_template": "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81_FT2022_AP_new/monthly/NOx/bkl_ENE/bkl_ENE_flx_nc.zip#bkl_ENE_{date:%Y}_monthly_flx.nc"
      },
      "temporal": {
        "start": "2000-01-01T00:00:00Z",
        "end": "2022-12-31T23:59:59Z",
        "file_period": "P1Y",
        "frequency": "P1M",
        "records_per_file": 12,
        "time_variable": "time"
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": 3600,
            "spacing": "uniform"
          },
          "lat": {
            "n": 1800,
            "spacing": "uniform"
          }
        }
      },
      "variables": {
        "NOx": {
          "file_variable": "emi_nox",
          "units": "kg/m^2/s",
          "description": "Monthly NOx flux (EDGAR ENE sector)"
        }
      },
      "reference": {
        "citation": "Crippa, M. et al. (2023) EDGARv8.1: a global air pollutant emission inventory. Earth Syst. Sci. Data.",
        "url": "https://edgar.jrc.ec.europa.eu/dataset_ap81"
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic",
          "edgar"
        ],
        "substance": "NOx",
        "sector": "ENE",
        "archive_format": "zip-of-yearly-nc"
      }
    }
  },
  "models": {
    "stub": {
      "variables": {
        "x": {
          "type": "state"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": 0
        }
      ]
    }
  }
}
