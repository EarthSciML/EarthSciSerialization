{
  "esm": "0.1.0",
  "metadata": {
    "name": "USGS3DEP_Elevation",
    "description": "Source: EarthSciData/src/usgs3dep.jl — USGS3DEPFileSet / USGS3DEP(). Parameter footprint: mirror (USGS National Map ImageServer REST API), bbox (w,s,e,n in degrees), width, height (pixels), resolution (arc-seconds, default 1/3). Static elevation dataset delivered as GeoTIFF via exportImage REST call. This fixture represents a CONUS-scale elevation pull at ~10 m resolution, clamped to 4000x4000 pixels.",
    "authors": ["EarthSciSerialization gt-mos"],
    "tags": ["topography", "static", "earthscidata.jl"]
  },
  "data_loaders": {
    "USGS3DEP_Elevation": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_w},{bbox_s},{bbox_e},{bbox_n}&bboxSR=4326&imageSR=4326&size={width},{height}&format=tiff&pixelType=F32&interpolation=+RSP_BilinearInterpolation&f=image"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 9.259259259e-05,
          "lat": 9.259259259e-05
        },
        "extent": {
          "lon": [-125.0, -66.0],
          "lat": [24.0, 50.0]
        }
      },
      "variables": {
        "elevation": {
          "file_variable": "elevation",
          "units": "m",
          "description": "Terrain elevation above sea level (USGS 3DEP)"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "U.S. Geological Survey, 3D Elevation Program (3DEP)",
        "url": "https://www.usgs.gov/3d-elevation-program"
      },
      "metadata": {
        "tags": ["topography", "static", "elevation"],
        "max_pixels": 4000,
        "resolution_arcsec": 0.333333,
        "coverage": "US only (CONUS, Alaska, Hawaii, territories)"
      }
    }
  },
  "models": {
    "stub": {
      "variables": {"x": {"type": "state"}},
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
