{
  "esm": "0.1.0",
  "metadata": {
    "name": "CEDS_NOx",
    "description": "Source: EarthSciData/src/ceds.jl — CEDSFileSet / CEDS(). Parameter footprint: mirror (ORNL ESGF THREDDS by default), species (NOx, SO2, CO, ...), version (CMIP7 version string), data_version, sectors, starttime, endtime. Input4MIPs CEDS CMIP anthropogenic emissions, 50-year chunked files, monthly data, 0.5 deg global. This fixture represents NOx emissions for the 1950-1999 chunk.",
    "authors": ["EarthSciSerialization gt-mos"],
    "tags": ["emissions", "anthropogenic", "earthscidata.jl"]
  },
  "data_loaders": {
    "CEDS_NOx": {
      "kind": "grid",
      "source": {
        "url_template": "https://esgf-node.ornl.gov/thredds/fileServer/user_pub_work/input4MIPs/CMIP7/CMIP/PNNL-JGCRI/{version}/atmos/mon/NOx_em_anthro/gn/{data_version}/NOx-em-anthro_input4MIPs_emissions_CMIP_{version}_gn_{chunk_start}01-{chunk_end}12.nc"
      },
      "temporal": {
        "start": "1750-01-01T00:00:00Z",
        "end": "2022-12-31T23:59:59Z",
        "file_period": "P50Y",
        "frequency": "P1M",
        "records_per_file": 600,
        "time_variable": "time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.5,
          "lat": 0.5
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "NOx_em_anthro_ene": {
          "file_variable": "NOx_em_anthro",
          "units": "kg/m^2/s",
          "description": "NOx anthropogenic emissions, energy sector (CEDS sector 'ene')"
        },
        "NOx_em_anthro_ind": {
          "file_variable": "NOx_em_anthro",
          "units": "kg/m^2/s",
          "description": "NOx anthropogenic emissions, industry sector (CEDS sector 'ind')"
        },
        "NOx_em_anthro_tra": {
          "file_variable": "NOx_em_anthro",
          "units": "kg/m^2/s",
          "description": "NOx anthropogenic emissions, transport sector (CEDS sector 'tra')"
        }
      },
      "regridding": {
        "fill_value": 0.0,
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Hoesly, R. M. et al. (2018) Historical (1750-2014) anthropogenic emissions of reactive gases and aerosols from the Community Emissions Data System (CEDS). Geosci. Model Dev.",
        "doi": "10.5194/gmd-11-369-2018",
        "url": "https://esgf-node.llnl.gov/search/input4mips/"
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "ceds", "cmip"],
        "species": "NOx",
        "version": "2024-09-05",
        "data_version": "v2024-09-05",
        "sectors": ["ene", "ind", "tra"]
      }
    }
  },
  "models": {
    "stub": {
      "variables": {"x": {"type": "state"}},
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
