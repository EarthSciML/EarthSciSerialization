{
  "esm": "0.1.0",
  "metadata": {
    "name": "ERA5_PressureLevels",
    "description": "Source: EarthSciData/src/era5.jl — ERA5PressureLevelFileSet / ERA5(). Parameter footprint: mirror (CDS API URL or file:// path), variables (list from ERA5_VARIABLES), domaininfo. Files are one-month NetCDF, 0.25 deg global, hourly samples, 37 pressure levels 1000→1 hPa.",
    "authors": ["EarthSciSerialization gt-mos"],
    "tags": ["meteorology", "reanalysis", "earthscidata.jl"]
  },
  "data_loaders": {
    "ERA5_PL": {
      "kind": "grid",
      "source": {
        "url_template": "cds://reanalysis-era5-pressure-levels/{date:%Y}/{date:%m}/era5_pl_{date:%Y}_{date:%m}.nc",
        "mirrors": [
          "file:///data/era5/era5_pl_{date:%Y}_{date:%m}.nc"
        ]
      },
      "temporal": {
        "file_period": "P1M",
        "frequency": "PT1H",
        "records_per_file": "auto",
        "time_variable": "valid_time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center",
          "pressure_level": "center"
        },
        "resolution": {
          "lon": 0.25,
          "lat": 0.25
        },
        "extent": {
          "lon": [-180.0, 180.0],
          "lat": [-90.0, 90.0]
        }
      },
      "variables": {
        "t": {
          "file_variable": "t",
          "units": "K",
          "description": "Air temperature (ERA5 'temperature')"
        },
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "Eastward wind (ERA5 'u_component_of_wind')"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "Northward wind (ERA5 'v_component_of_wind')"
        },
        "w": {
          "file_variable": "w",
          "units": "Pa/s",
          "description": "Vertical velocity in pressure coordinates (ERA5 'vertical_velocity')"
        },
        "q": {
          "file_variable": "q",
          "units": "kg/kg",
          "description": "Specific humidity (ERA5 'specific_humidity')"
        },
        "z": {
          "file_variable": "z",
          "units": "m^2/s^2",
          "description": "Geopotential (ERA5 'geopotential')"
        },
        "o3": {
          "file_variable": "o3",
          "units": "kg/kg",
          "description": "Ozone mass mixing ratio (ERA5 'ozone_mass_mixing_ratio')"
        }
      },
      "regridding": {
        "extrapolation": "clamp"
      },
      "reference": {
        "citation": "Hersbach, H. et al. (2020) The ERA5 global reanalysis. Q.J.R. Meteorol. Soc.",
        "doi": "10.1002/qj.3803",
        "url": "https://cds.climate.copernicus.eu/"
      },
      "metadata": {
        "tags": ["meteorology", "reanalysis", "pressure-levels"],
        "pressure_levels_hpa": [1000, 975, 950, 925, 900, 850, 800, 750, 700, 650, 600, 550, 500, 450, 400, 350, 300, 250, 200, 150, 100, 70, 50, 30, 20, 10, 7, 5, 3, 2, 1]
      }
    }
  },
  "models": {
    "stub": {
      "variables": {"x": {"type": "state"}},
      "equations": [
        {"lhs": {"op": "D", "args": ["x"], "wrt": "t"}, "rhs": 0}
      ]
    }
  }
}
