{
  "esm": "0.1.0",
  "metadata": {
    "name": "NEI2016Monthly_ptegu",
    "description": "Source: EarthSciData/src/nei2016monthly.jl — NEI2016MonthlyEmisFileSet / NEI2016MonthlyEmis(). Parameter footprint: mirror (EPA gaftp), sector (e.g. ptegu, ptnonipm, onroad, nonpt, ...), starttime, endtime. Monthly emission files on the 12US1 (12-km CONUS Lambert conformal) grid, one file per month. This fixture represents the 'ptegu' (EGU point sources) sector for 2016.",
    "authors": [
      "EarthSciSerialization gt-mos"
    ],
    "tags": [
      "emissions",
      "anthropogenic",
      "earthscidata.jl"
    ]
  },
  "data_loaders": {
    "NEI2016Monthly_ptegu": {
      "kind": "grid",
      "source": {
        "url_template": "https://gaftp.epa.gov/Air/emismod/2016/v1/gridded/monthly_netCDF/2016fh_16j_ptegu_12US1_month_{date:%m}.ncf"
      },
      "temporal": {
        "start": "2016-01-01T00:00:00Z",
        "end": "2016-12-31T23:59:59Z",
        "file_period": "P1M",
        "frequency": "P1M",
        "records_per_file": 1,
        "time_variable": "TSTEP"
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "lambert_conformal",
          "datum": "WGS84",
          "parameters": {
            "lat_1": 33,
            "lat_2": 45,
            "lat_0": 40,
            "lon_0": -97
          }
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "COL",
          "ROW"
        ],
        "extents": {
          "COL": {
            "n": "n_COL",
            "spacing": "uniform"
          },
          "ROW": {
            "n": "n_ROW",
            "spacing": "uniform"
          }
        },
        "parameters": {
          "n_COL": {
            "description": "COL cell count, resolved from the source dataset at load time"
          },
          "n_ROW": {
            "description": "ROW cell count, resolved from the source dataset at load time"
          }
        }
      },
      "variables": {
        "NO": {
          "file_variable": "NO",
          "units": "kg/m^2/s",
          "description": "NO emission flux",
          "unit_conversion": {
            "op": "*",
            "args": [
              1e-09,
              1.0
            ]
          }
        },
        "NO2": {
          "file_variable": "NO2",
          "units": "kg/m^2/s",
          "description": "NO2 emission flux"
        },
        "SO2": {
          "file_variable": "SO2",
          "units": "kg/m^2/s",
          "description": "SO2 emission flux"
        },
        "CO": {
          "file_variable": "CO",
          "units": "kg/m^2/s",
          "description": "CO emission flux"
        }
      },
      "reference": {
        "citation": "US EPA, 2016 National Emissions Inventory — Modeling Platform (2016fh)",
        "url": "https://www.epa.gov/air-emissions-modeling/2016v1-platform"
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic"
        ],
        "sector": "ptegu",
        "grid_id": "12US1",
        "year": 2016
      }
    }
  },
  "models": {
    "stub": {
      "variables": {
        "x": {
          "type": "state"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": 0
        }
      ]
    }
  }
}
