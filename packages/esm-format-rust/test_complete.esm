{
  "esm": "0.1.0",
  "metadata": {
    "name": "test_complete",
    "description": "A complete test model with reactions and coupling"
  },
  "models": {
    "chemistry": {
      "name": "Atmospheric Chemistry",
      "variables": [
        {
          "name": "O3",
          "type": "state",
          "units": "concentration"
        },
        {
          "name": "NO",
          "type": "state",
          "units": "concentration"
        }
      ],
      "equations": [
        {
          "lhs": {
            "op": "derivative",
            "args": ["O3"],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "k_O3_formation",
              {
                "op": "*",
                "args": ["NO", "O2"]
              }
            ]
          }
        }
      ]
    },
    "transport": {
      "name": "Transport Model",
      "variables": [
        {
          "name": "wind_speed",
          "type": "parameter",
          "units": "m/s"
        }
      ],
      "equations": []
    }
  },
  "reaction_systems": {
    "simple_ozone": {
      "name": "Simple Ozone Chemistry",
      "species": [
        {
          "name": "O3",
          "units": "mol/L"
        },
        {
          "name": "NO",
          "units": "mol/L"
        },
        {
          "name": "NO2",
          "units": "mol/L"
        }
      ],
      "reactions": [
        {
          "substrates": [
            {
              "species": "NO",
              "coefficient": 1.0
            },
            {
              "species": "O3",
              "coefficient": 1.0
            }
          ],
          "products": [
            {
              "species": "NO2",
              "coefficient": 1.0
            }
          ],
          "rate": {
            "op": "*",
            "args": ["k1", "NO", "O3"]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "source": "chemistry",
      "target": "transport",
      "mappings": [
        {
          "source_var": "O3",
          "target_var": "transported_O3"
        }
      ]
    }
  ]
}