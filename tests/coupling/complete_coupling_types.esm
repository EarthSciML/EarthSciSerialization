{
  "esm": "0.2.0",
  "metadata": {
    "name": "CompleteCouplingTests",
    "description": "Test all 6 coupling types: operator_compose, couple, variable_map, operator_apply, callback, event\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "coupling",
      "comprehensive",
      "all-types",
      "migrated_from_v01"
    ]
  },
  "models": {
    "AtmosphericChemistry": {
      "coupletype": "ChemistryCoupler",
      "reference": {
        "notes": "Primary atmospheric chemistry system for coupling tests"
      },
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone mixing ratio"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide mixing ratio"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide mixing ratio"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Air temperature"
        },
        "pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Air pressure"
        },
        "k_NO_O3": {
          "type": "parameter",
          "units": "cm^3/molec/s",
          "default": 1.8e-12,
          "description": "Rate constant for NO + O3 → NO2"
        },
        "jNO2": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "k_NO_O3"
                    ]
                  },
                  "O3",
                  "NO"
                ]
              },
              {
                "op": "*",
                "args": [
                  "jNO2",
                  "NO2"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "k_NO_O3"
                    ]
                  },
                  "O3",
                  "NO"
                ]
              },
              {
                "op": "*",
                "args": [
                  "jNO2",
                  "NO2"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_NO_O3",
                  "O3",
                  "NO"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "jNO2"
                    ]
                  },
                  "NO2"
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "O3_zero_gradient_xmin": {
          "variable": "O3",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "NO_zero_gradient_xmin": {
          "variable": "NO",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "NO2_zero_gradient_xmin": {
          "variable": "NO2",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "O3_zero_gradient_xmax": {
          "variable": "O3",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "NO_zero_gradient_xmax": {
          "variable": "NO",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "NO2_zero_gradient_xmax": {
          "variable": "NO2",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "O3_zero_gradient_ymin": {
          "variable": "O3",
          "side": "ymin",
          "kind": "zero_gradient"
        },
        "NO_zero_gradient_ymin": {
          "variable": "NO",
          "side": "ymin",
          "kind": "zero_gradient"
        },
        "NO2_zero_gradient_ymin": {
          "variable": "NO2",
          "side": "ymin",
          "kind": "zero_gradient"
        },
        "O3_zero_gradient_ymax": {
          "variable": "O3",
          "side": "ymax",
          "kind": "zero_gradient"
        },
        "NO_zero_gradient_ymax": {
          "variable": "NO",
          "side": "ymax",
          "kind": "zero_gradient"
        },
        "NO2_zero_gradient_ymax": {
          "variable": "NO2",
          "side": "ymax",
          "kind": "zero_gradient"
        }
      }
    },
    "AdvectionTransport": {
      "reference": {
        "notes": "Transport operator using _var placeholder for operator_compose coupling"
      },
      "variables": {
        "u_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 10.0,
          "description": "Eastward wind component"
        },
        "v_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Northward wind component"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "u_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "v_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "y"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "SurfaceExchange": {
      "coupletype": "SurfaceExchangeCoupler",
      "reference": {
        "notes": "Surface deposition model for couple coupling"
      },
      "variables": {
        "surface_resistance": {
          "type": "parameter",
          "units": "s/m",
          "default": 100.0,
          "description": "Surface resistance to deposition"
        },
        "aerodynamic_resistance": {
          "type": "parameter",
          "units": "s/m",
          "default": 50.0,
          "description": "Aerodynamic resistance"
        },
        "deposition_velocity_O3": {
          "type": "observed",
          "units": "m/s",
          "expression": {
            "op": "/",
            "args": [
              1.0,
              {
                "op": "+",
                "args": [
                  "surface_resistance",
                  "aerodynamic_resistance"
                ]
              }
            ]
          },
          "description": "O3 deposition velocity"
        },
        "boundary_layer_height": {
          "type": "parameter",
          "units": "m",
          "default": 1000.0,
          "description": "Planetary boundary layer height"
        }
      },
      "equations": []
    },
    "EmissionSources": {
      "reference": {
        "notes": "Emission model for testing callback coupling"
      },
      "variables": {
        "NOx_emission_rate": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-11,
          "description": "NOx emission rate"
        },
        "diurnal_factor": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Diurnal emission scaling factor"
        },
        "weekday_factor": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Weekday/weekend scaling factor"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "NOx_emission_rate",
              "diurnal_factor",
              "weekday_factor"
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "name": "hourly_emission_update",
          "trigger": {
            "type": "periodic",
            "interval": 3600.0
          },
          "affects": [
            {
              "lhs": "diurnal_factor",
              "rhs": {
                "op": "+",
                "args": [
                  1.0,
                  {
                    "op": "*",
                    "args": [
                      0.5,
                      {
                        "op": "sin",
                        "args": [
                          {
                            "op": "/",
                            "args": [
                              {
                                "op": "*",
                                "args": [
                                  2,
                                  3.14159,
                                  "t"
                                ]
                              },
                              86400
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "discrete_parameters": [
            "diurnal_factor"
          ],
          "description": "Update diurnal emission pattern every hour"
        }
      ]
    }
  },
  "data_loaders": {
    "MeteorologicalData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/GEOS_FP/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT3H",
        "file_period": "PT3H",
        "records_per_file": 1
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.625,
          "lat": 0.5
        }
      },
      "variables": {
        "temperature": {
          "file_variable": "temperature",
          "units": "K",
          "description": "Air temperature"
        },
        "pressure": {
          "file_variable": "pressure",
          "units": "Pa",
          "description": "Surface pressure"
        },
        "u_wind": {
          "file_variable": "u_wind",
          "units": "m/s",
          "description": "Eastward wind"
        },
        "v_wind": {
          "file_variable": "v_wind",
          "units": "m/s",
          "description": "Northward wind"
        }
      },
      "reference": {
        "citation": "NASA GEOS Forward Processing meteorological data"
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    },
    "EmissionInventory": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/EDGAR_v6/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "NOx_emission_rate": {
          "file_variable": "NOx_emission_rate",
          "units": "mol/mol/s",
          "description": "Nitrogen oxides emission rate"
        }
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic"
        ]
      }
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "AdvectionTransport"
      ],
      "description": "Add horizontal advection to all chemical species"
    },
    {
      "type": "couple",
      "systems": [
        "AtmosphericChemistry",
        "SurfaceExchange"
      ],
      "connector": {
        "equations": [
          {
            "from": "SurfaceExchange.deposition_velocity_O3",
            "to": "AtmosphericChemistry.O3",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {
                  "op": "-",
                  "args": [
                    "SurfaceExchange.deposition_velocity_O3"
                  ]
                },
                "AtmosphericChemistry.O3",
                {
                  "op": "/",
                  "args": [
                    1.0,
                    "SurfaceExchange.boundary_layer_height"
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "Couple surface deposition to atmospheric chemistry"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.temperature",
      "to": "AtmosphericChemistry.temperature",
      "transform": "param_to_var",
      "description": "Use meteorological temperature instead of constant"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.pressure",
      "to": "AtmosphericChemistry.pressure",
      "transform": "param_to_var",
      "description": "Use meteorological pressure"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.u_wind",
      "to": "AdvectionTransport.u_wind",
      "transform": "param_to_var",
      "description": "Use meteorological eastward wind"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.v_wind",
      "to": "AdvectionTransport.v_wind",
      "transform": "param_to_var",
      "description": "Use meteorological northward wind"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.NOx_emission_rate",
      "to": "EmissionSources.NOx_emission_rate",
      "transform": "param_to_var",
      "description": "Use inventory emission rates"
    },
    {
      "type": "callback",
      "callback_id": "DiurnalEmissionScaling",
      "config": {
        "update_frequency": 3600.0,
        "local_solar_time": true,
        "timezone": "UTC"
      },
      "description": "Scale emissions based on local solar time"
    },
    {
      "type": "callback",
      "callback_id": "PhotolysisRateUpdate",
      "config": {
        "solar_zenith_angle": true,
        "cloud_optical_depth": true,
        "update_frequency": 600.0
      },
      "description": "Update photolysis rates based on solar conditions"
    },
    {
      "type": "event",
      "event_type": "continuous",
      "name": "ozone_threshold_emission_cutoff",
      "conditions": [
        {
          "op": "-",
          "args": [
            "AtmosphericChemistry.O3",
            8e-08
          ]
        }
      ],
      "affects": [
        {
          "lhs": "EmissionSources.NOx_emission_rate",
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "Pre",
                "args": [
                  "EmissionSources.NOx_emission_rate"
                ]
              },
              0.5
            ]
          }
        }
      ],
      "description": "Reduce NOx emissions when ozone exceeds 80 ppb"
    },
    {
      "type": "event",
      "event_type": "discrete",
      "name": "weekend_emission_reduction",
      "trigger": {
        "type": "condition",
        "expression": {
          "op": ">=",
          "args": [
            {
              "op": "-",
              "args": [
                {
                  "op": "floor",
                  "args": [
                    {
                      "op": "/",
                      "args": [
                        "t",
                        86400
                      ]
                    }
                  ]
                },
                {
                  "op": "*",
                  "args": [
                    {
                      "op": "floor",
                      "args": [
                        {
                          "op": "/",
                          "args": [
                            {
                              "op": "floor",
                              "args": [
                                {
                                  "op": "/",
                                  "args": [
                                    "t",
                                    86400
                                  ]
                                }
                              ]
                            },
                            7
                          ]
                        }
                      ]
                    },
                    7
                  ]
                }
              ]
            },
            5
          ]
        }
      },
      "affects": [
        {
          "lhs": "EmissionSources.weekday_factor",
          "rhs": 0.7
        }
      ],
      "discrete_parameters": [
        "EmissionSources.weekday_factor"
      ],
      "description": "Reduce emissions on weekends (days 5-6 of week)"
    }
  ],
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-08T00:00:00Z",
        "reference_time": "2024-07-01T00:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 100000.0,
          "units": "meters",
          "grid_spacing": 5000.0
        },
        "y": {
          "min": 0.0,
          "max": 100000.0,
          "units": "meters",
          "grid_spacing": 5000.0
        }
      },
      "initial_conditions": {
        "type": "constant",
        "value": 0.0
      },
      "element_type": "Float64"
    }
  }
}
