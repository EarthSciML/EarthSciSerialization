{
  "esm": "0.1.0",
  "metadata": {
    "name": "CouplingResolutionAlgorithmTests",
    "description": "Step-by-step verification tests for ESM scoped reference resolution algorithm (Section 4.3)",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z"
  },
  "models": {
    "AtmosphereModel": {
      "coupletype": "AtmosphereCoupler",
      "variables": {
        "pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Surface pressure"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Surface temperature"
        }
      },
      "subsystems": {
        "Chemistry": {
          "coupletype": "ChemistryCoupler",
          "variables": {
            "O3": {
              "type": "state",
              "units": "mol/mol",
              "default": 4e-08,
              "description": "Ozone mixing ratio"
            },
            "NO": {
              "type": "state",
              "units": "mol/mol",
              "default": 1e-10,
              "description": "NO mixing ratio"
            },
            "temperature": {
              "type": "parameter",
              "units": "K",
              "default": 298.15,
              "description": "Chemistry temperature"
            }
          },
          "subsystems": {
            "FastReactions": {
              "variables": {
                "k1": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 1e-05,
                  "description": "Rate constant 1"
                },
                "k2": {
                  "type": "parameter",
                  "units": "cm^3/molec/s",
                  "default": 1.8e-12,
                  "description": "Rate constant 2"
                }
              },
              "equations": [
                {
                  "lhs": {
                    "op": "D",
                    "args": [
                      "O3"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "*",
                    "args": [
                      -1,
                      "k1",
                      "O3"
                    ]
                  }
                }
              ]
            },
            "SlowReactions": {
              "variables": {
                "k_slow": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 1e-07,
                  "description": "Slow rate constant"
                }
              },
              "equations": [
                {
                  "lhs": {
                    "op": "D",
                    "args": [
                      "NO"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "*",
                    "args": [
                      -1,
                      "k_slow",
                      "NO"
                    ]
                  }
                }
              ]
            }
          },
          "equations": []
        },
        "Transport": {
          "variables": {
            "wind_speed": {
              "type": "parameter",
              "units": "m/s",
              "default": 5.0,
              "description": "Wind speed"
            },
            "diffusivity": {
              "type": "parameter",
              "units": "m^2/s",
              "default": 10.0,
              "description": "Turbulent diffusivity"
            }
          },
          "subsystems": {
            "Advection": {
              "variables": {
                "u_wind": {
                  "type": "parameter",
                  "units": "m/s",
                  "default": 3.0,
                  "description": "Eastward wind"
                },
                "v_wind": {
                  "type": "parameter",
                  "units": "m/s",
                  "default": 4.0,
                  "description": "Northward wind"
                }
              },
              "equations": [
                {
                  "lhs": {
                    "op": "D",
                    "args": [
                      "u"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "+",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "u_wind"
                            ]
                          },
                          {
                            "op": "grad",
                            "args": [
                              "u"
                            ],
                            "dim": "x"
                          }
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "v_wind"
                            ]
                          },
                          {
                            "op": "grad",
                            "args": [
                              "u"
                            ],
                            "dim": "y"
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          },
          "equations": []
        }
      },
      "equations": []
    },
    "SurfaceModel": {
      "coupletype": "SurfaceCoupler",
      "variables": {
        "soil_temperature": {
          "type": "parameter",
          "units": "K",
          "default": 285.0,
          "description": "Soil temperature"
        },
        "surface_resistance": {
          "type": "parameter",
          "units": "s/m",
          "default": 100.0,
          "description": "Surface resistance"
        }
      },
      "subsystems": {
        "VegetationLayer": {
          "variables": {
            "leaf_area_index": {
              "type": "parameter",
              "units": "m^2/m^2",
              "default": 3.0,
              "description": "Leaf area index"
            },
            "stomatal_resistance": {
              "type": "parameter",
              "units": "s/m",
              "default": 200.0,
              "description": "Stomatal resistance"
            }
          },
          "equations": []
        }
      },
      "equations": []
    }
  },
  "data_loaders": {
    "MeteorologicalData": {
      "type": "gridded_data",
      "loader_id": "WRF",
      "config": {
        "file_pattern": "wrfout_*"
      },
      "provides": {
        "temperature": {
          "units": "K",
          "description": "Air temperature"
        },
        "pressure": {
          "units": "Pa",
          "description": "Surface pressure"
        },
        "wind_u": {
          "units": "m/s",
          "description": "Eastward wind component"
        },
        "wind_v": {
          "units": "m/s",
          "description": "Northward wind component"
        }
      }
    }
  },
  "operators": {
    "BiogenicEmissions": {
      "operator_id": "MEGAN",
      "config": {
        "emission_factor_map": "megan_ef.nc",
        "subsystems": {
          "TemperatureDependence": {
            "variables": {
              "beta": {
                "type": "parameter",
                "units": "1/K",
                "default": 0.09,
                "description": "Temperature dependence factor"
              }
            }
          }
        }
      },
      "needed_vars": [
        "temperature",
        "solar_radiation"
      ],
      "modifies": [
        "emission_rate_isoprene"
      ],
      "description": "MEGAN biogenic emissions model"
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphereModel.Chemistry",
        "AtmosphereModel.Transport"
      ],
      "description": "TEST CASE 1: Two-level scoped references - AtmosphereModel.Chemistry should resolve to Chemistry subsystem of AtmosphereModel"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.temperature",
      "to": "AtmosphereModel.temperature",
      "transform": "param_to_var",
      "description": "TEST CASE 2: Simple two-part scoped reference resolution - MeteorologicalData.temperature"
    },
    {
      "type": "variable_map",
      "from": "AtmosphereModel.Chemistry.temperature",
      "to": "SurfaceModel.soil_temperature",
      "transform": "param_to_var",
      "description": "TEST CASE 3: Three-level hierarchy - AtmosphereModel.Chemistry.temperature. Algorithm steps: [AtmosphereModel, Chemistry, temperature]. Find AtmosphereModel in models, find Chemistry in AtmosphereModel.subsystems, find temperature in Chemistry.variables"
    },
    {
      "type": "variable_map",
      "from": "AtmosphereModel.Chemistry.FastReactions.k1",
      "to": "AtmosphereModel.Chemistry.SlowReactions.k_slow",
      "transform": "param_to_var",
      "description": "TEST CASE 4: Four-level deep nesting - AtmosphereModel.Chemistry.FastReactions.k1. Algorithm steps: [AtmosphereModel, Chemistry, FastReactions, k1]. Verify each step of hierarchy walking."
    },
    {
      "type": "variable_map",
      "from": "AtmosphereModel.Transport.Advection.u_wind",
      "to": "AtmosphereModel.Transport.wind_speed",
      "transform": "conversion_factor",
      "factor": 1.0,
      "description": "TEST CASE 5: Four-level resolution in different subsystem branch - AtmosphereModel.Transport.Advection.u_wind"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalData.QualityControl.data_quality_flag",
      "to": "SurfaceModel.VegetationLayer.leaf_area_index",
      "transform": "multiplicative",
      "description": "TEST CASE 6: Data loader subsystem resolution - MeteorologicalData.QualityControl.data_quality_flag. Tests resolution in data_loaders section."
    },
    {
      "type": "variable_map",
      "from": "BiogenicEmissions.TemperatureDependence.beta",
      "to": "AtmosphereModel.Chemistry.FastReactions.k2",
      "transform": "multiplicative",
      "description": "TEST CASE 7: Operator subsystem resolution - BiogenicEmissions.TemperatureDependence.beta. Tests resolution in operators section."
    },
    {
      "type": "couple",
      "systems": [
        "AtmosphereModel.Chemistry",
        "SurfaceModel"
      ],
      "connector": {
        "equations": [
          {
            "from": "AtmosphereModel.Chemistry.O3",
            "to": "SurfaceModel.surface_resistance",
            "transform": "multiplicative",
            "expression": {
              "op": "+",
              "args": [
                1.0,
                {
                  "op": "*",
                  "args": [
                    0.1,
                    "AtmosphereModel.Chemistry.O3"
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "TEST CASE 8: couple with scoped references in connector expressions"
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-06-01T00:00:00Z",
        "end": "2024-06-01T12:00:00Z"
      }
    }
  }
}
