{
  "esm": "0.1.0",
  "metadata": {
    "name": "OperatorComposeResolutionFixtures",
    "description": "Test fixtures for operator_compose coupling resolution algorithm (Section 4.7.1)",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z"
  },
  "models": {
    "ChemistrySystem": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone mixing ratio"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-10,
          "description": "NO mixing ratio"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 2e-10,
          "description": "NO2 mixing ratio"
        },
        "k1": {
          "units": "1/s",
          "default": 1e-05,
          "description": "Reaction rate 1",
          "type": "parameter"
        },
        "k2": {
          "units": "cm^3/molec/s",
          "default": 1.8e-12,
          "description": "Reaction rate 2",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "k1",
              "O3"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "k2",
              "NO2"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "k2",
              "NO2"
            ]
          }
        }
      ]
    },
    "AdvectionSystem": {
      "variables": {
        "u": {
          "type": "parameter",
          "units": "m/s",
          "default": 3.0,
          "description": "Eastward wind"
        },
        "v": {
          "type": "parameter",
          "units": "m/s",
          "default": 4.0,
          "description": "Northward wind"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "y"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "DiffusionSystem": {
      "variables": {
        "ozone_conc": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone concentration"
        },
        "nitrogen_oxide": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-10,
          "description": "NO concentration"
        },
        "kh": {
          "units": "m^2/s",
          "default": 10.0,
          "description": "Horizontal diffusivity",
          "type": "parameter"
        },
        "kv": {
          "units": "m^2/s",
          "default": 1.0,
          "description": "Vertical diffusivity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "ozone_conc"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "kh",
                  {
                    "op": "laplacian",
                    "args": [
                      "ozone_conc"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "kv",
                  {
                    "op": "D",
                    "args": [
                      "ozone_conc"
                    ],
                    "wrt": "z"
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "nitrogen_oxide"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "kh",
                  {
                    "op": "laplacian",
                    "args": [
                      "nitrogen_oxide"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "kv",
                  {
                    "op": "D",
                    "args": [
                      "nitrogen_oxide"
                    ],
                    "wrt": "z"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "DepositionSystem": {
      "variables": {
        "surface_flux": {
          "type": "state",
          "units": "mol/m^2/s",
          "default": 0.0,
          "description": "Surface flux"
        },
        "deposition_velocity": {
          "units": "m/s",
          "default": 0.01,
          "description": "Deposition velocity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": "surface_flux",
          "rhs": {
            "op": "*",
            "args": [
              "deposition_velocity",
              "O3"
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "ChemistrySystem",
        "AdvectionSystem"
      ],
      "description": "TEST CASE 1: Basic operator_compose with placeholder expansion - AdvectionSystem's _var equation should expand to three equations for O3, NO, NO2"
    },
    {
      "type": "operator_compose",
      "systems": [
        "ChemistrySystem",
        "DiffusionSystem"
      ],
      "translate": {
        "O3": {
          "var": "ozone_conc",
          "factor": 1.0
        },
        "NO": {
          "var": "nitrogen_oxide",
          "factor": 1.0
        }
      },
      "description": "TEST CASE 2: operator_compose with translation mapping - ChemistrySystem.O3 maps to DiffusionSystem.ozone_conc"
    },
    {
      "type": "operator_compose",
      "systems": [
        "ChemistrySystem",
        "AdvectionSystem"
      ],
      "translate": {
        "O3": {
          "var": "O3",
          "factor": 1.0
        },
        "NO": {
          "var": "NO",
          "factor": 0.5
        },
        "NO2": {
          "var": "NO2",
          "factor": 2.0
        }
      },
      "description": "TEST CASE 3: operator_compose with conversion factors in translation - NO gets factor 0.5, NO2 gets factor 2.0"
    },
    {
      "type": "operator_compose",
      "systems": [
        "DiffusionSystem",
        "DepositionSystem"
      ],
      "translate": {
        "ozone_conc": {
          "var": "O3",
          "factor": 1.0
        }
      },
      "description": "TEST CASE 4: operator_compose between diffusion and algebraic constraint - mixing different equation types"
    }
  ]
}
