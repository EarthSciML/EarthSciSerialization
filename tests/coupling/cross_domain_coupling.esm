{
  "esm": "0.8.0",
  "metadata": {
    "name": "CrossDomainCoupling",
    "description": "Test fixture for cross-domain air-sea coupling with lifting strategies and a regridding aggregate.\nThe old air_sea interface (shared lon/lat between the atmosphere surface grid and the ocean surface grid) is re-expressed in v0.8.0 as a regridding aggregate inside Ocean3D: the atmosphere-grid sensible flux is remapped onto the ocean grid via overlap weights. 0-D <-> spatial mappings to the bulk flux calculator are captured by the coupling lifting field.\nMigrated to ESM v0.8.0.",
    "authors": [
      "EarthSciML"
    ],
    "created": "2026-04-09T00:00:00Z",
    "tags": [
      "cross-domain",
      "coupling",
      "regridding",
      "lifting",
      "migrated_to_v08"
    ]
  },
  "models": {
    "Ocean3D": {
      "index_sets": {
        "ocean_cells": {
          "kind": "interval",
          "size": 3
        },
        "atmos_cells": {
          "kind": "interval",
          "size": 3
        }
      },
      "variables": {
        "SST": {
          "type": "state",
          "units": "K",
          "default": 290.0,
          "shape": [
            "ocean_cells"
          ],
          "description": "Sea surface temperature on the ocean surface grid"
        },
        "salinity": {
          "type": "state",
          "units": "psu",
          "default": 35.0,
          "shape": [
            "ocean_cells"
          ],
          "description": "Salinity on the ocean surface grid"
        },
        "flux_atmos": {
          "type": "parameter",
          "units": "W/m^2",
          "default": 0.0,
          "shape": [
            "atmos_cells"
          ],
          "description": "Sensible heat flux sampled on the atmosphere surface grid (air-sea flux calculator output), regridded onto the ocean surface grid across the air-sea interface"
        },
        "air_sea_weight": {
          "type": "parameter",
          "units": "1",
          "shape": [
            "ocean_cells",
            "atmos_cells"
          ],
          "description": "Conservative air-sea regrid weights W[o,a] mapping atmosphere surface cells onto ocean surface cells over shared lon/lat (the old air_sea interface expressed as a regridding operator; each ocean-cell row sums to 1)"
        },
        "heat_flux": {
          "type": "observed",
          "units": "W/m^2",
          "shape": [
            "ocean_cells"
          ],
          "description": "Surface heat flux on the ocean grid, regridded from the atmosphere-grid sensible flux: heat_flux[o] = sum_a air_sea_weight[o,a] * flux_atmos[a]",
          "expression": {
            "op": "aggregate",
            "semiring": "sum_product",
            "output_idx": [
              "o"
            ],
            "ranges": {
              "o": {
                "from": "ocean_cells"
              },
              "a": {
                "from": "atmos_cells"
              }
            },
            "args": [
              "air_sea_weight",
              "flux_atmos"
            ],
            "expr": {
              "op": "*",
              "args": [
                {
                  "op": "index",
                  "args": [
                    "air_sea_weight",
                    "o",
                    "a"
                  ]
                },
                {
                  "op": "index",
                  "args": [
                    "flux_atmos",
                    "a"
                  ]
                }
              ]
            }
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "SST"
            ]
          },
          "rhs": 290.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "salinity"
            ]
          },
          "rhs": 290.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "SST"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              "heat_flux",
              4180000.0
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "salinity"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        }
      ]
    },
    "Atmosphere2D": {
      "variables": {
        "T_air": {
          "type": "state",
          "units": "K",
          "default": 288.0,
          "description": "Near-surface air temperature"
        },
        "wind_speed": {
          "type": "state",
          "units": "m/s",
          "default": 5.0,
          "description": "Surface wind speed"
        },
        "evap_rate": {
          "type": "parameter",
          "units": "kg/(m^2*s)",
          "default": 0.0,
          "description": "Evaporation rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "T_air"
            ]
          },
          "rhs": 288.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "wind_speed"
            ]
          },
          "rhs": 288.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "T_air"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "wind_speed"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        }
      ]
    },
    "BulkFluxCalculator": {
      "variables": {
        "T_air_in": {
          "type": "parameter",
          "units": "K",
          "default": 288.0
        },
        "SST_in": {
          "type": "parameter",
          "units": "K",
          "default": 290.0
        },
        "wind_in": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0
        },
        "C_D": {
          "type": "parameter",
          "units": "1",
          "default": 0.0015,
          "description": "Drag coefficient"
        },
        "rho": {
          "type": "parameter",
          "units": "kg/m^3",
          "default": 1.225
        },
        "c_p": {
          "type": "parameter",
          "units": "J/(kg*K)",
          "default": 1005.0
        },
        "sensible_flux": {
          "type": "observed",
          "units": "W/m^2",
          "expression": {
            "op": "*",
            "args": [
              "rho",
              "c_p",
              "C_D",
              "wind_in",
              {
                "op": "-",
                "args": [
                  "T_air_in",
                  "SST_in"
                ]
              }
            ]
          },
          "description": "Sensible heat flux"
        },
        "latent_flux": {
          "type": "observed",
          "units": "W/m^2",
          "expression": {
            "op": "*",
            "args": [
              "rho",
              2500000.0,
              "C_D",
              "wind_in",
              0.001
            ]
          },
          "description": "Latent heat flux (simplified)"
        }
      },
      "equations": []
    }
  },
  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-02T00:00:00Z"
    },
    "element_type": "Float64"
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "Atmosphere2D.T_air",
      "to": "BulkFluxCalculator.T_air_in",
      "transform": "param_to_var",
      "lifting": "pointwise",
      "description": "Air temperature to bulk flux calculator"
    },
    {
      "type": "variable_map",
      "from": "Atmosphere2D.wind_speed",
      "to": "BulkFluxCalculator.wind_in",
      "transform": "param_to_var",
      "lifting": "pointwise",
      "description": "Wind speed to bulk flux calculator"
    },
    {
      "type": "variable_map",
      "from": "Ocean3D.SST",
      "to": "BulkFluxCalculator.SST_in",
      "transform": "param_to_var",
      "lifting": "mean",
      "description": "SST from the spatial ocean surface grid reduced (mean) to the 0-D bulk flux calculator"
    },
    {
      "type": "variable_map",
      "from": "BulkFluxCalculator.sensible_flux",
      "to": "Ocean3D.flux_atmos",
      "transform": "param_to_var",
      "lifting": "broadcast",
      "description": "Sensible heat flux broadcast onto the atmosphere surface grid; Ocean3D regrids it onto the ocean grid (heat_flux) across the air-sea interface"
    }
  ]
}
