{
  "esm": "0.1.0",
  "metadata": {
    "name": "MultiStepCouplingChainsFixtures",
    "description": "Test fixtures for complex multi-step coupling resolution chains",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z"
  },
  "models": {
    "AtmosphereChemistry": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 2e-10,
          "description": "Nitrogen dioxide"
        },
        "HO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 5e-11,
          "description": "Hydroperoxyl radical"
        },
        "j_O3": {
          "units": "1/s",
          "default": 1e-05,
          "description": "Ozone photolysis rate",
          "type": "parameter"
        },
        "k_NO_HO2": {
          "units": "cm^3/molec/s",
          "default": 8e-12,
          "description": "NO + HO2 rate constant",
          "type": "parameter"
        },
        "temperature": {
          "units": "K",
          "default": 298.15,
          "description": "Temperature",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "j_O3",
                  "O3"
                ]
              },
              {
                "op": "*",
                "args": [
                  1e-14,
                  "O3",
                  "NO"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_NO_HO2",
                  "NO",
                  "HO2"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1e-14,
                  "O3",
                  "NO"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              1e-14,
              "O3",
              "NO"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "HO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "k_NO_HO2",
              "NO",
              "HO2"
            ]
          }
        }
      ]
    },
    "AtmosphereTransport": {
      "variables": {
        "u": {
          "type": "parameter",
          "units": "m/s",
          "default": 10.0,
          "description": "Zonal wind"
        },
        "v": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Meridional wind"
        },
        "w": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.1,
          "description": "Vertical wind"
        },
        "Kh": {
          "units": "m^2/s",
          "default": 100.0,
          "description": "Horizontal diffusivity",
          "type": "parameter"
        },
        "Kv": {
          "units": "m^2/s",
          "default": 10.0,
          "description": "Vertical diffusivity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "w"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "z"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "Kh",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "Kv",
                  {
                    "op": "D",
                    "args": [
                      "u"
                    ],
                    "wrt": "z"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "OceanBiogeochemistry": {
      "variables": {
        "DIC": {
          "type": "state",
          "units": "mol/m^3",
          "default": 2000.0,
          "description": "Dissolved inorganic carbon"
        },
        "O2": {
          "type": "state",
          "units": "mol/m^3",
          "default": 250.0,
          "description": "Dissolved oxygen"
        },
        "nutrients": {
          "type": "state",
          "units": "mol/m^3",
          "default": 30.0,
          "description": "Nutrient concentration"
        },
        "primary_production_rate": {
          "units": "1/s",
          "default": 1e-07,
          "description": "Primary production rate",
          "type": "parameter"
        },
        "respiration_rate": {
          "units": "1/s",
          "default": 5e-08,
          "description": "Respiration rate",
          "type": "parameter"
        },
        "gas_exchange_velocity": {
          "units": "m/s",
          "default": 3e-05,
          "description": "Air-sea gas exchange",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "DIC"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "respiration_rate",
                  "O2"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1,
                  "primary_production_rate",
                  "DIC",
                  "nutrients"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "O2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "primary_production_rate",
                  "DIC",
                  "nutrients"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1,
                  "respiration_rate",
                  "O2"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "nutrients"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "respiration_rate",
                  "O2",
                  0.16
                ]
              },
              {
                "op": "*",
                "args": [
                  -1,
                  "primary_production_rate",
                  "DIC",
                  "nutrients"
                ]
              }
            ]
          }
        }
      ]
    },
    "LandVegetation": {
      "variables": {
        "biomass": {
          "type": "state",
          "units": "kg/m^2",
          "default": 5.0,
          "description": "Vegetation biomass"
        },
        "soil_carbon": {
          "type": "state",
          "units": "kg/m^2",
          "default": 10.0,
          "description": "Soil carbon"
        },
        "photosynthesis_rate": {
          "units": "1/s",
          "default": 1e-07,
          "description": "Photosynthesis rate",
          "type": "parameter"
        },
        "respiration_rate": {
          "units": "1/s",
          "default": 5e-08,
          "description": "Plant respiration",
          "type": "parameter"
        },
        "decomposition_rate": {
          "units": "1/s",
          "default": 1e-08,
          "description": "Soil decomposition",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "biomass"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "photosynthesis_rate",
                  "biomass"
                ]
              },
              {
                "op": "*",
                "args": [
                  "respiration_rate",
                  "biomass"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "soil_carbon"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "respiration_rate",
                  "biomass"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1,
                  "decomposition_rate",
                  "soil_carbon"
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "data_loaders": {
    "MeteorologicalForcing": {
      "type": "gridded_data",
      "loader_id": "meteorological_netcdf",
      "config": {
        "url": "file://met_forcing.nc",
        "time_dimension": "time"
      },
      "provides": {
        "wind_u": {
          "units": "m/s",
          "description": "Zonal wind velocity"
        },
        "wind_v": {
          "units": "m/s",
          "description": "Meridional wind velocity"
        },
        "solar_flux": {
          "units": "W/m^2",
          "description": "Solar radiation flux"
        },
        "air_temperature": {
          "units": "K",
          "description": "Air temperature"
        }
      }
    },
    "EmissionInventory": {
      "type": "emissions",
      "loader_id": "emissions_csv",
      "config": {
        "url": "file://emissions.csv",
        "time_column": "datetime"
      },
      "provides": {
        "NOx_emissions": {
          "units": "mol/m^2/s",
          "description": "NOx emission rate"
        },
        "CO2_flux": {
          "units": "kg/m^2/s",
          "description": "CO2 surface flux"
        }
      }
    }
  },
  "operators": {
    "PhotolysisCalculator": {
      "description": "Calculate photolysis rates from solar radiation",
      "operator_id": "PhotolysisCalculator",
      "needed_vars": [],
      "config": {
        "inputs": [
          "solar_flux",
          "O3_column"
        ],
        "outputs": [
          "j_O3",
          "j_NO2"
        ],
        "algorithm": "TUV_photolysis"
      }
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphereChemistry",
        "AtmosphereTransport"
      ],
      "description": "STEP 1: Couple chemistry with transport (placeholder expansion for all chemical species)"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalForcing.wind_u",
      "to": "AtmosphereTransport.u",
      "transform": "param_to_var",
      "description": "STEP 2: Replace constant wind with time-varying meteorological data"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalForcing.wind_v",
      "to": "AtmosphereTransport.v",
      "transform": "param_to_var",
      "description": "STEP 3: Replace meridional wind with data"
    },
    {
      "type": "variable_map",
      "from": "MeteorologicalForcing.air_temperature",
      "to": "AtmosphereChemistry.temperature",
      "transform": "param_to_var",
      "description": "STEP 4: Replace constant temperature with meteorological forcing"
    },
    {
      "type": "operator_apply",
      "operator": "PhotolysisCalculator",
      "description": "STEP 5: Calculate photolysis rates from solar radiation and ozone column"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.NOx_emissions",
      "to": "AtmosphereChemistry.NO",
      "transform": "additive",
      "description": "STEP 6: Add surface NOx emissions to NO equation"
    },
    {
      "type": "couple2",
      "systems": [
        "AtmosphereChemistry",
        "OceanBiogeochemistry"
      ],
      "coupletype_pair": [
        "AtmosphereOceanCoupler",
        "OceanAtmosphereCoupler"
      ],
      "connector": {
        "equations": [
          {
            "from": "OceanBiogeochemistry.O2",
            "to": "AtmosphereChemistry.HO2",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "gas_exchange_velocity",
                {
                  "op": "-",
                  "args": [
                    "O2",
                    250.0
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "STEP 7: Couple atmosphere and ocean through gas exchange"
    },
    {
      "type": "couple2",
      "systems": [
        "AtmosphereChemistry",
        "LandVegetation"
      ],
      "coupletype_pair": [
        "AtmosphereLandCoupler",
        "LandAtmosphereCoupler"
      ],
      "connector": {
        "equations": [
          {
            "from": "LandVegetation.biomass",
            "to": "AtmosphereChemistry.O3",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                -1e-10,
                "biomass",
                "O3"
              ]
            }
          },
          {
            "from": "AtmosphereChemistry.O3",
            "to": "LandVegetation.photosynthesis_rate",
            "transform": "multiplicative",
            "expression": {
              "op": "exp",
              "args": [
                {
                  "op": "*",
                  "args": [
                    -0.1,
                    "O3"
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "STEP 8: Couple atmosphere and land through deposition and ozone stress"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.CO2_flux",
      "to": "LandVegetation.soil_carbon",
      "transform": "additive",
      "description": "STEP 9: Add anthropogenic CO2 flux to soil carbon budget"
    },
    {
      "type": "operator_compose",
      "systems": [
        "OceanBiogeochemistry",
        "AtmosphereTransport"
      ],
      "translate": {
        "DIC": {
          "var": "CO2_dissolved",
          "factor": 1.0
        },
        "O2": {
          "var": "O2_dissolved",
          "factor": 1.0
        }
      },
      "description": "STEP 10: Apply transport to dissolved ocean tracers (creates new variables)"
    }
  ]
}
