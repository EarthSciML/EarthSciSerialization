{
  "esm": "0.1.0",
  "metadata": {
    "name": "Couple2ResolutionFixtures",
    "description": "Test fixtures for couple2 coupling resolution algorithm (Section 4.7.2)",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z"
  },
  "models": {
    "FluidDynamics": {
      "variables": {
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 1.0,
          "description": "Flow velocity"
        },
        "pressure": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Fluid pressure"
        },
        "density": {
          "type": "parameter",
          "units": "kg/m^3",
          "default": 1000.0,
          "description": "Fluid density"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "/",
                "args": [
                  {
                    "op": "grad",
                    "args": [
                      "pressure"
                    ],
                    "dim": "x"
                  },
                  "density"
                ]
              },
              {
                "op": "*",
                "args": [
                  0.1,
                  "velocity"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "pressure"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "density",
              {
                "op": "div",
                "args": [
                  "velocity"
                ]
              }
            ]
          }
        }
      ]
    },
    "HeatTransfer": {
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 300.0,
          "description": "Temperature"
        },
        "heat_flux": {
          "type": "state",
          "units": "W/m^2",
          "default": 0.0,
          "description": "Heat flux"
        },
        "thermal_conductivity": {
          "units": "W/m/K",
          "default": 0.6,
          "description": "Thermal conductivity",
          "type": "parameter"
        },
        "heat_capacity": {
          "units": "J/kg/K",
          "default": 4180.0,
          "description": "Heat capacity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "/",
                "args": [
                  "thermal_conductivity",
                  "heat_capacity"
                ]
              },
              {
                "op": "laplacian",
                "args": [
                  "temperature"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "heat_flux"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "thermal_conductivity",
              {
                "op": "grad",
                "args": [
                  "temperature"
                ],
                "dim": "x"
              }
            ]
          }
        }
      ]
    },
    "MassTransfer": {
      "variables": {
        "concentration": {
          "type": "state",
          "units": "kg/m^3",
          "default": 1.0,
          "description": "Species concentration"
        },
        "mass_flux": {
          "type": "state",
          "units": "kg/m^2/s",
          "default": 0.0,
          "description": "Mass flux"
        },
        "diffusivity": {
          "units": "m^2/s",
          "default": 1e-09,
          "description": "Mass diffusivity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "diffusivity",
              {
                "op": "laplacian",
                "args": [
                  "concentration"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "mass_flux"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "diffusivity",
              {
                "op": "grad",
                "args": [
                  "concentration"
                ],
                "dim": "x"
              }
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "couple2",
      "systems": [
        "FluidDynamics",
        "HeatTransfer"
      ],
      "coupletype_pair": [
        "FluidThermalCoupler",
        "ThermalFluidCoupler"
      ],
      "connector": {
        "equations": [
          {
            "from": "FluidDynamics.velocity",
            "to": "HeatTransfer.temperature",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                0.01,
                "velocity"
              ]
            }
          },
          {
            "from": "HeatTransfer.temperature",
            "to": "FluidDynamics.density",
            "transform": "multiplicative",
            "expression": {
              "op": "/",
              "args": [
                300.0,
                "temperature"
              ]
            }
          }
        ]
      },
      "description": "TEST CASE 1: couple2 with additive and multiplicative transforms"
    },
    {
      "type": "couple2",
      "systems": [
        "HeatTransfer",
        "MassTransfer"
      ],
      "coupletype_pair": [
        "ThermalMassCoupler",
        "MassThermalCoupler"
      ],
      "connector": {
        "equations": [
          {
            "from": "HeatTransfer.temperature",
            "to": "MassTransfer.concentration",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                0.001,
                {
                  "op": "exp",
                  "args": [
                    {
                      "op": "/",
                      "args": [
                        {
                          "op": "-",
                          "args": [
                            "temperature",
                            300.0
                          ]
                        },
                        50.0
                      ]
                    }
                  ]
                }
              ]
            }
          },
          {
            "from": "MassTransfer.concentration",
            "to": "HeatTransfer.heat_flux",
            "transform": "replacement",
            "expression": {
              "op": "*",
              "args": [
                1000.0,
                "concentration"
              ]
            }
          }
        ]
      },
      "description": "TEST CASE 2: couple2 with additive and replacement transforms"
    },
    {
      "type": "couple2",
      "systems": [
        "FluidDynamics",
        "MassTransfer"
      ],
      "coupletype_pair": [
        "FluidMassCoupler",
        "MassFluidCoupler"
      ],
      "connector": {
        "equations": [
          {
            "from": "FluidDynamics.velocity",
            "to": "MassTransfer.mass_flux",
            "transform": "multiplicative",
            "expression": "velocity"
          },
          {
            "from": "MassTransfer.concentration",
            "to": "FluidDynamics.pressure",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                8314.0,
                "concentration"
              ]
            }
          },
          {
            "from": "FluidDynamics.pressure",
            "to": "MassTransfer.concentration",
            "transform": "multiplicative",
            "expression": {
              "op": "+",
              "args": [
                1.0,
                {
                  "op": "*",
                  "args": [
                    1e-06,
                    "pressure"
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "TEST CASE 3: couple2 with complex multi-directional coupling and all transform types"
    }
  ]
}
