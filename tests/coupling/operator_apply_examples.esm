{
  "esm": "0.2.0",
  "metadata": {
    "name": "OperatorApplyExamples",
    "description": "Test fixtures for operator_apply coupling with runtime operators\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z",
    "tags": [
      "migrated_from_v01"
    ]
  },
  "operators": {
    "SpatialAverage": {
      "operator_id": "spatial_average_1d",
      "description": "Compute spatial average over 1D domain",
      "needed_vars": [
        "input_field"
      ],
      "config": {
        "provides": [
          "averaged_value"
        ],
        "implementation": {
          "type": "builtin",
          "method": "integrate_trapezoid"
        }
      }
    },
    "GaussianSmoothing": {
      "operator_id": "gaussian_smooth",
      "description": "Apply Gaussian smoothing filter",
      "needed_vars": [
        "raw_field"
      ],
      "config": {
        "provides": [
          "smoothed_field"
        ],
        "parameters": {
          "sigma": {
            "units": "m",
            "default": 0.1,
            "description": "Smoothing width"
          }
        },
        "implementation": {
          "type": "convolution",
          "kernel": "gaussian"
        }
      }
    },
    "DerivativeOperator": {
      "operator_id": "central_difference",
      "description": "Central difference derivative",
      "needed_vars": [
        "field"
      ],
      "config": {
        "provides": [
          "field_derivative"
        ],
        "parameters": {
          "order": {
            "units": "1",
            "default": 2,
            "description": "Finite difference order"
          }
        },
        "implementation": {
          "type": "finite_difference",
          "stencil": "central"
        }
      }
    }
  },
  "models": {
    "ConcentrationField": {
      "reference": {
        "notes": "Scalar concentration field with local reactions"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/m^3",
          "default": 1.0,
          "description": "Local concentration"
        },
        "local_mean": {
          "type": "observed",
          "units": "mol/m^3",
          "description": "Spatially averaged concentration",
          "expression": 0.0
        },
        "smooth_conc": {
          "type": "observed",
          "units": "mol/m^3",
          "description": "Smoothed concentration",
          "expression": 0.0
        },
        "reaction_rate": {
          "units": "1/s",
          "default": 0.1,
          "description": "Local reaction rate",
          "type": "parameter"
        },
        "diffusion_coeff": {
          "units": "m^2/s",
          "default": 1e-05,
          "description": "Diffusion coefficient",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "diffusion_coeff",
                  {
                    "op": "laplacian",
                    "args": [
                      "concentration"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "reaction_rate",
                  {
                    "op": "-",
                    "args": [
                      "local_mean",
                      "concentration"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  0.05,
                  {
                    "op": "-",
                    "args": [
                      "smooth_conc",
                      "concentration"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "concentration_neumann_xmin": {
          "variable": "concentration",
          "side": "xmin",
          "kind": "neumann",
          "value": 0.0
        },
        "concentration_neumann_xmax": {
          "variable": "concentration",
          "side": "xmax",
          "kind": "neumann",
          "value": 0.0
        },
        "concentration_dirichlet_xmin": {
          "variable": "concentration",
          "side": "xmin",
          "kind": "dirichlet",
          "value": 0.0
        },
        "concentration_dirichlet_xmax": {
          "variable": "concentration",
          "side": "xmax",
          "kind": "dirichlet",
          "value": 0.0
        }
      }
    },
    "FlowField": {
      "reference": {
        "notes": "Velocity field with feedback from concentration gradients"
      },
      "variables": {
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Flow velocity"
        },
        "conc_gradient": {
          "type": "observed",
          "units": "mol/m^4",
          "description": "Concentration gradient",
          "expression": 0.0
        },
        "viscous_damping": {
          "units": "1/s",
          "default": 0.01,
          "description": "Viscous damping coefficient",
          "type": "parameter"
        },
        "buoyancy_strength": {
          "units": "m^4/(mol·s)",
          "default": 1e-06,
          "description": "Buoyancy coupling strength",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "viscous_damping"
                    ]
                  },
                  "velocity"
                ]
              },
              {
                "op": "*",
                "args": [
                  "buoyancy_strength",
                  "conc_gradient"
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "velocity_neumann_xmin": {
          "variable": "velocity",
          "side": "xmin",
          "kind": "neumann",
          "value": 0.0
        },
        "velocity_neumann_xmax": {
          "variable": "velocity",
          "side": "xmax",
          "kind": "neumann",
          "value": 0.0
        },
        "velocity_dirichlet_xmin": {
          "variable": "velocity",
          "side": "xmin",
          "kind": "dirichlet",
          "value": 0.0
        },
        "velocity_dirichlet_xmax": {
          "variable": "velocity",
          "side": "xmax",
          "kind": "dirichlet",
          "value": 0.0
        }
      }
    }
  },
  "coupling": [
    {
      "type": "operator_apply",
      "operator": "SpatialAverage"
    },
    {
      "type": "operator_apply",
      "operator": "GaussianSmoothing"
    },
    {
      "type": "operator_apply",
      "operator": "DerivativeOperator"
    },
    {
      "type": "operator_compose",
      "systems": [
        "ConcentrationField",
        "FlowField"
      ]
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T02:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 10.0,
          "grid_spacing": 0.1,
          "units": "m"
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "element_type": "Float64"
    }
  }
}
