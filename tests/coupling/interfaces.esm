{
  "esm": "0.8.0",
  "metadata": {
    "name": "InterfaceDefinitions",
    "description": "Test fixture for cross-grid coupling re-expressed as regridding aggregates.\nThe old tropopause/land_atmosphere/ice_atmosphere interfaces (shared lon/lat plus level/pressure selection between two domains) are migrated to v0.8.0: the tropopause coupling is realized as a regridding aggregate inside LowerAtmosphere that remaps stratospheric ozone onto the troposphere; spatial <-> 0-D mappings use the coupling lifting field.\nMigrated to ESM v0.8.0.",
    "authors": [
      "EarthSciML"
    ],
    "created": "2026-04-09T00:00:00Z",
    "tags": [
      "interfaces",
      "regridding",
      "cross-grid",
      "lifting",
      "migrated_to_v08"
    ]
  },
  "models": {
    "UpperAtmosphere": {
      "index_sets": {
        "upper_cells": {
          "kind": "interval",
          "size": 3
        }
      },
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-07,
          "shape": [
            "upper_cells"
          ],
          "description": "Ozone mixing ratio on the stratospheric grid"
        },
        "T": {
          "type": "state",
          "units": "K",
          "default": 220.0,
          "shape": [
            "upper_cells"
          ],
          "description": "Temperature on the stratospheric grid"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "O3"
            ]
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "T"
            ]
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "T"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        }
      ]
    },
    "LowerAtmosphere": {
      "index_sets": {
        "lower_cells": {
          "kind": "interval",
          "size": 3
        },
        "upper_cells": {
          "kind": "interval",
          "size": 3
        }
      },
      "variables": {
        "T": {
          "type": "state",
          "units": "K",
          "default": 288.0,
          "shape": [
            "lower_cells"
          ],
          "description": "Temperature on the tropospheric grid"
        },
        "q": {
          "type": "state",
          "units": "kg/kg",
          "default": 0.01,
          "shape": [
            "lower_cells"
          ],
          "description": "Specific humidity on the tropospheric grid"
        },
        "O3_strat": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 5e-08,
          "shape": [
            "upper_cells"
          ],
          "description": "Stratospheric ozone sampled on the upper-atmosphere grid (coupling input), regridded to the troposphere across the tropopause"
        },
        "tropopause_weight": {
          "type": "parameter",
          "units": "1",
          "shape": [
            "lower_cells",
            "upper_cells"
          ],
          "description": "Tropopause regrid weights mapping upper-atmosphere cells onto lower-atmosphere cells over shared lon/lat (the old tropopause interface expressed as a regridding operator; each lower-cell row sums to 1)"
        },
        "O3_boundary": {
          "type": "observed",
          "units": "mol/mol",
          "shape": [
            "lower_cells"
          ],
          "description": "Ozone boundary value on the tropospheric grid, regridded from the stratosphere: O3_boundary[l] = sum_u tropopause_weight[l,u] * O3_strat[u]",
          "expression": {
            "op": "aggregate",
            "semiring": "sum_product",
            "output_idx": [
              "l"
            ],
            "ranges": {
              "l": {
                "from": "lower_cells"
              },
              "u": {
                "from": "upper_cells"
              }
            },
            "args": [
              "tropopause_weight",
              "O3_strat"
            ],
            "expr": {
              "op": "*",
              "args": [
                {
                  "op": "index",
                  "args": [
                    "tropopause_weight",
                    "l",
                    "u"
                  ]
                },
                {
                  "op": "index",
                  "args": [
                    "O3_strat",
                    "u"
                  ]
                }
              ]
            }
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "T"
            ]
          },
          "rhs": 288.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "q"
            ]
          },
          "rhs": 288.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "T"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "q"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        }
      ]
    },
    "LandSurface": {
      "variables": {
        "T_soil": {
          "type": "state",
          "units": "K",
          "default": 290.0,
          "description": "Soil temperature"
        },
        "soil_moisture": {
          "type": "state",
          "units": "m^3/m^3",
          "default": 0.3,
          "description": "Volumetric soil moisture"
        },
        "atm_precip": {
          "type": "parameter",
          "units": "kg/(m^2*s)",
          "default": 0.0,
          "description": "Precipitation from atmosphere"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "T_soil"
            ]
          },
          "rhs": 290.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "soil_moisture"
            ]
          },
          "rhs": 290.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "T_soil"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "soil_moisture"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              "atm_precip",
              1000.0
            ]
          }
        }
      ]
    },
    "IceSheet": {
      "variables": {
        "thickness": {
          "type": "state",
          "units": "m",
          "default": 1000.0,
          "description": "Ice thickness"
        },
        "basal_melt": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Basal melting rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "ic",
            "args": [
              "thickness"
            ]
          },
          "rhs": 1000.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "thickness"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "basal_melt"
            ]
          }
        }
      ]
    }
  },
  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-02T00:00:00Z"
    },
    "element_type": "Float64"
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "UpperAtmosphere.O3",
      "to": "LowerAtmosphere.O3_strat",
      "transform": "param_to_var",
      "lifting": "pointwise",
      "description": "Stratospheric ozone supplied to the lower atmosphere on the upper grid; LowerAtmosphere regrids it to the troposphere (O3_boundary) across the tropopause"
    },
    {
      "type": "variable_map",
      "from": "LowerAtmosphere.q",
      "to": "LandSurface.atm_precip",
      "transform": "conversion_factor",
      "factor": 0.001,
      "lifting": "mean",
      "description": "Tropospheric humidity reduced (mean) from the spatial grid to the 0-D land surface as precipitation"
    }
  ]
}
