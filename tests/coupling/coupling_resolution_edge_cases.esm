{
  "esm": "0.1.0",
  "metadata": {
    "name": "CouplingResolutionEdgeCases",
    "description": "Edge cases and boundary conditions for coupling resolution algorithms",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z"
  },
  "models": {
    "EmptySystem": {
      "variables": {},
      "equations": []
    },
    "SingleVariableSystem": {
      "variables": {
        "x": {
          "type": "state",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Single state variable"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -0.1,
              "x"
            ]
          }
        }
      ]
    },
    "ParameterOnlySystem": {
      "variables": {
        "a": {
          "units": "1/s",
          "default": 0.5,
          "description": "Parameter a",
          "type": "parameter"
        },
        "b": {
          "units": "dimensionless",
          "default": 2.0,
          "description": "Parameter b",
          "type": "parameter"
        }
      },
      "equations": []
    },
    "AlgebraicSystem": {
      "variables": {
        "y": {
          "type": "observed",
          "units": "dimensionless",
          "description": "Algebraic variable",
          "expression": 0.0
        },
        "z": {
          "type": "observed",
          "units": "dimensionless",
          "description": "Another algebraic variable",
          "expression": 0.0
        },
        "c": {
          "units": "dimensionless",
          "default": 3.0,
          "description": "Coefficient",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": "y",
          "rhs": {
            "op": "+",
            "args": [
              "z",
              "c"
            ]
          }
        },
        {
          "lhs": "z",
          "rhs": {
            "op": "*",
            "args": [
              2.0,
              "c"
            ]
          }
        }
      ]
    },
    "ConflictingNamesSystem": {
      "variables": {
        "x": {
          "type": "state",
          "units": "m",
          "default": 0.0,
          "description": "Position x (different from SingleVariableSystem.x)"
        },
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 300.0,
          "description": "Temperature state"
        },
        "a": {
          "units": "m/s^2",
          "default": 1.0,
          "description": "Acceleration (different units from ParameterOnlySystem.a)",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "a",
              "temperature"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -0.01,
              "temperature"
            ]
          }
        }
      ]
    },
    "PlaceholderTestSystem": {
      "variables": {
        "normal_var": {
          "type": "state",
          "units": "dimensionless",
          "default": 2.0,
          "description": "Normal variable"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              "u"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "normal_var"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -2,
              "normal_var"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              "u",
              "normal_var"
            ]
          }
        }
      ]
    }
  },
  "data_loaders": {
    "EmptyDataLoader": {
      "kind": "static",
      "source": {
        "url_template": "file:///data/empty_csv.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "value": {
          "file_variable": "value",
          "units": "1"
        }
      },
      "metadata": {
        "tags": [
          "static"
        ]
      }
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "EmptySystem",
        "SingleVariableSystem"
      ],
      "description": "EDGE CASE 1: Compose empty system with non-empty system"
    },
    {
      "type": "operator_compose",
      "systems": [
        "EmptySystem",
        "EmptySystem"
      ],
      "description": "EDGE CASE 2: Compose two empty systems"
    },
    {
      "type": "operator_compose",
      "systems": [
        "SingleVariableSystem",
        "SingleVariableSystem"
      ],
      "description": "EDGE CASE 3: Self-coupling - compose system with itself"
    },
    {
      "type": "operator_compose",
      "systems": [
        "ParameterOnlySystem",
        "SingleVariableSystem"
      ],
      "description": "EDGE CASE 4: Compose parameter-only system with state system (placeholder expansion with no matching equations)"
    },
    {
      "type": "operator_compose",
      "systems": [
        "SingleVariableSystem",
        "AlgebraicSystem"
      ],
      "description": "EDGE CASE 5: Mix ODE and algebraic equations"
    },
    {
      "type": "operator_compose",
      "systems": [
        "SingleVariableSystem",
        "ConflictingNamesSystem"
      ],
      "translate": {
        "x": {
          "var": "x",
          "factor": 1.0
        }
      },
      "description": "EDGE CASE 6: Variable name conflict - both systems have 'x' with different meanings"
    },
    {
      "type": "operator_compose",
      "systems": [
        "SingleVariableSystem",
        "ConflictingNamesSystem"
      ],
      "translate": {
        "x": {
          "var": "nonexistent_var",
          "factor": 1.0
        }
      },
      "description": "EDGE CASE 7: Translation to non-existent variable"
    },
    {
      "type": "operator_compose",
      "systems": [
        "PlaceholderTestSystem",
        "SingleVariableSystem"
      ],
      "description": "EDGE CASE 8: System with variable literally named '_var' - disambiguation required"
    },
    {
      "type": "variable_map",
      "from": "EmptyDataLoader.nonexistent_var",
      "to": "SingleVariableSystem.x",
      "transform": "param_to_var",
      "description": "EDGE CASE 9: Map from non-existent data loader variable"
    },
    {
      "type": "variable_map",
      "from": "SingleVariableSystem.x",
      "to": "EmptySystem.nonexistent_param",
      "transform": "param_to_var",
      "description": "EDGE CASE 10: Map to non-existent parameter in empty system"
    },
    {
      "type": "variable_map",
      "from": "ParameterOnlySystem.a",
      "to": "ParameterOnlySystem.a",
      "transform": "identity",
      "description": "EDGE CASE 11: Self-mapping - parameter mapped to itself"
    },
    {
      "type": "variable_map",
      "from": "AlgebraicSystem.y",
      "to": "SingleVariableSystem.x",
      "transform": "additive",
      "description": "EDGE CASE 12: Map algebraic variable to ODE variable"
    },
    {
      "type": "couple",
      "systems": [
        "EmptySystem",
        "SingleVariableSystem"
      ],
      "connector": {
        "equations": [
          {
            "from": "x",
            "to": "y",
            "transform": "additive"
          }
        ]
      },
      "description": "EDGE CASE 13: couple with empty connector equations"
    },
    {
      "type": "couple",
      "systems": [
        "SingleVariableSystem",
        "SingleVariableSystem"
      ],
      "connector": {
        "equations": [
          {
            "from": "SingleVariableSystem.x",
            "to": "SingleVariableSystem.x",
            "transform": "multiplicative",
            "expression": {
              "op": "+",
              "args": [
                1.0,
                0.1
              ]
            }
          }
        ]
      },
      "description": "EDGE CASE 14: couple self-coupling"
    },
    {
      "type": "couple",
      "systems": [
        "ConflictingNamesSystem",
        "AlgebraicSystem"
      ],
      "connector": {
        "equations": [
          {
            "from": "ConflictingNamesSystem.temperature",
            "to": "AlgebraicSystem.y",
            "transform": "replacement",
            "expression": "temperature"
          },
          {
            "from": "AlgebraicSystem.y",
            "to": "ConflictingNamesSystem.temperature",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                0.01,
                "y"
              ]
            }
          }
        ]
      },
      "description": "EDGE CASE 15: couple with circular dependencies"
    }
  ]
}
