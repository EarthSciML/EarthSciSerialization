{
  "esm": "0.1.0",
  "metadata": {
    "name": "InterpolationCouplingExample",
    "description": "Example demonstrating interpolation operators in coupled model scenarios for data fusion and regridding",
    "authors": [
      "ESM Format Team"
    ],
    "created": "2026-02-19T00:00:00Z",
    "tags": [
      "interpolation",
      "coupling",
      "regridding",
      "data_fusion"
    ]
  },
  "operators": {
    "AtmosphericDataInterpolator": {
      "operator_id": "atmospheric_regrid",
      "reference": {
        "citation": "Atmospheric data regridding using bilinear interpolation",
        "notes": "Regrid atmospheric model data to observation grid for data assimilation"
      },
      "config": {
        "method": "bilinear",
        "grid_type": "regular",
        "extrapolation": "nearest",
        "coordinate_system": "geographic"
      },
      "needed_vars": [
        "atm_temperature",
        "atm_pressure",
        "atm_lon",
        "atm_lat",
        "obs_lon",
        "obs_lat"
      ],
      "modifies": [
        "regridded_temperature",
        "regridded_pressure"
      ],
      "description": "Interpolate atmospheric model data to observation grid"
    },
    "TemporalSmoother": {
      "operator_id": "temporal_spline_smooth",
      "reference": {
        "citation": "Temporal smoothing using cubic spline interpolation",
        "notes": "Smooth temporal variations in observational data for model integration"
      },
      "config": {
        "method": "cubic_spline",
        "smoothing_factor": 0.1,
        "boundary_condition": "natural"
      },
      "needed_vars": [
        "time_coords",
        "raw_observations"
      ],
      "modifies": [
        "smoothed_observations",
        "observation_uncertainty"
      ],
      "description": "Apply cubic spline smoothing to observational time series"
    },
    "ConservativeFluxRemapper": {
      "operator_id": "conservative_flux_remap",
      "reference": {
        "doi": "10.1175/1520-0493(1999)127<2204:FASOCR>2.0.CO;2",
        "citation": "Jones, P. W. (1999). Conservative remapping for flux quantities",
        "notes": "Mass-conserving remapping for emissions and flux data"
      },
      "config": {
        "method": "conservative",
        "order": 1,
        "normalization": "fracarea",
        "monotonic": true
      },
      "needed_vars": [
        "source_emissions",
        "source_cell_areas",
        "target_cell_areas"
      ],
      "modifies": [
        "remapped_emissions"
      ],
      "description": "Conservative remapping of emission fluxes between grids"
    }
  },
  "data_loaders": {
    "ObservationData": {
      "type": "timeseries",
      "loader_id": "csv_timeseries_loader",
      "provides": {
        "obs_temperature": {
          "units": "K",
          "description": "Observed temperature"
        },
        "obs_pressure": {
          "units": "Pa",
          "description": "Observed pressure"
        }
      },
      "interpolation": "linear",
      "temporal_resolution": "PT1H"
    },
    "EmissionInventory": {
      "type": "gridded_data",
      "loader_id": "netcdf_gridded_loader",
      "provides": {
        "NOx_emissions": {
          "units": "kg/m2/s",
          "description": "NOx emission flux"
        },
        "CO_emissions": {
          "units": "kg/m2/s",
          "description": "CO emission flux"
        }
      },
      "interpolation": "linear",
      "spatial_resolution": {
        "lon": 0.5,
        "lat": 0.5
      }
    }
  },
  "models": {
    "AtmosphericChemistry": {
      "variables": {
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 2e-08,
          "description": "NO2 concentration"
        },
        "CO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-07,
          "description": "CO concentration"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  1e-08,
                  "NOx_emissions"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1e-05,
                  "NO2"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "CO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  2e-08,
                  "CO_emissions"
                ]
              },
              {
                "op": "*",
                "args": [
                  -1e-06,
                  "CO"
                ]
              }
            ]
          }
        }
      ]
    },
    "DataAssimilation": {
      "variables": {
        "model_error": {
          "type": "state",
          "units": "dimensionless",
          "default": 0.0,
          "description": "Model-observation mismatch"
        },
        "obs_weight": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 0.5,
          "description": "Observational weight in assimilation"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "model_error"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "obs_weight",
              {
                "op": "-",
                "args": [
                  "obs_temperature",
                  "temperature"
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "operator_apply",
      "operator": "AtmosphericDataInterpolator",
      "description": "Interpolate atmospheric model data to observation locations"
    },
    {
      "type": "operator_apply",
      "operator": "TemporalSmoother",
      "description": "Smooth observational data for model integration"
    },
    {
      "type": "operator_apply",
      "operator": "ConservativeFluxRemapper",
      "description": "Remap emission inventories to model grid conservatively"
    },
    {
      "type": "variable_map",
      "from": "ObservationData.obs_temperature",
      "to": "DataAssimilation.obs_temperature",
      "transform": "identity",
      "description": "Map interpolated observation data to assimilation system"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.NOx_emissions",
      "to": "AtmosphericChemistry.NOx_emissions",
      "transform": "identity",
      "description": "Map remapped emissions to chemistry model"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.CO_emissions",
      "to": "AtmosphericChemistry.CO_emissions",
      "transform": "identity",
      "description": "Map remapped CO emissions to chemistry model"
    },
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "DataAssimilation"
      ],
      "description": "Compose atmospheric chemistry with data assimilation",
      "translate": {
        "temperature": "obs_temperature"
      }
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-06-01T00:00:00Z",
        "end": "2024-06-02T00:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -125.0,
          "max": -65.0,
          "units": "degrees_east",
          "grid_spacing": 0.25
        },
        "lat": {
          "min": 25.0,
          "max": 50.0,
          "units": "degrees_north",
          "grid_spacing": 0.25
        },
        "lev": {
          "min": 1000.0,
          "max": 100000.0,
          "units": "Pa",
          "grid_spacing": 1000.0
        }
      },
      "coordinate_transforms": [
        {
          "id": "pressure_to_altitude",
          "description": "Transform from pressure to altitude coordinates",
          "dimensions": [
            "lev"
          ]
        }
      ]
    }
  }
}
