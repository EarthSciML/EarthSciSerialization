{
  "esm": "0.1.0",
  "metadata": {
    "name": "VariableMapResolutionFixtures",
    "description": "Test fixtures for variable_map coupling resolution algorithm (Section 4.7.3)",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z"
  },
  "models": {
    "AtmosphericModel": {
      "variables": {
        "ozone": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone mixing ratio"
        },
        "pressure": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Atmospheric pressure"
        },
        "temperature": {
          "units": "K",
          "default": 298.15,
          "description": "Air temperature",
          "type": "parameter"
        },
        "humidity": {
          "units": "%",
          "default": 60.0,
          "description": "Relative humidity",
          "type": "parameter"
        },
        "wind_speed": {
          "units": "m/s",
          "default": 5.0,
          "description": "Wind speed",
          "type": "parameter"
        },
        "solar_radiation": {
          "units": "W/m^2",
          "default": 800.0,
          "description": "Solar radiation",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "ozone"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.001,
                  "solar_radiation",
                  "ozone"
                ]
              },
              {
                "op": "*",
                "args": [
                  -0.0001,
                  "temperature",
                  "ozone"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "pressure"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -0.1,
              "wind_speed",
              {
                "op": "grad",
                "args": [
                  "pressure"
                ],
                "dim": "x"
              }
            ]
          }
        }
      ]
    },
    "OceanModel": {
      "variables": {
        "sea_surface_temperature": {
          "type": "state",
          "units": "K",
          "default": 285.0,
          "description": "Sea surface temperature"
        },
        "salinity": {
          "type": "state",
          "units": "psu",
          "default": 35.0,
          "description": "Salinity"
        },
        "heat_exchange_coefficient": {
          "units": "W/m^2/K",
          "default": 20.0,
          "description": "Air-sea heat exchange",
          "type": "parameter"
        },
        "evaporation_rate": {
          "units": "m/s",
          "default": 1e-08,
          "description": "Evaporation rate",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "sea_surface_temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "heat_exchange_coefficient",
              {
                "op": "-",
                "args": [
                  "temperature",
                  "sea_surface_temperature"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "salinity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "evaporation_rate",
              "salinity"
            ]
          }
        }
      ]
    },
    "LandModel": {
      "variables": {
        "soil_moisture": {
          "type": "state",
          "units": "m^3/m^3",
          "default": 0.3,
          "description": "Soil moisture"
        },
        "leaf_temperature": {
          "type": "state",
          "units": "K",
          "default": 295.0,
          "description": "Leaf temperature"
        },
        "albedo": {
          "units": "dimensionless",
          "default": 0.2,
          "description": "Surface albedo",
          "type": "parameter"
        },
        "stomatal_conductance": {
          "units": "m/s",
          "default": 0.01,
          "description": "Stomatal conductance",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "soil_moisture"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  0.001,
                  "solar_radiation"
                ]
              },
              {
                "op": "*",
                "args": [
                  "stomatal_conductance",
                  "soil_moisture"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "leaf_temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      1.0,
                      "albedo"
                    ]
                  },
                  "solar_radiation"
                ]
              },
              0.001
            ]
          }
        }
      ]
    }
  },
  "data_loaders": {
    "WeatherStation": {
      "kind": "static",
      "source": {
        "url_template": "file:///data/weather_station_csv.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "air_temp": {
          "file_variable": "air_temp",
          "units": "K",
          "description": "Measured air temperature"
        },
        "rel_humidity": {
          "file_variable": "rel_humidity",
          "units": "%",
          "description": "Measured relative humidity"
        },
        "wind_velocity": {
          "file_variable": "wind_velocity",
          "units": "m/s",
          "description": "Measured wind speed"
        },
        "incoming_radiation": {
          "file_variable": "incoming_radiation",
          "units": "W/m^2",
          "description": "Measured solar irradiance"
        }
      },
      "metadata": {
        "tags": [
          "static"
        ]
      }
    },
    "SatelliteData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/satellite_netcdf/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "sst_satellite": {
          "file_variable": "sst_satellite",
          "units": "K",
          "description": "Satellite sea surface temperature"
        },
        "ocean_color": {
          "file_variable": "ocean_color",
          "units": "mg/m^3",
          "description": "Chlorophyll concentration"
        }
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "WeatherStation.air_temp",
      "to": "AtmosphericModel.temperature",
      "transform": "param_to_var",
      "description": "TEST CASE 1: param_to_var transform - promotes constant parameter to time-varying variable"
    },
    {
      "type": "variable_map",
      "from": "WeatherStation.rel_humidity",
      "to": "AtmosphericModel.humidity",
      "transform": "identity",
      "description": "TEST CASE 2: identity transform - direct assignment without type change"
    },
    {
      "type": "variable_map",
      "from": "WeatherStation.wind_velocity",
      "to": "AtmosphericModel.wind_speed",
      "transform": "additive",
      "description": "TEST CASE 3: additive transform - adds source value to target equation RHS"
    },
    {
      "type": "variable_map",
      "from": "WeatherStation.incoming_radiation",
      "to": "AtmosphericModel.solar_radiation",
      "transform": "multiplicative",
      "description": "TEST CASE 4: multiplicative transform - multiplies target equation RHS by source value"
    },
    {
      "type": "variable_map",
      "from": "WeatherStation.incoming_radiation",
      "to": "LandModel.albedo",
      "transform": "conversion_factor",
      "factor": 0.0001,
      "description": "TEST CASE 5: conversion_factor transform - param_to_var with unit conversion"
    },
    {
      "type": "variable_map",
      "from": "SatelliteData.sst_satellite",
      "to": "OceanModel.sea_surface_temperature",
      "transform": "param_to_var",
      "description": "TEST CASE 6: Cross-system param_to_var - satellite data drives ocean model"
    },
    {
      "type": "variable_map",
      "from": "AtmosphericModel.temperature",
      "to": "OceanModel.heat_exchange_coefficient",
      "transform": "multiplicative",
      "description": "TEST CASE 7: Model-to-model coupling - atmospheric temperature affects ocean heat exchange"
    },
    {
      "type": "variable_map",
      "from": "OceanModel.sea_surface_temperature",
      "to": "LandModel.stomatal_conductance",
      "transform": "conversion_factor",
      "factor": 1e-05,
      "description": "TEST CASE 8: Multi-step coupling chain - ocean temperature affects land processes"
    }
  ]
}
