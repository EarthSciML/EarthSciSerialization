{
  "esm": "0.1.0",
  "metadata": {
    "name": "ComprehensiveCompatibilityTest",
    "description": "Comprehensive test using all major ESM format features for version compatibility validation",
    "authors": [
      "ESM Format Team",
      "Version Compatibility Working Group"
    ],
    "created": "2024-01-15T00:00:00Z",
    "license": "MIT",
    "tags": [
      "test",
      "compatibility",
      "comprehensive"
    ]
  },
  "reaction_systems": {
    "AtmosphericChemistry": {
      "coupletype": "AtmosphericChemistryCoupler",
      "reference": {
        "doi": "10.1000/test.version.compat",
        "citation": "Test et al. (2024). Version Compatibility in ESM Format.",
        "url": "https://example.com/version-compat",
        "notes": "Comprehensive atmospheric chemistry mechanism for testing"
      },
      "species": {
        "O3": {
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone"
        },
        "NO": {
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide"
        },
        "NO2": {
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide"
        },
        "CO": {
          "units": "mol/mol",
          "default": 1e-07,
          "description": "Carbon monoxide"
        },
        "HO2": {
          "units": "mol/mol",
          "default": 1e-11,
          "description": "Hydroperoxy radical"
        }
      },
      "parameters": {
        "T": {
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "P": {
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure"
        },
        "M": {
          "units": "molec/cm^3",
          "default": 2.46e+19,
          "description": "Air number density"
        },
        "jNO2": {
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis rate"
        },
        "jO3": {
          "units": "1/s",
          "default": 0.0001,
          "description": "O3 photolysis rate"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "NO_O3_reaction",
          "substrates": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              1.8e-12,
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      -1370,
                      "T"
                    ]
                  }
                ]
              },
              "M"
            ]
          }
        },
        {
          "id": "R2",
          "name": "NO2_photolysis",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "rate": "jNO2"
        },
        {
          "id": "R3",
          "name": "CO_OH_reaction",
          "substrates": [
            {
              "species": "CO",
              "stoichiometry": 1
            },
            {
              "species": "HO2",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              1.5e-13,
              {
                "op": "exp",
                "args": [
                  250,
                  {
                    "op": "/",
                    "args": [
                      1,
                      "T"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "name": "daylight_switch",
          "trigger": {
            "type": "periodic",
            "interval": 86400,
            "initial_offset": 21600
          },
          "affects": [
            {
              "lhs": "jNO2",
              "rhs": {
                "op": "ifelse",
                "args": [
                  1,
                  0.01,
                  0.001
                ]
              }
            },
            {
              "lhs": "jO3",
              "rhs": {
                "op": "ifelse",
                "args": [
                  1,
                  0.0002,
                  5e-05
                ]
              }
            }
          ]
        }
      ]
    }
  },
  "models": {
    "Transport": {
      "reference": {
        "notes": "3D transport with diffusion"
      },
      "variables": {
        "u_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Zonal wind"
        },
        "v_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 2.0,
          "description": "Meridional wind"
        },
        "w_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.1,
          "description": "Vertical wind"
        },
        "Kh": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 1000.0,
          "description": "Horizontal diffusivity"
        },
        "Kv": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 10.0,
          "description": "Vertical diffusivity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "u_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "v_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "w_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "z"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "Kh",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "Kv",
                  {
                    "op": "D",
                    "args": [
                      {
                        "op": "D",
                        "args": [
                          "u"
                        ],
                        "wrt": "z"
                      }
                    ],
                    "wrt": "z"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "Emissions": {
      "reference": {
        "notes": "Anthropogenic and biogenic emissions"
      },
      "variables": {
        "E_NO": {
          "type": "parameter",
          "units": "molec/cm^3/s",
          "default": 1000000.0,
          "description": "NO emission rate"
        },
        "E_CO": {
          "type": "parameter",
          "units": "molec/cm^3/s",
          "default": 100000000.0,
          "description": "CO emission rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": "E_NO"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "CO"
            ],
            "wrt": "t"
          },
          "rhs": "E_CO"
        }
      ]
    }
  },
  "data_loaders": {
    "WeatherData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/ECMWF_ERA5/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "T": {
          "file_variable": "T",
          "units": "K",
          "description": "2-meter temperature"
        },
        "P": {
          "file_variable": "P",
          "units": "Pa",
          "description": "Surface pressure"
        },
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "10-meter eastward wind"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "10-meter northward wind"
        },
        "RH": {
          "file_variable": "RH",
          "units": "1",
          "description": "Relative humidity"
        }
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    },
    "EmissionInventory": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/CEDS_v2021/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "E_NO_total": {
          "file_variable": "E_NO_total",
          "units": "kg/m^2/s",
          "description": "Total NOx emissions"
        },
        "E_CO_total": {
          "file_variable": "E_CO_total",
          "units": "kg/m^2/s",
          "description": "Total CO emissions"
        }
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic"
        ]
      }
    }
  },
  "operators": {
    "WetDeposition": {
      "operator_id": "henry_law_washout",
      "description": "Henry's law wet deposition",
      "config": {
        "henry_constants": {
          "NO2": 0.01,
          "O3": 0.001,
          "CO": 0.0001
        },
        "precipitation_threshold": 0.1
      },
      "needed_vars": []
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "Transport"
      ],
      "description": "Couple chemistry with transport"
    },
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "Emissions"
      ],
      "description": "Couple chemistry with emissions"
    },
    {
      "type": "variable_map",
      "from": "WeatherData.T",
      "to": "AtmosphericChemistry.T",
      "transform": "param_to_var",
      "description": "Temperature from weather data"
    },
    {
      "type": "variable_map",
      "from": "WeatherData.P",
      "to": "AtmosphericChemistry.P",
      "transform": "param_to_var",
      "description": "Pressure from weather data"
    },
    {
      "type": "variable_map",
      "from": "WeatherData.u",
      "to": "Transport.u_wind",
      "transform": "param_to_var",
      "description": "Eastward wind component"
    },
    {
      "type": "variable_map",
      "from": "WeatherData.v",
      "to": "Transport.v_wind",
      "transform": "param_to_var",
      "description": "Northward wind component"
    },
    {
      "type": "variable_map",
      "from": "EmissionInventory.E_NO_total",
      "to": "Emissions.E_NO",
      "transform": "conversion_factor",
      "factor": 2.14e+19,
      "description": "Convert kg/m^2/s to molec/cm^3/s for NO"
    },
    {
      "type": "operator_apply",
      "operator": "WetDeposition",
      "description": "Apply wet deposition to all chemical species"
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-03T00:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -130.0,
          "max": -100.0,
          "grid_spacing": 0.5,
          "units": "degrees_east"
        },
        "lat": {
          "min": 25.0,
          "max": 50.0,
          "grid_spacing": 0.5,
          "units": "degrees_north"
        },
        "lev": {
          "min": 1000.0,
          "max": 100.0,
          "grid_spacing": 50.0,
          "units": "hPa"
        }
      },
      "coordinate_transforms": [
        {
          "id": "lonlat_to_cartesian",
          "dimensions": [
            "lon",
            "lat"
          ]
        },
        {
          "id": "pressure_to_altitude",
          "dimensions": [
            "lev"
          ]
        }
      ],
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "boundary_conditions": [
        {
          "type": "periodic",
          "dimensions": [
            "lon"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "lat"
          ]
        },
        {
          "type": "dirichlet",
          "dimensions": [
            "lev"
          ],
          "value": 0.0
        }
      ],
      "element_type": "Float64"
    }
  }
}
