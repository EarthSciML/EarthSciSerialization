{
  "esm": "0.3.0",
  "metadata": {
    "name": "ClosedFnFixture_interp_linear",
    "description": "Conformance fixture for `interp.linear` (esm-spec §9.2). Trivial ODE whose RHS invokes `interp.linear(table, axis, x)` against a fixed 5-point inline table. Bindings parse this file (exercising `fn`-op handling for the new primitive) and additionally exercise the per-scenario inputs from `expected.json`. Boundary scenarios cover exact-on-axis-knot (every position), midpoint and quarter-point blends, below-min / above-max extrapolate-flat clamps, NaN x propagation, two-point minimal axis, and non-uniform axis spacing. Load-time error scenarios (non-monotonic axis, equal-adjacent axis, NaN-in-axis, length mismatch, single-element axis) are covered in `expected.json` `error_scenarios`.",
    "authors": ["EarthSciML"],
    "tags": ["closed-function-registry", "interp", "interp.linear", "esm-94w"]
  },
  "models": {
    "Probe": {
      "variables": {
        "x": {
          "type": "parameter",
          "default": 0.0,
          "units": "1",
          "description": "Scalar query point."
        },
        "y": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "description": "Trivial state whose derivative is the interp.linear result. Bindings read evaluate(rhs, {x: <input>}) for each expected.json scenario and compare against the expected value at the per-fixture tolerance."
        }
      },
      "equations": [
        {
          "_comment": "RHS = interp.linear(table=[10,20,40,80,160], axis=[0,1,2,3,4], x). Strictly increasing axis. Below x=0 clamps to 10; above x=4 clamps to 160; at knot xs[i] returns table[i] exactly; in-cell uses pinned form result = t[i] + w*(t[i+1]-t[i]).",
          "lhs": { "op": "D", "args": ["y"], "wrt": "t" },
          "rhs": {
            "op": "fn",
            "name": "interp.linear",
            "args": [
              { "op": "const", "args": [], "value": [10.0, 20.0, 40.0, 80.0, 160.0] },
              { "op": "const", "args": [], "value": [0.0, 1.0, 2.0, 3.0, 4.0] },
              "x"
            ]
          }
        }
      ]
    }
  }
}
