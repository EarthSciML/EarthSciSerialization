{
  "esm": "0.3.0",
  "metadata": {
    "name": "ClosedFnFixture_interp_bilinear",
    "description": "Conformance fixture for `interp.bilinear` (esm-spec §9.2). Trivial ODE whose RHS invokes `interp.bilinear(table, axis_x, axis_y, x, y)` against a fixed 3x3 inline table. Bindings parse this file (exercising `fn`-op handling for the new primitive) and additionally exercise the per-scenario inputs from `expected.json`. Boundary scenarios cover exact corners, exact-on-interior-knot in either axis, midpoint and quarter-point blends in both axes, below/above each axis (extrapolate-flat clamps), NaN x or y propagation, minimal 2x2 grid, and non-uniform spacing in either axis. Load-time error scenarios (non-monotonic axis, equal-adjacent axis, NaN-in-axis, length mismatch on either axis, inner-row length mismatch, single-element axis) are covered in `expected.json` `error_scenarios`.",
    "authors": ["EarthSciML"],
    "tags": ["closed-function-registry", "interp", "interp.bilinear", "esm-94w"]
  },
  "models": {
    "Probe": {
      "variables": {
        "x": {
          "type": "parameter",
          "default": 0.0,
          "units": "1",
          "description": "Scalar x-axis query."
        },
        "y": {
          "type": "parameter",
          "default": 0.0,
          "units": "1",
          "description": "Scalar y-axis query."
        },
        "z": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "description": "Trivial state whose derivative is the interp.bilinear result. Bindings read evaluate(rhs, {x: <input_x>, y: <input_y>}) for each expected.json scenario and compare against the expected value at the per-fixture tolerance."
        }
      },
      "equations": [
        {
          "_comment": "RHS = interp.bilinear(table, axis_x=[0,1,2], axis_y=[0,10,20], x, y). table[i][j] = 10*axis_x[i] + axis_y[j]/10 → rows: i=0 [0,1,2], i=1 [10,11,12], i=2 [20,21,22]. Strictly increasing axes; row-major (table[i][j] at axis_x[i], axis_y[j]).",
          "lhs": { "op": "D", "args": ["z"], "wrt": "t" },
          "rhs": {
            "op": "fn",
            "name": "interp.bilinear",
            "args": [
              { "op": "const", "args": [], "value": [[0.0, 1.0, 2.0], [10.0, 11.0, 12.0], [20.0, 21.0, 22.0]] },
              { "op": "const", "args": [], "value": [0.0, 1.0, 2.0] },
              { "op": "const", "args": [], "value": [0.0, 10.0, 20.0] },
              "x",
              "y"
            ]
          }
        }
      ]
    }
  }
}
