{
  "esm": "0.3.0",
  "metadata": {
    "name": "ClosedFnFixture_datetime_day",
    "description": "Conformance fixture for `datetime.day` (esm-spec §9.2). Trivial ODE whose RHS invokes the function on a `t_utc` parameter; bindings exercise the same set of `t_utc` inputs from `expected.json` and assert agreement at the spec tolerance.",
    "authors": ["EarthSciML"],
    "tags": ["closed-function-registry", "datetime", "datetime.day", "esm-tzp", "esm-4aw"]
  },
  "models": {
    "Probe": {
      "variables": {
        "t_utc": {
          "type": "parameter",
          "default": 0.0,
          "units": "s",
          "description": "UTC seconds since Unix epoch (input to the closed function)."
        },
        "y": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "description": "Trivial state whose derivative is the closed-function output. Bindings read `evaluate(rhs, {t_utc: <input>})` and compare against expected.json."
        }
      },
      "equations": [
        {
          "_comment": "RHS = datetime.day(t_utc). Evaluator semantics pinned in esm-spec §9.2.",
          "lhs": { "op": "D", "args": ["y"], "wrt": "t" },
          "rhs": { "op": "fn", "name": "datetime.day", "args": ["t_utc"] }
        }
      ]
    }
  }
}
