      "memory_per_variable_mb": {
        "python": 0.001,
        "julia": 0.0005,
        "typescript": 0.002,
        "rust": 0.0002
      }
    },
    "expression_complexity": {
      "linear_terms_up_to": 1000,
      "nested_depth_limit": 100,
      "evaluation_overhead": "Polynomial in depth, linear in terms"
    },
    "coupling_networks": {
      "systems_count_linear_up_to": 100,
      "coupling_density_impact": "Quadratic in number of connections",
      "dependency_resolution_complexity": "O(V + E) where V=systems, E=couplings"
    }
