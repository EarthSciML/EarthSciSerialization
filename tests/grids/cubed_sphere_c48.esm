{
  "esm": "0.2.0",
  "metadata": {
    "name": "CubedSphereC48GridFixture",
    "description": "Conformance fixture for §6.4 cubed_sphere grid family. 6-panel C48 gnomonic cube with builtin-generated panel_connectivity (neighbors + D4 axis_flip per §6.4.1) and an analytic metric array (§6.5 expression generator). Exercises the cubed-sphere branch of the §6 grids top-level schema (gt-5kq3).",
    "authors": ["ESM Test Suite"],
    "created": "2026-04-19T00:00:00Z",
    "tags": ["grids", "cubed-sphere", "conformance"]
  },
  "models": {
    "CubeBox": {
      "reference": {"notes": "Placeholder model so the fixture satisfies the top-level 'models or reaction_systems' requirement."},
      "variables": {
        "T": {"type": "state", "units": "K", "default": 273.15}
      },
      "equations": [
        {"lhs": "D(T)", "rhs": "0"}
      ]
    }
  },
  "grids": {
    "cubed_c48": {
      "family": "cubed_sphere",
      "description": "C48 gnomonic cubed sphere (6 panels of 48x48 cells).",
      "dimensions": ["panel", "i", "j"],
      "extents": {
        "panel": {"n": 6},
        "i": {"n": "Nc"},
        "j": {"n": "Nc"}
      },
      "locations": ["cell_center", "i_edge", "j_edge", "vertex"],
      "panel_connectivity": {
        "neighbors": {
          "shape": [6, 4],
          "rank": 2,
          "generator": {"kind": "builtin", "name": "gnomonic_c6_neighbors"}
        },
        "axis_flip": {
          "shape": [6, 4],
          "rank": 2,
          "generator": {"kind": "builtin", "name": "gnomonic_c6_d4_action"}
        }
      },
      "metric_arrays": {
        "dxC": {
          "rank": 3,
          "dims": ["panel", "i", "j"],
          "generator": {
            "kind": "expression",
            "expr": {"op": "/", "args": ["cube_edge_length", {"op": "*", "args": ["Nc", 1.0]}]}
          }
        }
      },
      "parameters": {
        "Nc": {"default": 48},
        "cube_edge_length": {"default": 1.0, "units": "m"}
      }
    }
  }
}
