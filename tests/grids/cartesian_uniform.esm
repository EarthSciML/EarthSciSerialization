{
  "esm": "0.2.0",
  "metadata": {
    "name": "CartesianUniformGridFixture",
    "description": "Conformance fixture for §6.2 cartesian grid family. Uniform spacing in x,y; nonuniform in z with a rank-1 dz metric array loaded from an external z-level file (exercises scalar vs indexed metric-array distinction). Exercises §6 grids top-level schema (gt-5kq3).",
    "authors": ["ESM Test Suite"],
    "created": "2026-04-19T00:00:00Z",
    "tags": ["grids", "cartesian", "conformance"]
  },
  "models": {
    "AtmoBox": {
      "reference": {"notes": "Placeholder model so the fixture passes the 'models or reaction_systems required' constraint."},
      "variables": {
        "T": {"type": "state", "units": "K", "default": 273.15}
      },
      "equations": [
        {"lhs": "D(T)", "rhs": "0"}
      ]
    }
  },
  "data_loaders": {
    "zlev_file": {
      "kind": "grid",
      "source": {"url_template": "file:///data/zlev.nc"},
      "variables": {
        "dz": {"file_variable": "dz", "units": "m"}
      }
    }
  },
  "grids": {
    "atmos_rect": {
      "family": "cartesian",
      "description": "Uniform Nx x Ny horizontal with Nz nonuniform vertical levels.",
      "dimensions": ["x", "y", "z"],
      "extents": {
        "x": {"n": "Nx", "spacing": "uniform"},
        "y": {"n": "Ny", "spacing": "uniform"},
        "z": {"n": "Nz", "spacing": "nonuniform"}
      },
      "locations": ["cell_center", "x_face", "y_face", "z_face"],
      "metric_arrays": {
        "dx": {
          "rank": 0,
          "generator": {
            "kind": "expression",
            "expr": {"op": "/", "args": [{"op": "-", "args": ["x_max", "x_min"]}, "Nx"]}
          }
        },
        "dz": {
          "rank": 1,
          "dim": "z",
          "generator": {"kind": "loader", "loader": "zlev_file", "field": "dz"}
        }
      },
      "parameters": {
        "Nx": {"default": 64},
        "Ny": {"default": 64},
        "Nz": {"default": 32},
        "x_min": {"default": 0.0, "units": "m"},
        "x_max": {"default": 1.0, "units": "m"}
      }
    }
  }
}
