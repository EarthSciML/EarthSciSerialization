{
  "description": "Expected simulation results for coupled atmospheric system end-to-end test",
  "test_metadata": {
    "system_name": "CoupledAtmosphericSystem",
    "file": "coupled_atmospheric_system.esm",
    "simulation_duration": "48 hours",
    "domain_size": "167x167x150 grid cells",
    "spatial_resolution": "12km horizontal, 100m vertical",
    "temporal_resolution": "600s base timestep"
  },

  "coupling_verification": {
    "description": "Verification that all coupling types are properly assembled",
    "operator_compose": {
      "systems": ["AtmosphericChemistry", "AtmosphericTransport"],
      "verification": "Chemistry species (O3, NO, NO2, HCHO, HO2) receive transport terms",
      "expected_equations": 10,
      "transport_terms_per_species": 5,
      "coupling_mechanism": "_var placeholder expansion"
    },
    "couple2": {
      "systems": ["AtmosphericChemistry", "SurfaceExchange"],
      "verification": "Bidirectional coupling via connector equations",
      "connector_equations": 2,
      "coupled_species": ["O3", "NO2"],
      "deposition_flux_units": "mol/mol/s"
    },
    "variable_map": {
      "count": 8,
      "meteorological_couplings": [
        "temperature: MeteorologicalFields → AtmosphericChemistry",
        "pressure: MeteorologicalFields → AtmosphericChemistry",
        "humidity: MeteorologicalFields → AtmosphericChemistry",
        "u_wind: MeteorologicalFields → AtmosphericTransport",
        "v_wind: MeteorologicalFields → AtmosphericTransport",
        "boundary_layer_height: MeteorologicalFields → SurfaceExchange"
      ],
      "emission_couplings": [
        "NOx_emission_rate: EmissionInventories → EmissionSources",
        "VOC_emission_rate: EmissionInventories → EmissionSources"
      ],
      "verification": "Parameters replaced with time-varying data loader variables"
    },
    "operator_apply": {
      "count": 3,
      "operators": ["DryDepositionOperator", "TurbulentMixingOperator", "PhotolysisOperator"],
      "verification": "Runtime operators registered and applied during simulation"
    },
    "callback": {
      "count": 2,
      "callbacks": ["BiogenicEmissionTemperatureScaling", "WeekdayWeekendScaling"],
      "verification": "Callbacks registered for parameter updates"
    },
    "event": {
      "count": 3,
      "continuous_events": 2,
      "discrete_events": 1,
      "cross_system_events": 3,
      "verification": "Events affect variables across multiple systems"
    }
  },

  "system_assembly_verification": {
    "description": "Verification of complete coupled system assembly",
    "total_state_variables": 5,
    "total_parameters": 27,
    "total_observed_variables": 4,
    "total_equations": 15,
    "data_loader_variables": 6,
    "operator_modifications": 12,
    "event_affects": 4,
    "conservation_laws": [
      "Total nitrogen: NO + NO2 + emitted_NOx = conserved (accounting for deposition)",
      "Carbon mass: HCHO + emitted_VOC = conserved (accounting for photolysis and deposition)"
    ],
    "mass_balance_verification": {
      "NOx_budget": {
        "sources": ["EmissionSources", "atmospheric_transport_inflow"],
        "sinks": ["SurfaceExchange.deposition", "atmospheric_transport_outflow"],
        "expected_closure": "< 1% residual"
      },
      "O3_budget": {
        "sources": ["photochemical_production", "atmospheric_transport_inflow"],
        "sinks": ["NO_titration", "SurfaceExchange.deposition", "atmospheric_transport_outflow"],
        "expected_closure": "< 2% residual"
      }
    }
  },

  "cross_system_variable_flow": {
    "description": "Verification of variable flow between coupled systems",
    "meteorology_to_chemistry": {
      "temperature": {
        "source": "MeteorologicalFields",
        "destination": "AtmosphericChemistry",
        "coupling_type": "variable_map",
        "effect": "Temperature-dependent reaction rates"
      },
      "pressure": {
        "source": "MeteorologicalFields",
        "destination": "AtmosphericChemistry",
        "coupling_type": "variable_map",
        "effect": "Air density for reaction rate calculations"
      },
      "humidity": {
        "source": "MeteorologicalFields",
        "destination": "AtmosphericChemistry",
        "coupling_type": "variable_map",
        "effect": "Water vapor for heterogeneous reactions"
      }
    },
    "meteorology_to_transport": {
      "winds": {
        "source": "MeteorologicalFields.{u_wind,v_wind}",
        "destination": "AtmosphericTransport.{u_wind,v_wind}",
        "coupling_type": "variable_map",
        "effect": "Advection velocity fields"
      }
    },
    "meteorology_to_surface": {
      "boundary_layer_height": {
        "source": "MeteorologicalFields",
        "destination": "SurfaceExchange",
        "coupling_type": "variable_map",
        "effect": "Controls deposition flux normalization"
      }
    },
    "emissions_to_sources": {
      "emission_rates": {
        "source": "EmissionInventories.{NOx_emission_rate,VOC_emission_rate}",
        "destination": "EmissionSources.{NOx_emission_rate,VOC_emission_rate}",
        "coupling_type": "variable_map",
        "effect": "Spatially and temporally varying emissions"
      }
    },
    "chemistry_to_surface": {
      "concentrations": {
        "source": "AtmosphericChemistry.{O3,NO2}",
        "destination": "SurfaceExchange connector equations",
        "coupling_type": "couple2",
        "effect": "Concentration-dependent deposition fluxes"
      }
    },
    "surface_to_chemistry": {
      "deposition_fluxes": {
        "source": "SurfaceExchange.{deposition_velocity_O3,deposition_velocity_NO2}",
        "destination": "AtmosphericChemistry.{O3,NO2} equations",
        "coupling_type": "couple2",
        "effect": "Surface loss terms for species"
      }
    }
  },

