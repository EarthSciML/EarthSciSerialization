    "python_scipy_tests": [
      "Parse ESM → callable RHS function with 5 state variables",
      "Generate Jacobian for stiff solver (BDF method)",
      "Integrate with solve_ivp for 48 hours with event detection",
      "Verify conservation laws within numerical tolerance",
      "Verify diurnal patterns emerge from chemical kinetics",
      "Compare results with Julia MTK simulation (cross-validation)",
      "Test operator composition by comparing transport-only vs full system",
      "Verify emission and deposition flux calculations"
