  "data_loaders": {
    "ClimateForcing": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/CESM2_Output/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "temperature_ocean": {
          "file_variable": "temperature_ocean",
          "units": "K",
          "description": "Sea surface temperature"
        },
        "wind_speed": {
          "file_variable": "wind_speed",
          "units": "m/s",
          "description": "Surface wind speed"
        },
        "pressure": {
          "file_variable": "pressure",
          "units": "Pa",
          "description": "Sea level pressure"
        },
        "light": {
          "file_variable": "light",
          "units": "W/m^2",
          "description": "Net surface solar radiation"
        }
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    },
    "OceanObservations": {
      "kind": "points",
      "source": {
        "url_template": "file:///data/SOCAT_pCO2/{date:%Y%m%d}.csv"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "pCO2_observed": {
          "file_variable": "pCO2_observed",
          "units": "uatm",
          "description": "Observed ocean pCO2"
        }
      },
      "metadata": {
        "tags": [
          "observation",
          "point-data"
        ]
      }
    }
  },
  "operators": {
    "CarbonateChemistry": {
      "operator_id": "CO2SYS_v3",
      "reference": {
        "citation": "Lewis et al., 1998. Program developed for CO2 system calculations",
        "doi": "10.2172/639712"
      },
      "config": {
        "K1K2_constants": "Mehrbach_refit",
        "KSO4_constant": "Dickson",
        "pH_scale": "Total",
        "pressure_correction": true
      },
      "needed_vars": [
        "DIC",
        "ALK",
        "temperature_ocean",
        "salinity",
        "pressure"
      ],
      "modifies": [
        "CO2_solubility"
      ],
      "description": "Full carbonate system calculations"
    },
    "GasTransferVelocity": {
      "operator_id": "Wanninkhof2014",
      "reference": {
        "citation": "Wanninkhof, 2014. Relationship between wind speed and gas exchange over the ocean",
        "doi": "10.4319/lom.2014.12.351"
      },
      "config": {
        "parameterization": "cubic_wind_speed",
        "temperature_dependence": "schmidt_number_scaling"
      },
      "needed_vars": [
        "wind_speed",
        "temperature_ocean",
        "Schmidt_CO2",
        "Schmidt_O2"
      ],
      "modifies": [
        "k_CO2",
        "k_O2"
      ],
      "description": "Wind speed and temperature dependent gas transfer velocities"
    },
    "BiologicalPump": {
      "operator_id": "Export_Production",
      "reference": {
        "notes": "Biological carbon pump with export to deep ocean"
      },
      "config": {
        "export_ratio": 0.25,
        "sinking_velocity": 10.0,
        "remineralization_depth": 1000.0
      },
      "needed_vars": [
        "primary_production",
        "phytoplankton",
        "detritus"
      ],
      "modifies": [
        "DIC",
        "ALK",
        "nutrients"
      ],
      "description": "Export production and deep ocean remineralization"
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericCarbon",
        "AtmosphericCarbon_transport"
      ],
      "description": "Placeholder for atmospheric transport coupling if extended"
    },
    {
      "type": "couple",
      "systems": [
        "AtmosphericCarbon",
        "OceanCarbon"
      ],
      "connector": {
        "equations": [
          {
            "from": "AirSeaGasExchange.k_CO2",
            "to": "AtmosphericCarbon.CO2",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {
                  "op": "-",
                  "args": [
                    "AirSeaGasExchange.k_CO2"
                  ]
                },
                {
                  "op": "-",
                  "args": [
                    {
                      "op": "*",
                      "args": [
                        "AtmosphericCarbon.CO2",
                        "AtmosphericCarbon.pressure",
                        1e-06
                      ]
                    },
                    "OceanCarbon.pCO2_ocean"
                  ]
                }
              ]
            }
          },
          {
            "from": "AirSeaGasExchange.k_CO2",
            "to": "OceanCarbon.DIC",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "AirSeaGasExchange.k_CO2",
                {
                  "op": "-",
                  "args": [
                    {
                      "op": "*",
                      "args": [
                        "AtmosphericCarbon.CO2",
                        "AtmosphericCarbon.pressure",
                        1e-06
                      ]
                    },
                    "OceanCarbon.pCO2_ocean"
                  ]
                },
                {
                  "op": "/",
                  "args": [
                    1,
                    "OceanCarbon.mixed_layer_depth"
                  ]
                }
              ]
            }
          },
          {
            "from": "AirSeaGasExchange.k_O2",
            "to": "AtmosphericCarbon.O2",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {
                  "op": "-",
                  "args": [
                    "AirSeaGasExchange.k_O2"
                  ]
                },
                {
                  "op": "-",
                  "args": [
                    {
                      "op": "*",
                      "args": [
                        "AtmosphericCarbon.O2",
                        "AtmosphericCarbon.pressure"
                      ]
                    },
                    {
                      "op": "/",
                      "args": [
                        "OceanCarbon.O2_dissolved",
                        "OceanCarbon.O2_solubility"
                      ]
                    }
                  ]
                }
              ]
            }
          },
          {
            "from": "AirSeaGasExchange.k_O2",
            "to": "OceanCarbon.O2_dissolved",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "AirSeaGasExchange.k_O2",
                {
                  "op": "-",
                  "args": [
                    {
                      "op": "*",
                      "args": [
                        "AtmosphericCarbon.O2",
                        "AtmosphericCarbon.pressure"
                      ]
                    },
                    {
                      "op": "/",
                      "args": [
                        "OceanCarbon.O2_dissolved",
                        "OceanCarbon.O2_solubility"
                      ]
                    }
                  ]
                },
                {
                  "op": "/",
                  "args": [
                    1,
                    "OceanCarbon.mixed_layer_depth"
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "Bidirectional air-sea gas exchange for CO2 and O2"
    },
    {
      "type": "couple",
      "systems": [
        "OceanCarbon",
        "MarineEcosystem"
      ],
      "connector": {
        "equations": [
          {
            "from": "MarineEcosystem.primary_production",
            "to": "OceanCarbon.DIC",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {
                  "op": "-",
                  "args": [
                    "MarineEcosystem.primary_production"
                  ]
                },
                "MarineEcosystem.C_to_N_ratio",
                {
                  "op": "/",
                  "args": [
                    1,
                    86400
                  ]
                }
              ]
            }
          },
          {
            "from": "MarineEcosystem.remineralization_rate",
            "to": "OceanCarbon.DIC",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "MarineEcosystem.remineralization_rate",
                "MarineEcosystem.detritus",
                "MarineEcosystem.C_to_N_ratio",
                {
                  "op": "/",
                  "args": [
                    1,
                    86400
                  ]
                }
              ]
            }
          },
          {
            "from": "MarineEcosystem.primary_production",
            "to": "OceanCarbon.O2_dissolved",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "MarineEcosystem.primary_production",
                1.4,
                {
                  "op": "/",
                  "args": [
                    1,
                    86400
                  ]
                }
              ]
            }
          },
          {
            "from": "MarineEcosystem.remineralization_rate",
            "to": "OceanCarbon.O2_dissolved",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {
                  "op": "-",
                  "args": [
                    "MarineEcosystem.remineralization_rate"
                  ]
                },
                "MarineEcosystem.detritus",
                1.4,
                {
                  "op": "/",
                  "args": [
                    1,
                    86400
                  ]
                }
              ]
            }
          }
        ]
      },
      "description": "Couple marine ecosystem carbon and oxygen fluxes"
    },
    {
      "type": "variable_map",
      "from": "ClimateForcing.temperature_ocean",
      "to": "OceanCarbon.temperature_ocean",
      "transform": "param_to_var",
      "description": "Use CESM2 sea surface temperature"
    },
    {
      "type": "variable_map",
      "from": "ClimateForcing.wind_speed",
      "to": "AtmosphericCarbon.wind_speed",
      "transform": "param_to_var",
      "description": "Use CESM2 surface wind speed"
    },
    {
      "type": "variable_map",
      "from": "ClimateForcing.pressure",
      "to": "AtmosphericCarbon.pressure",
      "transform": "param_to_var",
      "description": "Use CESM2 sea level pressure"
    },
    {
      "type": "variable_map",
      "from": "ClimateForcing.light",
      "to": "MarineEcosystem.light",
      "transform": "param_to_var",
      "description": "Use CESM2 surface solar radiation"
    },
    {
      "type": "operator_apply",
      "operator": "CarbonateChemistry",
      "description": "Calculate full carbonate system equilibrium"
    },
    {
      "type": "operator_apply",
      "operator": "GasTransferVelocity",
      "description": "Update gas transfer velocities with wind and temperature"
    },
    {
      "type": "operator_apply",
      "operator": "BiologicalPump",
      "description": "Export production to deep ocean"
    },
    {
      "type": "callback",
      "callback_id": "SeasonalLightCycle",
      "config": {
        "latitude": 45.0,
        "declination_amplitude": 23.45,
        "clear_sky_fraction": 0.7
      },
      "description": "Seasonal and diurnal light variations"
    },
    {
      "type": "callback",
      "callback_id": "MixedLayerDepthSeasonal",
      "config": {
        "summer_depth": 20.0,
        "winter_depth": 100.0,
        "transition_months": [
          3,
          4,
          9,
          10
        ]
      },
      "description": "Seasonal mixed layer depth variations"
    },
    {
      "type": "event",
      "event_type": "continuous",
      "name": "phytoplankton_bloom_trigger",
      "conditions": [
        {
          "op": "-",
          "args": [
            "MarineEcosystem.phytoplankton",
            5.0
          ]
        }
      ],
      "affects": [
        {
          "lhs": "MarineEcosystem.max_growth_rate",
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "Pre",
                "args": [
                  "MarineEcosystem.max_growth_rate"
                ]
              },
              1.5
            ]
          }
        }
      ],
      "discrete_parameters": [
        "MarineEcosystem.max_growth_rate"
      ],
      "description": "Enhance growth rate during phytoplankton blooms"
    },
    {
      "type": "event",
      "event_type": "continuous",
      "name": "ocean_acidification_threshold",
      "conditions": [
        {
          "op": "-",
          "args": [
            7.8,
            "OceanCarbon.pH"
          ]
        }
      ],
      "affects": [
        {
          "lhs": "OceanCarbon.CO2_solubility",
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "Pre",
                "args": [
                  "OceanCarbon.CO2_solubility"
                ]
              },
              1.1
            ]
          }
        }
      ],
      "discrete_parameters": [
        "OceanCarbon.CO2_solubility"
      ],
      "description": "Increase CO2 solubility when pH drops below 7.8 (acidification response)"
    },
    {
      "type": "event",
      "event_type": "discrete",
      "name": "seasonal_nutrient_upwelling",
      "trigger": {
        "type": "periodic",
        "interval": 7776000.0,
        "initial_offset": 5184000.0
      },
      "affects": [
        {
          "lhs": "MarineEcosystem.nutrients",
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "Pre",
                "args": [
                  "MarineEcosystem.nutrients"
                ]
              },
              10.0
            ]
          }
        }
      ],
      "discrete_parameters": [
        "MarineEcosystem.nutrients"
      ],
      "description": "Seasonal nutrient injection every 90 days (upwelling)"
    }
  ],
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2025-01-01T00:00:00Z",
        "reference_time": "2024-01-01T00:00:00Z"
      },
      "spatial": {
        "x": {
          "min": -180.0,
          "max": 180.0,
          "units": "degrees_east",
          "grid_spacing": 2.0
        },
        "y": {
          "min": -90.0,
          "max": 90.0,
          "units": "degrees_north",
          "grid_spacing": 2.0
        },
        "z": {
          "min": 0.0,
          "max": 5000.0,
          "units": "meters",
          "grid_spacing": 50.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "AtmosphericCarbon.CO2": 0.00042,
          "AtmosphericCarbon.O2": 0.2095,
          "OceanCarbon.DIC": 2100.0,
          "OceanCarbon.ALK": 2300.0,
          "OceanCarbon.O2_dissolved": 250.0,
          "MarineEcosystem.nutrients": 15.0,
          "MarineEcosystem.phytoplankton": 2.0,
          "MarineEcosystem.zooplankton": 1.0,
          "MarineEcosystem.detritus": 0.5
        }
      },
      "element_type": "Float64"
    }
  }
}
