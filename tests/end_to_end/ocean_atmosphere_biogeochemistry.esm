    "AirSeaGasExchange": {
      "reference": {
        "notes": "Physical air-sea gas exchange using wind-speed dependent transfer velocities",
        "citation": "Wanninkhof, 2014. Relationship between wind speed and gas exchange"
      },
      "variables": {
        "k_CO2": {
          "type": "parameter",
          "units": "m/s",
          "default": 2e-05,
          "description": "CO2 gas transfer velocity"
        },
        "k_O2": {
          "type": "parameter",
          "units": "m/s",
          "default": 2.5e-05,
          "description": "O2 gas transfer velocity"
        },
        "Schmidt_CO2": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 600.0,
          "description": "CO2 Schmidt number"
        },
        "Schmidt_O2": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 500.0,
          "description": "O2 Schmidt number"
        }
      },
      "equations": []
    }
