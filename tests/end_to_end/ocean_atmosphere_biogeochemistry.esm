{
  "esm": "0.2.0",
  "metadata": {
    "name": "OceanAtmosphereBiogeochemistry",
    "description": "End-to-end test for coupled ocean-atmosphere biogeochemical cycles with CO2, O2, and marine ecosystem interactions\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "ESM Test Suite"
    ],
    "license": "MIT",
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "end-to-end",
      "ocean-atmosphere",
      "biogeochemistry",
      "carbon-cycle",
      "migrated_from_v01"
    ],
    "references": [
      {
        "citation": "Ocean-atmosphere biogeochemical coupling test fixture",
        "notes": "Tests bidirectional fluxes, ecosystem dynamics, and carbonate chemistry"
      }
    ]
  },
  "models": {
    "AtmosphericCarbon": {
      "coupletype": "AtmosphereCoupler",
      "reference": {
        "notes": "Atmospheric CO2 and O2 with air-sea gas exchange"
      },
      "variables": {
        "CO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.00042,
          "description": "Atmospheric CO2 mixing ratio"
        },
        "O2": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.2095,
          "description": "Atmospheric O2 mixing ratio"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 288.15,
          "description": "Air temperature"
        },
        "pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Atmospheric pressure"
        },
        "wind_speed": {
          "type": "parameter",
          "units": "m/s",
          "default": 7.0,
          "description": "Surface wind speed for gas exchange"
        },
        "total_carbon": {
          "type": "observed",
          "units": "mol/mol",
          "expression": "CO2",
          "description": "Total atmospheric carbon (simplified)"
        }
      },
      "equations": [],
      "boundary_conditions": {
        "CO2_periodic_xmin": {
          "variable": "CO2",
          "side": "xmin",
          "kind": "periodic"
        },
        "O2_periodic_xmin": {
          "variable": "O2",
          "side": "xmin",
          "kind": "periodic"
        },
        "CO2_zero_gradient_xmin": {
          "variable": "CO2",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "O2_zero_gradient_xmin": {
          "variable": "O2",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "CO2_zero_gradient_xmax": {
          "variable": "CO2",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "O2_zero_gradient_xmax": {
          "variable": "O2",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "CO2_neumann_xmin": {
          "variable": "CO2",
          "side": "xmin",
          "kind": "neumann"
        },
        "O2_neumann_xmin": {
          "variable": "O2",
          "side": "xmin",
          "kind": "neumann"
        },
        "CO2_neumann_xmax": {
          "variable": "CO2",
          "side": "xmax",
          "kind": "neumann"
        },
        "O2_neumann_xmax": {
          "variable": "O2",
          "side": "xmax",
          "kind": "neumann"
        },
        "CO2_zero_gradient_xmin_2": {
          "variable": "CO2",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "O2_zero_gradient_xmin_2": {
          "variable": "O2",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "CO2_zero_gradient_xmax_2": {
          "variable": "CO2",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "O2_zero_gradient_xmax_2": {
          "variable": "O2",
          "side": "xmax",
          "kind": "zero_gradient"
        }
      }
    },
    "OceanCarbon": {
      "coupletype": "OceanCoupler",
      "reference": {
        "notes": "Ocean carbonate system with pH, alkalinity, and dissolved inorganic carbon"
      },
      "variables": {
        "DIC": {
          "type": "state",
          "units": "mol/m^3",
          "default": 2100.0,
          "description": "Dissolved inorganic carbon"
        },
        "ALK": {
          "type": "state",
          "units": "mol/m^3",
          "default": 2300.0,
          "description": "Total alkalinity"
        },
        "O2_dissolved": {
          "type": "state",
          "units": "mol/m^3",
          "default": 250.0,
          "description": "Dissolved oxygen"
        },
        "temperature_ocean": {
          "type": "parameter",
          "units": "K",
          "default": 285.15,
          "description": "Sea surface temperature"
        },
        "salinity": {
          "type": "parameter",
          "units": "psu",
          "default": 35.0,
          "description": "Sea surface salinity"
        },
        "mixed_layer_depth": {
          "type": "parameter",
          "units": "m",
          "default": 50.0,
          "description": "Ocean mixed layer depth"
        },
        "CO2_solubility": {
          "type": "parameter",
          "units": "mol/m^3/atm",
          "default": 0.034,
          "description": "Henry's law constant for CO2"
        },
        "O2_solubility": {
          "type": "parameter",
          "units": "mol/m^3/atm",
          "default": 0.0013,
          "description": "Henry's law constant for O2"
        },
        "pCO2_ocean": {
          "type": "observed",
          "units": "atm",
          "expression": {
            "op": "/",
            "args": [
              "DIC",
              {
                "op": "*",
                "args": [
                  "CO2_solubility",
                  "mixed_layer_depth"
                ]
              }
            ]
          },
          "description": "Ocean surface pCO2"
        },
        "pH": {
          "type": "observed",
          "units": "dimensionless",
          "expression": {
            "op": "-",
            "args": [
              8.1,
              {
                "op": "*",
                "args": [
                  0.0002,
                  {
                    "op": "-",
                    "args": [
                      "DIC",
                      2100
                    ]
                  }
                ]
              }
            ]
          },
          "description": "Ocean pH (simplified relationship)"
        },
        "omega_aragonite": {
          "type": "observed",
          "units": "dimensionless",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "ALK",
                      1.2
                    ]
                  },
                  {
                    "op": "+",
                    "args": [
                      "DIC",
                      50
                    ]
                  }
                ]
              },
              {
                "op": "exp",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      0.01,
                      {
                        "op": "-",
                        "args": [
                          "temperature_ocean",
                          298.15
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "description": "Aragonite saturation state"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "DIC"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              0.0,
              "mixed_layer_depth"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "ALK"
            ],
            "wrt": "t"
          },
          "rhs": 0.0
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "O2_dissolved"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              0.0,
              "mixed_layer_depth"
            ]
          }
        }
      ],
      "boundary_conditions": {
        "DIC_periodic_xmin": {
          "variable": "DIC",
          "side": "xmin",
          "kind": "periodic"
        },
        "ALK_periodic_xmin": {
          "variable": "ALK",
          "side": "xmin",
          "kind": "periodic"
        },
        "O2_dissolved_periodic_xmin": {
          "variable": "O2_dissolved",
          "side": "xmin",
          "kind": "periodic"
        },
        "DIC_zero_gradient_xmin": {
          "variable": "DIC",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "ALK_zero_gradient_xmin": {
          "variable": "ALK",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "O2_dissolved_zero_gradient_xmin": {
          "variable": "O2_dissolved",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "DIC_zero_gradient_xmax": {
          "variable": "DIC",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "ALK_zero_gradient_xmax": {
          "variable": "ALK",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "O2_dissolved_zero_gradient_xmax": {
          "variable": "O2_dissolved",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "DIC_neumann_xmin": {
          "variable": "DIC",
          "side": "xmin",
          "kind": "neumann"
        },
        "ALK_neumann_xmin": {
          "variable": "ALK",
          "side": "xmin",
          "kind": "neumann"
        },
        "O2_dissolved_neumann_xmin": {
          "variable": "O2_dissolved",
          "side": "xmin",
          "kind": "neumann"
        },
        "DIC_neumann_xmax": {
          "variable": "DIC",
          "side": "xmax",
          "kind": "neumann"
        },
        "ALK_neumann_xmax": {
          "variable": "ALK",
          "side": "xmax",
          "kind": "neumann"
        },
        "O2_dissolved_neumann_xmax": {
          "variable": "O2_dissolved",
          "side": "xmax",
          "kind": "neumann"
        },
        "DIC_zero_gradient_xmin_2": {
          "variable": "DIC",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "ALK_zero_gradient_xmin_2": {
          "variable": "ALK",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "O2_dissolved_zero_gradient_xmin_2": {
          "variable": "O2_dissolved",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "DIC_zero_gradient_xmax_2": {
          "variable": "DIC",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "ALK_zero_gradient_xmax_2": {
          "variable": "ALK",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "O2_dissolved_zero_gradient_xmax_2": {
          "variable": "O2_dissolved",
          "side": "xmax",
          "kind": "zero_gradient"
        }
      }
    },
    "MarineEcosystem": {
      "reference": {
        "notes": "Simple NPZD (Nutrient-Phytoplankton-Zooplankton-Detritus) marine ecosystem model"
      },
      "variables": {
        "nutrients": {
          "type": "state",
          "units": "mol/m^3",
          "default": 15.0,
          "description": "Dissolved nutrients (as nitrogen)"
        },
        "phytoplankton": {
          "type": "state",
          "units": "mol/m^3",
          "default": 2.0,
          "description": "Phytoplankton biomass (as nitrogen)"
        },
        "zooplankton": {
          "type": "state",
          "units": "mol/m^3",
          "default": 1.0,
          "description": "Zooplankton biomass (as nitrogen)"
        },
        "detritus": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.5,
          "description": "Detrital matter (as nitrogen)"
        },
        "light": {
          "type": "parameter",
          "units": "W/m^2",
          "default": 200.0,
          "description": "Surface irradiance"
        },
        "max_growth_rate": {
          "type": "parameter",
          "units": "1/day",
          "default": 1.5,
          "description": "Maximum phytoplankton growth rate"
        },
        "half_saturation_light": {
          "type": "parameter",
          "units": "W/m^2",
          "default": 50.0,
          "description": "Half-saturation light intensity"
        },
        "half_saturation_nutrients": {
          "type": "parameter",
          "units": "mol/m^3",
          "default": 1.0,
          "description": "Half-saturation nutrient concentration"
        },
        "grazing_rate": {
          "type": "parameter",
          "units": "m^3/mol/day",
          "default": 0.8,
          "description": "Zooplankton grazing rate"
        },
        "mortality_rate": {
          "type": "parameter",
          "units": "1/day",
          "default": 0.1,
          "description": "Mortality rate for phytoplankton and zooplankton"
        },
        "remineralization_rate": {
          "type": "parameter",
          "units": "1/day",
          "default": 0.05,
          "description": "Detritus remineralization rate"
        },
        "C_to_N_ratio": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 6.625,
          "description": "Redfield C:N ratio"
        },
        "primary_production": {
          "type": "observed",
          "units": "mol/m^3/day",
          "expression": {
            "op": "*",
            "args": [
              "max_growth_rate",
              {
                "op": "/",
                "args": [
                  "light",
                  {
                    "op": "+",
                    "args": [
                      "light",
                      "half_saturation_light"
                    ]
                  }
                ]
              },
              {
                "op": "/",
                "args": [
                  "nutrients",
                  {
                    "op": "+",
                    "args": [
                      "nutrients",
                      "half_saturation_nutrients"
                    ]
                  }
                ]
              },
              "phytoplankton"
            ]
          },
          "description": "Primary production rate"
        },
        "grazing": {
          "type": "observed",
          "units": "mol/m^3/day",
          "expression": {
            "op": "*",
            "args": [
              "grazing_rate",
              "phytoplankton",
              "zooplankton"
            ]
          },
          "description": "Grazing rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "nutrients"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "primary_production"
                    ]
                  },
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "remineralization_rate",
                  "detritus",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "phytoplankton"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "primary_production",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "grazing"
                    ]
                  },
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "mortality_rate"
                    ]
                  },
                  "phytoplankton",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "zooplankton"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.7,
                  "grazing",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "mortality_rate"
                    ]
                  },
                  "zooplankton",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "detritus"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.3,
                  "grazing",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "mortality_rate",
                  {
                    "op": "+",
                    "args": [
                      "phytoplankton",
                      "zooplankton"
                    ]
                  },
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "remineralization_rate"
                    ]
                  },
                  "detritus",
                  {
                    "op": "/",
                    "args": [
                      1,
                      86400
                    ]
                  }
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "nutrients_periodic_xmin": {
          "variable": "nutrients",
          "side": "xmin",
          "kind": "periodic"
        },
        "phytoplankton_periodic_xmin": {
          "variable": "phytoplankton",
          "side": "xmin",
          "kind": "periodic"
        },
        "zooplankton_periodic_xmin": {
          "variable": "zooplankton",
          "side": "xmin",
          "kind": "periodic"
        },
        "detritus_periodic_xmin": {
          "variable": "detritus",
          "side": "xmin",
          "kind": "periodic"
        },
        "nutrients_zero_gradient_xmin": {
          "variable": "nutrients",
          "side": "xmin",
          "kind": "zero_gradient"
        },
        "phytoplankton_zero_gradient_xmin": {
          "variable": "phytoplankton",
