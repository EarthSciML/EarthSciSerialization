          "shape": []
        },
        "T_ref": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Reference temperature — scalar with explicit empty shape and no staggering",
          "shape": []
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["mass"], "wrt": "t" },
          "rhs": 0.0
