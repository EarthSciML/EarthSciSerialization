{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_13_concat_1d",
    "description": "Exercises the `concat` op along axis 0. Two 1D arrays a[1:3] and b[1:2] are held constant; concat(a, b, axis=0) yields a length-5 vector. Scalar `head` integrates index(concat(a,b,axis=0), 2) = a[2]. Scalar `tail` integrates index(concat(a,b,axis=0), 5) = b[2]. This verifies both the concat length (we index into positions past end(a)) and element order.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "concat"]
  },
  "models": {
    "Concat1D": {
      "variables": {
        "a":    { "type": "state" },
        "b":    { "type": "state" },
        "head": { "type": "state" },
        "tail": { "type": "state" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 1] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 2] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["a", 3] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["b", 1] }], "wrt": "t" }, "rhs": 0.0 },
        { "lhs": { "op": "D", "args": [{ "op": "index", "args": ["b", 2] }], "wrt": "t" }, "rhs": 0.0 },
        {
          "_comment": "head = index(concat(a,b,axis=0), 2) = a[2] = 20.0.",
          "lhs": { "op": "D", "args": ["head"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "concat", "args": ["a", "b"], "axis": 0 },
              2
            ]
          }
        },
        {
          "_comment": "tail = index(concat(a,b,axis=0), 5) = b[2] = 200.0.",
          "lhs": { "op": "D", "args": ["tail"], "wrt": "t" },
          "rhs": {
            "op": "index",
            "args": [
              { "op": "concat", "args": ["a", "b"], "axis": 0 },
              5
            ]
          }
        }
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "concat_element_check",
          "description": "a=[10,20,30], b=[100,200]. head integrates a[2]=20 → head(1)=20. tail integrates b[2]=200 → tail(1)=200.",
          "initial_conditions": {
            "a[1]": 10.0, "a[2]": 20.0, "a[3]": 30.0,
            "b[1]": 100.0, "b[2]": 200.0,
            "head": 0.0, "tail": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "head", "time": 1.0, "expected": 20.0 },
            { "variable": "tail", "time": 1.0, "expected": 200.0 }
          ]
        }
      ]
    }
  }
}
