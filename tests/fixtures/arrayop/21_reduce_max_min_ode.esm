{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_21_reduce_max_ode",
    "description": "Tests arrayop with reduce=max in the ODE equation path: D(u[i]) = arrayop[i,j reduce=max] body. Two cells converge to max_j(i+2j-2)=i+2. Complements fixture 19 (reduce=+) and fixture 20 (embedded max) by exercising max in the top-level D(u[i])=arrayop... form.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "einsum",
      "contraction",
      "reduce",
      "max",
      "ode"
    ]
  },
  "models": {
    "MaxReducerODE": {
      "tolerance": {
        "rel": 1e-3,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i"]
        }
      },
      "equations": [
        {
          "_comment": "D(u[i]) = max_j(i + 2*j - 2 - u[i]) for j in [1,2]. Since u[i] does not depend on j, this equals max_j(i+2j-2) - u[i] = (i+2) - u[i]. Steady state: u[1]=3, u[2]=4. Solution: u[i](t) = (i+2)*(1-exp(-t)).",
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 2]}
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "-",
              "args": [
                {
                  "op": "+",
                  "args": [
                    {"op": "+", "args": ["i", {"op": "*", "args": [2, "j"]}]},
                    -2
                  ]
                },
                {"op": "index", "args": ["u", "i"]}
              ]
            },
            "reduce": "max",
            "ranges": {"i": [1, 2], "j": [1, 2]}
          }
        }
      ],
      "tests": [
        {
          "id": "max_convergence_t10",
          "description": "Starting from zero ICs, u[i] converges to (i+2): u[1]->3, u[2]->4. At t=10, both cells are within 1e-3 relative of steady state. Expected: (i+2)*(1-exp(-10)).",
          "initial_conditions": {
            "u[1]": 0.0,
            "u[2]": 0.0
          },
          "time_span": {"start": 0.0, "end": 10.0},
          "assertions": [
            {"variable": "u[1]", "time": 10.0, "expected": 2.999863800210713},
            {"variable": "u[2]", "time": 10.0, "expected": 3.999818400280950}
          ]
        }
      ]
    }
  }
}
