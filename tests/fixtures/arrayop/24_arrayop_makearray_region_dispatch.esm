{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_24_arrayop_makearray_region_dispatch",
    "description": "Pins _resolve_index_of_makearray (ESS tree_walk.jl:1114) in the LHS-arrayop context. The RHS body is index(makearray(regions,values),i,j) where i,j are arrayop output loop variables — they are substituted to concrete integers during arrayop unrolling, then passed to the resolver. 3x3 2D domain: Region 1 [[1:3],[1:3]]=1.0 (base); Region 2 [[2:2],[2:2]]=4.0 overwrites the center cell. Integrating D(u[i,j])=C[i,j] from u=0 over t=[0,1] yields u[i,j](1)=C[i,j]. (ess-e9l)",
    "authors": [
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "arrayop",
      "makearray",
      "region_dispatch",
      "conformance",
      "pin_resolver"
    ]
  },
  "models": {
    "MakeArrayLoopRegions": {
      "tolerance": {
        "rel": 1e-6,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i", "j"]
        }
      },
      "equations": [
        {
          "_comment": "D(u[i,j]) = index(makearray([[1:3],[1:3]]=1.0, [[2:2],[2:2]]=4.0), i, j). Region 2 overwrites the center (2,2) cell.",
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 3], "j": [1, 3]}
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "index",
              "args": [
                {
                  "op": "makearray",
                  "args": [],
                  "regions": [[[1, 3], [1, 3]], [[2, 2], [2, 2]]],
                  "values": [1.0, 4.0]
                },
                "i",
                "j"
              ]
            },
            "ranges": {"i": [1, 3], "j": [1, 3]}
          }
        }
      ],
      "tests": [
        {
          "id": "region_dispatch_at_t1",
          "description": "From u=0, integrating D(u[i,j])=C[i,j] to t=1 gives u[i,j]=C[i,j]. Region 1 [[1:3],[1:3]]=1.0 fills all cells; Region 2 [[2:2],[2:2]]=4.0 overwrites the center. All 8 border cells are 1.0; u[2,2]=4.0.",
          "initial_conditions": {
            "u[1,1]": 0.0, "u[1,2]": 0.0, "u[1,3]": 0.0,
            "u[2,1]": 0.0, "u[2,2]": 0.0, "u[2,3]": 0.0,
            "u[3,1]": 0.0, "u[3,2]": 0.0, "u[3,3]": 0.0
          },
          "time_span": {"start": 0.0, "end": 1.0},
          "assertions": [
            {"variable": "u[1,1]", "time": 1.0, "expected": 1.0},
            {"variable": "u[1,2]", "time": 1.0, "expected": 1.0},
            {"variable": "u[1,3]", "time": 1.0, "expected": 1.0},
            {"variable": "u[2,1]", "time": 1.0, "expected": 1.0},
            {"variable": "u[2,2]", "time": 1.0, "expected": 4.0},
            {"variable": "u[2,3]", "time": 1.0, "expected": 1.0},
            {"variable": "u[3,1]", "time": 1.0, "expected": 1.0},
            {"variable": "u[3,2]", "time": 1.0, "expected": 1.0},
            {"variable": "u[3,3]", "time": 1.0, "expected": 1.0}
          ]
        }
      ]
    }
  }
}
