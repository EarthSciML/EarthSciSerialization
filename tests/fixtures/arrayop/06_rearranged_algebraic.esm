{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_06_rearranged_algebraic",
    "description": "Regression test for arrayop with the algebraic variable buried in a rearranged LHS sum: (-1 - 0.5*sin(u[i]) + v[i]) ~ (v[i] - v[i]). v should still be eliminated during mtkcompile. Mirrors MTK fork test #6 which guards against the MethodOfLines PDE discretization producing this specific shape.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "algebraic_elimination", "rearranged"]
  },
  "models": {
    "Rearranged": {
      "variables": {
        "u": { "type": "state" },
        "v": { "type": "state" }
      },
      "equations": [
        {
          "_comment": "D(u[i]) = v[i]",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "D", "args": [{ "op": "index", "args": ["u", "i"] }], "wrt": "t" },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "index", "args": ["v", "i"] },
            "ranges": { "i": [1, 5] }
          }
        },
        {
          "_comment": "(-1 - 0.5*sin(u[i]) + v[i]) = (v[i] - v[i])  [RHS = 0]",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": {
              "op": "+",
              "args": [
                -1.0,
                { "op": "*", "args": [-0.5, { "op": "sin", "args": [{ "op": "index", "args": ["u", "i"] }] }] },
                { "op": "index", "args": ["v", "i"] }
              ]
            },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": {
              "op": "-",
              "args": [
                { "op": "index", "args": ["v", "i"] },
                { "op": "index", "args": ["v", "i"] }
              ]
            },
            "ranges": { "i": [1, 5] }
          }
        }
      ],
      "tolerance": { "rel": 1.0e-4 },
      "tests": [
        {
          "id": "short_run_smoke",
          "description": "Smoke test: solve over [0, 0.1] and verify the solver returns Success. Deep numerical validation lives in the native MTK fork test.",
          "initial_conditions": {
            "u[1]": 0.0, "u[2]": 0.0, "u[3]": 0.0, "u[4]": 0.0, "u[5]": 0.0
          },
          "time_span": { "start": 0.0, "end": 0.1 },
          "assertions": [
            { "variable": "u[1]", "time": 0.0, "expected": 0.0 }
          ]
        }
      ]
    }
  }
}
