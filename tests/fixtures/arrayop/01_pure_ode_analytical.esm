{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_01_pure_ode_analytical",
    "description": "Pure ODE on an N=5 array state u. D(u[i]) = -u[i], analytical u_i(t) = i*exp(-t). Mirrors MTK fork test #1 at /tmp/mtk-arrayop/test/arrayop_block_tearing_test.jl line 12.",
    "authors": ["EarthSciSerialization/polecats/brahmin"],
    "tags": ["arrayop", "conformance", "analytical"]
  },
  "models": {
    "PureODE": {
      "variables": {
        "u": { "type": "state" }
      },
      "equations": [
        {
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "expr": { "op": "D", "args": [{ "op": "index", "args": ["u", "i"] }], "wrt": "t" },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "expr": { "op": "-", "args": [{ "op": "index", "args": ["u", "i"] }] },
            "ranges": { "i": [1, 5] }
          }
        }
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "analytical_t1",
          "description": "At t=1.0, u[i](1) = i * exp(-1) for i in 1..5.",
          "initial_conditions": {
            "u[1]": 1.0,
            "u[2]": 2.0,
            "u[3]": 3.0,
            "u[4]": 4.0,
            "u[5]": 5.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "u[1]", "time": 1.0, "expected": 0.36787944117144233 },
            { "variable": "u[2]", "time": 1.0, "expected": 0.7357588823428847 },
            { "variable": "u[3]", "time": 1.0, "expected": 1.103638323514327 },
            { "variable": "u[4]", "time": 1.0, "expected": 1.4715177646857694 },
            { "variable": "u[5]", "time": 1.0, "expected": 1.8393972058572117 }
          ]
        }
      ]
    }
  }
}
