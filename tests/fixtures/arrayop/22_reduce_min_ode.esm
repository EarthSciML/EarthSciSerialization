{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_22_reduce_min_ode",
    "description": "Tests arrayop with reduce=min in the ODE equation path: D(v[i]) = arrayop[i,j reduce=min] body. Two cells converge to min_j(i+2j-2)=i. Complements fixture 21 (reduce=max) and fixture 20 (embedded max) by adding the min reducer to the ODE path coverage.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "einsum",
      "contraction",
      "reduce",
      "min",
      "ode"
    ]
  },
  "models": {
    "MinReducerODE": {
      "tolerance": {
        "rel": 1e-3,
        "abs": 0.0
      },
      "variables": {
        "v": {
          "type": "state",
          "shape": ["i"]
        }
      },
      "equations": [
        {
          "_comment": "D(v[i]) = min_j(i + 2*j - 2 - v[i]) for j in [1,2]. Since v[i] does not depend on j, this equals min_j(i+2j-2) - v[i] = i - v[i]. Steady state: v[1]=1, v[2]=2. Solution: v[i](t) = i*(1-exp(-t)).",
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["v", "i"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 2]}
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "-",
              "args": [
                {
                  "op": "+",
                  "args": [
                    {"op": "+", "args": ["i", {"op": "*", "args": [2, "j"]}]},
                    -2
                  ]
                },
                {"op": "index", "args": ["v", "i"]}
              ]
            },
            "reduce": "min",
            "ranges": {"i": [1, 2], "j": [1, 2]}
          }
        }
      ],
      "tests": [
        {
          "id": "min_convergence_t10",
          "description": "Starting from zero ICs, v[i] converges to i: v[1]->1, v[2]->2. At t=10, both cells are within 1e-3 relative of steady state. Expected: i*(1-exp(-10)).",
          "initial_conditions": {
            "v[1]": 0.0,
            "v[2]": 0.0
          },
          "time_span": {"start": 0.0, "end": 10.0},
          "assertions": [
            {"variable": "v[1]", "time": 10.0, "expected": 0.9999546000702375},
            {"variable": "v[2]", "time": 10.0, "expected": 1.9999092001404750}
          ]
        }
      ]
    }
  }
}
