{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_16_discretized_2d_heat",
    "description": "Discretized 2D heat equation on a 3x3 interior grid (Cartesian, uniform, h=0.25) with homogeneous Dirichlet BCs. Stencil coefficient 1/h^2=16. IC: u[i,j,0]=sin(i*pi/4)*sin(j*pi/4). Exact discrete solution: u[i,j,t]=sin(i*pi/4)*sin(j*pi/4)*exp(lambda_2D*t) where lambda_2D=2*16*(2*cos(pi/4)-2)=-18.745165204060956. The single-arrayop RHS uses ifelse+max/min to encode Dirichlet ghost-cell semantics: each neighbor index is clamped to [1,3] and guarded by ifelse so out-of-bounds accesses evaluate to 0 rather than triggering MTK bounds-check errors. Tests the neighbor-coupled indexed-state path (ess-ing).",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux",
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "stencil",
      "2d",
      "pde",
      "neighbor_coupling",
      "ghost_cell_ifelse"
    ]
  },
  "models": {
    "Heat2D": {
      "tolerance": {
        "rel": 1e-3,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i", "j"]
        }
      },
      "equations": [
        {
          "_comment": "All 9 interior cells in one arrayop. Dirichlet ghost cells handled via ifelse+max/min: neighbor index clamped to [1,3] and conditional on being in range, else 0.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 3], "j": [1, 3]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "*",
              "args": [
                16,
                {
                  "op": "+",
                  "args": [
                    {"op": "ifelse", "args": [
                      {"op": ">=", "args": ["i", 2]},
                      {"op": "index", "args": ["u", {"op": "max", "args": [1, {"op": "-", "args": ["i", 1]}]}, "j"]},
                      0
                    ]},
                    {"op": "ifelse", "args": [
                      {"op": "<=", "args": ["i", 2]},
                      {"op": "index", "args": ["u", {"op": "min", "args": [3, {"op": "+", "args": ["i", 1]}]}, "j"]},
                      0
                    ]},
                    {"op": "ifelse", "args": [
                      {"op": ">=", "args": ["j", 2]},
                      {"op": "index", "args": ["u", "i", {"op": "max", "args": [1, {"op": "-", "args": ["j", 1]}]}]},
                      0
                    ]},
                    {"op": "ifelse", "args": [
                      {"op": "<=", "args": ["j", 2]},
                      {"op": "index", "args": ["u", "i", {"op": "min", "args": [3, {"op": "+", "args": ["j", 1]}]}]},
                      0
                    ]},
                    {"op": "*", "args": [-4, {"op": "index", "args": ["u", "i", "j"]}]}
                  ]
                }
              ]
            },
            "ranges": {"i": [1, 3], "j": [1, 3]}
          }
        }
      ],
      "tests": [
        {
          "id": "mode1_decay_t0.05",
          "description": "First-mode sinusoidal IC decays to exp(lambda_2D*0.05)*IC. lambda_2D=-18.745165204060956 gives decay factor exp(-0.9372583)~=0.391702. Asserts three representative cells.",
          "initial_conditions": {
            "u[1,1]": 0.5,
            "u[1,2]": 0.7071067811865476,
            "u[1,3]": 0.5,
            "u[2,1]": 0.7071067811865476,
            "u[2,2]": 1.0,
            "u[2,3]": 0.7071067811865476,
            "u[3,1]": 0.5,
            "u[3,2]": 0.7071067811865476,
            "u[3,3]": 0.5
          },
          "time_span": {"start": 0.0, "end": 0.05},
          "assertions": [
            {"variable": "u[2,2]", "time": 0.05, "expected": 0.391702},
            {"variable": "u[1,1]", "time": 0.05, "expected": 0.195851},
            {"variable": "u[2,1]", "time": 0.05, "expected": 0.276975}
          ]
        }
      ]
    }
  }
}
