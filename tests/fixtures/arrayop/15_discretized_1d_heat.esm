{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_15_discretized_1d_heat",
    "description": "Discretized 1D heat equation on 4 cells with Dirichlet BCs (ghost cells u[0]=u[5]=0). dx=0.2, stencil coefficient 1/dx^2=25. Full-grid arrayop with makearray ghost lowering (ess-j8t): region 0=[1,4] interior, region 1=[1,1] xmin ghost (u[i-1]→0), region 2=[4,4] xmax ghost (u[i+1]→0). The first-mode sinusoidal IC u[i]=sin(pi*i/5) decays with the exact discrete eigenvalue lambda_1=25*(2*cos(pi/5)-2)=-9.5492, so u[i,t]=exp(lambda_1*t)*sin(pi*i/5). This fixture tests the spatial-PDE dispatch path: simulate() must route models with shape-d state variables to the ArrayOp runtime.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "stencil",
      "spatial_dispatch",
      "pde",
      "makearray",
      "boundary_conditions"
    ]
  },
  "models": {
    "Heat1D": {
      "tolerance": {
        "rel": 1e-3,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i"]
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 4]}
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "index",
              "args": [
                {
                  "op": "makearray",
                  "args": [],
                  "regions": [[[1, 4]], [[1, 1]], [[4, 4]]],
                  "values": [
                    {
                      "op": "*",
                      "args": [
                        25,
                        {
                          "op": "+",
                          "args": [
                            {"op": "index", "args": ["u", {"op": "-", "args": ["i", 1]}]},
                            {"op": "*", "args": [-2, {"op": "index", "args": ["u", "i"]}]},
                            {"op": "index", "args": ["u", {"op": "+", "args": ["i", 1]}]}
                          ]
                        }
                      ]
                    },
                    {
                      "op": "*",
                      "args": [
                        25,
                        {
                          "op": "+",
                          "args": [
                            0,
                            {"op": "*", "args": [-2, {"op": "index", "args": ["u", "i"]}]},
                            {"op": "index", "args": ["u", {"op": "+", "args": ["i", 1]}]}
                          ]
                        }
                      ]
                    },
                    {
                      "op": "*",
                      "args": [
                        25,
                        {
                          "op": "+",
                          "args": [
                            {"op": "index", "args": ["u", {"op": "-", "args": ["i", 1]}]},
                            {"op": "*", "args": [-2, {"op": "index", "args": ["u", "i"]}]},
                            0
                          ]
                        }
                      ]
                    }
                  ]
                },
                "i"
              ]
            },
            "ranges": {"i": [1, 4]}
          }
        }
      ],
      "tests": [
        {
          "id": "mode1_decay_t0.1",
          "description": "First-mode sinusoidal IC decays to exp(lambda_1*0.1)*IC; exact discrete eigenvalue gives 0.38485 decay factor at t=0.1.",
          "initial_conditions": {
            "u[1]": 0.5877852522924731,
            "u[2]": 0.9510565162951535,
            "u[3]": 0.9510565162951536,
            "u[4]": 0.5877852522924732
          },
          "time_span": {"start": 0.0, "end": 0.1},
          "assertions": [
            {"variable": "u[1]", "time": 0.1, "expected": 0.22620612381309183},
            {"variable": "u[2]", "time": 0.1, "expected": 0.36600919679294946},
            {"variable": "u[3]", "time": 0.1, "expected": 0.36600919679294946},
            {"variable": "u[4]", "time": 0.1, "expected": 0.22620612381309183}
          ]
        }
      ]
    }
  }
}
