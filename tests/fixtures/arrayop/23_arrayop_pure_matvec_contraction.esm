{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_23_pure_matvec_contraction",
    "description": "Cross-port conformance fixture for arrayop contraction (ess-zmm). Two pure-index ODEs: (1) reduce=+ matvec: D(y[i])/dt = sum_{j=1}^{3} i*j, giving y[1]=6, y[2]=12 at t=1; (2) reduce=max column-max: D(w[i])/dt = max_{j=1}^{3}(i+j), giving w[1]=4, w[2]=5 at t=1. No state variable appears in the contraction body — reduction is purely over index expressions. Executing ports: Python, Rust, Julia (both MTK and tree-walk paths). Non-executing ports skip: TypeScript, Go (no arrayop numeric executor). Ref: ess-zmm.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "contraction",
      "einsum",
      "reduce",
      "matvec",
      "ess-zmm"
    ]
  },
  "models": {
    "PureMatVecContraction": {
      "tolerance": {
        "rel": 1e-6,
        "abs": 0.0
      },
      "variables": {
        "y": {
          "type": "state",
          "shape": ["i"]
        },
        "w": {
          "type": "state",
          "shape": ["i"]
        }
      },
      "equations": [
        {
          "_comment": "D(y[i])/dt = sum_{j=1..3} i*j. For i=1: 1*1+1*2+1*3=6. For i=2: 2*1+2*2+2*3=12. Pure reduce=+ contraction: j is contracted, i is the output index.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{ "op": "index", "args": ["y", "i"] }],
              "wrt": "t"
            },
            "ranges": { "i": [1, 2] }
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "reduce": "+",
            "ranges": { "i": [1, 2], "j": [1, 3] },
            "expr": { "op": "*", "args": ["i", "j"] }
          }
        },
        {
          "_comment": "D(w[i])/dt = max_{j=1..3}(i+j). For i=1: max(2,3,4)=4. For i=2: max(3,4,5)=5. Pure reduce=max contraction: j is contracted, i is the output index.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{ "op": "index", "args": ["w", "i"] }],
              "wrt": "t"
            },
            "ranges": { "i": [1, 2] }
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i"],
            "reduce": "max",
            "ranges": { "i": [1, 2], "j": [1, 3] },
            "expr": { "op": "+", "args": ["i", "j"] }
          }
        }
      ],
      "tests": [
        {
          "id": "matvec_t1",
          "description": "Constant-RHS ODEs from zero ICs. D(y[i])=i*(1+2+3)=6i, D(w[i])=i+3. At t=1: y[1]=6, y[2]=12, w[1]=4, w[2]=5.",
          "initial_conditions": {
            "y[1]": 0.0,
            "y[2]": 0.0,
            "w[1]": 0.0,
            "w[2]": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "y[1]", "time": 1.0, "expected": 6.0 },
            { "variable": "y[2]", "time": 1.0, "expected": 12.0 },
            { "variable": "w[1]", "time": 1.0, "expected": 4.0 },
            { "variable": "w[2]", "time": 1.0, "expected": 5.0 }
          ]
        }
      ]
    }
  }
}
