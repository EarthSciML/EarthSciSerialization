{
  "esm": "0.1.0",
  "metadata": {
    "name": "CoordinateTransforms",
    "description": "Test various coordinate transformation specifications for projecting between different spatial coordinate systems",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "coordinate-transforms",
      "projections",
      "spatial-mapping"
    ],
    "references": [
      {
        "citation": "Coordinate transformation test fixture for earth system modeling",
        "notes": "Tests geographic-to-cartesian, pressure-to-height, and custom coordinate mappings"
      }
    ]
  },
  "models": {
    "GlobalTransport": {
      "reference": {
        "notes": "Global atmospheric transport requiring multiple coordinate transforms"
      },
      "variables": {
        "co2_mixing_ratio": {
          "type": "state",
          "units": "ppm",
          "default": 420.0,
          "description": "Carbon dioxide mixing ratio"
        },
        "ch4_mixing_ratio": {
          "type": "state",
          "units": "ppb",
          "default": 1900.0,
          "description": "Methane mixing ratio"
        },
        "zonal_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 10.0,
          "description": "Eastward wind component"
        },
        "meridional_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Northward wind component"
        },
        "vertical_wind": {
          "type": "parameter",
          "units": "Pa/s",
          "default": 0.0,
          "description": "Vertical velocity in pressure coordinates"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "co2_mixing_ratio"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "zonal_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "co2_mixing_ratio"
                    ],
                    "dim": "lon"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "meridional_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "co2_mixing_ratio"
                    ],
                    "dim": "lat"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "vertical_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "co2_mixing_ratio"
                    ],
                    "dim": "lev"
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "ch4_mixing_ratio"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "zonal_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "ch4_mixing_ratio"
                    ],
                    "dim": "lon"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "meridional_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "ch4_mixing_ratio"
                    ],
                    "dim": "lat"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "vertical_wind"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "ch4_mixing_ratio"
                    ],
                    "dim": "lev"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-08T00:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -180.0,
          "max": 180.0,
          "units": "degrees",
          "grid_spacing": 2.5
        },
        "lat": {
          "min": -90.0,
          "max": 90.0,
          "units": "degrees",
          "grid_spacing": 2.0
        },
        "lev": {
          "min": 1000.0,
          "max": 10.0,
          "units": "hPa",
          "grid_spacing": 50.0
        },
        "x_proj": {
          "min": -20037508.34,
          "max": 20037508.34,
          "units": "meters",
          "grid_spacing": 250000.0
        },
        "y_proj": {
          "min": -15496570.74,
          "max": 18764656.23,
          "units": "meters",
          "grid_spacing": 250000.0
        },
        "z_height": {
          "min": 0.0,
          "max": 30000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        }
      },
      "coordinate_transforms": [
        {
          "id": "lonlat_to_mercator",
          "description": "Web Mercator projection from geographic to projected coordinates",
          "dimensions": [
            "lon",
            "lat"
          ]
        },
        {
          "id": "pressure_to_height_standard",
          "description": "Standard atmosphere pressure-to-height conversion",
          "dimensions": [
            "lev"
          ]
        },
        {
          "id": "mercator_to_lonlat",
          "description": "Inverse Web Mercator projection",
          "dimensions": [
            "x_proj",
            "y_proj"
          ]
        },
        {
          "id": "height_to_pressure_standard",
          "description": "Standard atmosphere height-to-pressure conversion",
          "dimensions": [
            "z_height"
          ]
        },
        {
          "id": "spherical_to_cartesian",
          "description": "Spherical Earth to 3D Cartesian coordinates",
          "dimensions": [
            "lon",
            "lat",
            "z_height"
          ]
        },
        {
          "id": "cartesian_to_spherical",
          "description": "3D Cartesian to spherical Earth coordinates",
          "dimensions": [
            "x_cart",
            "y_cart",
            "z_cart"
          ]
        }
      ],
      "spatial_ref": "EPSG:4326",
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "co2_mixing_ratio": 420.0,
          "ch4_mixing_ratio": 1900.0
        }
      },
      "boundary_conditions": [
        {
          "type": "periodic",
          "dimensions": [
            "lon"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "lat"
          ]
        },
        {
          "type": "constant",
          "dimensions": [
            "lev"
          ],
          "value": 0.0
        },
        {
          "type": "periodic",
          "dimensions": [
            "x_proj"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "y_proj"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "z_height"
          ]
        }
      ],
      "element_type": "Float32",
      "array_type": "Array"
    }
  }
}
