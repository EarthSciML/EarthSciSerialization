        }
      }
    ]
  },
  {
    "name": "Logical and comparison operations",
    "tests": [
      {
        "description": "Greater than true",
        "input": {"op": ">", "args": [5, 3]},
        "expected_type": "OpExpr",
        "serialized": {"op": ">", "args": [5.0, 3.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": true
        }
      },
      {
        "description": "Greater than false",
        "input": {"op": ">", "args": [2, 7]},
        "expected_type": "OpExpr",
        "serialized": {"op": ">", "args": [2.0, 7.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": false
        }
      },
      {
        "description": "Less than or equal true",
        "input": {"op": "<=", "args": [3, 3]},
        "expected_type": "OpExpr",
        "serialized": {"op": "<=", "args": [3.0, 3.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": true
        }
      },
      {
        "description": "Equality true",
        "input": {"op": "==", "args": ["x", "x"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "==", "args": ["x", "x"]},
        "evaluation": {
          "bindings": {"x": 42.0},
          "expected_result": true
        }
      },
      {
        "description": "Inequality with variables",
        "input": {"op": "!=", "args": ["a", "b"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "!=", "args": ["a", "b"]},
        "evaluation": {
          "bindings": {"a": 3.0, "b": 4.0},
          "expected_result": true
        }
      },
      {
        "description": "Logical AND true",
        "input": {"op": "and", "args": [{"op": ">", "args": ["x", 0]}, {"op": "<", "args": ["x", 10]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "and", "args": [{"op": ">", "args": ["x", 0.0]}, {"op": "<", "args": ["x", 10.0]}]},
        "evaluation": {
          "bindings": {"x": 5.0},
          "expected_result": true
        }
      },
      {
        "description": "Logical OR false",
        "input": {"op": "or", "args": [{"op": "<", "args": ["y", 0]}, {"op": ">", "args": ["y", 100]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "or", "args": [{"op": "<", "args": ["y", 0.0]}, {"op": ">", "args": ["y", 100.0]}]},
        "evaluation": {
          "bindings": {"y": 50.0},
          "expected_result": false
        }
      },
      {
        "description": "Logical NOT",
        "input": {"op": "not", "args": [{"op": ">", "args": ["z", 100]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "not", "args": [{"op": ">", "args": ["z", 100.0]}]},
        "evaluation": {
          "bindings": {"z": 25.0},
          "expected_result": true
        }
      }
    ]
  },
  {
    "name": "Complex nested expressions",
    "tests": [
      {
        "description": "Nested arithmetic (order of operations)",
        "input": {"op": "+", "args": [{"op": "*", "args": [2, 3]}, {"op": "*", "args": [4, 5]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "+", "args": [{"op": "*", "args": [2.0, 3.0]}, {"op": "*", "args": [4.0, 5.0]}]},
        "evaluation": {
          "bindings": {},
          "expected_result": 26.0
        }
      },
      {
        "description": "Polynomial evaluation",
        "input": {"op": "+", "args": [{"op": "*", "args": ["a", {"op": "^", "args": ["x", 2]}]}, {"op": "*", "args": ["b", "x"]}, "c"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "+", "args": [{"op": "*", "args": ["a", {"op": "^", "args": ["x", 2.0]}]}, {"op": "*", "args": ["b", "x"]}, "c"]},
        "evaluation": {
          "bindings": {"a": 2.0, "b": -3.0, "c": 1.0, "x": 4.0},
          "expected_result": 21.0
        }
      },
      {
        "description": "Arrhenius rate expression",
        "input": {"op": "*", "args": ["A", {"op": "exp", "args": [{"op": "/", "args": [{"op": "-", "args": ["Ea"]}, {"op": "*", "args": ["R", "T"]}]}]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "*", "args": ["A", {"op": "exp", "args": [{"op": "/", "args": [{"op": "-", "args": ["Ea"]}, {"op": "*", "args": ["R", "T"]}]}]}]},
        "evaluation": {
          "bindings": {"A": 1e13, "Ea": 5000, "R": 8.314, "T": 300},
          "expected_result": 497870683.6544984
        }
      },
      {
        "description": "Gaussian function",
        "input": {"op": "*", "args": ["A", {"op": "exp", "args": [{"op": "/", "args": [{"op": "-", "args": [{"op": "^", "args": [{"op": "-", "args": ["x", "μ"]}, 2]}]}, {"op": "*", "args": [2, {"op": "^", "args": ["σ", 2]}]}]}]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "*", "args": ["A", {"op": "exp", "args": [{"op": "/", "args": [{"op": "-", "args": [{"op": "^", "args": [{"op": "-", "args": ["x", "μ"]}, 2.0]}]}, {"op": "*", "args": [2.0, {"op": "^", "args": ["σ", 2.0]}]}]}]}]},
        "evaluation": {
          "bindings": {"A": 1.0, "x": 0.0, "μ": 0.0, "σ": 1.0},
          "expected_result": 1.0
        }
      },
      {
        "description": "Distance formula in 3D",
        "input": {"op": "sqrt", "args": [{"op": "+", "args": [{"op": "^", "args": [{"op": "-", "args": ["x2", "x1"]}, 2]}, {"op": "^", "args": [{"op": "-", "args": ["y2", "y1"]}, 2]}, {"op": "^", "args": [{"op": "-", "args": ["z2", "z1"]}, 2]}]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "sqrt", "args": [{"op": "+", "args": [{"op": "^", "args": [{"op": "-", "args": ["x2", "x1"]}, 2.0]}, {"op": "^", "args": [{"op": "-", "args": ["y2", "y1"]}, 2.0]}, {"op": "^", "args": [{"op": "-", "args": ["z2", "z1"]}, 2.0]}]}]},
        "evaluation": {
          "bindings": {"x1": 1.0, "y1": 2.0, "z1": 3.0, "x2": 4.0, "y2": 6.0, "z2": 8.0},
          "expected_result": 7.0710678118654755
        }
      }
    ]
  },
  {
    "name": "Conditional expressions",
    "tests": [
      {
        "description": "If-else condition true branch",
        "input": {"op": "ifelse", "args": [{"op": ">", "args": ["x", 0]}, "x", {"op": "-", "args": ["x"]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "ifelse", "args": [{"op": ">", "args": ["x", 0.0]}, "x", {"op": "-", "args": ["x"]}]},
        "evaluation": {
          "bindings": {"x": 5.0},
          "expected_result": 5.0
        }
      },
      {
        "description": "If-else condition false branch",
        "input": {"op": "ifelse", "args": [{"op": ">", "args": ["x", 0]}, "x", {"op": "-", "args": ["x"]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "ifelse", "args": [{"op": ">", "args": ["x", 0.0]}, "x", {"op": "-", "args": ["x"]}]},
        "evaluation": {
          "bindings": {"x": -3.0},
          "expected_result": 3.0
        }
      },
      {
        "description": "Piecewise function with multiple conditions",
        "input": {"op": "ifelse", "args": [{"op": "<", "args": ["t", 1]}, 0, {"op": "ifelse", "args": [{"op": "<", "args": ["t", 2]}, "t", 2]}]},
        "expected_type": "OpExpr",
        "serialized": {"op": "ifelse", "args": [{"op": "<", "args": ["t", 1.0]}, 0.0, {"op": "ifelse", "args": [{"op": "<", "args": ["t", 2.0]}, "t", 2.0]}]},
        "evaluation": {
          "bindings": {"t": 1.5},
          "expected_result": 1.5
        }
      }
    ]
  },
  {
    "name": "Calculus operators with special fields",
    "tests": [
      {
        "description": "Time derivative",
        "input": {"op": "D", "args": ["concentration"], "wrt": "t"},
        "expected_type": "OpExpr",
        "serialized": {"op": "D", "args": ["concentration"], "wrt": "t"},
        "evaluation": {
          "note": "Derivatives cannot be evaluated without symbolic computation",
          "round_trip_only": true
        }
      },
      {
        "description": "Partial derivative with respect to space",
        "input": {"op": "D", "args": ["temperature"], "wrt": "x"},
        "expected_type": "OpExpr",
        "serialized": {"op": "D", "args": ["temperature"], "wrt": "x"},
        "evaluation": {
          "note": "Derivatives cannot be evaluated without symbolic computation",
          "round_trip_only": true
        }
      },
      {
        "description": "Gradient operator with dimension",
        "input": {"op": "grad", "args": ["phi"], "dim": "x"},
        "expected_type": "OpExpr",
        "serialized": {"op": "grad", "args": ["phi"], "dim": "x"},
        "evaluation": {
          "note": "Spatial operators cannot be evaluated without field data",
          "round_trip_only": true
        }
      },
      {
        "description": "Divergence operator",
        "input": {"op": "div", "args": ["velocity"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "div", "args": ["velocity"]},
        "evaluation": {
          "note": "Spatial operators cannot be evaluated without field data",
          "round_trip_only": true
        }
      },
      {
        "description": "Laplacian operator",
        "input": {"op": "laplacian", "args": ["u"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "laplacian", "args": ["u"]},
        "evaluation": {
          "note": "Spatial operators cannot be evaluated without field data",
          "round_trip_only": true
        }
      },
      {
        "description": "Mixed derivative with both wrt and dim",
        "input": {"op": "D", "args": [{"op": "grad", "args": ["field"], "dim": "x"}], "wrt": "t"},
        "expected_type": "OpExpr",
        "serialized": {"op": "D", "args": [{"op": "grad", "args": ["field"], "dim": "x"}], "wrt": "t"},
        "evaluation": {
          "note": "Mixed spatial-temporal operators cannot be evaluated without field data",
          "round_trip_only": true
        }
      }
    ]
  },
  {
    "name": "Event-specific operators",
    "tests": [
      {
        "description": "Pre operator for accessing previous values",
        "input": {"op": "Pre", "args": ["velocity"]},
        "expected_type": "OpExpr",
        "serialized": {"op": "Pre", "args": ["velocity"]},
        "evaluation": {
          "note": "Pre operator requires event context for evaluation",
          "round_trip_only": true
        }
      },
      {
        "description": "Pre operator in conditional context",
        "input": {"op": ">", "args": [{"op": "Pre", "args": ["position"]}, "threshold"]},
        "expected_type": "OpExpr",
        "serialized": {"op": ">", "args": [{"op": "Pre", "args": ["position"]}, "threshold"]},
        "evaluation": {
          "note": "Pre operator requires event context for evaluation",
          "round_trip_only": true
        }
      }
    ]
  },
  {
    "name": "Edge cases and error conditions",
    "tests": [
      {
        "description": "Very small number near machine epsilon",
        "input": 1e-16,
        "expected_type": "NumExpr",
        "expected_value": 1e-16,
        "serialized": 1e-16,
        "evaluation": {
          "bindings": {},
          "expected_result": 1e-16
        }
      },
      {
        "description": "Very large number",
        "input": 1e15,
        "expected_type": "NumExpr",
        "expected_value": 1e15,
        "serialized": 1e15,
        "evaluation": {
          "bindings": {},
          "expected_result": 1e15
        }
      },
      {
        "description": "Variable with special characters and subscripts",
        "input": "CO₂_concentration",
        "expected_type": "VarExpr",
        "expected_name": "CO₂_concentration",
        "serialized": "CO₂_concentration",
        "evaluation": {
          "bindings": {"CO₂_concentration": 415.0},
          "expected_result": 415.0
        }
      },
      {
        "description": "Zero division handling",
        "input": {"op": "/", "args": [1, 0]},
        "expected_type": "OpExpr",
        "serialized": {"op": "/", "args": [1.0, 0.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": "Inf",
          "note": "Division by zero results in infinity"
        }
      },
      {
        "description": "Square root of negative number",
        "input": {"op": "sqrt", "args": [-1]},
        "expected_type": "OpExpr",
        "serialized": {"op": "sqrt", "args": [-1.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": "NaN",
          "note": "Square root of negative number results in NaN"
        }
      },
      {
        "description": "Logarithm of zero",
        "input": {"op": "log", "args": [0]},
        "expected_type": "OpExpr",
        "serialized": {"op": "log", "args": [0.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": "-Inf",
          "note": "Logarithm of zero results in negative infinity"
        }
      }
    ]
  }
]