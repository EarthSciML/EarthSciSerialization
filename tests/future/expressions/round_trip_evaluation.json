        }
      },
      {
        "description": "Maximum function",
        "input": {"op": "max", "args": [3, 1, 4, 1, 5]},
        "expected_type": "OpExpr",
        "serialized": {"op": "max", "args": [3.0, 1.0, 4.0, 1.0, 5.0]},
        "evaluation": {
          "bindings": {},
