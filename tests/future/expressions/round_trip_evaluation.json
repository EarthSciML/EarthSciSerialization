        "serialized": {"op": "sin", "args": [1.5707963267948966]},
        "evaluation": {
          "bindings": {},
          "expected_result": 1.0
        }
      },
      {
        "description": "Cosine function",
        "input": {"op": "cos", "args": [0]},
        "expected_type": "OpExpr",
        "serialized": {"op": "cos", "args": [0.0]},
        "evaluation": {
          "bindings": {},
          "expected_result": 1.0
        }
      },
      {
        "description": "Absolute value positive",
        "input": {"op": "abs", "args": [5]},
        "expected_type": "OpExpr",
        "serialized": {"op": "abs", "args": [5.0]},
        "evaluation": {
          "bindings": {},
