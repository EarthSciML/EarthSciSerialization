[
  {
    "description": "Add coupling entry to existing file",
    "operation": "add_coupling",
    "input_file": {
      "esm": "0.1.0",
      "reaction_systems": {
        "Chemistry": {
          "species": {
            "O3": {
              "units": "mol/mol",
              "default": 4e-08,
              "description": "Ozone"
            },
            "NO": {
              "units": "mol/mol",
              "default": 1e-10,
              "description": "Nitric oxide"
            }
          },
          "parameters": {
            "T": {
              "units": "K",
              "default": 298.15,
              "description": "Temperature"
            }
          },
          "reactions": [
            {
              "id": "R1",
              "name": "NO_O3",
              "substrates": [
                {
                  "species": "NO",
                  "stoichiometry": 1
                },
                {
                  "species": "O3",
                  "stoichiometry": 1
                }
              ],
              "products": [
                {
                  "species": "NO2",
                  "stoichiometry": 1
                }
              ],
              "rate": 1.8e-12
            }
          ]
        }
      },
      "models": {
        "Transport": {
          "variables": {
            "u_wind": {
              "type": "parameter",
              "units": "m/s",
              "default": 5.0
            },
            "v_wind": {
              "type": "parameter",
              "units": "m/s",
              "default": 2.0
            }
          },
          "equations": [
            {
              "lhs": {
                "op": "D",
                "args": [
                  "_var"
                ],
                "wrt": "t"
              },
              "rhs": {
                "op": "*",
                "args": [
                  "u_wind",
                  {
                    "op": "grad",
                    "args": [
                      "_var"
                    ],
                    "dim": "x"
                  }
                ]
              }
            }
          ]
        }
      },
      "data_loaders": {
        "MetData": {
          "kind": "grid",
          "source": {
            "url_template": "file:///data/GEOSFP/{date:%Y%m%d_%H%M}.nc"
          },
          "spatial": {
            "crs": "EPSG:4326",
            "grid_type": "latlon",
            "staggering": {
              "lon": "center",
              "lat": "center"
            }
          },
          "variables": {
            "T": {
              "file_variable": "T",
              "units": "K",
              "description": "Temperature"
            },
            "u": {
              "file_variable": "u",
              "units": "m/s",
              "description": "Eastward wind"
            }
          },
          "metadata": {
            "tags": [
              "meteorology",
              "reanalysis"
            ]
          }
        }
      },
      "coupling": [
        {
          "type": "operator_compose",
          "systems": [
            "Chemistry",
            "Transport"
          ]
        }
      ]
    },
    "parameters": {
      "entry": {
        "type": "variable_map",
        "from": "MetData.T",
        "to": "Chemistry.T",
        "transform": "param_to_var"
      }
    },
    "expected_file": {
      "esm": "0.1.0",
      "reaction_systems": {
        "Chemistry": {
          "species": {
            "O3": {
              "units": "mol/mol",
              "default": 4e-08,
              "description": "Ozone"
