                ]
              }
            }
          ]
        }
      },
      "data_loaders": {
        "MetData": {
          "kind": "grid",
          "source": {
            "url_template": "file:///data/GEOSFP/{date:%Y%m%d_%H%M}.nc"
          },
          "spatial": {
            "crs": "EPSG:4326",
