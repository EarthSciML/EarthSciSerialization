{
  "category": "pde_simulation_pipeline",
  "version": "0.1-draft",
  "status": "phase-0-scaffold",
  "description": "Cross-language conformance for FULL-pipeline PDE simulations that require data loaders, per-species Dirichlet BCs, and nonlinear (mass-action) reactions (DESIGN.md). Sibling to `pde_simulation` (pre-discretized, linear, matrix-exponential-anchored). Here fixtures run the full lowering pipeline (reaction-gen -> template match -> operator_compose -> pointwise-lift -> scoped-`ic`) with loaded fields injected through each binding's data-Provider seam from the manifest `inputs`. Because the system is nonlinear there is no matrix-exponential `analytic`; the trajectory anchor is an independent reference integrator (see `reference/`). Phase 0 = contract + reference integrator + manifest scaffold + Gate G0; adapters, golden, and test-conformance.sh wiring are Phase 2.",
  "reference_binding": "julia",
  "reference_integrator": "reference/reference_integrator.py",
  "bindings_required": [
    "julia",
    "python",
    "rust"
  ],
  "scope_excluded": {
    "go": "rewrite-only port; no makearray lowering / simulator",
    "typescript": "rewrite-only port; no makearray lowering / simulator"
  },
  "tolerances": {
    "rhs_rtol": 1e-09,
    "rhs_atol": 1e-11,
    "traj_golden_rtol": 1e-06,
    "traj_golden_atol": 1e-09,
    "traj_analytic_rtol": 0.0001,
    "traj_analytic_atol": 1e-06
  },
  "trajectory_anchoring": {
    "mode": "reference",
    "note": "Nonlinear system: no matrix-exponential `trajectory.analytic`. Each binding's trajectory is gated against BOTH the Julia golden (`traj_golden` band) and the independent `trajectory.reference` (`traj_analytic` band, which absorbs integrator differences). The runner treats absent `trajectory.analytic` + present `trajectory.reference` as this category's sanctioned mode (DESIGN.md 6)."
  },
  "integrators": {
    "reference": {
      "algorithm": "DOPRI5 (hand-rolled, adaptive)",
      "rtol": 1e-11,
      "atol": 1e-13
    },
    "julia": {
      "algorithm": "Tsit5",
      "reltol": 1e-10,
      "abstol": 1e-12
    },
    "python": {
      "method": "RK45",
      "rtol": 1e-10,
      "atol": 1e-12
    },
    "rust": {
      "solver": "Erk",
      "reltol": 1e-10,
      "abstol": 1e-12
    }
  },
