              "i"
            ],
            "expr": {
              "op": "D",
              "args": [
                {
                  "op": "index",
                  "args": [
                    "u",
                    "i"
                  ]
                }
              ],
              "wrt": "t"
            },
            "ranges": {
              "i": [
                1,
                4
              ]
            }
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": [
              "i"
            ],
            "expr": {
              "op": "index",
              "args": [
                {
