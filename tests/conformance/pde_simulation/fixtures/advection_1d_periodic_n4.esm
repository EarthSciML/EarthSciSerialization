                      ]
                    ]
                  ],
                  "values": [
                    {
                      "op": "*",
                      "args": [
                        -4.0,
                        {
                          "op": "-",
                          "args": [
                            {
                              "op": "index",
                              "args": [
                                "u",
                                "i"
                              ]
                            },
                            {
