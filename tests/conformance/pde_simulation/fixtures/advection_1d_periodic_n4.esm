{
  "esm": "0.1.0",
  "metadata": {
    "name": "advection_1d_periodic_n4",
    "description": "Discretized 1-D linear advection (upwind, a=1, dx=0.25, nu=4) on 4 cells, periodic. First-derivative stencil with a single-cell left makearray region wrapping u[0]->u[N]. du[i]/dt = -nu (u[i]-u[i-1]).",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "pde",
      "simulation",
      "periodic",
      "advection"
    ]
  },
  "models": {
    "Advect1D": {
      "tolerance": {
        "rel": 0.001,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": [
            "i"
          ]
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "aggregate",
            "args": [],
