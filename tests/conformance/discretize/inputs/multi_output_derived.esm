{
  "esm": "0.2.0",
  "metadata": {
    "name": "multi_output_derived",
    "description": "RFC §7.9 OQ3 (ess-qxs): derived (non-stencil) outputs. A MultiOutputStencilScheme with two stencil outputs (q_L, q_R) and one derived output (da = q_R - q_L, the parabola width) consumed via trigger 1 (directly-consumed path). Verifies that derived outputs are emitted as pointwise arrayop equations referencing stencil outputs by their mangled names."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 8, "periodic": true, "spacing": "uniform" }
      ]
    }
  },
  "discretizations": {
    "recon_with_derived": {
      "kind": "multi_output_stencil",
      "applies_to": { "op": "reconstruct", "args": ["$q"], "dim": "$x" },
      "grid_family": "cartesian",
      "outputs": ["q_L", "q_R", "da"],
      "stencil": {
        "q_L": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 }
        ],
        "q_R": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  1 }, "coeff": 0.5 }
        ]
      },
      "derived": {
        "da": { "op": "-", "args": ["q_R", "q_L"] }
      },
      "primary": "q_L",
      "emits_location": "face",
      "description": "Reconstruction scheme with stencil outputs q_L and q_R plus derived output da = q_R - q_L. Trigger 1: a use: rule matches reconstruct($q, dim=$x) and the primary (q_L) substitutes at the match site."
    }
  },
  "rules": [
    {
      "name": "recon_rule",
      "pattern": { "op": "reconstruct", "args": ["$q"], "dim": "$x" },
      "use": "recon_with_derived"
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "q": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["q"], "wrt": "t" },
          "rhs": { "op": "reconstruct", "args": ["q"], "dim": "i" }
        }
      ]
    }
  }
}
