{
  "esm": "0.2.0",
  "metadata": {
    "name": "ic_arrayop",
    "description": "IC arrayop engine: initialization_equations with a spatial RHS are materialized into arrayop form with coord substitution x→index(coord_x,i) (ess-tt6). Two models: M_uniform (spacing=uniform) and M_nonuniform (spacing=nonuniform) — both produce identical discretize output since coord_x is always resolved via const_array at evaluation time."
  },
  "grids": {
    "g_uniform": {
      "family": "cartesian",
      "dimensions": [
        {"name": "x", "size": 4, "periodic": false, "spacing": "uniform"}
      ]
    },
    "g_nonuniform": {
      "family": "cartesian",
      "dimensions": [
        {"name": "x", "size": 4, "periodic": false, "spacing": "nonuniform"}
      ]
    }
  },
  "models": {
    "M_uniform": {
      "grid": "g_uniform",
      "variables": {
        "u": {"type": "state", "shape": ["x"]}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "-", "args": ["u"]}
        }
      ],
      "initialization_equations": [
        {
          "lhs": "u",
          "rhs": {"op": "sin", "args": [{"op": "*", "args": [{"op": "pi", "args": []}, "x"]}]}
        }
      ]
    },
    "M_nonuniform": {
      "grid": "g_nonuniform",
      "variables": {
        "u": {"type": "state", "shape": ["x"]}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "-", "args": ["u"]}
        }
      ],
      "initialization_equations": [
        {
          "lhs": "u",
          "rhs": {"op": "sin", "args": [{"op": "*", "args": [{"op": "pi", "args": []}, "x"]}]}
        }
      ]
    }
  }
}
