{
  "esm": "0.2.0",
  "metadata": {
    "name": "multi_output_demand_driven",
    "description": "RFC §7.9 trigger 2: a Scheme consumer with requires fires a provider-only MultiOutputStencilScheme (primary=null) via the demand-driven path. The provider emits two observed equations (q_left_edge__q__i, q_right_edge__q__i) and the consumer coefficient substitutes the mangled names. Grid is periodic so E_SCHEME_BOUNDED_DIM does not fire. Bead ess-699 acceptance fixture."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 8, "periodic": true, "spacing": "uniform" }
      ]
    }
  },
  "discretizations": {
    "ppm_recon": {
      "kind": "multi_output_stencil",
      "applies_to": { "op": "reconstruct", "args": ["$q"], "dim": "$x" },
      "grid_family": "cartesian",
      "outputs": ["q_left_edge", "q_right_edge"],
      "emits_location": "face",
      "stencil": {
        "q_left_edge": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 }
        ],
        "q_right_edge": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  1 }, "coeff": 0.5 }
        ]
      },
      "description": "Provider-only PPM edge reconstruction (primary=null). Fires only via demand-driven path when a consumer requires one of its outputs."
    },
    "ppm_flux": {
      "kind": "stencil",
      "applies_to": { "op": "flux", "args": ["$q", "$c"], "dim": "$x" },
      "grid_family": "cartesian",
      "requires": {
        "q_left_edge":  "ppm_recon#q_left_edge",
        "q_right_edge": "ppm_recon#q_right_edge"
      },
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
          "coeff": {
            "op": "-",
            "args": [
              { "op": "*", "args": ["$c", "q_right_edge"] },
              { "op": "*", "args": ["$c", "q_left_edge"] }
            ]
          }
        }
      ],
      "description": "PPM flux scheme consuming left/right edges from ppm_recon via demand-driven provider mechanism (RFC §7.9 trigger 2)."
    }
  },
  "rules": [
    {
      "name": "flux_rule",
      "pattern": { "op": "flux", "args": ["$q", "$c"], "dim": "$x" },
      "use": "ppm_flux"
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "q": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        },
        "c": {
          "type": "parameter",
          "default": 1.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["q"], "wrt": "t" },
          "rhs": { "op": "flux", "args": ["q", "c"], "dim": "i" }
        }
      ]
    }
  }
}
