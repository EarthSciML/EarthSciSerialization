{
  "esm": "0.2.0",
  "metadata": {
    "name": "nonuniform_1d_diffusion",
    "description": "1D diffusion on a geometric-progression grid. Exercises §6.2.1 auto-index rewrite: bare metric-array name 'dz' in the scheme's stencil coefficients is rewritten to index(dz, i) by expand_scheme. The explicit-neighbor references dz[i+1] (already index nodes) are preserved unchanged."
  },
  "grids": {
    "gz": {
      "family": "cartesian",
      "dimensions": [
        {"name": "z", "size": 8, "periodic": true, "spacing": "nonuniform"}
      ],
      "metric_arrays": {
        "dz": {
          "rank": 1,
          "dim": "z",
          "generator": {
            "kind": "expression",
            "expr": {"op": "*", "args": [1.0, {"op": "^", "args": [1.2, "i"]}]}
          }
        }
      }
    }
  },
  "discretizations": {
    "d2_nonuniform_z": {
      "applies_to": {"op": "laplacian", "args": ["$u"], "dim": "$z"},
      "grid_family": "cartesian",
      "combine": "+",
      "stencil": [
        {
          "selector": {"kind": "cartesian", "axis": "$z", "offset": -1},
          "coeff": {
            "op": "/",
            "args": [2, {
              "op": "*",
              "args": [
                "dz",
                {"op": "+", "args": [
                  "dz",
                  {"op": "index", "args": ["dz", {"op": "+", "args": ["i", 1]}]}
                ]}
              ]
            }]
          }
        },
        {
          "selector": {"kind": "cartesian", "axis": "$z", "offset": 0},
          "coeff": {
            "op": "neg",
            "args": [{
              "op": "/",
              "args": [2, {
                "op": "*",
                "args": [
                  "dz",
                  {"op": "index", "args": ["dz", {"op": "+", "args": ["i", 1]}]}
                ]
              }]
            }]
          }
        },
        {
          "selector": {"kind": "cartesian", "axis": "$z", "offset": 1},
          "coeff": {
            "op": "/",
            "args": [2, {
              "op": "*",
              "args": [
                {"op": "index", "args": ["dz", {"op": "+", "args": ["i", 1]}]},
                {"op": "+", "args": [
                  "dz",
                  {"op": "index", "args": ["dz", {"op": "+", "args": ["i", 1]}]}
                ]}
              ]
            }]
          }
        }
      ]
    }
  },
  "rules": [
    {
      "name": "d2_nonuniform_z_rule",
      "pattern": {"op": "laplacian", "args": ["$u"], "dim": "$z"},
      "use": "d2_nonuniform_z"
    }
  ],
  "models": {
    "M": {
      "grid": "gz",
      "variables": {
        "u": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "laplacian", "args": ["u"], "dim": "z"}
        }
      ]
    }
  }
}
