{
  "esm": "0.2.0",
  "metadata": {
    "name": "multi_output_bounded_face",
    "description": "RFC §7.9 OQ1: multi_output_stencil with face-located outputs on a bounded (non-periodic) dimension. A size-8 bounded grid; face extent is n+1=9 along the stencil axis. Exercises the staggered-range path via demand-driven trigger (ess-z31 acceptance fixture)."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 8, "periodic": false, "spacing": "uniform" }
      ]
    }
  },
  "discretizations": {
    "ppm_recon": {
      "kind": "multi_output_stencil",
      "applies_to": { "op": "reconstruct", "args": ["$q"], "dim": "$x" },
      "grid_family": "cartesian",
      "outputs": ["q_left_edge", "q_right_edge"],
      "emits_location": "face",
      "stencil": {
        "q_left_edge": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 }
        ],
        "q_right_edge": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  1 }, "coeff": 0.5 }
        ]
      },
      "description": "Provider-only PPM edge reconstruction on a bounded grid (primary=null). Fires via demand-driven path; OQ1 stagger: face extent = n+1 = 9 on bounded dimension i."
    },
    "ppm_flux": {
      "kind": "stencil",
      "applies_to": { "op": "flux", "args": ["$q", "$c"], "dim": "$x" },
      "grid_family": "cartesian",
      "requires": {
        "q_left_edge":  "ppm_recon#q_left_edge",
        "q_right_edge": "ppm_recon#q_right_edge"
      },
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
          "coeff": {
            "op": "-",
            "args": [
              { "op": "*", "args": ["$c", "q_right_edge"] },
              { "op": "*", "args": ["$c", "q_left_edge"] }
            ]
          }
        }
      ],
      "description": "PPM flux scheme consuming left/right edges from ppm_recon via demand-driven provider (RFC §7.9 trigger 2). Bounded grid: OQ1 acceptance fixture."
    }
  },
  "rules": [
    {
      "name": "flux_rule",
      "pattern": { "op": "flux", "args": ["$q", "$c"], "dim": "$x" },
      "use": "ppm_flux"
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "q": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        },
        "c": {
          "type": "parameter",
          "default": 1.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["q"], "wrt": "t" },
          "rhs": { "op": "flux", "args": ["q", "c"], "dim": "i" }
        }
      ]
    }
  }
}
