{
  "esm": "0.2.0",
  "metadata": {
    "name": "multi_output_direct_consumed",
    "description": "RFC §7.9 trigger 1: a use:-rule fires on a MultiOutputStencilScheme with non-null primary. The matched expression is rewritten to index(primary_mangled, i) and two observed equations (q_lo__q__i, q_hi__q__i) are injected. Grid is periodic so E_SCHEME_BOUNDED_DIM does not fire. Bead ess-ebe acceptance fixture."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 8, "periodic": true, "spacing": "uniform" }
      ]
    }
  },
  "discretizations": {
    "recon1d": {
      "kind": "multi_output_stencil",
      "applies_to": { "op": "recon", "args": ["$q"], "dim": "$x" },
      "grid_family": "cartesian",
      "outputs": ["q_lo", "q_hi"],
      "emits_location": "face",
      "primary": "q_lo",
      "stencil": {
        "q_lo": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 }
        ],
        "q_hi": [
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  0 }, "coeff": 0.5 },
          { "selector": { "kind": "cartesian", "axis": "$x", "offset":  1 }, "coeff": 0.5 }
        ]
      }
    }
  },
  "rules": [
    {
      "name": "recon1d_rule",
      "pattern": { "op": "recon", "args": ["$q"], "dim": "$x" },
      "use": "recon1d"
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "q": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["q"], "wrt": "t" },
          "rhs": { "op": "recon", "args": ["q"], "dim": "i" }
        }
      ]
    }
  }
}
