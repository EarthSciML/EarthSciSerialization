{
  "esm": "0.2.0",
  "metadata": {
    "name": "stencil_gen_fornberg_nonuniform",
    "description": "Exercises stencil_gen with method=fornberg, spacing=from_grid on a non-uniform cartesian grid (ess-d0a). The loader generates stencil entries referencing per-location float weight arrays __stgfw_z_2_n1 and __stgfw_z_2_p1; expand_scheme auto-registers these as metric arrays so _rewrite_metric_refs indexes them to index(__stgfw_z_2_n1, i) etc. Accuracy order 2, offsets [-1, +1]."
  },
  "grids": {
    "gz": {
      "family": "cartesian",
      "dimensions": [
        {"name": "z", "size": 6, "periodic": true, "spacing": "nonuniform"}
      ]
    }
  },
  "discretizations": {
    "centered_2nd_nonuniform_z": {
      "applies_to": {"op": "grad", "args": ["$u"], "dim": "$z"},
      "grid_family": "cartesian",
      "combine": "+",
      "stencil_gen": {
        "method": "fornberg",
        "deriv_order": 1,
        "accuracy_order": 2,
        "stagger": "centered",
        "axis": "$z",
        "spacing": "from_grid"
      }
    }
  },
  "rules": [
    {
      "name": "centered_2nd_nonuniform_z_rule",
      "pattern": {"op": "grad", "args": ["$u"], "dim": "$z"},
      "use": "centered_2nd_nonuniform_z"
    }
  ],
  "models": {
    "M": {
      "grid": "gz",
      "variables": {
        "u": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "grad", "args": ["u"], "dim": "z"}
        }
      ]
    }
  }
}
