{
  "esm": "0.2.0",
  "metadata": {
    "name": "interface_bc_lowering"
  },
  "grids": {
    "g1": {
      "family": "cartesian",
      "dimensions": [
        { "name": "x", "size": 4, "periodic": false, "spacing": "uniform" }
      ]
    }
  },
  "rules": [
    {
      "name": "interface_bc_xmax",
      "pattern": { "op": "bc", "fn": "interface", "dim": "xmax", "args": ["$var", "$coupled"] },
      "replacement": { "op": "index", "args": ["$coupled", 1] }
    },
    {
      "name": "interface_bc_xmin",
      "pattern": { "op": "bc", "fn": "interface", "dim": "xmin", "args": ["$var", "$coupled"] },
      "where": [
        { "guard": "var_has_grid", "pvar": "$var", "grid": "$g" },
        { "guard": "bind_side_dim_size", "pvar": "$N", "grid": "$g", "side": "xmin" }
      ],
      "replacement": { "op": "index", "args": ["$coupled", "$N"] }
    }
  ],
  "models": {
    "M": {
      "grid": "g1",
      "variables": {
        "u": { "type": "state", "default": 0.0, "units": "1" },
        "v": { "type": "state", "default": 0.0, "units": "1" }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["u"], "wrt": "t" },
          "rhs": 0.0
        },
        {
          "lhs": { "op": "D", "args": ["v"], "wrt": "t" },
          "rhs": 0.0
        }
      ],
      "boundary_conditions": {
        "u_interface_xmax": {
          "variable": "u",
          "side": "xmax",
          "kind": "interface",
          "coupled_variable": "v"
        },
        "v_interface_xmin": {
          "variable": "v",
          "side": "xmin",
          "kind": "interface",
          "coupled_variable": "u"
        }
      }
    }
  }
}
