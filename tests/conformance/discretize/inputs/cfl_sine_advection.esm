{
  "esm": "0.2.0",
  "metadata": {
    "name": "cfl_sine_advection",
    "description": "1D upwind scalar advection on a periodic Cartesian grid. Exercises rule boundary_policy and time-varying bindings (RFC §5.2.8): velocity is per-cell, dt is per-step, dx is static. The rule rewrites grad(u, dim=i) to a backward-difference upwind stencil that references velocity and dx as bare bindings. The discretized model carries the rewritten equation; the rules array preserves boundary_policy and bindings verbatim across the discretize pipeline."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 16, "periodic": true, "spacing": "uniform" }
      ]
    }
  },
  "rules": [
    {
      "name": "upwind_advect_x",
      "pattern": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "boundary_policy": "periodic",
      "bindings": {
        "dt":       { "kind": "per_step", "description": "Adaptive timestep, set from CFL <= 0.5" },
        "velocity": { "kind": "per_cell", "description": "Cell-centered advected wind speed" },
        "dx":       { "kind": "static",   "default": 0.0625, "description": "Uniform grid spacing 1/16" }
      },
      "replacement": {
        "op": "/",
        "args": [
          {
            "op": "*",
            "args": [
              "velocity",
              {
                "op": "+",
                "args": [
                  "$u",
                  {
                    "op": "-",
                    "args": [
                      { "op": "index", "args": ["$u", { "op": "-", "args": ["$x", 1] }] }
                    ]
                  }
                ]
              }
            ]
          },
          "dx"
        ]
      }
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "u": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["u"], "wrt": "t" },
          "rhs": { "op": "grad", "args": ["u"], "dim": "i" }
        }
      ]
    }
  }
}
