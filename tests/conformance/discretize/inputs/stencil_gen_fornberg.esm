{
  "esm": "0.2.0",
  "metadata": {
    "name": "stencil_gen_fornberg",
    "description": "Exercises stencil_gen with method=fornberg, deriv_order=1, accuracy_order=4, stagger=centered on a uniform cartesian grid (ess-bq1). The loader expands the declarative descriptor into the same 4-point stencil as the hand-authored centered_arbitrary_order_uniform.esm: weights [+1,-8,+8,-1]/(12*dx) at offsets [-2,-1,+1,+2]."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        { "name": "i", "size": 8, "periodic": true, "spacing": "uniform" }
      ]
    }
  },
  "discretizations": {
    "centered_4th_grad_gen": {
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx^4)",
      "stencil_gen": {
        "method": "fornberg",
        "deriv_order": 1,
        "accuracy_order": 4,
        "stagger": "centered",
        "axis": "$x",
        "spacing": "dx"
      }
    }
  },
  "rules": [
    {
      "name": "centered_4th_grad_gen_rule",
      "pattern": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "use": "centered_4th_grad_gen"
    }
  ],
  "models": {
    "M": {
      "grid": "gx",
      "variables": {
        "u": {
          "type": "state",
          "default": 0.0,
          "units": "1",
          "shape": ["i"],
          "location": "cell_center"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["u"], "wrt": "t" },
          "rhs": { "op": "grad", "args": ["u"], "dim": "i" }
        }
      ]
    }
  }
}
