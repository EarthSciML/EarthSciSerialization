{
  "esm": "0.4.0",
  "metadata": {
    "name": "function_tables_linear_conformance",
    "description": "Single-output 1-axis linear function table — the canonical 1-D blend (esm-spec §9.5.6).",
    "authors": ["esm-hid conformance"]
  },
  "function_tables": {
    "sigma_O3_298": {
      "description": "O3 absorption cross-section vs. wavelength bin index, T=298 K (synthetic).",
      "axes": [
        {"name": "lambda_idx", "values": [1, 2, 3, 4, 5, 6, 7, 8]}
      ],
      "interpolation": "linear",
      "out_of_bounds": "clamp",
      "data": [1.10e-17, 1.00e-17, 9.50e-18, 8.70e-18, 7.90e-18, 7.00e-18, 6.10e-18, 5.20e-18]
    }
  },
  "models": {
    "M": {
      "variables": {
        "k_O3":  {"type": "state",     "default": 0.0},
        "lambda":{"type": "parameter", "default": 4.5}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["k_O3"], "wrt": "t"},
          "rhs": {
            "op": "table_lookup",
            "table": "sigma_O3_298",
            "axes": {"lambda_idx": "lambda"},
            "args": []
          }
        }
      ]
    }
  }
}
