{
  "esm": "0.4.0",
  "metadata": {
    "name": "function_tables_bilinear_conformance",
    "description": "Multi-output 2-axis bilinear function table with named outputs (esm-spec §9.5.6).",
    "authors": ["esm-hid conformance"]
  },
  "function_tables": {
    "F_actinic": {
      "description": "Actinic flux F vs. (P, cos_sza) for three photolysis species (synthetic).",
      "axes": [
        {"name": "P",       "units": "Pa", "values": [10.0, 100.0, 1000.0]},
        {"name": "cos_sza",                "values": [0.1, 0.5, 1.0]}
      ],
      "interpolation": "bilinear",
      "out_of_bounds": "clamp",
      "outputs": ["NO2", "O3", "HCHO"],
      "data": [
        [[1.0, 1.5, 2.0], [1.1, 1.6, 2.1], [1.2, 1.7, 2.2]],
        [[2.0, 2.5, 3.0], [2.1, 2.6, 3.1], [2.2, 2.7, 3.2]],
        [[3.0, 3.5, 4.0], [3.1, 3.6, 4.1], [3.2, 3.7, 4.2]]
      ]
    }
  },
  "models": {
    "M": {
      "variables": {
        "j_NO2":  {"type": "state",     "default": 0.0},
        "j_O3":   {"type": "state",     "default": 0.0},
        "P_atm":  {"type": "parameter", "default": 100.0},
        "cos_sza":{"type": "parameter", "default": 0.5}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["j_NO2"], "wrt": "t"},
          "rhs": {
            "op": "table_lookup",
            "table": "F_actinic",
            "axes": {"P": "P_atm", "cos_sza": "cos_sza"},
            "output": "NO2",
            "args": []
          }
        },
        {
          "lhs": {"op": "D", "args": ["j_O3"], "wrt": "t"},
          "rhs": {
            "op": "table_lookup",
            "table": "F_actinic",
            "axes": {"P": "P_atm", "cos_sza": "cos_sza"},
            "output": 1,
            "args": []
          }
        }
      ]
    }
  }
}
