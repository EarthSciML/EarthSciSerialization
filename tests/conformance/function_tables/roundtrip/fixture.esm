{
  "esm": "0.4.0",
  "metadata": {
    "name": "function_tables_roundtrip_conformance",
    "description": "Mixed file: a function_tables block plus a hand-written inline-const interp.linear lookup. Round-trip MUST preserve both forms verbatim — no auto-promotion of the inline-const lookup into a table_lookup, no demotion of the table_lookup into an inline-const lookup. Pinned by esm-spec §9.5.4.",
    "authors": ["esm-hid conformance"]
  },
  "function_tables": {
    "sigma_O3": {
      "axes": [
        {"name": "lambda_idx", "values": [1.0, 2.0, 3.0, 4.0]}
      ],
      "interpolation": "linear",
      "data": [1.1, 1.0, 0.95, 0.87]
    }
  },
  "models": {
    "M": {
      "variables": {
        "k_table":   {"type": "state", "default": 0.0},
        "k_inline":  {"type": "state", "default": 0.0},
        "lambda":    {"type": "parameter", "default": 2.5}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["k_table"], "wrt": "t"},
          "rhs": {
            "op": "table_lookup",
            "table": "sigma_O3",
            "axes": {"lambda_idx": "lambda"},
            "args": []
          }
        },
        {
          "lhs": {"op": "D", "args": ["k_inline"], "wrt": "t"},
          "rhs": {
            "op": "fn",
            "name": "interp.linear",
            "args": [
              {"op": "const", "args": [], "value": [1.1, 1.0, 0.95, 0.87]},
              {"op": "const", "args": [], "value": [1.0, 2.0, 3.0, 4.0]},
              "lambda"
            ]
          }
        }
      ]
    }
  }
