{
  "category": "grid_conformance",
  "version": "1.0",
  "family": "cartesian",
  "description": "In-tree example manifest used by run-grid-conformance.py --self-test (gt-usme). Exercises every query op so the runner's plumbing is covered. Real family suites live in EarthSciDiscretizations/conformance/grids/<family>/.",
  "tolerances": {
    "default_rel": 1e-14,
    "per_field": {
      "dx": 1e-12
    }
  },
  "bindings_required": ["julia", "rust"],
  "bindings_optional": ["python", "typescript"],
  "fixtures": [
    {
      "id": "cart_minimal",
      "tags": ["smoke", "self_test"],
      "description": "Trivial 4x4x4 cartesian grid exercised through every accessor op.",
      "grid": {
        "source": "generator",
        "family": "cartesian",
        "opts": {
          "nx": 4,
          "ny": 4,
          "nz": 4,
          "extent": [[0.0, 0.0, 0.0], [1.0, 1.0, 1.0]]
        }
      },
      "queries": [
        { "id": "esm_sha",      "op": "to_esm_sha" },
        { "id": "ctr_origin",   "op": "cell_center", "args": [0, 0, 0] },
        { "id": "nbrs_of_5",    "op": "neighbors",   "args": [5] },
        { "id": "dx_at_0_0",    "op": "metric_eval", "args": ["dx", 0, 0] }
      ]
    }
  ]
}
