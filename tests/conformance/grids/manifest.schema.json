{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ctessum/EarthSciSerialization/tests/conformance/grids/manifest.schema.json",
  "title": "Grid Conformance Manifest",
  "description": "Schema for ESD-side family-specific grid conformance suites consumed by scripts/run-grid-conformance.py (gt-usme).",
  "type": "object",
  "required": ["category", "version", "fixtures"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "const": "grid_conformance"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "family": {
      "type": "string",
      "description": "Family name (informational only; the runner is family-agnostic).",
      "enum": [
        "cartesian",
        "lat_lon",
        "stretched_lat_lon",
        "cubed_sphere",
        "stretched_cubed_sphere",
        "mpas",
        "duo",
        "arakawa",
        "vertical"
      ]
    },
    "description": {
      "type": "string"
    },
    "tolerances": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_rel": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1e-14
        },
        "default_abs": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "per_field": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "bindings_required": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["julia", "python", "rust", "typescript", "go"]
      },
      "uniqueItems": true,
      "default": []
    },
    "bindings_optional": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["julia", "python", "rust", "typescript", "go"]
      },
      "uniqueItems": true,
      "default": []
    },
    "reference_binding": {
      "type": "string",
      "enum": ["julia", "python", "rust", "typescript", "go"],
      "description": "Binding whose output is the reference for ULP ties (GRIDS_API §4.3). Defaults to julia.",
      "default": "julia"
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/Fixture"}
    }
  },
  "$defs": {
    "Fixture": {
      "type": "object",
      "required": ["id", "grid"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Stable identifier; used in result diffs and CI output."
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "description": {"type": "string"},
        "sha_check": {
          "type": "boolean",
          "default": true,
          "description": "If false, skip the byte-identical canonical SHA check and rely solely on query-point comparison."
        },
        "grid": {"$ref": "#/$defs/GridSource"},
        "queries": {
          "type": "array",
          "items": {"$ref": "#/$defs/Query"},
          "default": []
        },
        "tolerances": {
          "$ref": "#/properties/tolerances",
          "description": "Per-fixture override for the suite-level tolerances."
        }
      }
    },
    "GridSource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["source", "family", "opts"],
          "additionalProperties": false,
          "properties": {
            "source": {"const": "generator"},
            "family": {"type": "string"},
            "opts": {
              "type": "object",
              "description": "Options forwarded verbatim to the binding's grid generator (see GRIDS_API §2.7)."
            }
          }
        },
        {
          "type": "object",
          "required": ["source", "path"],
          "additionalProperties": false,
          "properties": {
            "source": {"const": "file"},
            "path": {
              "type": "string",
              "description": "Path relative to the manifest's directory. Must point at a §6-schema-valid .esm grid document."
            }
          }
        }
      ]
    },
    "Query": {
      "type": "object",
      "required": ["id", "op"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "op": {
          "type": "string",
          "enum": ["to_esm_sha", "cell_center", "neighbors", "metric_eval"]
        },
        "args": {
          "type": "array",
          "default": []
        },
        "tolerance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rel": {"type": "number", "exclusiveMinimum": 0},
            "abs": {"type": "number", "minimum": 0}
          },
          "description": "Per-query tolerance override (highest precedence)."
        }
      }
    }
  }
}
