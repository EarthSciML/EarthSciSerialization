{
  "esm": "0.6.0",
  "metadata": {
    "name": "LegacyLoaderRegriddingRejected",
    "description": "Cross-binding REJECTION fixture (ess-v9a.7). A pre-0.7.0 loader file that still carries the removed DataLoader.regridding block. Regridding was removed from DataLoader in the v0.7.0 pure-I/O hard break (RFC pure-io-data-loaders 4.1); it is now a per-variable Model.regrid concern. Every binding MUST reject this at load with the named, version-keyed diagnostic data_loader_regridding_removed (it also fails JSON-Schema additionalProperties:false). Migrate by deleting 'regridding' and moving the per-variable choice to the owning model's Model.regrid map.",
    "authors": [
      "Test Suite"
    ],
    "tags": [
      "migration",
      "0_6_to_0_7",
      "rejection",
      "pure-io",
      "ess-v9a.7"
    ]
  },
  "data_loaders": {
    "weather": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/weather/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT1H",
        "file_period": "PT1H",
        "records_per_file": 1
      },
      "regridding": {
        "method": "conservative",
        "extrapolation": "clamp",
        "fill_value": 0.0
      },
      "variables": {
        "temperature": {
          "file_variable": "T2",
          "units": "K",
          "description": "2 m air temperature read from the source dataset"
        }
      }
    }
  }
}
