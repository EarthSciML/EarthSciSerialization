{
  "esm": "0.6.0",
  "metadata": {
    "name": "LegacyLoaderSpatialRejected",
    "description": "Cross-binding REJECTION fixture (ess-v9a.7). A pre-0.7.0 loader file that still carries the removed DataLoader.spatial block (the former DataLoaderSpatial). The loader's native-grid description was removed from DataLoader in the v0.7.0 pure-I/O hard break (RFC pure-io-data-loaders 4.1); the native grid is now a GDD Grid under 'grid'. Every binding MUST reject this at load with the named, version-keyed diagnostic data_loader_spatial_removed (it also fails JSON-Schema additionalProperties:false). Migrate by replacing 'spatial' with a GDD Grid under 'grid'.",
    "authors": [
      "Test Suite"
    ],
    "tags": [
      "migration",
      "0_6_to_0_7",
      "rejection",
      "pure-io",
      "ess-v9a.7"
    ]
  },
  "data_loaders": {
    "weather": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/weather/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT1H",
        "file_period": "PT1H",
        "records_per_file": 1
      },
      "spatial": {
        "grid_mapping": "lambert_conformal",
        "crs": "EPSG:4326",
        "resolution": [0.25, 0.25],
        "interpolation": "bilinear"
      },
      "variables": {
        "temperature": {
          "file_variable": "T2",
          "units": "K",
          "description": "2 m air temperature read from the source dataset"
        }
      }
    }
  }
}
