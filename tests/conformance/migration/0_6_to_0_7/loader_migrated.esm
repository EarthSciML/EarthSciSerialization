{
  "esm": "0.7.0",
  "metadata": {
    "name": "MigratedPureIoLoader",
    "description": "Cross-binding ACCEPTANCE fixture (ess-v9a.7): the post-migration 0.7.0 shape of the rejection fixtures in this directory. A pure-I/O grid loader whose native grid is a GDD Grid under 'grid' (replacing the removed 'spatial' block) and which carries no 'regridding' (now a per-variable Model.regrid concern). Every binding MUST load this file without error — this is the positive counterpart proving the v0.7.0 bump accepts migrated files.",
    "authors": [
      "Test Suite"
    ],
    "tags": [
      "migration",
      "0_6_to_0_7",
      "accepted",
      "pure-io",
      "gdd-grid",
      "ess-v9a.7"
    ]
  },
  "data_loaders": {
    "weather": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/weather/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT1H",
        "file_period": "PT1H",
        "records_per_file": 1
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": "n_lon",
            "spacing": "uniform"
          },
          "lat": {
            "n": "n_lat",
            "spacing": "uniform"
          }
        },
        "parameters": {
          "n_lon": {
            "description": "lon cell count, resolved from the source dataset at load time"
          },
          "n_lat": {
            "description": "lat cell count, resolved from the source dataset at load time"
          }
        }
      },
      "variables": {
        "temperature": {
          "file_variable": "T2",
          "units": "K",
          "description": "2 m air temperature read from the source dataset"
        }
      }
    }
  }
}
