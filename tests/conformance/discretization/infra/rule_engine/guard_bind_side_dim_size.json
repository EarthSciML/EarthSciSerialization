{
  "id": "guard_bind_side_dim_size",
  "description": "Guard bind_side_dim_size (§5.2.4). Binds $N to the integer cell count for the spatial dim matching the side. Grid g1: spatial_dims=[i,j], dim_sizes={i:4,j:8}. Side ymax maps to axis index 1 → dim j → N=8.",
  "context": {
    "grids": {
      "g1": {
        "spatial_dims": ["i", "j"],
        "dim_sizes": {"i": 4, "j": 8}
      }
    },
    "variables": {
      "u": {"grid": "g1"}
    }
  },
  "rules": [
    {
      "name": "bc_dim_size",
      "pattern": {"op": "bc", "args": ["$u"], "fn": "interface", "dim": "$side"},
      "where": [
        {"guard": "var_has_grid", "pvar": "$u", "grid": "$g"},
        {"guard": "bind_side_dim_size", "pvar": "$N", "side": "$side", "grid": "$g"}
      ],
      "replacement": {"op": "index", "args": ["$u", "$N"]}
    }
  ],
  "input": {"op": "bc", "args": ["u"], "fn": "interface", "dim": "ymax"},
  "expect": {
    "kind": "output",
    "canonical_json": "{\"args\":[\"u\",8],\"op\":\"index\"}"
  },
  "tags": ["guard", "bind_side_dim_size"]
}
