{
  "id": "region_mask_field",
  "description": "region.mask_field scope (RFC §5.2.7). Rule fires only at query points where the named loader-backed mask is truthy. 'is_land' is truthy at (i=0, j=0) and (i=1, j=0); at query_point (i=0, j=0) the rule fires.",
  "context": {
    "query_point": {"i": 0, "j": 0},
    "mask_fields": {
      "is_land": [
        {"i": 0, "j": 0},
        {"i": 1, "j": 0}
      ]
    }
  },
  "rules": [
    {
      "name": "zero_on_land",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "mask_field", "field": "is_land"},
      "replacement": 0
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "output",
    "canonical_json": "0"
  },
  "requires_per_point_scope": true,
  "tags": ["region", "mask_field"]
}
