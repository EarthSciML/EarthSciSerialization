{
  "id": "guard_bind_side_axis",
  "description": "Guard bind_side_axis (§5.2.4). Binds $axis to the canonical axis label ('x'/'y'/'z') for the matched side. Tests xmin→x, ymax→y.",
  "context": {
    "grids": {
      "g1": {
        "spatial_dims": ["i", "j"],
        "dim_sizes": {"i": 4, "j": 8}
      }
    },
    "variables": {
      "u": {"grid": "g1"}
    }
  },
  "rules": [
    {
      "name": "bc_axis_tag",
      "pattern": {"op": "bc", "args": ["$u"], "fn": "dirichlet", "dim": "$side"},
      "where": [
        {"guard": "bind_side_axis", "pvar": "$axis", "side": "$side"}
      ],
      "replacement": {"op": "axis_marker", "args": ["$u", "$axis"]}
    }
  ],
  "input": {"op": "bc", "args": ["u"], "fn": "dirichlet", "dim": "xmin"},
  "expect": {
    "kind": "output",
    "canonical_json": "{\"args\":[\"u\",\"x\"],\"op\":\"axis_marker\"}"
  },
  "tags": ["guard", "bind_side_axis"]
}
