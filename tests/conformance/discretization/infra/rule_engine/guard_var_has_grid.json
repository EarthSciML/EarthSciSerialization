{
  "id": "guard_var_has_grid",
  "description": "Guard var_has_grid (§5.2.4). Rule fires only when the matched variable is bound to the given grid. Context supplies variable→grid metadata.",
  "context": {
    "grids": {
      "atmos_rect": {
        "spatial_dims": ["x", "y"]
      }
    },
    "variables": {
      "T": {"grid": "atmos_rect"},
      "S": {"grid": "ocean_curv"}
    }
  },
  "rules": [
    {
      "name": "drop_on_atmos",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "where":       [
        {"guard": "var_has_grid", "pvar": "$u", "grid": "atmos_rect"}
      ],
      "replacement": "$u"
    }
  ],
  "input": {
    "op": "+",
    "args": [
      {"op": "grad", "args": ["T"], "dim": "x"},
      {"op": "grad", "args": ["S"], "dim": "x"}
    ]
  },
  "expect": {
    "kind": "output",
    "canonical_json": "{\"args\":[\"T\",{\"args\":[\"S\"],\"dim\":\"x\",\"op\":\"grad\"}],\"op\":\"+\"}"
  },
  "tags": ["guard", "var_has_grid"]
}
