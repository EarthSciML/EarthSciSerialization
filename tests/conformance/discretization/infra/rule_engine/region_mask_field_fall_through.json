{
  "id": "region_mask_field_fall_through",
  "description": "region.mask_field fall-through (RFC §5.2.7). Query point (i=2, j=0) is NOT in the 'is_land' mask, so the scoped rule does not fire; the next rule (unscoped) fires. Verifies fall-through preserves rule-ordering semantics for loader-backed masks.",
  "context": {
    "query_point": {"i": 2, "j": 0},
    "mask_fields": {
      "is_land": [
        {"i": 0, "j": 0},
        {"i": 1, "j": 0}
      ]
    }
  },
  "rules": [
    {
      "name": "zero_on_land",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "mask_field", "field": "is_land"},
      "replacement": 0
    },
    {
      "name": "fallback_identity",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "replacement": "$u"
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "output",
    "canonical_json": "\"T\""
  },
  "requires_per_point_scope": true,
  "tags": ["region", "mask_field", "fall_through"]
}
