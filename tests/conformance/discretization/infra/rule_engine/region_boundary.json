{
  "id": "region_boundary",
  "description": "region.boundary scope (RFC §5.2.7). Rule fires only at the named boundary; 'xmin' on grid g1 resolves to index i == dim_bounds['x'][0] via spatial_dims position. At query_point i=0 (grid lo bound) the rule fires.",
  "context": {
    "grid_name": "g1",
    "grids": {
      "g1": {
        "spatial_dims": ["x", "y"],
        "dim_bounds": {"x": [0, 9], "y": [0, 9]}
      }
    },
    "query_point": {"i": 0, "j": 3}
  },
  "rules": [
    {
      "name": "zero_at_xmin",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "boundary", "side": "xmin"},
      "replacement": 0
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "output",
    "canonical_json": "0"
  },
  "requires_per_point_scope": true,
  "tags": ["region", "boundary"]
}
