{
  "id": "region_index_range",
  "description": "region.index_range scope (RFC §5.2.7). Rule fires only when the query point's axis index lies in the declared [lo, hi]. At query_point i=0 the rule fires; at i=2 it does not (fall-through).",
  "context": {
    "query_point": {"i": 0}
  },
  "rules": [
    {
      "name": "zero_at_left_edge",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "index_range", "axis": "i", "lo": 0, "hi": 0},
      "replacement": 0
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "output",
    "canonical_json": "0"
  },
  "requires_per_point_scope": true,
  "tags": ["region", "index_range"]
}
