{
  "id": "region_panel_boundary_grid_mismatch",
  "description": "region.panel_boundary E_REGION_GRID_MISMATCH (RFC §5.2.7, §6.4). Applying a panel_boundary-scoped rule to a non-cubed-sphere grid (no panel_connectivity) is an error. The grid is a plain cartesian grid — the binding must emit E_REGION_GRID_MISMATCH at rewrite time.",
  "context": {
    "grid_name": "g_cartesian",
    "grids": {
      "g_cartesian": {
        "spatial_dims": ["x", "y"],
        "dim_bounds": {"x": [0, 9], "y": [0, 9]}
      }
    },
    "query_point": {"p": 0, "i": 0, "j": 0}
  },
  "rules": [
    {
      "name": "zero_at_panel0_west",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "panel_boundary", "panel": 0, "side": "west"},
      "replacement": 0
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "error",
    "code": "E_REGION_GRID_MISMATCH"
  },
  "requires_per_point_scope": true,
  "tags": ["region", "panel_boundary", "grid_mismatch", "error"]
}
