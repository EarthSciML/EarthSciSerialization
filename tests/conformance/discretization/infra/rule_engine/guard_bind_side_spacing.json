{
  "id": "guard_bind_side_spacing",
  "description": "Guard bind_side_spacing (§5.2.4). Binds $h to 1/N for the spatial dim matching the side. Grid g1 has spatial_dims=[i,j], dim_sizes={i:4,j:8}. Side xmin maps to axis index 0 → dim i → N=4 → h=0.25.",
  "context": {
    "grids": {
      "g1": {
        "spatial_dims": ["i", "j"],
        "dim_sizes": {"i": 4, "j": 8}
      }
    },
    "variables": {
      "u": {"grid": "g1"}
    }
  },
  "rules": [
    {
      "name": "bc_spacing",
      "pattern": {"op": "bc", "args": ["$u"], "fn": "dirichlet", "dim": "$side"},
      "where": [
        {"guard": "var_has_grid", "pvar": "$u", "grid": "$g"},
        {"guard": "bind_side_spacing", "pvar": "$h", "side": "$side", "grid": "$g"}
      ],
      "replacement": {"op": "spacing_marker", "args": ["$u", "$h"]}
    }
  ],
  "input": {"op": "bc", "args": ["u"], "fn": "dirichlet", "dim": "xmin"},
  "expect": {
    "kind": "output",
    "canonical_json": "{\"args\":[\"u\",0.25],\"op\":\"spacing_marker\"}"
  },
  "tags": ["guard", "bind_side_spacing"]
}
