{
  "id": "region_index_range_fall_through",
  "description": "region.index_range fall-through (RFC §5.2.7). The scoped rule whose [lo, hi] does NOT contain the query point falls through; the next rule (unscoped) fires. Verifies fall-through preserves v0.2 rule-ordering semantics.",
  "context": {
    "query_point": {"i": 2}
  },
  "rules": [
    {
      "name": "zero_at_left_edge",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "region":      {"kind": "index_range", "axis": "i", "lo": 0, "hi": 0},
      "replacement": 0
    },
    {
      "name": "fallback_identity",
      "pattern":     {"op": "grad", "args": ["$u"], "dim": "$x"},
      "replacement": "$u"
    }
  ],
  "input": {"op": "grad", "args": ["T"], "dim": "x"},
  "expect": {
    "kind": "output",
    "canonical_json": "\"T\""
  },
  "requires_per_point_scope": true,
  "tags": ["region", "index_range", "fall_through"]
}
