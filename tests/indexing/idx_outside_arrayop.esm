{
  "esm": "0.1.0",
  "metadata": {
    "name": "idx_outside_arrayop",
    "description": "Exercises the standalone `index` op in scalar expression contexts outside of `arrayop.expr`, per RFC discretization.md §5.1 (C1). The fixture uses `index` on a declared array-shaped state variable with (a) an integer-literal index and (b) a composite-arithmetic index expression, both on the RHS of a scalar ODE. No symbolic index variables appear — bare-string args are ordinary parameter references. All five bindings MUST parse, round-trip, and evaluate this fixture; bindings which also supply a numeric evaluator MUST produce the analytically-known scalar trajectory below.",
    "authors": ["EarthSciSerialization/polecats/chrome"],
    "tags": ["indexing", "conformance", "index", "rfc-discretization-5.1"]
  },
  "models": {
    "IdxOutsideArrayop": {
      "variables": {
        "u": { "type": "state" },
        "s_literal": { "type": "state" },
        "s_composite": { "type": "state" }
      },
      "equations": [
        {
          "_comment": "Array ODE: D(u[i]) = -u[i] for i in 1..5 (analytical u_i(t) = u_i(0) * exp(-t)).",
          "lhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "D", "args": [{ "op": "index", "args": ["u", "i"] }], "wrt": "t" },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "arrayop", "args": [], "output_idx": ["i"],
            "expr": { "op": "-", "args": [{ "op": "index", "args": ["u", "i"] }] },
            "ranges": { "i": [1, 5] }
          }
        },
        {
          "_comment": "Scalar ODE driven by `index` with an integer-literal index. D(s_literal) = index(u, 2). Analytically s_literal(t) = u_2(0) * (1 - exp(-t)).",
          "lhs": { "op": "D", "args": ["s_literal"], "wrt": "t" },
          "rhs": { "op": "index", "args": ["u", 2] }
        },
        {
          "_comment": "Scalar ODE driven by `index` with a composite-arithmetic index expression. `index(u, 1 + 2)` resolves to u[3] per spec §4.3.3 (the inner + is a constant-fold of two integer literals). Analytically s_composite(t) = u_3(0) * (1 - exp(-t)).",
          "lhs": { "op": "D", "args": ["s_composite"], "wrt": "t" },
          "rhs": { "op": "index", "args": ["u", { "op": "+", "args": [1, 2] }] }
        }
      ],
      "tolerance": { "rel": 1.0e-6 },
      "tests": [
        {
          "id": "idx_outside_arrayop_integrate",
          "description": "With u_2(0)=2.0 and u_3(0)=3.0, at t=1: s_literal(1) = 2*(1 - exp(-1)) ≈ 1.264241117657115; s_composite(1) = 3*(1 - exp(-1)) ≈ 1.896361676485673.",
          "initial_conditions": {
            "u[1]": 1.0,
            "u[2]": 2.0,
            "u[3]": 3.0,
            "u[4]": 4.0,
            "u[5]": 5.0,
            "s_literal": 0.0,
            "s_composite": 0.0
          },
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "u[2]",        "time": 1.0, "expected": 0.7357588823428847 },
            { "variable": "u[3]",        "time": 1.0, "expected": 1.103638323514327  },
            { "variable": "s_literal",   "time": 1.0, "expected": 1.2642411176571153 },
            { "variable": "s_composite", "time": 1.0, "expected": 1.896361676485673  }
          ]
        }
      ]
    }
  }
}
