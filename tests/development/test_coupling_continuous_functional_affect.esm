{
  "esm": "0.1.0",
  "metadata": {
    "name": "CouplingContinuousFunctionalTest",
    "description": "Test continuous CouplingEvent with functional_affect support",
    "authors": [
      "Claude Sonnet 4"
    ]
  },
  "models": {
    "ChemModel": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 8e-08
        },
        "emission_rate": {
          "type": "parameter",
          "units": "1/s",
          "default": 1e-06
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "emission_rate",
              {
                "op": "-",
                "args": [
                  1e-07,
                  "O3"
                ]
              }
            ]
          }
        }
      ]
    },
    "EmissionModel": {
      "variables": {
        "source_strength": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0
        }
      },
      "equations": []
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "ChemModel",
        "EmissionModel"
      ]
    },
    {
      "type": "event",
      "event_type": "continuous",
      "name": "ozone_threshold_control",
      "conditions": [
        {
          "op": "-",
          "args": [
            "ChemModel.O3",
            8.5e-08
          ]
        }
      ],
      "functional_affect": {
        "handler_id": "adaptive_emission_controller",
        "read_vars": [
          "ChemModel.O3"
        ],
        "read_params": [
          "ChemModel.emission_rate",
          "EmissionModel.source_strength"
        ],
        "modified_params": [
          "EmissionModel.source_strength"
        ],
        "config": {
          "threshold": 8.5e-08,
          "reduction_factor": 0.8,
          "recovery_rate": 0.05
        }
      },
      "discrete_parameters": [
        "EmissionModel.source_strength"
      ],
      "root_find": "left",
      "description": "Reduce emissions when ozone exceeds threshold"
    }
  ],
  "solver": {
    "strategy": "strang_serial",
    "config": {
      "timestep": 1.0
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T02:00:00Z"
      },
      "initial_conditions": {
        "type": "constant",
        "value": 1.0
      }
    }
  }
}
