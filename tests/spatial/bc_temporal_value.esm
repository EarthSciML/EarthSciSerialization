{
  "esm": "0.2.0",
  "metadata": {
    "name": "bc_temporal_value",
    "description": "Time-varying boundary-condition values (ess-x1w). A BC value that references the independent variable t (e.g. value=g(t)) is evaluated per timestep. No discretizer change is needed: t is a free symbol that flows through the value-agnostic BC pipeline into the per-cell makearray boundary region and is supplied by the integrator each step. Dirichlet here; robin gamma=g(t) (value-agnostic, same mechanism) is verified inline in test/bc_space_time_values_test.jl, where goldens are checked analytically (the boundary ghost equals g(t) at each evaluation time)."
  },
  "grids": {
    "g1": {
      "family": "cartesian",
      "dimensions": [
        {"name": "x", "size": 5, "periodic": false, "spacing": "uniform"}
      ]
    }
  },
  "models": {
    "dirichlet_1d_t": {
      "grid": "g1",
      "variables": {
        "u":  {"type": "state", "default": 0.0, "shape": ["x"], "location": "cell_center"},
        "dx": {"type": "parameter", "default": 1.0}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "+", "args": [
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", {"op": "-", "args": ["i", 1]}]}]},
            {"op": "*", "args": [{"op": "/", "args": [-2, {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", "i"]}]},
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", {"op": "+", "args": ["i", 1]}]}]}
          ]}
        }
      ],
      "boundary_conditions": {
        "left":  {"variable": "u", "side": "xmin", "kind": "dirichlet", "value": {"op": "sin", "args": ["t"]}},
        "right": {"variable": "u", "side": "xmax", "kind": "dirichlet", "value": 1.0}
      }
    }
  }
}
