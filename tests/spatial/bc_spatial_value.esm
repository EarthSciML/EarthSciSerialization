{
  "esm": "0.2.0",
  "metadata": {
    "name": "bc_spatial_value",
    "description": "Space-varying boundary-condition values (ess-x1w). A BC value that references a spatial coordinate (a grid dimension name, e.g. value=f(x)) resolves to the per-cell coordinate at each boundary/corner cell. The discretizer reuses the IC coordinate-binding vocabulary: it rewrites each coordinate symbol to index(coord_<dim>, <loop_idx>), and the per-cell makearray boundary region binds the loop index so coord_<dim> (a const_array of cell centers) is read at the boundary cell. Dirichlet here; neumann/robin coordinate resolution (value-agnostic, same mechanism) is verified inline in test/bc_space_time_values_test.jl. Each model uses a distinct variable name. Goldens are checked analytically in that test (Julia reference; coord_<dim> supplied as a const_array at evaluation time). Cross-binding parity is a sibling bead (Python)."
  },
  "grids": {
    "g1": {
      "family": "cartesian",
      "dimensions": [
        {"name": "x", "size": 5, "periodic": false, "spacing": "uniform"}
      ]
    },
    "g2": {
      "family": "cartesian",
      "dimensions": [
        {"name": "x", "size": 4, "periodic": false, "spacing": "uniform"},
        {"name": "y", "size": 4, "periodic": false, "spacing": "uniform"}
      ]
    }
  },
  "models": {
    "dirichlet_1d": {
      "grid": "g1",
      "variables": {
        "u":  {"type": "state", "default": 0.0, "shape": ["x"], "location": "cell_center"},
        "dx": {"type": "parameter", "default": 1.0}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["u"], "wrt": "t"},
          "rhs": {"op": "+", "args": [
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", {"op": "-", "args": ["i", 1]}]}]},
            {"op": "*", "args": [{"op": "/", "args": [-2, {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", "i"]}]},
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["u", {"op": "+", "args": ["i", 1]}]}]}
          ]}
        }
      ],
      "boundary_conditions": {
        "left":  {"variable": "u", "side": "xmin", "kind": "dirichlet", "value": {"op": "sin", "args": [{"op": "*", "args": [{"op": "pi", "args": []}, "x"]}]}},
        "right": {"variable": "u", "side": "xmax", "kind": "dirichlet", "value": 0.0}
      }
    },
    "dirichlet_2d_edge": {
      "grid": "g2",
      "variables": {
        "w":  {"type": "state", "default": 0.0, "shape": ["x", "y"], "location": "cell_center"},
        "dx": {"type": "parameter", "default": 1.0},
        "dy": {"type": "parameter", "default": 1.0}
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["w"], "wrt": "t"},
          "rhs": {"op": "+", "args": [
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["w", {"op": "-", "args": ["i", 1]}, "j"]}]},
            {"op": "*", "args": [{"op": "/", "args": [-2, {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["w", "i", "j"]}]},
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dx", "dx"]}]}, {"op": "index", "args": ["w", {"op": "+", "args": ["i", 1]}, "j"]}]},
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dy", "dy"]}]}, {"op": "index", "args": ["w", "i", {"op": "-", "args": ["j", 1]}]}]},
            {"op": "*", "args": [{"op": "/", "args": [-2, {"op": "*", "args": ["dy", "dy"]}]}, {"op": "index", "args": ["w", "i", "j"]}]},
            {"op": "*", "args": [{"op": "/", "args": [1,  {"op": "*", "args": ["dy", "dy"]}]}, {"op": "index", "args": ["w", "i", {"op": "+", "args": ["j", 1]}]}]}
          ]}
        }
      ],
      "boundary_conditions": {
        "south": {"variable": "w", "side": "ymin", "kind": "dirichlet", "value": {"op": "+", "args": ["x", {"op": "*", "args": [10.0, "y"]}]}}
      }
    }
  }
}
