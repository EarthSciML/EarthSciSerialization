{
  "esm": "0.1.0",
  "metadata": {
    "name": "BoundaryConditionTests",
    "description": "Test boundary condition implementation for atmospheric models",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-14T00:00:00Z",
    "tags": ["boundary-conditions", "atmospheric-modeling", "spatial-discretization"]
  },

  "models": {
    "NeumannBoundary": {
      "reference": {
        "notes": "Test zero-gradient (Neumann) boundary conditions: ∂C/∂n = 0 at domain edges"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-8,
          "description": "Species concentration with zero-gradient at boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        }
      },
      "equations": [
        {
          "_comment": "Pure diffusion with zero-gradient boundaries",
          "lhs": {"op": "D", "args": ["concentration"], "wrt": "t"},
          "rhs": {
            "op": "*",
            "args": ["diffusivity", {"op": "laplacian", "args": ["concentration"]}]
          }
        }
      ]
    },

    "DirichletBoundary": {
      "reference": {
        "notes": "Test fixed-value (Dirichlet) boundary conditions: C = C₀ at domain edges"
      },
      "variables": {
        "tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Tracer with fixed concentration at boundaries"
        },
        "boundary_value": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 1e-6,
          "description": "Fixed boundary concentration"
        },
        "K_diff": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0
        }
      },
      "equations": [
        {
          "_comment": "Diffusion with constant boundary values",
          "lhs": {"op": "D", "args": ["tracer"], "wrt": "t"},
          "rhs": {
            "op": "*",
            "args": ["K_diff", {"op": "laplacian", "args": ["tracer"]}]
          }
        }
      ]
    },

    "PeriodicBoundary": {
      "reference": {
        "notes": "Test periodic boundary conditions: C(0) = C(L) for global atmospheric models"
      },
      "variables": {
        "global_tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-9,
          "description": "Globally transported species with periodic longitude boundaries"
        },
        "wind_speed": {
          "type": "parameter",
          "units": "m/s",
          "default": 20.0,
          "description": "Zonal wind speed"
        }
      },
      "equations": [
        {
          "_comment": "Pure advection with periodic boundaries",
          "lhs": {"op": "D", "args": ["global_tracer"], "wrt": "t"},
          "rhs": {
            "op": "*",
            "args": [
              {"op": "-", "args": ["wind_speed"]},
              {"op": "grad", "args": ["global_tracer"], "dim": "lon"}
            ]
          }
        }
      ]
    },

    "MixedBoundaries": {
      "reference": {
        "notes": "Test mixed boundary conditions: different BC types on different domain edges"
      },
      "variables": {
        "pollution": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Pollutant with mixed boundary conditions"
        },
        "surface_emission": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-10,
          "description": "Surface emission flux"
        },
        "deposition_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.01,
          "description": "Surface deposition velocity"
        }
      },
      "equations": [
        {
          "_comment": "Pollutant transport with surface emission and deposition",
          "lhs": {"op": "D", "args": ["pollution"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              "surface_emission",
              {
                "_comment": "Surface loss term: -v_dep * pollution at bottom boundary",
                "op": "*",
                "args": [
                  {"op": "-", "args": ["deposition_velocity"]},
                  "pollution"
                ]
              }
            ]
          }
        }
      ]
    }
  },

  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T06:00:00Z"
    },
    "spatial": {
      "x": {
        "min": 0.0,
        "max": 50000.0,
        "units": "meters",
        "grid_spacing": 1000.0,
        "description": "West-east domain"
      },
      "y": {
        "min": 0.0,
        "max": 50000.0,
        "units": "meters",
        "grid_spacing": 1000.0,
        "description": "South-north domain"
      },
      "lon": {
        "min": -180.0,
        "max": 180.0,
        "units": "degrees",
        "grid_spacing": 2.0,
        "description": "Longitude for periodic test"
      }
    },
    "initial_conditions": {
      "type": "per_variable",
      "values": {
        "concentration": "1e-8",
        "tracer": "0.0",
        "global_tracer": "1e-9",
        "pollution": "0.0"
      }
    },
    "boundary_conditions": [
      {
        "type": "zero_gradient",
        "dimensions": ["x", "y"],
        "applies_to": ["concentration"],
        "description": "∂C/∂n = 0 at all boundaries"
      },
      {
        "type": "constant",
        "dimensions": ["x", "y"],
        "value": "1e-6",
        "applies_to": ["tracer"],
        "description": "Fixed concentration at boundaries"
      },
      {
        "type": "periodic",
        "dimensions": ["lon"],
        "applies_to": ["global_tracer"],
        "description": "C(lon=-180°) = C(lon=+180°)"
      },
      {
        "type": "mixed",
        "applies_to": ["pollution"],
        "conditions": [
          {
            "boundary": "bottom",
            "type": "flux",
            "value": "surface_emission",
            "description": "Upward emission flux at surface"
          },
          {
            "boundary": "top",
            "type": "zero_gradient",
            "description": "No flux through model top"
          },
          {
            "boundary": "lateral",
            "type": "zero_gradient",
            "description": "No lateral flux"
          }
        ]
      }
    ],
    "element_type": "Float64"
  },

  "solver": {
    "strategy": "strang_serial",
    "config": {
      "stiff_algorithm": "Rodas4",
      "timestep": 300.0,
      "boundary_method": "ghost_cells",
      "stiff_kwargs": {
        "abstol": 1e-10,
        "reltol": 1e-8
      }
    }
  }
}