{
  "esm": "0.1.0",
  "metadata": {
    "name": "BoundaryConditionTests",
    "description": "Test boundary condition implementation for atmospheric models",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "boundary-conditions",
      "atmospheric-modeling",
      "spatial-discretization"
    ]
  },
  "models": {
    "NeumannBoundary": {
      "reference": {
        "notes": "Test zero-gradient (Neumann) boundary conditions: \u2202C/\u2202n = 0 at domain edges"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-08,
          "description": "Species concentration with zero-gradient at boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "diffusivity",
              {
                "op": "laplacian",
                "args": [
                  "concentration"
                ]
              }
            ]
          }
        }
      ]
    },
    "DirichletBoundary": {
      "reference": {
        "notes": "Test fixed-value (Dirichlet) boundary conditions: C = C\u2080 at domain edges"
      },
      "variables": {
        "tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Tracer with fixed concentration at boundaries"
        },
        "boundary_value": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Fixed boundary concentration"
        },
        "K_diff": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "K_diff",
              {
                "op": "laplacian",
                "args": [
                  "tracer"
                ]
              }
            ]
          }
        }
      ]
    },
    "PeriodicBoundary": {
      "reference": {
        "notes": "Test periodic boundary conditions: C(0) = C(L) for global atmospheric models"
      },
      "variables": {
        "global_tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Globally transported species with periodic longitude boundaries"
        },
        "wind_speed": {
          "type": "parameter",
          "units": "m/s",
          "default": 20.0,
          "description": "Zonal wind speed"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "global_tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "wind_speed"
                ]
              },
              {
                "op": "grad",
                "args": [
                  "global_tracer"
                ],
                "dim": "lon"
              }
            ]
          }
        }
      ]
    },
    "MixedBoundaries": {
      "reference": {
        "notes": "Test mixed boundary conditions: different BC types on different domain edges"
      },
      "variables": {
        "pollution": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Pollutant with mixed boundary conditions"
        },
        "surface_emission": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-10,
          "description": "Surface emission flux"
        },
        "deposition_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.01,
          "description": "Surface deposition velocity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "pollution"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              "surface_emission",
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "deposition_velocity"
                    ]
                  },
                  "pollution"
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T06:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "y": {
          "min": 0.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "lon": {
          "min": -180.0,
          "max": 180.0,
          "units": "degrees",
          "grid_spacing": 2.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "concentration": 1e-08,
          "tracer": 0.0,
          "global_tracer": 1e-09,
          "pollution": 0.0
        }
      },
      "boundary_conditions": [
        {
          "type": "zero_gradient",
          "dimensions": [
            "x",
            "y"
          ]
        },
        {
          "type": "constant",
          "dimensions": [
            "x",
            "y"
          ],
          "value": 1e-06
        },
        {
          "type": "periodic",
          "dimensions": [
            "lon"
          ]
        },
        {
          "type": "robin",
          "dimensions": [
            "x"
          ]
        }
      ],
      "element_type": "Float64"
    }
  }
}
