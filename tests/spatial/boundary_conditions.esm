{
  "esm": "0.2.0",
  "metadata": {
    "name": "BoundaryConditionTests",
    "description": "Test boundary condition implementation for atmospheric models (ESM v0.2.0 — model-level BCs per docs/rfcs/discretization.md §9)",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "boundary-conditions",
      "atmospheric-modeling",
      "spatial-discretization"
    ]
  },
  "models": {
    "NeumannBoundary": {
      "reference": {
        "notes": "Test zero-gradient (Neumann) boundary conditions: \u2202C/\u2202n = 0 at domain edges"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-08,
          "description": "Species concentration with zero-gradient at boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "diffusivity",
              {
                "op": "laplacian",
                "args": [
                  "concentration"
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "concentration_zero_gradient_xmin": {
          "variable": "concentration",
          "side": "xmin",
          "kind": "zero_gradient",
          "description": "Zero-gradient Neumann on x=0"
        },
        "concentration_zero_gradient_xmax": {
          "variable": "concentration",
          "side": "xmax",
          "kind": "zero_gradient"
        },
        "concentration_zero_gradient_ymin": {
          "variable": "concentration",
          "side": "ymin",
          "kind": "zero_gradient"
        },
        "concentration_zero_gradient_ymax": {
          "variable": "concentration",
          "side": "ymax",
          "kind": "zero_gradient"
        }
      }
    },
    "DirichletBoundary": {
      "reference": {
        "notes": "Test fixed-value (Dirichlet) boundary conditions: C = C\u2080 at domain edges"
      },
      "variables": {
        "tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Tracer with fixed concentration at boundaries"
        },
        "boundary_value": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Fixed boundary concentration"
        },
        "K_diff": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "K_diff",
              {
                "op": "laplacian",
                "args": [
                  "tracer"
                ]
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "tracer_dirichlet_xmin": {
          "variable": "tracer",
          "side": "xmin",
          "kind": "dirichlet",
          "value": "boundary_value"
        },
        "tracer_dirichlet_xmax": {
          "variable": "tracer",
          "side": "xmax",
          "kind": "dirichlet",
          "value": "boundary_value"
        }
      }
    },
    "PeriodicBoundary": {
      "reference": {
        "notes": "Test periodic boundary conditions: C(0) = C(L) for global atmospheric models. Per RFC \u00a79.2.1, declare once on xmin; the xmax side is implicit."
      },
      "variables": {
        "global_tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Globally transported species with periodic longitude boundaries"
        },
        "wind_speed": {
          "type": "parameter",
          "units": "m/s",
          "default": 20.0,
          "description": "Zonal wind speed"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "global_tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "wind_speed"
                ]
              },
              {
                "op": "grad",
                "args": [
                  "global_tracer"
                ],
                "dim": "lon"
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "global_tracer_periodic_lon": {
          "variable": "global_tracer",
          "side": "xmin",
          "kind": "periodic",
          "description": "Periodic x-axis wrap (declared once on xmin per RFC \u00a79.2.1)"
        }
      }
    },
    "RobinBoundary": {
      "reference": {
        "notes": "Test Robin boundary conditions: \u03b1u + \u03b2\u2202u/\u2202n = \u03b3 at the domain edge."
      },
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 288.15
        },
        "htc": {
          "type": "parameter",
          "units": "W/m^2/K",
          "default": 25.0
        },
        "t_ambient": {
          "type": "parameter",
          "units": "K",
          "default": 295.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "laplacian",
            "args": [
              "temperature"
            ]
          }
        }
      ],
      "boundary_conditions": {
        "temperature_robin_xmin": {
          "variable": "temperature",
          "side": "xmin",
          "kind": "robin",
          "robin_alpha": "htc",
          "robin_beta": 1.0,
          "robin_gamma": {
            "op": "*",
            "args": ["htc", "t_ambient"]
          }
        }
      }
    },
    "MixedBoundaries": {
      "reference": {
        "notes": "Test mixed BCs: a flux_contrib from a dry deposition component and an emission flux_contrib on the same (variable, side) pair — the rewrite engine aggregates both into the zmin Neumann template (RFC \u00a79.3)."
      },
      "variables": {
        "pollution": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Pollutant with mixed boundary conditions"
        },
        "surface_emission": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-10,
          "description": "Surface emission flux"
        },
        "deposition_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.01,
          "description": "Surface deposition velocity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "pollution"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "laplacian",
            "args": [
              "pollution"
            ]
          }
        }
      ],
      "boundary_conditions": {
        "pollution_neumann_zmin": {
          "variable": "pollution",
          "side": "zmin",
          "kind": "neumann",
          "value": 0.0,
          "description": "Enclosing neumann template; flux_contrib entries aggregate into this side's flux."
        },
        "pollution_deposition_zmin": {
          "variable": "pollution",
          "side": "zmin",
          "kind": "flux_contrib",
          "value": {
            "op": "*",
            "args": [
              {"op": "-", "args": ["deposition_velocity"]},
              "pollution"
            ]
          },
          "contributed_by": {
            "component": "dry_deposition",
            "flux_sign": "-"
          }
        },
        "pollution_emission_zmin": {
          "variable": "pollution",
          "side": "zmin",
          "kind": "flux_contrib",
          "value": "surface_emission",
          "contributed_by": {
            "component": "emissions",
            "flux_sign": "+"
          }
        }
      }
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T06:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "y": {
          "min": 0.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "lon": {
          "min": -180.0,
          "max": 180.0,
          "units": "degrees",
          "grid_spacing": 2.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "concentration": 1e-08,
          "tracer": 0.0,
          "global_tracer": 1e-09,
          "pollution": 0.0,
          "temperature": 288.15
        }
      },
      "element_type": "Float64"
    }
  }
}
