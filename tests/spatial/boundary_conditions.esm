{
  "esm": "0.2.0",
  "metadata": {
    "name": "BoundaryConditionTests",
    "description": "Test boundary condition implementation for atmospheric models (ESM v0.2.0 — model-level BCs per docs/rfcs/discretization.md §9)",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "boundary-conditions",
      "atmospheric-modeling",
      "spatial-discretization"
    ]
  },
  "models": {
    "NeumannBoundary": {
      "reference": {
        "notes": "Test zero-gradient (Neumann) boundary conditions: ∂C/∂n = 0 at domain edges"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-08,
          "description": "Species concentration with zero-gradient at boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "diffusivity",
              {
                "op": "laplacian",
                "args": [
                  "concentration"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "concentration"
            ]
          },
          "rhs": 1e-08
        }
      ]
    },
    "DirichletBoundary": {
      "reference": {
        "notes": "Test fixed-value (Dirichlet) boundary conditions: C = C₀ at domain edges"
      },
      "variables": {
        "tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Tracer with fixed concentration at boundaries"
        },
        "boundary_value": {
          "type": "parameter",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Fixed boundary concentration"
        },
        "K_diff": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "K_diff",
              {
                "op": "laplacian",
                "args": [
                  "tracer"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "tracer"
            ]
          },
          "rhs": 0.0
        }
      ]
    },
    "PeriodicBoundary": {
      "reference": {
        "notes": "Test periodic boundary conditions: C(0) = C(L) for global atmospheric models. Per RFC §9.2.1, declare once on xmin; the xmax side is implicit."
      },
      "variables": {
        "global_tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Globally transported species with periodic longitude boundaries"
        },
        "wind_speed": {
          "type": "parameter",
          "units": "m/s",
          "default": 20.0,
          "description": "Zonal wind speed"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "global_tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "wind_speed"
                ]
              },
              {
                "op": "grad",
                "args": [
                  "global_tracer"
                ],
                "dim": "lon"
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "global_tracer"
            ]
          },
          "rhs": 1e-09
        }
      ]
    },
    "RobinBoundary": {
      "reference": {
        "notes": "Test Robin boundary conditions: αu + β∂u/∂n = γ at the domain edge."
      },
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 288.15
        },
        "htc": {
          "type": "parameter",
          "units": "W/m^2/K",
          "default": 25.0
        },
        "t_ambient": {
          "type": "parameter",
          "units": "K",
          "default": 295.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "laplacian",
            "args": [
              "temperature"
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "temperature"
            ]
          },
          "rhs": 288.15
        }
      ]
    },
    "MixedBoundaries": {
      "reference": {
        "notes": "Test mixed BCs: a flux_contrib from a dry deposition component and an emission flux_contrib on the same (variable, side) pair — the rewrite engine aggregates both into the zmin Neumann template (RFC §9.3)."
      },
      "variables": {
        "pollution": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Pollutant with mixed boundary conditions"
        },
        "surface_emission": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-10,
          "description": "Surface emission flux"
        },
        "deposition_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.01,
          "description": "Surface deposition velocity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "pollution"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "laplacian",
            "args": [
              "pollution"
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "pollution"
            ]
          },
          "rhs": 0.0
        }
      ]
    }
  },
  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T06:00:00Z"
    },
    "element_type": "Float64"
  }
}
