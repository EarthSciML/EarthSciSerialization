{
  "esm": "0.1.0",
  "metadata": {
    "name": "BackwardCompatible",
    "description": "ESM file that should remain compatible across minor versions",
    "authors": [
      "Test Suite"
    ],
    "license": "MIT",
    "created": "2026-02-19T00:00:00Z",
    "modified": "2026-02-19T00:00:00Z"
  },
  "models": {
    "stable_model": {
      "variables": {
        "concentration": {
          "units": "mol/L",
          "default": 100.0,
          "type": "parameter"
        },
        "temperature": {
          "units": "K",
          "default": 298.15,
          "type": "parameter"
        },
        "decay_rate": {
          "units": "1/s",
          "type": "parameter"
        },
        "heat_capacity": {
          "units": "J/(mol*K)",
          "type": "parameter"
        }
      },
      "equations": []
    }
  },
  "solver": {
    "strategy": "strang_serial",
    "config": {
      "rtol": 1e-06,
      "atol": 1e-08,
      "max_steps": 1000
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2023-01-01T00:00:00Z",
        "end": "2023-01-02T00:00:00Z"
      }
    }
  }
}
