{
  "esm": "0.1.0",
  "metadata": {
    "name": "registered_funcs_two_d_table_lookup",
    "description": "Exercises a 2D table-lookup handler (`A_table`) invoked inside a product term, plus a second registered function (`r_c_wesely`) with per-argument units hints. Mirrors the AtmosphericDeposition.jl `A_table`/`α_table`/`γ_table` pattern from the MTK audit (gt-p3ep). The fixture only declares the calling contract; handler bodies are supplied at runtime.",
    "authors": ["EarthSciSerialization/polecats/enclave"],
    "tags": ["registered_functions", "call", "conformance", "table_lookup", "gt-p3ep"]
  },
  "registered_functions": {
    "A_table": {
      "id": "A_table",
      "signature": {
        "arg_count": 2,
        "arg_types": ["scalar", "scalar"],
        "return_type": "scalar"
      },
      "description": "2D deposition coefficient table lookup indexed by land-use category and season."
    },
    "r_c_wesely": {
      "id": "r_c_wesely",
      "signature": {
        "arg_count": 3,
        "arg_types": ["scalar", "scalar", "scalar"],
        "return_type": "scalar"
      },
      "units": "s/m",
      "arg_units": ["K", "m^2/m^2", null],
      "description": "Wesely (1989) canopy resistance as a function of temperature, LAI, and season index.",
      "references": [
        { "doi": "10.1016/0004-6981(89)90153-4" }
      ]
    }
  },
  "models": {
    "TableLookupDeposition": {
      "variables": {
        "T":       { "type": "parameter", "units": "K",       "default": 298.0 },
        "LAI":     { "type": "parameter", "units": "m^2/m^2", "default": 3.2   },
        "season":  { "type": "parameter", "units": "dimensionless", "default": 2.0 },
        "landuse": { "type": "parameter", "units": "dimensionless", "default": 5.0 },
        "C":       { "type": "state",     "units": "mol/m^3" }
      },
      "equations": [
        {
          "_comment": "D(C) = -A_table(landuse, season) * C / r_c_wesely(T, LAI, season) — two registered-function calls in the same RHS.",
          "lhs": { "op": "D", "args": ["C"], "wrt": "t" },
          "rhs": {
            "op": "*",
            "args": [
              -1,
              { "op": "call", "handler_id": "A_table",    "args": ["landuse", "season"] },
              "C",
              {
                "op": "/",
                "args": [
                  1,
                  { "op": "call", "handler_id": "r_c_wesely", "args": ["T", "LAI", "season"] }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
