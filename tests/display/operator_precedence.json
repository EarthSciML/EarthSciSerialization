{
  "description": "Comprehensive operator precedence and associativity test cases",
  "test_cases": [
    {
      "category": "Arithmetic Precedence",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "*", "args": ["a", "b"]}, "c"]},
          "unicode": "a·b + c",
          "latex": "a \\cdot b + c",
          "ascii": "a * b + c",
          "note": "Multiplication binds tighter than addition"
        },
        {
          "input": {"op": "*", "args": [{"op": "+", "args": ["a", "b"]}, "c"]},
          "unicode": "(a + b)·c",
          "latex": "(a + b) \\cdot c",
          "ascii": "(a + b) * c",
          "note": "Parentheses required for addition inside multiplication"
        },
        {
          "input": {"op": "^", "args": ["a", {"op": "+", "args": ["b", "c"]}]},
          "unicode": "a^(b + c)",
          "latex": "a^{b + c}",
          "ascii": "a^(b + c)",
          "note": "Exponentiation requires parentheses for addition in exponent"
        },
        {
          "input": {"op": "+", "args": [{"op": "^", "args": ["a", "b"]}, "c"]},
          "unicode": "a^b + c",
          "latex": "a^{b} + c",
          "ascii": "a^b + c",
          "note": "Exponentiation binds tighter than addition"
        }
      ]
    },

    {
      "category": "Unary Minus Precedence",
      "cases": [
        {
          "input": {"op": "-", "args": [{"op": "*", "args": ["a", "b"]}]},
          "unicode": "−a·b",
          "latex": "-a \\cdot b",
          "ascii": "-a * b",
          "note": "Unary minus binds tighter than multiplication"
        },
        {
          "input": {"op": "*", "args": [{"op": "-", "args": ["a"]}, "b"]},
          "unicode": "−a·b",
          "latex": "-a \\cdot b",
          "ascii": "-a * b",
          "note": "Same result: unary minus has high precedence"
        },
        {
          "input": {"op": "-", "args": [{"op": "^", "args": ["a", "b"]}]},
          "unicode": "−a^b",
          "latex": "-a^{b}",
          "ascii": "-a^b",
          "note": "Unary minus binds looser than exponentiation"
        },
        {
          "input": {"op": "^", "args": [{"op": "-", "args": ["a"]}, "b"]},
          "unicode": "(−a)^b",
          "latex": "(-a)^{b}",
          "ascii": "(-a)^b",
          "note": "Parentheses needed for negative base"
        }
      ]
    },

    {
      "category": "Function Application",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "sin", "args": ["x"]}, "y"]},
          "unicode": "sin(x) + y",
          "latex": "\\sin(x) + y",
          "ascii": "sin(x) + y",
          "note": "Function application has highest precedence"
        },
        {
          "input": {"op": "sin", "args": [{"op": "+", "args": ["x", "y"]}]},
          "unicode": "sin(x + y)",
          "latex": "\\sin(x + y)",
          "ascii": "sin(x + y)",
          "note": "Addition inside function argument"
        },
        {
          "input": {"op": "*", "args": [{"op": "exp", "args": ["x"]}, "y"]},
          "unicode": "exp(x)·y",
          "latex": "\\exp(x) \\cdot y",
          "ascii": "exp(x) * y",
          "note": "Function multiplication without parentheses"
        }
      ]
    },

    {
      "category": "Calculus Operators",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "D", "args": ["x"], "wrt": "t"}, "y"]},
          "unicode": "∂x/∂t + y",
          "latex": "\\frac{\\partial x}{\\partial t} + y",
          "ascii": "D(x,t) + y",
          "note": "Derivative has function-like precedence"
        },
        {
          "input": {"op": "D", "args": [{"op": "+", "args": ["x", "y"]}], "wrt": "t"},
          "unicode": "∂(x + y)/∂t",
          "latex": "\\frac{\\partial (x + y)}{\\partial t}",
          "ascii": "D(x + y, t)",
          "note": "Derivative of sum requires parentheses"
        },
        {
          "input": {"op": "grad", "args": [{"op": "*", "args": ["f", "g"]}], "dim": "x"},
          "unicode": "∂(f·g)/∂x",
          "latex": "\\frac{\\partial (f \\cdot g)}{\\partial x}",
          "ascii": "grad(f * g, x)",
          "note": "Gradient of product"
        }
      ]
    },

    {
      "category": "Associativity",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "+", "args": ["a", "b"]}, "c"]},
          "unicode": "a + b + c",
          "latex": "a + b + c",
          "ascii": "a + b + c",
          "note": "Addition is left-associative, no extra parentheses"
        },
        {
          "input": {"op": "+", "args": ["a", {"op": "+", "args": ["b", "c"]}]},
          "unicode": "a + b + c",
          "latex": "a + b + c",
          "ascii": "a + b + c",
          "note": "Addition is associative, same result"
        },
        {
          "input": {"op": "*", "args": [{"op": "*", "args": ["a", "b"]}, "c"]},
          "unicode": "a·b·c",
          "latex": "a \\cdot b \\cdot c",
          "ascii": "a * b * c",
          "note": "Multiplication is associative"
        },
        {
          "input": {"op": "^", "args": ["a", {"op": "^", "args": ["b", "c"]}]},
          "unicode": "a^(b^c)",
          "latex": "a^{b^{c}}",
          "ascii": "a^(b^c)",
          "note": "Exponentiation is right-associative"
        },
        {
          "input": {"op": "^", "args": [{"op": "^", "args": ["a", "b"]}, "c"]},
          "unicode": "(a^b)^c",
          "latex": "(a^{b})^{c}",
          "ascii": "(a^b)^c",
          "note": "Left-grouped exponentiation needs parentheses"
        }
      ]
    },

    {
      "category": "Mixed Operations",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "*", "args": [{"op": "sin", "args": ["x"]}, {"op": "cos", "args": ["y"]}]}, {"op": "^", "args": ["z", 2]}]},
          "unicode": "sin(x)·cos(y) + z²",
          "latex": "\\sin(x) \\cdot \\cos(y) + z^{2}",
          "ascii": "sin(x) * cos(y) + z^2",
          "note": "Complex expression with all precedence levels"
        },
        {
          "input": {"op": "/", "args": [{"op": "+", "args": ["a", "b"]}, {"op": "*", "args": ["c", "d"]}]},
          "unicode": "(a + b)/(c·d)",
          "latex": "\\frac{a + b}{c \\cdot d}",
          "ascii": "(a + b) / (c * d)",
          "note": "Division with complex numerator and denominator"
        }
      ]
    },

    {
      "category": "Chemical Species",
      "cases": [
        {
          "input": {"op": "*", "args": ["O3", "NO"]},
          "unicode": "O₃·NO",
          "latex": "\\mathrm{O_3} \\cdot \\mathrm{NO}",
          "ascii": "O3 * NO",
          "note": "Chemical species with subscripts"
        },
        {
          "input": {"op": "+", "args": [{"op": "D", "args": ["CH2O"], "wrt": "t"}, {"op": "*", "args": ["k_OH", "CH2O", "OH"]}]},
          "unicode": "∂CH₂O/∂t + k_OH·CH₂O·OH",
          "latex": "\\frac{\\partial \\mathrm{CH_2O}}{\\partial t} + k_{\\mathrm{OH}} \\cdot \\mathrm{CH_2O} \\cdot \\mathrm{OH}",
          "ascii": "D(CH2O,t) + k_OH * CH2O * OH",
          "note": "Complex chemical equation with subscripts"
        }
      ]
    },

    {
      "category": "Spatial Operators",
      "cases": [
        {
          "input": {"op": "+", "args": [{"op": "grad", "args": ["phi"], "dim": "x"}, {"op": "laplacian", "args": ["psi"]}]},
          "unicode": "∂φ/∂x + ∇²ψ",
          "latex": "\\frac{\\partial \\phi}{\\partial x} + \\nabla^2 \\psi",
          "ascii": "grad(phi,x) + laplacian(psi)",
          "note": "Spatial operators in atmospheric modeling"
        },
        {
          "input": {"op": "div", "args": [{"op": "*", "args": ["u", "tracer"]}]},
          "unicode": "∇·(u·tracer)",
          "latex": "\\nabla \\cdot (u \\cdot \\mathrm{tracer})",
          "ascii": "div(u * tracer)",
          "note": "Divergence of flux"
        }
      ]
    },

    {
      "category": "Logical Operations",
      "cases": [
        {
          "input": {"op": "and", "args": [{"op": ">", "args": ["x", 0]}, {"op": "<", "args": ["x", 10]}]},
          "unicode": "x > 0 ∧ x < 10",
          "latex": "x > 0 \\land x < 10",
          "ascii": "(x > 0) and (x < 10)",
          "note": "Logical conjunction of comparisons"
        },
        {
          "input": {"op": "or", "args": [{"op": "<=", "args": ["t", 0]}, {"op": ">=", "args": ["t", 86400]}]},
          "unicode": "t ≤ 0 ∨ t ≥ 86400",
          "latex": "t \\leq 0 \\lor t \\geq 86400",
          "ascii": "(t <= 0) or (t >= 86400)",
          "note": "Outside time window condition"
        }
      ]
    },

    {
      "category": "Event Operators",
      "cases": [
        {
          "input": {"op": "Pre", "args": ["velocity"]},
          "unicode": "Pre(velocity)",
          "latex": "\\mathrm{Pre}(\\mathrm{velocity})",
          "ascii": "Pre(velocity)",
          "note": "Pre operator for events"
        },
        {
          "input": {"op": "+", "args": [{"op": "Pre", "args": ["x"]}, 1]},
          "unicode": "Pre(x) + 1",
          "latex": "\\mathrm{Pre}(x) + 1",
          "ascii": "Pre(x) + 1",
          "note": "Pre operator in arithmetic expression"
        }
      ]
    }
  ],

  "rendering_requirements": {
    "unicode_format": {
      "multiplication": "·",
      "minus": "−",
      "subscripts": "₀₁₂₃₄₅₆₇₈₉",
      "superscripts": "⁰¹²³⁴⁵⁶⁷⁸⁹",
      "derivatives": "∂",
      "spatial_ops": {
        "gradient": "∂/∂",
        "divergence": "∇·",
        "laplacian": "∇²"
      },
      "logical_ops": {
        "and": "∧",
        "or": "∨",
        "not": "¬"
      },
      "comparisons": {
        "<=": "≤",
        ">=": "≥",
        "!=": "≠"
      }
    },

    "latex_format": {
      "fractions": "\\frac{numerator}{denominator}",
      "derivatives": "\\frac{\\partial var}{\\partial t}",
      "exponents": "base^{exponent}",
      "chemical_species": "\\mathrm{species_name}",
      "subscripts": "var_{subscript}",
      "spatial_ops": {
        "gradient": "\\frac{\\partial}{\\partial dim}",
        "divergence": "\\nabla \\cdot",
        "laplacian": "\\nabla^2"
      },
      "functions": {
        "sin": "\\sin",
        "cos": "\\cos",
        "exp": "\\exp",
        "log": "\\ln"
      }
    },

    "precedence_rules": [
      {"level": 1, "operators": ["function_application", "Pre", "D", "grad", "div", "laplacian"]},
      {"level": 2, "operators": ["^"], "associativity": "right"},
      {"level": 3, "operators": ["-"], "note": "unary minus"},
      {"level": 4, "operators": ["*", "/"], "associativity": "left"},
      {"level": 5, "operators": ["+", "-"], "associativity": "left"},
      {"level": 6, "operators": [">", "<", ">=", "<=", "==", "!="]},
      {"level": 7, "operators": ["and"]},
      {"level": 8, "operators": ["or"]}
    ]
  }
}