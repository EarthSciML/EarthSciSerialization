{
  "description": "Expression tree analysis with detailed AST-based dependency extraction",
  "input_file": "expr_graphs_variable_deps.esm",
  "analysis_type": "ast_dependency_graph",

  "test_cases": [
    {
      "name": "Nested arithmetic expression",
      "input_selector": {
        "type": "expression",
        "system": "VariableDependencyModel",
        "equation_index": 0,
        "expression": {
          "op": "*",
          "args": [
            { "op": "exp", "args": [{ "op": "/", "args": [-1000, "T"] }] },
            "P",
            "z"
          ]
        }
      },
      "expected_ast_nodes": [
        {
          "id": "root",
          "op": "*",
          "type": "operator",
          "arity": 3,
          "children": ["exp_node", "P_var", "z_var"]
        },
        {
          "id": "exp_node",
          "op": "exp",
          "type": "function",
          "arity": 1,
          "children": ["div_node"]
        },
        {
          "id": "div_node",
          "op": "/",
          "type": "operator",
          "arity": 2,
          "children": ["const_-1000", "T_var"]
        },
        {
          "id": "const_-1000",
          "value": -1000,
          "type": "constant",
          "arity": 0
        },
        {
          "id": "T_var",
          "name": "T",
          "type": "variable",
          "arity": 0
        },
        {
          "id": "P_var",
          "name": "P",
          "type": "variable",
          "arity": 0
        },
        {
          "id": "z_var",
          "name": "z",
          "type": "variable",
          "arity": 0
        }
      ],
      "expected_variable_dependencies": [
        {
          "variable": "T",
          "path_to_root": ["T_var", "div_node", "exp_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 3,
          "surrounding_context": "exp(-1000/T)"
        },
        {
          "variable": "P",
          "path_to_root": ["P_var", "root"],
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "direct multiplicative factor"
        },
        {
          "variable": "z",
          "path_to_root": ["z_var", "root"],
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "direct multiplicative factor"
        }
      ]
    },

    {
      "name": "Power and composite function expression",
      "input_selector": {
        "type": "expression",
        "system": "VariableDependencyModel",
        "equation_index": 1,
        "expression": {
          "op": "*",
          "args": [
            "k2",
            { "op": "^", "args": ["x", "alpha"] },
            { "op": "^", "args": ["z", "beta"] }
          ]
        }
      },
      "expected_ast_nodes": [
        {
          "id": "root",
          "op": "*",
          "type": "operator",
          "arity": 3,
          "children": ["k2_var", "x_power", "z_power"]
        },
        {
          "id": "x_power",
          "op": "^",
          "type": "operator",
          "arity": 2,
          "children": ["x_var", "alpha_var"]
        },
        {
          "id": "z_power",
          "op": "^",
          "type": "operator",
          "arity": 2,
          "children": ["z_var", "beta_var"]
        }
      ],
      "expected_variable_dependencies": [
        {
          "variable": "k2",
          "path_to_root": ["k2_var", "root"],
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "rate constant factor"
        },
        {
          "variable": "x",
          "path_to_root": ["x_var", "x_power", "root"],
          "dependency_type": "power_base",
          "depth": 2,
          "surrounding_context": "x^alpha"
        },
        {
          "variable": "alpha",
          "path_to_root": ["alpha_var", "x_power", "root"],
          "dependency_type": "power_exponent",
          "depth": 2,
          "surrounding_context": "exponent in x^alpha"
        },
        {
          "variable": "z",
          "path_to_root": ["z_var", "z_power", "root"],
          "dependency_type": "power_base",
          "depth": 2,
          "surrounding_context": "z^beta"
        },
        {
          "variable": "beta",
          "path_to_root": ["beta_var", "z_power", "root"],
          "dependency_type": "power_exponent",
          "depth": 2,
          "surrounding_context": "exponent in z^beta"
        }
      ]
    },

    {
      "name": "Deeply nested expression with multiple function composition",
      "input_selector": {
        "type": "expression",
        "system": "VariableDependencyModel",
        "equation_index": 2,
        "expression": {
          "op": "*",
          "args": [
            { "op": "sqrt", "args": [
              { "op": "+", "args": [
                { "op": "*", "args": ["x", "y"] },
                { "op": "^", "args": ["T", 2] }
              ]}
            ]},
            { "op": "log", "args": [
              { "op": "+", "args": [
                1.0,
                { "op": "*", "args": ["P", "alpha", "beta"] }
              ]}
            ]}
          ]
        }
      },
      "expected_complexity_metrics": {
        "max_depth": 4,
        "total_nodes": 15,
        "variable_nodes": 6,
        "operator_nodes": 7,
        "constant_nodes": 2,
        "function_nodes": 2
      },
      "expected_variable_dependencies": [
        {
          "variable": "x",
          "path_to_root": ["x_var", "xy_mult", "sum1", "sqrt_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "sqrt(x*y + T^2)"
        },
        {
          "variable": "y",
          "path_to_root": ["y_var", "xy_mult", "sum1", "sqrt_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "sqrt(x*y + T^2)"
        },
        {
          "variable": "T",
          "path_to_root": ["T_var", "T_squared", "sum1", "sqrt_node", "root"],
          "dependency_type": "power_base",
          "depth": 4,
          "surrounding_context": "sqrt(x*y + T^2)"
        },
        {
          "variable": "P",
          "path_to_root": ["P_var", "triple_mult", "sum2", "log_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "log(1 + P*alpha*beta)"
        },
        {
          "variable": "alpha",
          "path_to_root": ["alpha_var", "triple_mult", "sum2", "log_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "log(1 + P*alpha*beta)"
        },
        {
          "variable": "beta",
          "path_to_root": ["beta_var", "triple_mult", "sum2", "log_node", "root"],
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "log(1 + P*alpha*beta)"
        }
      ]
    },

    {
      "name": "Reaction rate with Arrhenius kinetics",
      "input_selector": {
        "type": "reaction_rate",
        "system": "ComplexKinetics",
        "reaction_id": "R1",
        "expression": {
          "op": "*",
          "args": [
            "k_forward",
            { "op": "exp", "args": [
              { "op": "/", "args": [
                { "op": "-", "args": ["activation_energy"] },
                { "op": "*", "args": [8.314, "T_reaction"] }
              ]}
            ]},
            "A",
            "B"
          ]
        }
      },
      "expected_variable_dependencies": [
        {
          "variable": "k_forward",
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "pre-exponential factor"
        },
        {
          "variable": "activation_energy",
          "dependency_type": "additive",
          "depth": 4,
          "surrounding_context": "exp(-activation_energy/(8.314*T_reaction))"
        },
        {
          "variable": "T_reaction",
          "dependency_type": "multiplicative",
          "depth": 4,
          "surrounding_context": "exp(-activation_energy/(8.314*T_reaction))"
        },
        {
          "variable": "A",
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "substrate concentration"
        },
        {
          "variable": "B",
          "dependency_type": "multiplicative",
          "depth": 1,
          "surrounding_context": "substrate concentration"
        }
      ],
      "kinetics_analysis": {
        "type": "arrhenius",
        "temperature_dependent": true,
        "order": {
          "A": 1,
          "B": 1,
          "overall": 2
        }
      }
    }
  ],

  "graph_export_formats": {
    "dot": "digraph AST_Dependencies {\n  node [shape=box];\n  subgraph cluster_variables {\n    label=\"Variables\";\n    style=filled;\n    color=lightgrey;\n    T P z x y alpha beta k2 k_forward activation_energy T_reaction A B [color=lightblue];\n  }\n  \n  subgraph cluster_operators {\n    label=\"Operators\";\n    style=filled;\n    color=lightyellow;\n    multiply [label=\"*\"];\n    exp [label=\"exp\"];\n    divide [label=\"/\"];\n    power [label=\"^\"];\n    sqrt [label=\"sqrt\"];\n    log [label=\"log\"];\n    add [label=\"+\"];\n  }\n  \n  # AST structure edges\n  T -> exp [label=\"argument\"];\n  exp -> multiply [label=\"factor\"];\n  P -> multiply [label=\"factor\"];\n  z -> multiply [label=\"factor\"];\n  \n  # Dependency strength indicators\n  T [penwidth=3]; # High impact through exponential\n  P [penwidth=2]; # Medium impact, direct multiplication\n  z [penwidth=2]; # Medium impact, direct multiplication\n}",

    "mermaid": "graph TD\n  subgraph Variables\n    T[T - Temperature]\n    P[P - Pressure]\n    z[z - Concentration]\n    x[x - State]\n    y[y - State]\n  end\n  \n  subgraph Operators\n    exp[exp function]\n    mult[* operator]\n    div[/ operator]\n  end\n  \n  T -.-> div\n  div --> exp\n  exp --> mult\n  P --> mult\n  z --> mult\n  \n  classDef variable fill:#e1f5fe\n  classDef operator fill:#fff3e0\n  classDef highImpact stroke:#f44336,stroke-width:3px\n  \n  class T,P,z,x,y variable\n  class exp,mult,div operator\n  class T highImpact",

    "json_adjacency": {
      "nodes": ["T", "P", "z", "x", "y", "alpha", "beta", "k2", "exp", "*", "/", "^", "sqrt", "log", "+"],
      "adjacency": {
        "T": [
          {"neighbor": "exp", "edge": {"type": "function_argument", "depth": 3}},
          {"neighbor": "^", "edge": {"type": "power_base", "depth": 2}}
        ],
        "P": [
          {"neighbor": "*", "edge": {"type": "direct_factor", "depth": 1}}
        ],
        "z": [
          {"neighbor": "*", "edge": {"type": "direct_factor", "depth": 1}},
          {"neighbor": "^", "edge": {"type": "power_base", "depth": 2}}
        ],
        "x": [
          {"neighbor": "*", "edge": {"type": "direct_factor", "depth": 2}},
          {"neighbor": "^", "edge": {"type": "power_base", "depth": 2}}
        ],
        "y": [
          {"neighbor": "*", "edge": {"type": "direct_factor", "depth": 2}}
        ],
        "alpha": [
          {"neighbor": "^", "edge": {"type": "power_exponent", "depth": 2}}
        ],
        "beta": [
          {"neighbor": "^", "edge": {"type": "power_exponent", "depth": 2}}
        ]
      }
    }
  }
}