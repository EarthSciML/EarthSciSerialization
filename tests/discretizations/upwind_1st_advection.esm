{
  "esm": "0.1.0",
  "metadata": {
    "name": "Upwind1stAdvection",
    "description": "Discretization scheme: 1st-order upwind finite difference for advection on a uniform cartesian grid. Uses ifelse on a velocity sign to pick the upwind neighbor.",
    "authors": ["gt-yhkn"],
    "created": "2026-04-19T00:00:00Z",
    "tags": ["discretization", "cartesian", "advection", "upwind"]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "upwind_1st": {
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx)",
      "free_variables": ["$u", "$x"],
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 },
          "coeff": {
            "op": "ifelse",
            "args": [
              { "op": ">=", "args": ["vel", 0] },
              { "op": "/", "args": [-1, "dx"] },
              0
            ]
          }
        },
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
          "coeff": {
            "op": "ifelse",
            "args": [
              { "op": ">=", "args": ["vel", 0] },
              { "op": "/", "args": [1, "dx"] },
              { "op": "/", "args": [-1, "dx"] }
            ]
          }
        },
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 1 },
          "coeff": {
            "op": "ifelse",
            "args": [
              { "op": ">=", "args": ["vel", 0] },
              0,
              { "op": "/", "args": [1, "dx"] }
            ]
          }
        }
      ],
      "description": "1st-order upwind finite difference for scalar advection; the sign of the velocity 'vel' selects the upwind neighbor."
    }
  }
}
