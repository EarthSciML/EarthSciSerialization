{
  "esm": "0.1.0",
  "metadata": {
    "name": "PeriodicBC",
    "description": "Discretization scheme: periodic boundary condition on a cartesian grid. Demonstrates ghost_vars declaration and an indirect selector providing a wrapped index.",
    "authors": ["gt-yhkn"],
    "created": "2026-04-19T00:00:00Z",
    "tags": ["discretization", "boundary_condition", "periodic"]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "periodic_bc_x": {
      "applies_to": { "op": "boundary", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "requires_locations": ["cell_center"],
      "ghost_vars": [
        { "name": "phi_ghost_left",  "source": "periodic", "description": "Left halo cell wraps to the rightmost interior cell." },
        { "name": "phi_ghost_right", "source": "periodic", "description": "Right halo cell wraps to the leftmost interior cell." }
      ],
      "stencil": [
        {
          "selector": {
            "kind": "indirect",
            "index_expr": { "op": "%", "args": [{ "op": "+", "args": ["$target", "nx"] }, "nx"] }
          },
          "coeff": 1
        }
      ],
      "description": "Periodic-BC scheme: the ghost cell at position $target wraps via modulo nx into the interior."
    }
  }
}
