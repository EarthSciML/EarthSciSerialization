{
  "esm": "0.2.0",
  "metadata": {
    "name": "disc_ref_resolve",
    "description": "Tests {ref} resolution in a discretizations block (§4.7.1). The centered_grad scheme is loaded from an external ESD rule file via {ref} instead of being defined inline."
  },
  "models": {
    "M": {
      "variables": {
        "x": { "type": "state", "default": 0.0, "units": "1" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["x"], "wrt": "t" }, "rhs": 0.0 }
      ]
    }
  },
  "discretizations": {
    "centered_grad": { "ref": "centered_grad_rule.esm" }
  }
}
