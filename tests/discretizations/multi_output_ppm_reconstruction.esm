{
  "esm": "0.2.0",
  "metadata": {
    "name": "MultiOutputPPMReconstruction",
    "description": "Multi-output stencil rule (RFC §7.9): PPM edge reconstruction emitting q_left_edge and q_right_edge from a single reconstruct(q, dim=x) operator match, consumed by a flux scheme via the provider `requires` mechanism. This fixture exercises parse + round-trip of the multi_output_stencil shape (provider) and the Discretization.requires consumer map. Bindings need not execute demand-driven expansion — schema conformance and lossless round-trip are the acceptance criteria.",
    "authors": ["ess-7hb"],
    "created": "2026-06-14T00:00:00Z",
    "tags": ["discretization", "cartesian", "multi-output", "ppm", "reconstruction"]
  },
  "models": {
    "Empty": {
      "variables": {
        "q": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["q"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "ppm_reconstruction": {
      "kind": "multi_output_stencil",
      "applies_to": { "op": "reconstruct", "args": ["$q"], "dim": "$x" },
      "grid_family": "cartesian",
      "outputs": ["q_left_edge", "q_right_edge"],
      "emits_location": "face",
      "primary": null,
      "accuracy": "O(dx^2)",
      "free_variables": ["$q", "$x"],
      "stencil": {
        "q_left_edge": [
          {
            "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 },
            "coeff": 0.5
          },
          {
            "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
            "coeff": 0.5
          }
        ],
        "q_right_edge": [
          {
            "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
            "coeff": 0.5
          },
          {
            "selector": { "kind": "cartesian", "axis": "$x", "offset": 1 },
            "coeff": 0.5
          }
        ]
      },
      "description": "Linear-order PPM edge reconstruction: left edge averages cells [i-1, i]; right edge averages cells [i, i+1]. Provider-only (primary=null): fires only when demanded via consumer requires."
    },
    "ppm_flux": {
      "kind": "stencil",
      "applies_to": { "op": "flux", "args": ["$q", "$c"], "dim": "$x" },
      "grid_family": "cartesian",
      "free_variables": ["$q", "$c", "$x"],
      "requires": {
        "q_left_edge":  "ppm_reconstruction#q_left_edge",
        "q_right_edge": "ppm_reconstruction#q_right_edge"
      },
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 0 },
          "coeff": {
            "op": "-",
            "args": [
              { "op": "*", "args": ["$c", "q_right_edge"] },
              { "op": "*", "args": ["$c", "q_left_edge"] }
            ]
          }
        }
      ],
      "description": "PPM flux scheme consuming left/right edges from ppm_reconstruction via the demand-driven provider mechanism (RFC §7.9). The stencil coefficient encodes upwind flux: c * (q_right - q_left)."
    }
  }
}
