{
  "esm": "0.2.0",
  "metadata": {
    "name": "CAM5FvFfslAdvection1D",
    "description": "Discretization rule: minimal 1D flux-form semi-Lagrangian (FFSL) advection — the Lin & Rood (1996 MWR) family used by CAM5's finite-volume dycore. This fixture exercises the new `kind: flux_form_semi_lagrangian` rule type with a centered reconstruction and conservative remap on a single axis. Composes with a dimensional-split rule (sibling bead) for the full 2D scheme.",
    "authors": ["esm-1rj"],
    "created": "2026-04-24T00:00:00Z",
    "tags": ["discretization", "cartesian", "advection", "flux-form", "semi-lagrangian", "ffsl", "cam5"],
    "references": [
      {
        "citation": "Lin, S.-J., and R. B. Rood (1996), Multidimensional flux-form semi-Lagrangian transport schemes, Mon. Wea. Rev., 124, 2046-2070.",
        "doi": "10.1175/1520-0493(1996)124<2046:MFFSLT>2.0.CO;2"
      }
    ]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "cam5_ffsl_1d": {
      "kind": "flux_form_semi_lagrangian",
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "reconstruction": {
        "order": "centered"
      },
      "remap": {
        "semantics": "conservative",
        "flux_form": "lin_rood_1996"
      },
      "cfl_policy": "conservative",
      "dimensions": ["x"],
      "accuracy": "O(dx^2)",
      "free_variables": ["$u", "$x"],
      "description": "1D flux-form semi-Lagrangian advection (centered reconstruction, conservative remap) — the single-axis building block that a dimensional-split rule composes into the CAM5 FV dycore's 2D scheme.",
      "reference": {
        "citation": "Lin, S.-J., and R. B. Rood (1996), Mon. Wea. Rev., 124, 2046-2070.",
        "doi": "10.1175/1520-0493(1996)124<2046:MFFSLT>2.0.CO;2"
      }
    }
  }
}
