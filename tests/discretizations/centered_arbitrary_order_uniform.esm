{
  "esm": "0.1.0",
  "metadata": {
    "name": "CenteredArbitraryOrderUniform",
    "description": "Discretization scheme: 4th-order centered finite difference for grad on a uniform cartesian grid, authored against the arbitrary-order family via the order parameter. Exercises the RFC §7.1.2 order field (esm-z6d). Retired hand-authored stencil array in favour of declarative stencil_gen (ess-bq1); the loader expands to byte-identical weights [+1,-8,+8,-1]/(12*dx) at offsets [-2,-1,+1,+2].",
    "authors": ["esm-z6d"],
    "created": "2026-04-24T00:00:00Z",
    "tags": ["discretization", "cartesian", "gradient", "fornberg", "arbitrary-order", "stencil-gen"]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "centered_arbitrary_order_uniform": {
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx^4)",
      "order": 4,
      "stencil_gen": {
        "method": "fornberg",
        "deriv_order": 1,
        "accuracy_order": 4,
        "stagger": "centered",
        "axis": "$x",
        "spacing": "dx"
      },
      "description": "4th-order centered finite difference for gradient on a uniform grid, with Fornberg weights [+1,-8,+8,-1]/(12*dx) at offsets [-2,-1,+1,+2]. Generated by the Fornberg recurrence (ess-bq1). The order field selects stencil width at rule-application time."
    }
  }
}
