{
  "esm": "0.2.0",
  "metadata": {
    "name": "DimSplit2DStrang",
    "description": "Discretization scheme: 2D Strang-split gradient built from the 1D centered_2nd_uniform inner scheme applied along x and y. RFC §7.4 worked example.",
    "authors": ["esm-okt"],
    "created": "2026-04-24T00:00:00Z",
    "tags": ["discretization", "cartesian", "dimensional_split", "strang"]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "centered_2nd_uniform": {
      "kind": "stencil",
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx^2)",
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 },
          "coeff": { "op": "/", "args": [-1, { "op": "*", "args": [2, "dx"] }] }
        },
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 1 },
          "coeff": { "op": "/", "args": [1, { "op": "*", "args": [2, "dx"] }] }
        }
      ],
      "description": "Classic centered O(dx^2) finite difference for the 1D gradient on a uniform grid."
    },
    "strang_grad_xy": {
      "kind": "dimensional_split",
      "applies_to": { "op": "grad", "args": ["$u"] },
      "grid_family": "cartesian",
      "axes": ["x", "y"],
      "inner_rule": "centered_2nd_uniform",
      "splitting": "strang",
      "order_of_sweeps": "alternating",
      "accuracy": "O(dt^2) + O(dx^2)",
      "description": "2D gradient applied as Strang-split 1D sweeps (Δt/2 along x, Δt along y, Δt/2 along x) using the 1D centered_2nd_uniform inner scheme."
    }
  }
}
