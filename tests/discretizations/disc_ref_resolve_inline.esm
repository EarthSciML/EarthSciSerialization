{
  "esm": "0.2.0",
  "metadata": {
    "name": "disc_ref_resolve_inline",
    "description": "Inline equivalent of disc_ref_resolve.esm. The centered_grad scheme is defined directly in this file instead of via {ref}."
  },
  "models": {
    "M": {
      "variables": {
        "x": { "type": "state", "default": 0.0, "units": "1" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["x"], "wrt": "t" }, "rhs": 0.0 }
      ]
    }
  },
  "discretizations": {
    "centered_grad": {
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx^2)",
      "stencil": [
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": -1 },
          "coeff": { "op": "/", "args": [-1, { "op": "*", "args": [2, "dx"] }] }
        },
        {
          "selector": { "kind": "cartesian", "axis": "$x", "offset": 1 },
          "coeff": { "op": "/", "args": [1, { "op": "*", "args": [2, "dx"] }] }
        }
      ]
    }
  }
}
