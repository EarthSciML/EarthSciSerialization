{
  "esm": "0.1.0",
  "metadata": {
    "name": "Centered2ndUniform",
    "description": "Discretization scheme: 2nd-order centered finite difference for grad on a uniform cartesian grid. RFC §7 example. Retired hand-authored stencil array in favour of declarative stencil_gen (ess-bq1); the loader expands to identical weights [-1,+1]/(2*dx) at offsets [-1,+1].",
    "authors": ["gt-yhkn"],
    "created": "2026-04-19T00:00:00Z",
    "tags": ["discretization", "cartesian", "gradient", "fornberg", "stencil-gen"]
  },
  "models": {
    "Empty": {
      "variables": {
        "phi": { "type": "state", "units": "1", "default": 0.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["phi"], "wrt": "t" },
          "rhs": 0.0
        }
      ]
    }
  },
  "discretizations": {
    "centered_2nd_uniform": {
      "applies_to": { "op": "grad", "args": ["$u"], "dim": "$x" },
      "grid_family": "cartesian",
      "combine": "+",
      "accuracy": "O(dx^2)",
      "stencil_gen": {
        "method": "fornberg",
        "deriv_order": 1,
        "accuracy_order": 2,
        "stagger": "centered",
        "axis": "$x",
        "spacing": "dx"
      },
      "description": "Classic centered O(dx^2) finite difference for the gradient on a uniform grid. Weights [-1,+1]/(2*dx) generated by the Fornberg recurrence (ess-bq1)."
    }
  }
}
