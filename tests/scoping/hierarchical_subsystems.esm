{
  "esm": "0.1.0",
  "metadata": {
    "name": "HierarchicalSubsystemTests",
    "description": "Test hierarchical subsystem and scoped reference resolution with 3-level nesting",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-14T00:00:00Z",
    "tags": ["scoping", "subsystems", "hierarchical", "reference-resolution"]
  },

  "models": {
    "AtmosphereModel": {
      "reference": {
        "notes": "Top-level atmospheric model with nested subsystems"
      },
      "variables": {
        "global_temperature": {
          "type": "parameter",
          "units": "K",
          "default": 288.15,
          "description": "Global mean temperature"
        },
        "surface_pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Global mean surface pressure"
        }
      },
      "equations": [],

      "subsystems": {
        "TroposphereLayer": {
          "reference": {
            "notes": "Tropospheric chemistry and dynamics"
          },
          "variables": {
            "layer_height": {
              "type": "parameter",
              "units": "m",
              "default": 12000.0,
              "description": "Troposphere height"
            },
            "mixing_efficiency": {
              "type": "parameter",
              "units": "dimensionless",
              "default": 0.8,
              "description": "Vertical mixing efficiency"
            }
          },
          "equations": [],

          "subsystems": {
            "ChemicalMechanism": {
              "reference": {
                "notes": "Nested chemical mechanism within troposphere"
              },
              "variables": {
                "O3": {
                  "type": "state",
                  "units": "mol/mol",
                  "default": 40e-9,
                  "description": "Ozone mixing ratio"
                },
                "NO": {
                  "type": "state",
                  "units": "mol/mol",
                  "default": 0.1e-9,
                  "description": "Nitric oxide mixing ratio"
                },
                "NO2": {
                  "type": "state",
                  "units": "mol/mol",
                  "default": 1e-9,
                  "description": "Nitrogen dioxide mixing ratio"
                },
                "rate_constant": {
                  "type": "parameter",
                  "units": "cm^3/molec/s",
                  "default": 1.8e-12,
                  "description": "Temperature-dependent rate constant"
                }
              },
              "equations": [
                {
                  "_comment": "NO + O3 → NO2 reaction",
                  "lhs": {"op": "D", "args": ["O3"], "wrt": "t"},
                  "rhs": {"op": "*", "args": [{"op": "-", "args": ["rate_constant"]}, "O3", "NO"]}
                },
                {
                  "lhs": {"op": "D", "args": ["NO"], "wrt": "t"},
                  "rhs": {"op": "*", "args": [{"op": "-", "args": ["rate_constant"]}, "O3", "NO"]}
                },
                {
                  "lhs": {"op": "D", "args": ["NO2"], "wrt": "t"},
                  "rhs": {"op": "*", "args": ["rate_constant", "O3", "NO"]}
                }
              ]
            },

            "TransportProcess": {
              "reference": {
                "notes": "Transport within troposphere"
              },
              "variables": {
                "horizontal_diffusivity": {
                  "type": "parameter",
                  "units": "m^2/s",
                  "default": 1000.0,
                  "description": "Horizontal turbulent diffusivity"
                },
                "vertical_diffusivity": {
                  "type": "parameter",
                  "units": "m^2/s",
                  "default": 10.0,
                  "description": "Vertical turbulent diffusivity"
                }
              },
              "equations": [
                {
                  "_comment": "Horizontal diffusion for _var placeholder",
                  "lhs": {"op": "D", "args": ["_var"], "wrt": "t"},
                  "rhs": {"op": "*", "args": ["horizontal_diffusivity", {"op": "laplacian", "args": ["_var"]}]}
                }
              ]
            }
          }
        },

        "StratosphereLayer": {
          "reference": {
            "notes": "Stratospheric chemistry with ozone production"
          },
          "variables": {
            "layer_top": {
              "type": "parameter",
              "units": "m",
              "default": 50000.0,
              "description": "Stratosphere top"
            }
          },
          "equations": [],

          "subsystems": {
            "StratChemistry": {
              "variables": {
                "O3": {
                  "type": "state",
                  "units": "mol/mol",
                  "default": 8e-6,
                  "description": "Stratospheric ozone"
                },
                "production_rate": {
                  "type": "parameter",
                  "units": "mol/mol/s",
                  "default": 1e-12,
                  "description": "Ozone production from O2 photolysis"
                },
                "loss_rate": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 1e-7,
                  "description": "Ozone loss rate"
                }
              },
              "equations": [
                {
                  "_comment": "Stratospheric ozone production and loss",
                  "lhs": {"op": "D", "args": ["O3"], "wrt": "t"},
                  "rhs": {
                    "op": "+",
                    "args": [
                      "production_rate",
                      {"op": "*", "args": [{"op": "-", "args": ["loss_rate"]}, "O3"]}
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },

    "SurfaceModel": {
      "reference": {
        "notes": "Surface processes for testing cross-system scoped references"
      },
      "variables": {
        "land_use_type": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Land use category"
        },
        "surface_temperature": {
          "type": "parameter",
          "units": "K",
          "default": 295.0,
          "description": "Surface temperature"
        }
      },
      "equations": [],

      "subsystems": {
        "VegetationCanopy": {
          "variables": {
            "leaf_area_index": {
              "type": "parameter",
              "units": "m^2/m^2",
              "default": 3.0,
              "description": "Leaf area index"
            },
            "stomatal_conductance": {
              "type": "parameter",
              "units": "m/s",
              "default": 0.01,
              "description": "Stomatal conductance"
            }
          },
          "equations": []
        }
      }
    }
  },

  "data_loaders": {
    "MeteorologicalFields": {
      "type": "gridded_data",
      "loader_id": "ECMWF_ERA5",
      "provides": {
        "temperature_3d": {"units": "K", "description": "3D temperature field"},
        "wind_u": {"units": "m/s", "description": "Eastward wind component"},
        "wind_v": {"units": "m/s", "description": "Northward wind component"}
      }
    }
  },

  "coupling": [
    {
      "_comment": "Test scoped references in operator_compose",
      "type": "operator_compose",
      "systems": ["AtmosphereModel.TroposphereLayer.ChemicalMechanism", "AtmosphereModel.TroposphereLayer.TransportProcess"],
      "translate": {
        "AtmosphereModel.TroposphereLayer.ChemicalMechanism.O3": "AtmosphereModel.TroposphereLayer.TransportProcess._var",
        "AtmosphereModel.TroposphereLayer.ChemicalMechanism.NO": "AtmosphereModel.TroposphereLayer.TransportProcess._var",
        "AtmosphereModel.TroposphereLayer.ChemicalMechanism.NO2": "AtmosphereModel.TroposphereLayer.TransportProcess._var"
      },
      "description": "Add transport to tropospheric chemistry using scoped references"
    },

    {
      "_comment": "Test variable_map with deeply nested references",
      "type": "variable_map",
      "from": "MeteorologicalFields.temperature_3d",
      "to": "AtmosphereModel.TroposphereLayer.ChemicalMechanism.rate_constant",
      "transform": "param_to_var",
      "description": "Map 3D temperature to affect reaction rate in nested chemistry"
    },

    {
      "type": "variable_map",
      "from": "AtmosphereModel.global_temperature",
      "to": "SurfaceModel.surface_temperature",
      "transform": "additive",
      "factor": 1.02,
      "description": "Surface temperature follows global temperature with offset"
    },

    {
      "_comment": "Test cross-system variable reference with 3-level nesting",
      "type": "variable_map",
      "from": "AtmosphereModel.TroposphereLayer.mixing_efficiency",
      "to": "SurfaceModel.VegetationCanopy.stomatal_conductance",
      "transform": "multiplicative",
      "factor": 0.5,
      "description": "Atmospheric mixing affects vegetation gas exchange"
    },

    {
      "_comment": "Test event with cross-system scoped references",
      "type": "event",
      "event_type": "continuous",
      "name": "stratosphere_troposphere_exchange",
      "conditions": [
        {
          "_comment": "When tropospheric ozone drops below threshold",
          "op": "-",
          "args": ["AtmosphereModel.TroposphereLayer.ChemicalMechanism.O3", 20e-9]
        }
      ],
      "affects": [
        {
          "_comment": "Increase stratospheric ozone transport downward",
          "lhs": "AtmosphereModel.TroposphereLayer.ChemicalMechanism.O3",
          "rhs": {
            "op": "+",
            "args": [
              {"op": "Pre", "args": ["AtmosphereModel.TroposphereLayer.ChemicalMechanism.O3"]},
              {"op": "*", "args": [0.1, "AtmosphereModel.StratosphereLayer.StratChemistry.O3"]}
            ]
          }
        }
      ],
      "description": "Cross-layer ozone transport using deeply nested scoped references"
    }
  ],

  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-06-01T00:00:00Z",
      "end": "2024-06-02T00:00:00Z"
    },
    "spatial": {
      "z": {
        "min": 0.0,
        "max": 50000.0,
        "units": "meters",
        "grid_spacing": 1000.0,
        "description": "Vertical coordinate"
      }
    },
    "initial_conditions": {
      "type": "constant",
      "value": 0.0
    },
    "boundary_conditions": [
      {
        "type": "zero_gradient",
        "dimensions": ["z"]
      }
    ],
    "element_type": "Float64"
  },

  "solver": {
    "strategy": "strang_threads",
    "config": {
      "threads": 2,
      "stiff_algorithm": "Rosenbrock23",
      "timestep": 600.0,
      "stiff_kwargs": {
        "abstol": 1e-10,
        "reltol": 1e-8
      }
    }
  }
}