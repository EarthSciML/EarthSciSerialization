{
  "esm": "0.1.0",
  "metadata": {
    "name": "BareReferenceResolutionTest",
    "description": "Test fixture for bare reference resolution within system contexts (no dots in variable names)",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "scoping",
      "bare-references",
      "local-context"
    ]
  },
  "models": {
    "SimpleChemistry": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide"
        },
        "k_rate": {
          "type": "parameter",
          "units": "cm^3/molec/s",
          "default": 1.8e-12,
          "description": "Rate constant"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "k_rate"
                ]
              },
              "O3",
              "NO"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "k_rate"
                ]
              },
              "O3",
              "NO"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO2"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "k_rate",
              "O3",
              "NO"
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "temperature_adjustment",
          "conditions": [
            {
              "op": ">",
              "args": [
                "temperature",
                310.0
              ]
            }
          ],
          "affects": [
            {
              "lhs": "k_rate",
              "rhs": {
                "op": "*",
                "args": [
                  0.8,
                  {
                    "op": "Pre",
                    "args": [
                      "k_rate"
                    ]
                  }
                ]
              }
            }
          ],
          "description": "High temperature reduces reaction rate"
        }
      ],
      "subsystems": {
        "Photochemistry": {
          "variables": {
            "photolysis_rate": {
              "type": "parameter",
              "units": "1/s",
              "default": 1e-05,
              "description": "Photolysis rate"
            },
            "solar_zenith": {
              "type": "parameter",
              "units": "rad",
              "default": 0.5,
              "description": "Solar zenith angle"
            },
            "NO2_photo": {
              "type": "state",
              "units": "mol/mol",
              "default": 1e-09,
              "description": "NO2 for photolysis"
            }
          },
          "equations": [
            {
              "lhs": {
                "op": "D",
                "args": [
                  "NO2_photo"
                ],
                "wrt": "t"
              },
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "photolysis_rate"
                    ]
                  },
                  "NO2_photo",
                  {
                    "op": "cos",
                    "args": [
                      "solar_zenith"
                    ]
                  }
                ]
              }
            }
          ],
          "discrete_events": [
            {
              "name": "daily_reset",
              "trigger": {
                "type": "condition",
                "expression": {
                  "op": "and",
                  "args": [
                    {
                      "op": ">",
                      "args": [
                        "solar_zenith",
                        1.57
                      ]
                    },
                    {
                      "op": "<",
                      "args": [
                        {
                          "op": "Pre",
                          "args": [
                            "solar_zenith"
                          ]
                        },
                        1.57
                      ]
                    }
                  ]
                }
              },
              "affects": [
                {
                  "lhs": "photolysis_rate",
                  "rhs": 0.0
                }
              ],
              "description": "Reset photolysis at sunset using bare references"
            }
          ]
        }
      }
    },
    "Transport": {
      "variables": {
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0,
          "description": "Diffusion coefficient"
        },
        "velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Advection velocity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "u"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "data_loaders": {
    "MeteoData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/WRF_output/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "wind_speed": {
          "file_variable": "wind_speed",
          "units": "m/s",
          "description": "Wind speed field"
        },
        "boundary_layer_height": {
          "file_variable": "boundary_layer_height",
          "units": "m",
          "description": "PBL height"
        }
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "MeteoData.wind_speed",
      "to": "Transport.velocity",
      "transform": "identity",
      "description": "Wind speed drives transport velocity"
    },
    {
      "type": "operator_compose",
      "systems": [
        "SimpleChemistry",
        "Transport"
      ],
      "translate": {
        "SimpleChemistry.O3": "Transport._var",
        "SimpleChemistry.NO": "Transport._var",
        "SimpleChemistry.NO2": "Transport._var"
      },
      "description": "Add transport to chemistry - demonstrates scoped vs bare reference contexts"
    },
    {
      "type": "event",
      "event_type": "continuous",
      "name": "cross_system_coupling",
      "conditions": [
        {
          "op": ">",
          "args": [
            "Transport.diffusivity",
            50.0
          ]
        }
      ],
      "affects": [
        {
          "lhs": "SimpleChemistry.temperature",
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "Pre",
                "args": [
                  "SimpleChemistry.temperature"
                ]
              },
              2.0
            ]
          }
        }
      ],
      "description": "Cross-system event showing required scoped references in coupling context"
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-01T06:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 1000.0,
          "units": "m",
          "grid_spacing": 10.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "SimpleChemistry.O3": 4e-08,
          "SimpleChemistry.NO": 1e-10,
          "SimpleChemistry.NO2": 1e-09,
          "SimpleChemistry.Photochemistry.NO2_photo": 1e-09
        }
      }
    }
  }
}
