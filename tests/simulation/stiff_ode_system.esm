{
  "esm": "0.1.0",
  "metadata": {
    "name": "StiffODESystemTest",
    "description": "Stiff ODE system requiring implicit solvers for numerical stability",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "stiff",
      "numerical_stability"
    ]
  },
  "models": {
    "StiffSystem": {
      "reference": {
        "notes": "Van der Pol oscillator with small epsilon parameter creating stiffness"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 2.0,
          "description": "Position variable"
        },
        "y": {
          "type": "state",
          "units": "1",
          "default": 0.0,
          "description": "Velocity variable"
        },
        "epsilon": {
          "type": "parameter",
          "units": "1",
          "default": 0.01,
          "description": "Stiffness parameter (small value)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": "y"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "y"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "/",
                "args": [
                  1.0,
                  "epsilon"
                ]
              },
              {
                "op": "-",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          {
                            "op": "^",
                            "args": [
                              "x",
                              2
                            ]
                          },
                          1.0
                        ]
                      },
                      "y"
                    ]
                  },
                  "x"
                ]
              }
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-4,
        "abs": 1.0e-8
      },
      "tests": [
        {
          "id": "initial_condition_identity",
          "description": "Van der Pol with epsilon=0.01 (default) is extremely stiff and cannot be integrated by Tsit5 over a meaningful interval. This smoke test verifies MTK compile + solve-at-t0 round-trip: at t=0, solver returns the initial condition exactly. Larger-scale reference solutions require an implicit solver (Rosenbrock/Rodas) and are out of scope for the Tsit5-based inline runner.",
          "initial_conditions": {
            "x": 2.0,
            "y": 0.0
          },
          "parameter_overrides": {
            "epsilon": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0e-6
          },
          "assertions": [
            { "variable": "x", "time": 0.0, "expected": 2.0, "tolerance": { "abs": 1.0e-12 } },
            { "variable": "y", "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1.0e-12 } }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {},
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "StiffSystem.x": 2.0,
          "StiffSystem.y": 0.0
        }
      }
    }
  }
}
