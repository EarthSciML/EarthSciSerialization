{
  "esm": "0.1.0",
  "metadata": {
    "name": "PerformanceBenchmarksTest",
    "description": "Large-scale system for performance and scalability testing",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "performance",
      "scalability",
      "large_system"
    ]
  },
  "reaction_systems": {
    "LargeReactionNetwork": {
      "reference": {
        "notes": "Simplified atmospheric chemistry network with 50+ species and 200+ reactions"
      },
      "species": {
        "O2": {
          "units": "mol/L",
          "default": 0.21,
          "description": "Oxygen"
        },
        "N2": {
          "units": "mol/L",
          "default": 0.78,
          "description": "Nitrogen"
        },
        "H2O": {
          "units": "mol/L",
          "default": 0.01,
          "description": "Water vapor"
        },
        "CO2": {
          "units": "mol/L",
          "default": 0.0004,
          "description": "Carbon dioxide"
        },
        "O3": {
          "units": "mol/L",
          "default": 1e-08,
          "description": "Ozone"
        },
        "NO": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Nitric oxide"
        },
        "NO2": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Nitrogen dioxide"
        },
        "OH": {
          "units": "mol/L",
          "default": 1e-12,
          "description": "Hydroxyl radical"
        },
        "HO2": {
          "units": "mol/L",
          "default": 1e-11,
          "description": "Hydroperoxyl radical"
        },
        "CH4": {
          "units": "mol/L",
          "default": 1.8e-06,
          "description": "Methane"
        },
        "CO": {
          "units": "mol/L",
          "default": 1e-07,
          "description": "Carbon monoxide"
        },
        "H2O2": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Hydrogen peroxide"
        },
        "HCHO": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Formaldehyde"
        },
        "CH3O2": {
          "units": "mol/L",
          "default": 1e-12,
          "description": "Methyl peroxy radical"
        },
        "CH3OH": {
          "units": "mol/L",
          "default": 1e-10,
          "description": "Methanol"
        },
        "C2H4": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Ethylene"
        },
        "C2H6": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Ethane"
        },
        "C3H8": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Propane"
        },
        "SO2": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Sulfur dioxide"
        },
        "NH3": {
          "units": "mol/L",
          "default": 1e-09,
          "description": "Ammonia"
        }
      },
      "parameters": {
        "k_photo_O3": {
          "units": "1/s",
          "default": 1e-05,
          "description": "O3 photolysis rate"
        },
        "k_photo_NO2": {
          "units": "1/s",
          "default": 0.008,
          "description": "NO2 photolysis rate"
        },
        "k_OH_CO": {
          "units": "L/(mol*s)",
          "default": 2.3e-13,
          "description": "OH + CO rate"
        },
        "k_OH_CH4": {
          "units": "L/(mol*s)",
          "default": 6.4e-15,
          "description": "OH + CH4 rate"
        },
        "k_NO_O3": {
          "units": "L/(mol*s)",
          "default": 1.4e-14,
          "description": "NO + O3 rate"
        },
        "k_NO2_OH": {
          "units": "L/(mol*s)",
          "default": 1.1e-11,
          "description": "NO2 + OH rate"
        },
        "temperature": {
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "pressure": {
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "O3_photolysis",
          "substrates": [
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "O2",
              "stoichiometry": 1
            }
          ],
          "rate": "k_photo_O3"
        },
        {
          "id": "R2",
          "name": "NO2_photolysis",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O2",
              "stoichiometry": 1
            }
          ],
          "rate": "k_photo_NO2"
        },
        {
          "id": "R3",
          "name": "OH_CO_reaction",
          "substrates": [
            {
              "species": "OH",
              "stoichiometry": 1
            },
            {
              "species": "CO",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "HO2",
              "stoichiometry": 1
            },
            {
              "species": "CO2",
              "stoichiometry": 1
            }
          ],
          "rate": "k_OH_CO"
        },
        {
          "id": "R4",
          "name": "OH_CH4_reaction",
          "substrates": [
            {
              "species": "OH",
              "stoichiometry": 1
            },
            {
              "species": "CH4",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "CH3O2",
              "stoichiometry": 1
            },
            {
              "species": "H2O",
              "stoichiometry": 1
            }
          ],
          "rate": "k_OH_CH4"
        },
        {
          "id": "R5",
          "name": "NO_O3_reaction",
          "substrates": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            },
            {
              "species": "O2",
              "stoichiometry": 1
            }
          ],
          "rate": "k_NO_O3"
        }
      ],
      "tolerance": {
        "rel": 0.0001,
        "abs": 1e-20
      },
      "tests": [
        {
          "id": "large_network_build_smoke",
          "description": "Large-system build/compile smoke test: exercises the Catalyst flatten + MTK system build + solve-at-t0 path for an atmospheric-chemistry network. IC-identity at t=0 is the only portable reference (trace-species concentrations span ~20 orders of magnitude; closed-form or numerically-verified references are out of scope here). tspan extends 1 microsecond so that the solver actually runs.",
          "initial_conditions": {
            "O3": 1e-08,
            "NO": 1e-09,
            "NO2": 1e-09,
            "OH": 1e-12,
            "HO2": 1e-11,
            "CO": 1e-07,
            "CH4": 1.8e-06,
            "H2O": 0.01,
            "CO2": 0.0004,
            "H2O2": 1e-09,
            "HCHO": 1e-09,
            "CH3O2": 1e-12,
            "CH3OH": 1e-10,
            "C2H4": 1e-09,
            "C2H6": 1e-09,
            "C3H8": 1e-09,
            "SO2": 1e-09,
            "NH3": 1e-09,
            "O2": 0.21,
            "N2": 0.78
          },
          "time_span": {
            "start": 0.0,
            "end": 1e-06
          },
          "assertions": [
            {
              "variable": "O3",
              "time": 0.0,
              "expected": 1e-08,
              "tolerance": {
                "abs": 1e-20
              }
            },
            {
              "variable": "NO",
              "time": 0.0,
              "expected": 1e-09,
              "tolerance": {
                "abs": 1e-20
              }
            },
            {
              "variable": "NO2",
              "time": 0.0,
              "expected": 1e-09,
              "tolerance": {
                "abs": 1e-20
              }
            },
            {
              "variable": "OH",
              "time": 0.0,
              "expected": 1e-12,
              "tolerance": {
                "abs": 1e-22
              }
            },
            {
              "variable": "CO",
              "time": 0.0,
              "expected": 1e-07,
              "tolerance": {
                "abs": 1e-18
              }
            },
            {
              "variable": "CH4",
              "time": 0.0,
              "expected": 1.8e-06,
              "tolerance": {
                "abs": 1e-18
              }
            }
          ]
        }
      ]
    }
  },
  "domains": {
