{
  "esm": "0.1.0",
  "metadata": {
    "name": "JuliaMTKIntegration",
    "description": "Test Julia ModelingToolkit integration and simulation capability",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "julia",
      "mtk",
      "simulation",
      "integration-test"
    ]
  },
  "models": {
    "SimpleOscillator": {
      "reference": {
        "notes": "Harmonic oscillator with analytical solution for MTK conversion validation"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "meters",
          "default": 1.0,
          "description": "Position"
        },
        "v": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Velocity"
        },
        "omega": {
          "type": "parameter",
          "units": "rad/s",
          "default": 1.0,
          "description": "Angular frequency"
        },
        "energy": {
          "type": "observed",
          "units": "J/kg",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "/",
                "args": [
                  {
                    "op": "^",
                    "args": [
                      "v",
                      2
                    ]
                  },
                  2
                ]
              },
              {
                "op": "/",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "^",
                        "args": [
                          "omega",
                          2
                        ]
                      },
                      {
                        "op": "^",
                        "args": [
                          "x",
                          2
                        ]
                      }
                    ]
                  },
                  2
                ]
              }
            ]
          },
          "description": "Total energy (should be conserved)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": "v"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "v"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  {
                    "op": "^",
                    "args": [
                      "omega",
                      2
                    ]
                  }
                ]
              },
              "x"
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6,
        "abs": 1.0e-10
      },
      "tests": [
        {
          "id": "harmonic_analytical",
          "description": "Harmonic oscillator x'' + omega^2*x = 0 with x(0)=1, v(0)=0, omega=1. Closed-form solution is x(t)=cos(omega*t), v(t)=-omega*sin(omega*t); energy = 0.5 constant. Sample at t = 0, pi/2, pi, 3*pi/2, 2*pi.",
          "initial_conditions": {
            "x": 1.0,
            "v": 0.0
          },
          "parameter_overrides": {
            "omega": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 6.283185307179586
          },
          "assertions": [
            { "variable": "x", "time": 0.0,                "expected": 1.0 },
            { "variable": "x", "time": 1.5707963267948966, "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "x", "time": 3.141592653589793,  "expected": -1.0 },
            { "variable": "x", "time": 4.71238898038469,   "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "x", "time": 6.283185307179586,  "expected": 1.0 },
            { "variable": "v", "time": 0.0,                "expected": 0.0,  "tolerance": { "abs": 1.0e-10 } },
            { "variable": "v", "time": 1.5707963267948966, "expected": -1.0 },
            { "variable": "v", "time": 3.141592653589793,  "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "v", "time": 4.71238898038469,   "expected": 1.0 }
          ]
        }
      ]
    },
    "StiffChemistry": {
      "reference": {
        "notes": "Stiff chemical system to test MTK solver selection and event handling"
      },
      "variables": {
        "A": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Fast-reacting species A"
        },
        "B": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.0,
          "description": "Product species B"
        },
        "k_fast": {
          "type": "parameter",
          "units": "1/s",
          "default": 1000.0,
          "description": "Fast reaction rate"
        },
        "k_slow": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.1,
          "description": "Slow reaction rate"
        },
        "total_species": {
          "type": "observed",
          "units": "mol/mol",
          "expression": {
            "op": "+",
            "args": [
              "A",
              "B"
            ]
          },
          "description": "Total mass (conserved)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "A"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "k_fast"
                    ]
                  },
                  "A"
                ]
              },
              {
                "op": "*",
                "args": [
                  "k_slow",
                  "B"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "B"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_fast",
                  "A"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "k_slow"
                    ]
                  },
                  "B"
                ]
              }
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "reset_when_depleted",
          "conditions": [
            {
              "op": "-",
              "args": [
                "A",
                1e-12
              ]
            }
          ],
          "affects": [
            {
              "lhs": "A",
              "rhs": 1e-08
            }
          ],
          "description": "Reset A concentration when nearly depleted"
        }
      ]
    }
  },
  "reaction_systems": {
    "TestMechanism": {
      "reference": {
        "notes": "Simple reaction system to test Catalyst.jl integration and ODE derivation"
      },
      "species": {
        "O3": {
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone"
        },
        "NO": {
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide"
        },
        "NO2": {
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide"
        }
      },
      "parameters": {
        "k1": {
          "units": "cm^3/molec/s",
          "default": 1.8e-12,
          "description": "NO + O3 rate"
        },
        "j1": {
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis rate"
        },
        "M": {
          "units": "molec/cm^3",
          "default": 2.46e+19,
          "description": "Air density"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "NO_O3_reaction",
          "substrates": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "k1",
              "M"
            ]
          }
        },
        {
          "id": "R2",
          "name": "NO2_photolysis",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "rate": "j1"
        }
      ],
      "tolerance": {
        "rel": 1.0e-4,
        "abs": 1.0e-20
      },
      "tests": [
        {
          "id": "ic_smoke",
          "description": "IC-identity smoke test for the Catalyst ReactionSystem path: flatten + MTK build + solve-at-t0 round-trip for the NO-O3-NO2 photostationary-state triplet. No closed-form solution (the network is a 3-species nonlinear system coupled through NO+O3 <-> NO2); a short tspan (1 microsecond) ensures the solver actually runs without requiring a numerical reference.",
          "initial_conditions": {
            "O3": 4e-08,
            "NO": 1e-10,
            "NO2": 1e-09
          },
          "parameter_overrides": {
            "k1": 1.8e-12,
            "j1": 0.005,
            "M": 2.46e19
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0e-6
          },
          "assertions": [
            { "variable": "O3",  "time": 0.0, "expected": 4e-08, "tolerance": { "abs": 1e-20 } },
            { "variable": "NO",  "time": 0.0, "expected": 1e-10, "tolerance": { "abs": 1e-22 } },
            { "variable": "NO2", "time": 0.0, "expected": 1e-09, "tolerance": { "abs": 1e-20 } }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T01:00:00Z",
        "reference_time": "2024-01-01T00:00:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "x": 1.0,
          "v": 0.0,
          "A": 1e-06,
          "B": 0.0
        }
      },
      "element_type": "Float64"
    }
  }
}
