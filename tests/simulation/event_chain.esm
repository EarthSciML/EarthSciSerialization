{
  "esm": "0.1.0",
  "metadata": {
    "name": "EventChainTest",
    "description": "Complex event system test with interconnected events and parameter modifications",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-16T00:00:00Z",
    "tags": [
      "test",
      "events",
      "discrete",
      "chain",
      "parameter-modification"
    ]
  },
  "models": {
    "EventSystem": {
      "reference": {
        "notes": "Multi-stage system with temperature-dependent reactions and discrete dosing events"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/L",
          "default": 0.1,
          "description": "Reactant concentration"
        },
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 298.15,
          "description": "System temperature"
        },
        "product": {
          "type": "state",
          "units": "mol/L",
          "default": 0.0,
          "description": "Product concentration"
        },
        "heating_rate": {
          "type": "parameter",
          "units": "K/s",
          "default": 0.1,
          "description": "Heating rate"
        },
        "reaction_rate": {
          "type": "parameter",
          "units": "L/(mol*s)",
          "default": 0.01,
          "description": "Base reaction rate constant"
        },
        "activation_energy": {
          "type": "parameter",
          "units": "J/mol",
          "default": 50000.0,
          "description": "Activation energy"
        },
        "R": {
          "type": "parameter",
          "units": "J/(mol*K)",
          "default": 8.314,
          "description": "Gas constant"
        },
        "dose_amount": {
          "type": "parameter",
          "units": "mol/L",
          "default": 0.05,
          "description": "Discrete dose amount"
        },
        "dose_counter": {
          "type": "parameter",
          "units": "1",
          "default": 0,
          "description": "Number of doses administered"
        },
        "heating_active": {
          "type": "parameter",
          "units": "1",
          "default": 1,
          "description": "Heating system status (0=off, 1=on)"
        },
        "k_eff": {
          "type": "observed",
          "units": "L/(mol*s)",
          "description": "Effective rate constant",
          "expression": 0.0
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "heating_rate",
              "heating_active"
            ]
          }
        },
        {
          "lhs": "k_eff",
          "rhs": {
            "op": "*",
            "args": [
              "reaction_rate",
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "activation_energy"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "R",
                          "temperature"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_eff",
                  {
                    "op": "^",
                    "args": [
                      "concentration",
                      2
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "product"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "k_eff",
              {
                "op": "^",
                "args": [
                  "concentration",
                  2
                ]
              }
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1e-04
      },
      "tests": [
        {
          "id": "slow_heating_low_conversion",
          "description": "With base reaction_rate=0.01 and activation_energy=50 kJ/mol, the Arrhenius-rate Michaelis-like dynamics are extremely slow at room temperature. Over a 500 s linear-heating run the temperature rises from 298.15 K to 348.15 K, but the concentration stays within 10^-8 of its initial value and only a few picomoles of product form. Assertions check temperature (dominated by the linear heating equation) and verify that concentration and product remain tiny.",
          "initial_conditions": {
            "concentration": 0.1,
            "temperature": 298.15,
            "product": 0.0
          },
          "parameter_overrides": {
            "heating_rate": 0.1,
            "reaction_rate": 0.01,
            "activation_energy": 50000.0,
            "R": 8.314
          },
          "time_span": {
            "start": 0.0,
            "end": 500.0
          },
          "assertions": [
            { "variable": "temperature", "time": 0.0,   "expected": 298.15 },
            { "variable": "temperature", "time": 48.0,  "expected": 302.95 },
            { "variable": "temperature", "time": 98.0,  "expected": 307.95 },
            { "variable": "temperature", "time": 500.0, "expected": 348.15, "tolerance": { "abs": 1e-06 } },
            { "variable": "concentration", "time": 0.0,   "expected": 0.1 },
            { "variable": "concentration", "time": 500.0, "expected": 0.1,  "tolerance": { "abs": 1e-07 } },
            { "variable": "product",       "time": 0.0,   "expected": 0.0 },
            { "variable": "product",       "time": 500.0, "expected": 6e-10, "tolerance": { "abs": 1e-09 } }
          ]
        }
      ],
      "examples": [
        {
          "id": "temperature_ramp",
          "description": "Illustrative run: a 500 s linear heating ramp at 0.1 K/s with the default reaction parameters. Plots temperature, concentration, and product on their own axes; rates are low enough that concentration looks flat, which is informative in itself.",
          "initial_state": {
            "type": "per_variable",
            "values": {
              "concentration": 0.1,
              "temperature": 298.15,
              "product": 0.0
            }
          },
          "parameters": {
            "heating_rate": 0.1,
            "reaction_rate": 0.01,
            "activation_energy": 50000.0,
            "R": 8.314
          },
          "time_span": {
            "start": 0.0,
            "end": 500.0
          },
          "plots": [
            {
              "id": "temperature_vs_time",
              "type": "line",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "temperature", "label": "temperature (K)" }
            },
            {
              "id": "product_vs_time",
              "type": "line",
              "description": "Product buildup driven by the temperature-dependent Arrhenius rate.",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "product", "label": "product (mol/L)" }
            }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {},
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "EventSystem.concentration": 0.1,
          "EventSystem.temperature": 298.15,
          "EventSystem.product": 0.0,
          "EventSystem.dose_counter": 0,
          "EventSystem.heating_active": 1
        }
      }
    }
  }
}
