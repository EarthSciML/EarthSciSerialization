{
  "esm": "0.1.0",
  "metadata": {
    "name": "PythonSciPyIntegration",
    "description": "Test Python SciPy simulation capability for 0D box models",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "python",
      "scipy",
      "simulation",
      "box-model"
    ]
  },
  "models": {
    "ExponentialDecay": {
      "reference": {
        "notes": "Simple exponential decay with analytical solution: C(t) = C\u2080 * exp(-k*t)"
      },
      "variables": {
        "concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Decaying species concentration"
        },
        "decay_rate": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.001,
          "description": "First-order decay constant"
        },
        "analytical_solution": {
          "type": "observed",
          "units": "mol/mol",
          "expression": {
            "op": "*",
            "args": [
              1e-06,
              {
                "op": "exp",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "decay_rate"
                        ]
                      },
                      "t"
                    ]
                  }
                ]
              }
            ]
          },
          "description": "C\u2080 * exp(-k*t)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "decay_rate"
                ]
              },
              "concentration"
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6
      },
      "tests": [
        {
          "id": "exponential_decay_analytical",
          "description": "Closed-form C(t) = 1e-6 * exp(-0.001 * t). Samples at t=0, 100, 500, 693.147 (half-life), 1000, 3000.",
          "initial_conditions": {
            "concentration": 1.0e-6
          },
          "parameter_overrides": {
            "decay_rate": 0.001
          },
          "time_span": {
            "start": 0.0,
            "end": 3000.0
          },
          "assertions": [
            { "variable": "concentration", "time": 0.0,                "expected": 1.0e-6 },
            { "variable": "concentration", "time": 100.0,              "expected": 9.048374180359595e-7 },
            { "variable": "concentration", "time": 500.0,              "expected": 6.065306597126334e-7 },
            { "variable": "concentration", "time": 693.1471805599453,  "expected": 5.0e-7 },
            { "variable": "concentration", "time": 1000.0,             "expected": 3.6787944117144233e-7 },
            { "variable": "concentration", "time": 3000.0,             "expected": 4.9787068367863944e-8 }
          ]
        }
      ]
    },
    "LogisticGrowth": {
      "reference": {
        "notes": "Test nonlinear dynamics with logistic growth equation"
      },
      "variables": {
        "population": {
          "type": "state",
          "units": "dimensionless",
          "default": 0.1,
          "description": "Normalized population (0-1)"
        },
        "growth_rate": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.1,
          "description": "Intrinsic growth rate"
        },
        "carrying_capacity": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Maximum sustainable population"
        },
        "equilibrium": {
          "type": "observed",
          "units": "dimensionless",
          "expression": "carrying_capacity",
          "description": "Steady-state solution"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "population"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "growth_rate",
              "population",
              {
                "op": "-",
                "args": [
                  1.0,
                  {
                    "op": "/",
                    "args": [
                      "population",
                      "carrying_capacity"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6
      },
      "tests": [
        {
          "id": "logistic_growth_analytical",
          "description": "Closed-form N(t) = K / (1 + (K/N0 - 1) * exp(-r*t)). With K=1, N0=0.1, r=0.1: samples at t=0, 10, 20, 50, 100.",
          "initial_conditions": {
            "population": 0.1
          },
          "parameter_overrides": {
            "growth_rate": 0.1,
            "carrying_capacity": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 100.0
          },
          "assertions": [
            { "variable": "population", "time": 0.0,   "expected": 0.1 },
            { "variable": "population", "time": 10.0,  "expected": 0.2319416897192268 },
            { "variable": "population", "time": 20.0,  "expected": 0.45078030754938094 },
            { "variable": "population", "time": 50.0,  "expected": 0.9427548370970797 },
            { "variable": "population", "time": 100.0, "expected": 0.999591671410288 }
          ]
        }
      ]
    }
  },
  "reaction_systems": {
    "SimpleKinetics": {
      "reference": {
        "notes": "Test reaction system \u2192 ODE conversion and mass balance verification"
      },
      "species": {
        "A": {
          "units": "mol/mol",
          "default": 0.001,
          "description": "Reactant A"
        },
        "B": {
          "units": "mol/mol",
          "default": 0.0,
          "description": "Product B"
        },
        "C": {
          "units": "mol/mol",
          "default": 0.0,
          "description": "Product C"
        }
      },
      "parameters": {
        "k_forward": {
          "units": "1/s",
          "default": 0.1,
          "description": "Forward rate constant"
        },
        "k_reverse": {
          "units": "1/s",
          "default": 0.01,
          "description": "Reverse rate constant"
        },
        "k_side": {
          "units": "1/s",
          "default": 0.005,
          "description": "Side reaction rate"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "main_reaction",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "rate": "k_forward"
        },
        {
          "id": "R2",
          "name": "reverse_reaction",
          "substrates": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "rate": "k_reverse"
        },
        {
          "id": "R3",
          "name": "side_reaction",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            }
          ],
          "rate": "k_side"
        }
      ]
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T12:00:00Z",
        "reference_time": "2024-01-01T00:00:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "concentration": 1e-06,
          "population": 0.1,
          "A": 0.001,
          "B": 0.0,
          "C": 0.0
        }
      },
      "element_type": "Float64"
    }
  }
}
