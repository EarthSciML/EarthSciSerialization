{
  "esm": "0.1.0",
  "metadata": {
    "name": "SpatialDiffusionTest",
    "description": "1D diffusion equation with spatial operators",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "spatial",
      "pde",
      "diffusion"
    ]
  },
  "models": {
    "DiffusionSystem": {
      "reference": {
        "notes": "Heat equation: \u2202u/\u2202t = D * \u2202\u00b2u/\u2202x\u00b2 with Dirichlet boundary conditions"
      },
      "variables": {
        "u": {
          "type": "state",
          "units": "K",
          "default": 0.0,
          "description": "Temperature field"
        },
        "D": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 0.1,
          "description": "Diffusion coefficient"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "D",
              {
                "op": "D",
                "args": [
                  "u"
                ],
                "wrt": "x"
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 1.0
        }
      },
      "temporal": {},
      "boundary_conditions": [
        {
          "type": "dirichlet",
          "dimensions": [
            "x"
          ],
          "value": 0.0
        },
        {
          "type": "dirichlet",
          "dimensions": [
            "x"
          ],
          "value": 0.0
        }
      ],
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      }
    }
  }
}
