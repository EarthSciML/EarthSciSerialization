{
  "esm": "0.2.0",
  "metadata": {
    "name": "SpatialDiffusionTest",
    "description": "1D diffusion equation with spatial operators\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "spatial",
      "pde",
      "diffusion",
      "migrated_from_v01"
    ]
  },
  "models": {
    "DiffusionSystem": {
      "reference": {
        "notes": "Heat equation: ∂u/∂t = D * ∂²u/∂x² with Dirichlet boundary conditions"
      },
      "variables": {
        "u": {
          "type": "state",
          "units": "K",
          "default": 0.0,
          "description": "Temperature field"
        },
        "D": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 0.1,
          "description": "Diffusion coefficient"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "D",
              {
                "op": "D",
                "args": [
                  "u"
                ],
                "wrt": "x"
              }
            ]
          }
        }
      ],
      "boundary_conditions": {
        "u_dirichlet_xmin": {
          "variable": "u",
          "side": "xmin",
          "kind": "dirichlet",
          "value": 0.0
        },
        "u_dirichlet_xmax": {
          "variable": "u",
          "side": "xmax",
          "kind": "dirichlet",
          "value": 0.0
        },
        "u_dirichlet_xmin_2": {
          "variable": "u",
          "side": "xmin",
          "kind": "dirichlet",
          "value": 0.0
        },
        "u_dirichlet_xmax_2": {
          "variable": "u",
          "side": "xmax",
          "kind": "dirichlet",
          "value": 0.0
        }
      }
    }
  },
  "domains": {
    "default": {
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 1.0
        }
      },
      "temporal": {},
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      }
    }
  }
}
