{
  "esm": "0.1.0",
  "metadata": {
    "name": "BouncingBallTest",
    "description": "Ball dropping with elastic collisions - continuous event handling test",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "events",
      "continuous",
      "collision"
    ]
  },
  "models": {
    "BallDynamics": {
      "reference": {
        "notes": "Free falling ball with elastic bounces: h'' = -g, bounce when h = 0"
      },
      "variables": {
        "height": {
          "type": "state",
          "units": "m",
          "default": 10.0,
          "description": "Height above ground"
        },
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Vertical velocity (positive upward)"
        },
        "g": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravitational acceleration"
        },
        "restitution": {
          "type": "parameter",
          "units": "1",
          "default": 0.8,
          "description": "Coefficient of restitution"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "height"
            ],
            "wrt": "t"
          },
          "rhs": "velocity"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "g"
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "ground_collision",
          "description": "Ball hits ground when height crosses zero from above",
          "conditions": [
            "height"
          ],
          "affects": [
            {
              "lhs": "height",
              "rhs": 0.0
            },
            {
              "lhs": "velocity",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "restitution"
                    ]
                  },
                  {
                    "op": "Pre",
                    "args": [
                      "velocity"
                    ]
                  }
                ]
              }
            }
          ],
          "root_find": "left"
        }
      ],
      "tolerance": {
        "abs": 0.02,
        "rel": 0.01
      },
      "tests": [
        {
          "id": "elastic_bounce_sequence",
          "description": "Drop a ball from h=10 m under g=9.81 m/s^2 with restitution=0.8 and watch the bounce sequence over 10 seconds. The ball's peak height decays as h_n = 10 * restitution^(2n), which is verified by sampling the trajectory around several bounces. Assertions use absolute tolerance on height (meters) because the event-driven dynamics make tight relative tolerance impractical near zero crossings.",
          "initial_conditions": {
            "height": 10.0,
            "velocity": 0.0
          },
          "parameter_overrides": {
            "g": 9.81,
            "restitution": 0.8
          },
          "time_span": {
            "start": 0.0,
            "end": 10.0
          },
          "assertions": [
            { "variable": "height",   "time": 0.0, "expected": 10.0 },
            { "variable": "velocity", "time": 0.0, "expected": 0.0  },
            { "variable": "height",   "time": 0.998492, "expected": 5.109785, "tolerance": { "abs": 0.01 } },
            { "variable": "velocity", "time": 0.998492, "expected": -9.795204, "tolerance": { "abs": 0.02 } },
            { "variable": "height",   "time": 1.984081, "expected": 4.882389, "tolerance": { "abs": 0.05 } },
            { "variable": "height",   "time": 2.967430, "expected": 3.321709, "tolerance": { "abs": 0.05 } },
            { "variable": "height",   "time": 4.919295, "expected": 1.003747, "tolerance": { "abs": 0.05 } },
            { "variable": "height",   "time": 6.805605, "expected": 0.013223, "tolerance": { "abs": 0.05 } },
            { "variable": "height",   "time": 10.0,     "expected": 0.0,      "tolerance": { "abs": 0.02 } }
          ]
        }
      ],
      "examples": [
        {
          "id": "default_drop",
          "description": "A single ball dropped from h=10 m and allowed to bounce for 10 s under default gravity and restitution. Plots height and velocity versus time on a shared time axis.",
          "initial_state": {
            "type": "per_variable",
            "values": {
              "height": 10.0,
              "velocity": 0.0
            }
          },
          "parameters": {
            "g": 9.81,
            "restitution": 0.8
          },
          "time_span": {
            "start": 0.0,
            "end": 10.0
          },
          "plots": [
            {
              "id": "height_vs_time",
              "type": "line",
              "description": "Ball height versus simulation time, illustrating the decaying envelope of successive bounces.",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "height", "label": "height (m)" }
            },
            {
              "id": "velocity_vs_time",
              "type": "line",
              "description": "Ball vertical velocity versus time, showing the discontinuous jumps at each elastic collision.",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "velocity", "label": "velocity (m/s)" }
            }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2026-01-01T00:00:00Z",
        "end": "2026-01-01T00:10:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "BallDynamics.height": 10.0,
          "BallDynamics.velocity": 0.0
        }
      }
    }
  }
}
