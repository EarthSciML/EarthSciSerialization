{
  "esm": "0.1.0",
  "metadata": {
    "name": "BouncingBallTest",
    "description": "Ball dropping with elastic collisions - continuous event handling test",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "events",
      "continuous",
      "collision"
    ]
  },
  "models": {
    "BallDynamics": {
      "reference": {
        "notes": "Free falling ball with elastic bounces: h'' = -g, bounce when h = 0"
      },
      "variables": {
        "height": {
          "type": "state",
          "units": "m",
          "default": 10.0,
          "description": "Height above ground"
        },
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Vertical velocity (positive upward)"
        },
        "g": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravitational acceleration"
        },
        "restitution": {
          "type": "parameter",
          "units": "1",
          "default": 0.8,
          "description": "Coefficient of restitution"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "height"
            ],
            "wrt": "t"
          },
          "rhs": "velocity"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "g"
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "ground_collision",
          "description": "Ball hits ground when height crosses zero from above",
          "conditions": [
            "height"
          ],
          "affects": [
            {
              "lhs": "height",
              "rhs": 0.0
            },
            {
              "lhs": "velocity",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "restitution"
                    ]
                  },
                  {
                    "op": "Pre",
                    "args": [
                      "velocity"
                    ]
                  }
                ]
              }
            }
          ],
          "root_find": "left"
        }
      ]
    }
  },
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "algorithm": "Tsit5",
      "rtol": 1e-06,
      "atol": 1e-08,
      "event_tolerance": 1e-09
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2026-01-01T00:00:00Z",
        "end": "2026-01-01T00:10:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "BallDynamics.height": 10.0,
          "BallDynamics.velocity": 0.0
        }
      }
    }
  }
}
