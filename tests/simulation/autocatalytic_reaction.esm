{
  "esm": "0.1.0",
  "metadata": {
    "name": "AutocatalyticReactionTest",
    "description": "Chemical reaction network with autocatalysis and mass conservation",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "chemical_reactions",
      "mass_conservation"
    ]
  },
  "reaction_systems": {
    "ChemicalSystem": {
      "reference": {
        "notes": "Autocatalytic reaction: A + B -> 2B (rate k1), B -> C (rate k2)"
      },
      "species": {
        "A": {
          "units": "mol",
          "default": 100.0,
          "description": "Substrate species"
        },
        "B": {
          "units": "mol",
          "default": 1.0,
          "description": "Autocatalytic species"
        },
        "C": {
          "units": "mol",
          "default": 0.0,
          "description": "Product species"
        }
      },
      "parameters": {
        "k1": {
          "units": "1/(mol*s)",
          "default": 0.1,
          "description": "Autocatalytic rate constant"
        },
        "k2": {
          "units": "1/s",
          "default": 0.05,
          "description": "Product formation rate constant"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "autocatalytic_step",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            },
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "B",
              "stoichiometry": 2
            }
          ],
          "rate": "k1"
        },
        {
          "id": "R2",
          "name": "product_formation",
          "substrates": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            }
          ],
          "rate": "k2"
        }
      ],
      "tolerance": {
        "rel": 0.0001,
        "abs": 1e-08
      },
      "tests": [
        {
          "id": "ic_smoke",
          "description": "IC-identity smoke test: Catalyst flatten + MTK build + solve-at-t0 round-trip for the autocatalytic network A+B->2B (rate k1*A*B), B->C (rate k2*B). No closed-form solution exists (Lotka-Volterra class), so this verifies the reaction-system construction path. Full numerical references would require bootstrapping from a trusted solve and are tracked separately. The removed total_mass species + constraint_equations block previously blocked compile (Catalyst flatten does not currently honour constraint_equations on a ReactionSystem).",
          "initial_conditions": {
            "A": 100.0,
            "B": 1.0,
            "C": 0.0
          },
          "parameter_overrides": {
            "k1": 0.1,
            "k2": 0.05
          },
          "time_span": {
            "start": 0.0,
            "end": 1e-06
          },
          "assertions": [
            {
              "variable": "A",
              "time": 0.0,
              "expected": 100.0,
              "tolerance": {
                "abs": 1e-10
              }
            },
            {
              "variable": "B",
              "time": 0.0,
              "expected": 1.0,
              "tolerance": {
                "abs": 1e-10
              }
            },
            {
              "variable": "C",
              "time": 0.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1e-12
              }
            }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {},
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "ChemicalSystem.A": 100.0,
          "ChemicalSystem.B": 1.0,
          "ChemicalSystem.C": 0.0
        }
      }
    }
  }
}
