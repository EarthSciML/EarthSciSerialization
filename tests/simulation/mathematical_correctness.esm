{
  "esm": "0.1.0",
  "metadata": {
    "name": "MathematicalCorrectnessTests",
    "description": "Test mathematical correctness of ESM operations: mass conservation, ODE derivation, and numerical accuracy",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z"
  },
  "reaction_systems": {
    "MassConservationTest": {
      "reference": {
        "notes": "Simple reaction network for testing mass conservation: A + B -> C + D (1:1:1:1 stoichiometry)"
      },
      "species": {
        "A": {
          "units": "mol",
          "default": 1.0,
          "description": "Reactant A"
        },
        "B": {
          "units": "mol",
          "default": 1.0,
          "description": "Reactant B"
        },
        "C": {
          "units": "mol",
          "default": 0.0,
          "description": "Product C"
        },
        "D": {
          "units": "mol",
          "default": 0.0,
          "description": "Product D"
        }
      },
      "parameters": {
        "k": {
          "units": "1/(mol*s)",
          "default": 0.1,
          "description": "Rate constant"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "A_plus_B_to_C_plus_D",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            },
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            },
            {
              "species": "D",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "k",
              "A",
              "B"
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6,
        "abs": 1.0e-10
      },
      "tests": [
        {
          "id": "symmetric_second_order_decay",
          "description": "A + B -> C + D at rate k*A*B with A(0)=B(0)=1 and C(0)=D(0)=0. Symmetry gives A(t)=B(t) and C(t)=D(t)=1-A(t), reducing to dA/dt = -k*A^2 with closed form A(t) = 1/(1+k*t). With k=0.1, A(5)=1/1.5 and A(10)=0.5. Conservation A+C is implied by the per-species assertions rather than a constraint_equations total_mass species (Catalyst flatten does not currently honour constraint_equations on a ReactionSystem).",
          "initial_conditions": {
            "A": 1.0,
            "B": 1.0,
            "C": 0.0,
            "D": 0.0
          },
          "parameter_overrides": {
            "k": 0.1
          },
          "time_span": {
            "start": 0.0,
            "end": 10.0
          },
          "assertions": [
            { "variable": "A", "time": 0.0,  "expected": 1.0 },
            { "variable": "B", "time": 0.0,  "expected": 1.0 },
            { "variable": "C", "time": 0.0,  "expected": 0.0, "tolerance": { "abs": 1.0e-10 } },
            { "variable": "D", "time": 0.0,  "expected": 0.0, "tolerance": { "abs": 1.0e-10 } },
            { "variable": "A", "time": 5.0,  "expected": 0.6666666666666666 },
            { "variable": "B", "time": 5.0,  "expected": 0.6666666666666666 },
            { "variable": "C", "time": 5.0,  "expected": 0.3333333333333333 },
            { "variable": "D", "time": 5.0,  "expected": 0.3333333333333333 },
            { "variable": "A", "time": 10.0, "expected": 0.5 },
            { "variable": "B", "time": 10.0, "expected": 0.5 },
            { "variable": "C", "time": 10.0, "expected": 0.5 },
            { "variable": "D", "time": 10.0, "expected": 0.5 }
          ]
        }
      ]
    },
    "LinearChain": {
      "reference": {
        "notes": "Linear reaction chain A -> B -> C with known analytical solution for testing ODE derivation accuracy"
      },
      "species": {
        "A": {
          "units": "mol",
          "default": 1.0,
          "description": "Initial species"
        },
        "B": {
          "units": "mol",
          "default": 0.0,
          "description": "Intermediate"
        },
        "C": {
          "units": "mol",
          "default": 0.0,
          "description": "Final product"
        }
      },
      "parameters": {
        "k1": {
          "units": "1/s",
          "default": 0.5,
          "description": "A -> B rate"
        },
        "k2": {
          "units": "1/s",
          "default": 0.3,
          "description": "B -> C rate"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "A_to_B",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "k1",
              "A"
            ]
          }
        },
        {
          "id": "R2",
          "name": "B_to_C",
          "substrates": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "k2",
              "B"
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6,
        "abs": 1.0e-10
      },
      "tests": [
        {
          "id": "bateman_chain",
          "description": "Linear radioactive-decay chain A -> B -> C. Closed-form Bateman equations: A(t)=exp(-k1*t), B(t)=k1/(k2-k1)*(exp(-k1*t)-exp(-k2*t)), C(t)=1-A-B. With A(0)=1, B(0)=C(0)=0, k1=0.5, k2=0.3. Sampled at t=1,2,5. The k1 != k2 form avoids the degenerate Bateman limit.",
          "initial_conditions": {
            "A": 1.0,
            "B": 0.0,
            "C": 0.0
          },
          "parameter_overrides": {
            "k1": 0.5,
            "k2": 0.3
          },
          "time_span": {
            "start": 0.0,
            "end": 5.0
          },
          "assertions": [
            { "variable": "A", "time": 0.0, "expected": 1.0 },
            { "variable": "B", "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1.0e-10 } },
            { "variable": "C", "time": 0.0, "expected": 0.0, "tolerance": { "abs": 1.0e-10 } },
            { "variable": "A", "time": 1.0, "expected": 0.6065306597126334 },
            { "variable": "B", "time": 1.0, "expected": 0.33571890242271123 },
            { "variable": "C", "time": 1.0, "expected": 0.05775043786465538 },
            { "variable": "A", "time": 2.0, "expected": 0.36787944117144233 },
            { "variable": "B", "time": 2.0, "expected": 0.4523304873064602 },
            { "variable": "C", "time": 2.0, "expected": 0.17979007152209747 },
            { "variable": "A", "time": 5.0, "expected": 0.0820849986238988 },
            { "variable": "B", "time": 5.0, "expected": 0.35261290381132754 },
            { "variable": "C", "time": 5.0, "expected": 0.5653020975647737 }
          ]
        }
      ]
    },
    "StoichiometryTest": {
      "reference": {
        "notes": "Complex stoichiometry test: 2A + 3B -> C + 4D for testing stoichiometric matrix computation"
      },
      "species": {
        "A": {
          "units": "mol",
          "default": 2.0,
          "description": "Reactant A"
        },
        "B": {
          "units": "mol",
          "default": 3.0,
          "description": "Reactant B"
        },
        "C": {
          "units": "mol",
          "default": 0.0,
          "description": "Product C"
        },
        "D": {
          "units": "mol",
          "default": 0.0,
          "description": "Product D"
        }
      },
      "parameters": {
        "k": {
          "units": "1/(mol^4*s)",
          "default": 0.01,
          "description": "Rate constant"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "complex_stoichiometry",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 2
            },
            {
              "species": "B",
              "stoichiometry": 3
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            },
            {
              "species": "D",
              "stoichiometry": 4
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "k",
              {
                "op": "^",
                "args": [
                  "A",
                  2
                ]
              },
              {
                "op": "^",
                "args": [
                  "B",
                  3
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "models": {
    "AnalyticalODE": {
      "reference": {
        "notes": "Simple harmonic oscillator with known analytical solution: x'' + omega^2 * x = 0"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "m",
          "default": 1.0,
          "description": "Position"
        },
        "v": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Velocity"
        },
        "omega": {
          "type": "parameter",
          "units": "1/s",
          "default": 1.0,
          "description": "Angular frequency"
        },
        "energy": {
          "type": "observed",
          "units": "J",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.5,
                  {
                    "op": "^",
                    "args": [
                      "v",
                      2
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  0.5,
                  {
                    "op": "^",
                    "args": [
                      "omega",
                      2
                    ]
                  },
                  {
                    "op": "^",
                    "args": [
                      "x",
                      2
                    ]
                  }
                ]
              }
            ]
          },
          "description": "Total energy (should be conserved)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": "v"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "v"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  {
                    "op": "^",
                    "args": [
                      "omega",
                      2
                    ]
                  }
                ]
              },
              "x"
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1.0e-6,
        "abs": 1.0e-10
      },
      "tests": [
        {
          "id": "harmonic_analytical",
          "description": "Undamped harmonic oscillator x'' + omega^2*x = 0 with x(0)=1, v(0)=0, omega=1. Closed-form: x(t)=cos(omega*t), v(t)=-omega*sin(omega*t); energy = 0.5 conserved. Sampled at the four quarter-period phases plus t=2*pi.",
          "initial_conditions": {
            "x": 1.0,
            "v": 0.0
          },
          "parameter_overrides": {
            "omega": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 6.283185307179586
          },
          "assertions": [
            { "variable": "x", "time": 0.0,                "expected": 1.0 },
            { "variable": "x", "time": 1.5707963267948966, "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "x", "time": 3.141592653589793,  "expected": -1.0 },
            { "variable": "x", "time": 4.71238898038469,   "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "x", "time": 6.283185307179586,  "expected": 1.0 },
            { "variable": "v", "time": 0.0,                "expected": 0.0,  "tolerance": { "abs": 1.0e-10 } },
            { "variable": "v", "time": 1.5707963267948966, "expected": -1.0 },
            { "variable": "v", "time": 3.141592653589793,  "expected": 0.0,  "tolerance": { "abs": 1.0e-6 } },
            { "variable": "v", "time": 4.71238898038469,   "expected": 1.0 }
          ]
        }
      ]
    },
    "NumericalStabilityTest": {
      "reference": {
        "notes": "Stiff equation system for testing numerical stability: fast and slow dynamics"
      },
      "variables": {
        "y_fast": {
          "type": "state",
          "units": "1",
          "default": 1.0,
          "description": "Fast variable"
        },
        "y_slow": {
          "type": "state",
          "units": "1",
          "default": 1.0,
          "description": "Slow variable"
        },
        "lambda_fast": {
          "type": "parameter",
          "units": "1/s",
          "default": -1000,
          "description": "Fast decay rate"
        },
        "lambda_slow": {
          "type": "parameter",
          "units": "1/s",
          "default": -1,
          "description": "Slow decay rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "y_fast"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "lambda_fast",
              "y_fast"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "y_slow"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "lambda_slow",
                  "y_slow"
                ]
              },
              {
                "op": "*",
                "args": [
                  0.1,
                  "y_fast"
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T00:10:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "MassConservationTest.A": 1.0,
          "MassConservationTest.B": 1.0,
          "MassConservationTest.C": 0.0,
          "MassConservationTest.D": 0.0,
          "LinearChain.A": 1.0,
          "LinearChain.B": 0.0,
          "LinearChain.C": 0.0,
          "StoichiometryTest.A": 2.0,
          "StoichiometryTest.B": 3.0,
          "StoichiometryTest.C": 0.0,
          "StoichiometryTest.D": 0.0,
          "AnalyticalODE.x": 1.0,
          "AnalyticalODE.v": 0.0,
          "NumericalStabilityTest.y_fast": 1.0,
          "NumericalStabilityTest.y_slow": 1.0
        }
      }
    }
  }
}
