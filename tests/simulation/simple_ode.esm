{
  "esm": "0.1.0",
  "metadata": {
    "name": "SimpleODETest",
    "description": "Basic ODE test for exponential decay with known analytical solution",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "simple",
      "analytical"
    ]
  },
  "models": {
    "ExponentialDecay": {
      "reference": {
        "notes": "Simple exponential decay: dN/dt = -lambda * N, analytical solution N(t) = N0 * exp(-lambda * t)"
      },
      "variables": {
        "N": {
          "type": "state",
          "units": "mol",
          "default": 100.0,
          "description": "Amount of decaying species"
        },
        "lambda": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.1,
          "description": "Decay constant"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "N"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "lambda"
                ]
              },
              "N"
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {},
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "ExponentialDecay.N": 100.0
        }
      }
    }
  }
}
