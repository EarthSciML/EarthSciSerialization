{
  "esm": "0.1.0",
  "metadata": {
    "name": "DiscreteEventExamples",
    "description": "Test fixtures for discrete event handling (periodic, preset, threshold)",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z"
  },
  "models": {
    "PeriodicDosing": {
      "reference": {
        "notes": "Periodic drug dosing with clearance"
      },
      "variables": {
        "C": {
          "type": "state",
          "units": "mg/L",
          "default": 0.0,
          "description": "Drug concentration"
        },
        "dose": {
          "units": "mg",
          "default": 100.0,
          "description": "Dose amount",
          "type": "parameter"
        },
        "V": {
          "units": "L",
          "default": 70.0,
          "description": "Volume of distribution",
          "type": "parameter"
        },
        "k": {
          "units": "1/h",
          "default": 0.1,
          "description": "Elimination rate constant",
          "type": "parameter"
        },
        "period": {
          "units": "h",
          "default": 8.0,
          "description": "Dosing interval",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "C"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "k"
                ]
              },
              "C"
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "trigger": {
            "type": "periodic",
            "initial_offset": 0.0,
            "interval": 1.0
          },
          "affects": [
            {
              "lhs": "C",
              "rhs": {
                "op": "+",
                "args": [
                  "C",
                  {
                    "op": "/",
                    "args": [
                      "dose",
                      "V"
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "PresetTreatment": {
      "reference": {
        "notes": "Treatment at specific preset times"
      },
      "variables": {
        "infection": {
          "type": "state",
          "units": "1",
          "default": 1.0,
          "description": "Infection level"
        },
        "immunity": {
          "type": "state",
          "units": "1",
          "default": 0.0,
          "description": "Immune response"
        },
        "growth_rate": {
          "units": "1/day",
          "default": 0.5,
          "description": "Infection growth rate",
          "type": "parameter"
        },
        "decay_rate": {
          "units": "1/day",
          "default": 0.1,
          "description": "Immunity decay rate",
          "type": "parameter"
        },
        "treatment_strength": {
          "units": "1",
          "default": 0.8,
          "description": "Treatment effectiveness",
          "type": "parameter"
        },
        "immune_boost": {
          "units": "1",
          "default": 0.3,
          "description": "Immunity boost from treatment",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "infection"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "growth_rate",
              "infection",
              {
                "op": "-",
                "args": [
                  1,
                  "immunity"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "immunity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "decay_rate"
                ]
              },
              "immunity"
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "trigger": {
            "type": "preset_times",
            "times": [
              2.0,
              5.0,
              10.0,
              15.0
            ]
          },
          "affects": [
            {
              "lhs": "infection",
              "rhs": {
                "op": "*",
                "args": [
                  "infection",
                  {
                    "op": "-",
                    "args": [
                      1,
                      "treatment_strength"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "immunity",
              "rhs": {
                "op": "+",
                "args": [
                  "immunity",
                  "immune_boost"
                ]
              }
            }
          ]
        }
      ]
    },
    "ThresholdSampling": {
      "reference": {
        "notes": "Sample system state when thresholds are crossed"
      },
      "variables": {
        "temperature": {
          "type": "state",
          "units": "\u00b0C",
          "default": 20.0,
          "description": "System temperature"
        },
        "sample_count": {
          "type": "parameter",
          "units": "1",
          "default": 0,
          "description": "Number of samples taken"
        },
        "heating_rate": {
          "units": "\u00b0C/min",
          "default": 2.0,
          "description": "Heating rate",
          "type": "parameter"
        },
        "cooling_rate": {
          "units": "\u00b0C/min",
          "default": -1.0,
          "description": "Cooling rate",
          "type": "parameter"
        },
        "switch_temp": {
          "units": "\u00b0C",
          "default": 80.0,
          "description": "Temperature switch point",
          "type": "parameter"
        },
        "sample_threshold": {
          "units": "\u00b0C",
          "default": 50.0,
          "description": "Sampling threshold",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "ifelse",
            "args": [
              {
                "op": "<",
                "args": [
                  "temperature",
                  "switch_temp"
                ]
              },
              "heating_rate",
              "cooling_rate"
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "trigger": {
            "type": "condition",
            "expression": {
              "op": ">",
              "args": [
                "temperature",
                "sample_threshold"
              ]
            }
          },
          "affects": [
            {
              "lhs": "sample_count",
              "rhs": {
                "op": "+",
                "args": [
                  "sample_count",
                  1
                ]
              }
            }
          ]
        },
        {
          "trigger": {
            "type": "condition",
            "expression": {
              "op": "<",
              "args": [
                "temperature",
                "sample_threshold"
              ]
            }
          },
          "affects": [
            {
              "lhs": "sample_count",
              "rhs": {
                "op": "+",
                "args": [
                  "sample_count",
                  1
                ]
              }
            }
          ]
        }
      ]
    },
    "ConditionalEvent": {
      "reference": {
        "notes": "Event triggered by complex logical conditions"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 0.0,
          "description": "System state x"
        },
        "y": {
          "type": "state",
          "units": "1",
          "default": 5.0,
          "description": "System state y"
        },
        "active": {
          "type": "parameter",
          "units": "1",
          "default": 1.0,
          "description": "System activity flag"
        },
        "rate_x": {
          "units": "1/s",
          "default": 1.0,
          "description": "Rate constant for x",
          "type": "parameter"
        },
        "rate_y": {
          "units": "1/s",
          "default": -0.5,
          "description": "Rate constant for y",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "ifelse",
            "args": [
              "active",
              "rate_x",
              0
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "y"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "ifelse",
            "args": [
              "active",
              "rate_y",
              0
            ]
          }
        }
      ],
      "discrete_events": [
        {
          "trigger": {
            "type": "condition",
            "expression": {
              "op": "and",
              "args": [
                {
                  "op": ">",
                  "args": [
                    "x",
                    3
                  ]
                },
                {
                  "op": "<",
                  "args": [
                    "y",
                    2
                  ]
                },
                "active"
              ]
            }
          },
          "affects": [
            {
              "lhs": "active",
              "rhs": 0
            },
            {
              "lhs": "x",
              "rhs": 0
            },
            {
              "lhs": "y",
              "rhs": 5
            }
          ]
        },
        {
          "trigger": {
            "type": "condition",
            "expression": {
              "op": "and",
              "args": [
                {
                  "op": "not",
                  "args": [
                    "active"
                  ]
                },
                {
                  "op": ">",
                  "args": [
                    {
                      "op": "+",
                      "args": [
                        "x",
                        "y"
                      ]
                    },
                    4
                  ]
                }
              ]
            }
          },
          "affects": [
            {
              "lhs": "active",
              "rhs": 1
            }
          ]
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T24:00:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "element_type": "Float64"
    }
  }
}
