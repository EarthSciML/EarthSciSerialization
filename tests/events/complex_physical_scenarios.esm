{
  "esm": "0.1.0",
  "metadata": {
    "name": "ComplexPhysicalScenarios",
    "description": "Complex event scenarios: bouncing ball, reactor control, epidemic models, and ecosystem dynamics",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z"
  },
  "models": {
    "AdvancedBouncingBall": {
      "variables": {
        "height": {
          "type": "state",
          "units": "m",
          "default": 2.0,
          "description": "Ball height"
        },
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Ball velocity"
        },
        "g": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravitational acceleration"
        },
        "drag_coefficient": {
          "type": "parameter",
          "units": "1",
          "default": 0.01,
          "description": "Air resistance coefficient"
        },
        "restitution": {
          "type": "parameter",
          "units": "1",
          "default": 0.8,
          "description": "Coefficient of restitution"
        },
        "bounce_count": {
          "type": "parameter",
          "units": "1",
          "default": 0,
          "description": "Number of bounces"
        },
        "total_energy": {
          "type": "observed",
          "units": "J",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.5,
                  {
                    "op": "^",
                    "args": [
                      "velocity",
                      2
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "g",
                  "height"
                ]
              }
            ]
          },
          "description": "Total mechanical energy"
        },
        "energy_loss_rate": {
          "type": "parameter",
          "units": "J/s",
          "default": 0.0,
          "description": "Energy loss tracking"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "height"
            ],
            "wrt": "t"
          },
          "rhs": "velocity"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "g",
              {
                "op": "*",
                "args": [
                  "drag_coefficient",
                  {
                    "op": "*",
                    "args": [
                      "velocity",
                      {
                        "op": "abs",
                        "args": [
                          "velocity"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "ground_impact",
          "conditions": [
            {
              "op": "-",
              "args": [
                0.0,
                "height"
              ]
            }
          ],
          "affects": [
            {
              "lhs": "velocity",
              "rhs": {
                "op": "*",
                "args": [
                  -1.0,
                  "restitution",
                  {
                    "op": "Pre",
                    "args": [
                      "velocity"
                    ]
                  }
                ]
              }
            },
            {
              "lhs": "bounce_count",
              "rhs": {
                "op": "+",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "bounce_count"
                    ]
                  },
                  1
                ]
              }
            },
            {
              "lhs": "energy_loss_rate",
              "rhs": {
                "op": "*",
                "args": [
                  0.5,
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          1.0,
                          {
                            "op": "^",
                            "args": [
                              "restitution",
                              2
                            ]
                          }
                        ]
                      },
                      {
                        "op": "^",
                        "args": [
                          {
                            "op": "Pre",
                            "args": [
                              "velocity"
                            ]
                          },
                          2
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ],
          "reinitialize": true,
          "root_find": "left",
          "description": "Ball bounces with energy loss on ground contact"
        },
        {
          "name": "low_energy_stop",
          "conditions": [
            {
              "op": "and",
              "args": [
                {
                  "op": "<",
                  "args": [
                    "total_energy",
                    0.01
                  ]
                },
                {
                  "op": "<",
                  "args": [
                    "height",
                    0.001
                  ]
                }
              ]
            }
          ],
          "affects": [
            {
              "lhs": "velocity",
              "rhs": 0.0
            },
            {
              "lhs": "drag_coefficient",
              "rhs": 1000.0
            }
          ],
          "reinitialize": true,
          "description": "Stop simulation when energy becomes negligible"
        }
      ],
      "discrete_events": [
        {
          "name": "restitution_degradation",
          "trigger": {
            "type": "condition",
            "expression": {
              "op": ">",
              "args": [
                "bounce_count",
                5
              ]
            }
          },
          "affects": [
            {
              "lhs": "restitution",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "restitution"
                    ]
                  },
                  0.95
                ]
              }
            }
          ],
          "discrete_parameters": [
            "restitution"
          ],
          "description": "Degrade restitution coefficient after multiple bounces"
        }
      ]
    },
    "ChemicalReactorController": {
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 298.15,
          "description": "Reactor temperature"
        },
        "concentration": {
          "type": "state",
          "units": "mol/L",
          "default": 1.0,
          "description": "Reactant concentration"
        },
        "cooling_flow": {
          "type": "parameter",
          "units": "L/min",
          "default": 5.0,
          "description": "Coolant flow rate"
        },
        "heating_power": {
          "type": "parameter",
          "units": "W",
          "default": 100.0,
          "description": "Heater power"
        },
        "setpoint_temp": {
          "type": "parameter",
          "units": "K",
          "default": 350.0,
          "description": "Temperature setpoint"
        },
        "safety_state": {
          "type": "parameter",
          "units": "1",
          "default": 0,
          "description": "Safety system state (0=normal, 1=warning, 2=emergency)"
        },
        "reaction_rate": {
          "type": "observed",
          "units": "mol/(L*s)",
          "expression": {
            "op": "*",
            "args": [
              0.001,
              "concentration",
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          5000.0
                        ]
                      },
                      "temperature"
                    ]
                  }
                ]
              }
            ]
          },
          "description": "Arrhenius reaction rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  0.01,
                  {
                    "op": "-",
                    "args": [
                      "setpoint_temp",
                      "temperature"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  0.001,
                  "heating_power"
                ]
              },
              {
                "op": "*",
                "args": [
                  -0.002,
                  "cooling_flow",
                  {
                    "op": "-",
                    "args": [
                      "temperature",
                      298.15
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  50.0,
                  "reaction_rate"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1.0,
              "reaction_rate"
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "temperature_warning",
          "conditions": [
            {
              "op": "-",
              "args": [
                "temperature",
                400.0
              ]
            }
          ],
          "affects": [
            {
              "lhs": "safety_state",
              "rhs": 1
            },
            {
              "lhs": "cooling_flow",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "cooling_flow"
                    ]
                  },
                  2.0
                ]
              }
            }
          ],
          "reinitialize": true,
          "description": "Activate warning and increase cooling at high temperature"
        },
        {
          "name": "emergency_shutdown",
          "conditions": [
            {
              "op": "-",
              "args": [
                "temperature",
                450.0
              ]
            }
          ],
          "affects": [
            {
              "lhs": "safety_state",
              "rhs": 2
            },
            {
              "lhs": "heating_power",
              "rhs": 0.0
            },
            {
              "lhs": "cooling_flow",
              "rhs": 50.0
            }
          ],
          "reinitialize": true,
          "description": "Emergency shutdown at critical temperature"
        },
        {
          "name": "temperature_recovery",
          "conditions": [
            {
              "op": "-",
              "args": [
                380.0,
                "temperature"
              ]
            }
          ],
          "affects": [
            {
              "lhs": "safety_state",
              "rhs": 0
            },
            {
              "lhs": "cooling_flow",
              "rhs": 5.0
            }
          ],
          "reinitialize": true,
          "description": "Reset to normal operation when temperature drops"
        }
      ],
      "discrete_events": [
        {
          "name": "periodic_maintenance",
          "trigger": {
            "type": "periodic",
            "interval": 3600.0
          },
          "affects": [
            {
              "lhs": "heating_power",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "heating_power"
                    ]
                  },
                  0.99
                ]
              }
            }
          ],
          "discrete_parameters": [
            "heating_power"
          ],
          "description": "Gradual efficiency degradation over time"
        },
        {
          "name": "setpoint_optimization",
          "trigger": {
            "type": "condition",
            "expression": {
              "op": "<",
              "args": [
                "concentration",
                0.1
              ]
            }
          },
          "affects": [
            {
              "lhs": "setpoint_temp",
              "rhs": {
                "op": "+",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "setpoint_temp"
                    ]
                  },
                  10.0
                ]
              }
            }
          ],
          "discrete_parameters": [
            "setpoint_temp"
          ],
          "description": "Increase setpoint when concentration is low"
        }
      ]
    },
