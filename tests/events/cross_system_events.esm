{
  "esm": "0.1.0",
  "metadata": {
    "name": "CrossSystemEventExamples",
    "description": "Test fixtures for events that affect multiple coupled systems",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z"
  },
  "models": {
    "PredatorSystem": {
      "reference": {
        "notes": "Predator population dynamics"
      },
      "variables": {
        "predator": {
          "type": "state",
          "units": "individuals",
          "default": 10.0,
          "description": "Predator population"
        },
        "death_rate": {
          "units": "1/time",
          "default": 0.1,
          "description": "Predator death rate",
          "type": "parameter"
        },
        "hunting_efficiency": {
          "units": "L/(ind\u00b7time)",
          "default": 0.01,
          "description": "Hunting efficiency",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "predator"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "hunting_efficiency",
                  "predator",
                  "PreySystem.prey"
                ]
              },
              {
                "op": "*",
                "args": [
                  "death_rate",
                  "predator"
                ]
              }
            ]
          }
        }
      ]
    },
    "PreySystem": {
      "reference": {
        "notes": "Prey population dynamics"
      },
      "variables": {
        "prey": {
          "type": "state",
          "units": "individuals",
          "default": 100.0,
          "description": "Prey population"
        },
        "growth_rate": {
          "units": "1/time",
          "default": 0.5,
          "description": "Prey growth rate",
          "type": "parameter"
        },
        "carrying_capacity": {
          "units": "individuals",
          "default": 500.0,
          "description": "Prey carrying capacity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "prey"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "growth_rate",
                  "prey",
                  {
                    "op": "-",
                    "args": [
                      1,
                      {
                        "op": "/",
                        "args": [
                          "prey",
                          "carrying_capacity"
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  0.01,
                  "prey",
                  "PredatorSystem.predator"
                ]
              }
            ]
          }
        }
      ]
    },
    "EnvironmentSystem": {
      "reference": {
        "notes": "Environmental conditions affecting both populations"
      },
      "variables": {
        "resource_level": {
          "type": "state",
          "units": "units",
          "default": 1.0,
          "description": "Environmental resource level"
        },
        "resource_recovery": {
          "units": "1/time",
          "default": 0.2,
          "description": "Resource recovery rate",
          "type": "parameter"
        },
        "base_consumption": {
          "units": "1/time",
          "default": 0.05,
          "description": "Base resource consumption",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "resource_level"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "resource_recovery",
                  {
                    "op": "-",
                    "args": [
                      1,
                      "resource_level"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "base_consumption",
                  "resource_level",
                  "PreySystem.prey"
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "PredatorSystem",
        "PreySystem"
      ]
    }
  ],
  "solver": {
    "strategy": "strang_serial",
    "config": {
      "algorithm": "Tsit5",
      "adaptive": true,
      "event_handling": "precise_callbacks"
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-02T00:00:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "element_type": "Float64"
    }
  }
}
