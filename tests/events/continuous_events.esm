{
  "esm": "0.1.0",
  "metadata": {
    "name": "ContinuousEventExamples",
    "description": "Test fixtures for continuous event handling (root-finding)",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z"
  },
  "models": {
    "BouncingBall": {
      "reference": {
        "notes": "Ball bouncing off ground with energy loss"
      },
      "variables": {
        "y": {
          "type": "state",
          "units": "m",
          "default": 10.0,
          "description": "Ball height"
        },
        "v": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Ball velocity"
        },
        "g": {
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravity acceleration",
          "type": "parameter"
        },
        "e": {
          "units": "1",
          "default": 0.8,
          "description": "Coefficient of restitution",
          "type": "parameter"
        },
        "ground": {
          "units": "m",
          "default": 0.0,
          "description": "Ground level",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "y"
            ],
            "wrt": "t"
          },
          "rhs": "v"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "v"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "g"
            ]
          }
        }
      ]
    },
    "HysteresisSwitch": {
      "reference": {
        "notes": "System with hysteresis switching behavior"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 0.0,
          "description": "System state"
        },
        "mode": {
          "type": "parameter",
          "units": "1",
          "default": 1,
          "description": "Operating mode"
        },
        "upper_threshold": {
          "units": "1",
          "default": 5.0,
          "description": "Upper switch threshold",
          "type": "parameter"
        },
        "lower_threshold": {
          "units": "1",
          "default": -5.0,
          "description": "Lower switch threshold",
          "type": "parameter"
        },
        "k1": {
          "units": "1/s",
          "default": 1.0,
          "description": "Mode 1 rate constant",
          "type": "parameter"
        },
        "k2": {
          "units": "1/s",
          "default": -0.5,
          "description": "Mode 2 rate constant",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "ifelse",
            "args": [
              {
                "op": "==",
                "args": [
                  "mode",
                  1
                ]
              },
              "k1",
              "k2"
            ]
          }
        }
      ]
    },
    "PopulationGrowthWithCrash": {
      "reference": {
        "notes": "Population growth with catastrophic collapse"
      },
      "variables": {
        "P": {
          "type": "state",
          "units": "individuals",
          "default": 10.0,
          "description": "Population size"
        },
        "r": {
          "units": "1/time",
          "default": 0.1,
          "description": "Growth rate",
          "type": "parameter"
        },
        "K": {
          "units": "individuals",
          "default": 1000.0,
          "description": "Carrying capacity",
          "type": "parameter"
        },
        "crash_threshold": {
          "units": "individuals",
          "default": 950.0,
          "description": "Population crash threshold",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "P"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              "r",
              "P",
              {
                "op": "-",
                "args": [
                  1,
                  {
                    "op": "/",
                    "args": [
                      "P",
                      "K"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T10:00:00Z"
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "element_type": "Float64"
    }
  }
}
