digraph SystemGraph {
    rankdir=LR;
    node [shape=box, style=filled];

    // System nodes
    SimpleOzone [fillcolor=lightblue, label="SimpleOzone\nreaction_system\n3 species, 3 params\n2 reactions"];
    Advection [fillcolor=lightgreen, label="Advection\nmodel\n2 variables\n1 equation"];
    GEOSFP [fillcolor=lightyellow, label="GEOSFP\ndata_loader\nGridded data\nprovides: u, v, T"];

    // System coupling edges
    SimpleOzone -> Advection [label="operator_compose", style=dashed, dir=both];
    GEOSFP -> SimpleOzone [label="T", color=red];
    GEOSFP -> Advection [label="u", color=red];
    GEOSFP -> Advection [label="v", color=red];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor=white;

        legend_system [shape=box, fillcolor=lightblue, label="System"];
        legend_data [shape=box, fillcolor=lightyellow, label="Data Loader"];
        legend_model [shape=box, fillcolor=lightgreen, label="Model"];
        legend_compose [style=dashed, label="operator_compose"];
        legend_varmap [color=red, label="variable_map"];

        legend_system -> legend_data [style=invis];
        legend_data -> legend_model [style=invis];
        legend_model -> legend_compose [style=invis];
        legend_compose -> legend_varmap [style=invis];
    }
}