digraph ExpressionGraph {
    rankdir=TB;
    node [shape=box, style=filled];

    // Variable nodes
    subgraph cluster_species {
        label="Species Variables";
        style=filled;
        fillcolor=lightblue;

        var_O3 [fillcolor=lightcyan, label="O3\n40e-9 mol/mol\nOzone"];
        var_NO [fillcolor=lightcyan, label="NO\n0.1e-9 mol/mol\nNitric oxide"];
        var_NO2 [fillcolor=lightcyan, label="NO2\n1.0e-9 mol/mol\nNitrogen dioxide"];
    }

    subgraph cluster_parameters {
        label="Parameters";
        style=filled;
        fillcolor=lightgreen;

        var_T [fillcolor=lightgreen, label="T\n298.15 K\nTemperature"];
        var_M [fillcolor=lightgreen, label="M\n2.46e19 molec/cm³\nAir density"];
        var_jNO2 [fillcolor=lightgreen, label="jNO2\n0.005 1/s\nPhotolysis rate"];
    }

    // Rate expression nodes
    subgraph cluster_rates {
        label="Rate Expressions";
        style=filled;
        fillcolor=pink;

        rate_R1 [fillcolor=pink, label="R1 Rate\nNO + O3 → NO2\nk = 1.8e-12 × exp(-1370/T) × M"];
        rate_R2 [fillcolor=pink, label="R2 Rate\nNO2 → NO + O3\nk = jNO2"];
    }

    // Rate dependencies
    var_T -> rate_R1 [label="temp dep", color=blue];
    var_M -> rate_R1 [label="density dep", color=blue];
    var_jNO2 -> rate_R2 [label="photolysis", color=blue];

    // Stoichiometric dependencies
    var_NO -> rate_R1 [label="substrate", color=red, style=bold];
    var_O3 -> rate_R1 [label="substrate", color=red, style=bold];
    rate_R1 -> var_NO2 [label="product", color=green, style=bold];

    var_NO2 -> rate_R2 [label="substrate", color=red, style=bold];
    rate_R2 -> var_NO [label="product", color=green, style=bold];
    rate_R2 -> var_O3 [label="product", color=green, style=bold];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor=white;

        legend_species [shape=box, fillcolor=lightcyan, label="Species"];
        legend_param [shape=box, fillcolor=lightgreen, label="Parameter"];
        legend_rate [shape=box, fillcolor=pink, label="Rate Expression"];
        legend_substrate [color=red, style=bold, label="Reactant"];
        legend_product [color=green, style=bold, label="Product"];
        legend_ratedep [color=blue, label="Rate Dependency"];

        legend_species -> legend_param [style=invis];
        legend_param -> legend_rate [style=invis];
        legend_rate -> legend_substrate [style=invis];
        legend_substrate -> legend_product [style=invis];
        legend_product -> legend_ratedep [style=invis];
    }
}