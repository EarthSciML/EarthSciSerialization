  {
    "name": "conditional_expression",
    "description": "Conditional expression with ifelse operator",
    "expression": {
      "op": "ifelse",
      "args": [
        { "op": ">", "args": ["x", 0] },
        { "op": "sqrt", "args": ["x"] },
        0
      ]
    },
    "variables": ["x"],
    "constants": [0],
    "expected_graph": {
      "nodes": [
        {
          "id": "var_x",
          "type": "variable",
          "name": "x",
          "operation": null
        },
        {
          "id": "const_0_1",
          "type": "constant",
          "value": 0,
          "operation": null
        },
        {
          "id": "const_0_2",
          "type": "constant",
          "value": 0,
          "operation": null
        },
        {
          "id": "gt_1",
          "type": "operation",
          "operation": ">",
          "inputs": ["var_x", "const_0_1"]
        },
        {
          "id": "sqrt_1",
          "type": "operation",
          "operation": "sqrt",
          "inputs": ["var_x"]
        },
        {
          "id": "ifelse_1",
          "type": "operation",
          "operation": "ifelse",
          "inputs": ["gt_1", "sqrt_1", "const_0_2"]
        }
      ],
      "edges": [
        { "from": "var_x", "to": "gt_1", "type": "data_dependency" },
        { "from": "const_0_1", "to": "gt_1", "type": "data_dependency" },
        { "from": "var_x", "to": "sqrt_1", "type": "data_dependency" },
        { "from": "gt_1", "to": "ifelse_1", "type": "control_dependency" },
        { "from": "sqrt_1", "to": "ifelse_1", "type": "conditional_dependency" },
        { "from": "const_0_2", "to": "ifelse_1", "type": "conditional_dependency" }
      ],
      "root": "ifelse_1"
    },
    "dependency_analysis": {
      "depth": 2,
      "parallelizable_operations": ["var_x", "const_0_1", "const_0_2", "gt_1", "sqrt_1"],
      "critical_path": ["var_x", "ifelse_1"],
      "operation_count": { ">": 1, "sqrt": 1, "ifelse": 1 },
      "has_conditional": true,
      "control_flow": true
    }
  },

