    "name": "simple_expression",
    "description": "Basic arithmetic expression graph",
    "expression": {
      "op": "+",
      "args": [
        { "op": "*", "args": ["a", "b"] },
        "c"
      ]
    },
    "variables": ["a", "b", "c"],
    "expected_graph": {
      "nodes": [
        {
          "id": "var_a",
          "type": "variable",
          "name": "a",
          "operation": null
        },
        {
          "id": "var_b",
          "type": "variable",
          "name": "b",
          "operation": null
        },
        {
          "id": "var_c",
          "type": "variable",
          "name": "c",
          "operation": null
        },
        {
          "id": "mult_1",
          "type": "operation",
          "operation": "*",
          "inputs": ["var_a", "var_b"]
        },
        {
          "id": "add_1",
          "type": "operation",
          "operation": "+",
          "inputs": ["mult_1", "var_c"]
        }
      ],
      "edges": [
        { "from": "var_a", "to": "mult_1", "type": "data_dependency" },
        { "from": "var_b", "to": "mult_1", "type": "data_dependency" },
        { "from": "mult_1", "to": "add_1", "type": "data_dependency" },
        { "from": "var_c", "to": "add_1", "type": "data_dependency" }
      ],
      "root": "add_1"
    },
    "dependency_analysis": {
      "depth": 2,
      "parallelizable_operations": ["var_a", "var_b", "var_c"],
      "critical_path": ["var_a", "mult_1", "add_1"],
      "operation_count": { "*": 1, "+": 1 }
    }
  },

