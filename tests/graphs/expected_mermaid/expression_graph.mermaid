graph TD
    %% Species Variables
    subgraph Species["Species Variables"]
        var_O3["O3<br/>40e-9 mol/mol<br/>Ozone"]
        var_NO["NO<br/>0.1e-9 mol/mol<br/>Nitric oxide"]
        var_NO2["NO2<br/>1.0e-9 mol/mol<br/>Nitrogen dioxide"]
    end

    %% Parameters
    subgraph Parameters["Parameters"]
        var_T["T<br/>298.15 K<br/>Temperature"]
        var_M["M<br/>2.46e19 molec/cm³<br/>Air density"]
        var_jNO2["jNO2<br/>0.005 1/s<br/>Photolysis rate"]
    end

    %% Rate Expressions
    subgraph Rates["Rate Expressions"]
        rate_R1["R1 Rate<br/>NO + O3 → NO2<br/>k = 1.8e-12 × exp(-1370/T) × M"]
        rate_R2["R2 Rate<br/>NO2 → NO + O3<br/>k = jNO2"]
    end

    %% Rate dependencies
    var_T -.->|"temp dep"| rate_R1
    var_M -.->|"density dep"| rate_R1
    var_jNO2 -.->|"photolysis"| rate_R2

    %% Stoichiometric dependencies - reactants
    var_NO -->|"substrate"| rate_R1
    var_O3 -->|"substrate"| rate_R1
    var_NO2 -->|"substrate"| rate_R2

    %% Stoichiometric dependencies - products
    rate_R1 -->|"product"| var_NO2
    rate_R2 -->|"product"| var_NO
    rate_R2 -->|"product"| var_O3

    %% Styling
    classDef species fill:#e0ffff,stroke:#333,stroke-width:2px
    classDef parameter fill:#90ee90,stroke:#333,stroke-width:2px
    classDef rate fill:#ffc0cb,stroke:#333,stroke-width:2px

    class var_O3,var_NO,var_NO2 species
    class var_T,var_M,var_jNO2 parameter
    class rate_R1,rate_R2 rate