graph LR
    %% System nodes with styling
    SimpleOzone["SimpleOzone<br/>reaction_system<br/>3 species, 3 params<br/>2 reactions"]
    Advection["Advection<br/>model<br/>2 variables<br/>1 equation"]
    GEOSFP["GEOSFP<br/>data_loader<br/>Gridded data<br/>provides: u, v, T"]

    %% System coupling
    SimpleOzone -.->|"operator_compose"| Advection
    Advection -.->|"operator_compose"| SimpleOzone
    GEOSFP -->|"T"| SimpleOzone
    GEOSFP -->|"u"| Advection
    GEOSFP -->|"v"| Advection

    %% Styling
    classDef reactionSystem fill:#add8e6,stroke:#333,stroke-width:2px
    classDef model fill:#90ee90,stroke:#333,stroke-width:2px
    classDef dataLoader fill:#ffffe0,stroke:#333,stroke-width:2px

    class SimpleOzone reactionSystem
    class Advection model
    class GEOSFP dataLoader