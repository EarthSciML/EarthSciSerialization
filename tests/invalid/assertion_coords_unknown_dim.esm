{
  "esm": "0.1.0",
  "metadata": {
    "name": "AssertionCoordsUnknownDim",
    "description": "Assertion coords keys MUST be names declared in component.domain.spatial. Using a coordinate name absent from the spatial map is a structural error.",
    "authors": ["ESM Test Suite"],
    "created": "2026-04-22T00:00:00Z"
  },
  "models": {
    "Heat1D": {
      "domain": "heat_1d",
      "variables": {
        "u": { "type": "state", "units": "1", "default": 0.0 },
        "alpha": { "type": "parameter", "units": "1", "default": 0.01 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["u"], "wrt": "t" },
          "rhs": { "op": "*", "args": ["alpha", { "op": "laplacian", "args": ["u"] }] }
        }
      ],
      "tests": [
        {
          "id": "unknown_coord_key",
          "time_span": { "start": 0.0, "end": 0.1 },
          "tolerance": { "abs": 1.0e-3 },
          "assertions": [
            { "variable": "u", "time": 0.1, "expected": 0.5, "coords": { "y": 0.5 } }
          ]
        }
      ]
    }
  },
  "domains": {
    "heat_1d": {
      "independent_variable": "t",
      "spatial": {
        "x": { "min": 0.0, "max": 1.0, "units": "1", "grid_spacing": 0.02 }
      },
      "element_type": "Float64"
    }
  }
}
