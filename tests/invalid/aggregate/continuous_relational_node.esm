{
  "esm": "0.6.0",
  "metadata": {
    "name": "continuous_relational_node",
    "description": "INVALID — CADENCE-PARTITION-LEVEL (bead ess-my4.3.11; RFC semiring-faq-unified-ir §6.1, CONFORMANCE_SPEC.md §5.7.6 guard 2). A relational / value-invention `aggregate` node (`distinct: true` under `bool_and_or`) whose Skolem `key` reads the `state` variable `u`. The cadence-partition pass classifies the node CONTINUOUS (class = max over inputs; a state input is CONTINUOUS), and guard 2 — \"no relational engine on the hot path\" — REJECTS it: state-dependent topology may not run per step in v1. This is SCHEMA-VALID (the schema does not encode cadence, exactly as a state-dependent distinct is well-formed against esm-schema.json), so the schema-only bindings (TypeScript, Go) ACCEPT it and tests/invalid/expected_errors.json marks it `resolver_only: true`. It is rejected only by the partition guard in the evaluating bindings: Julia Cadence.run_guards → CadenceError; Rust cadence::partition_model → Err(CadenceError); Python cadence.partition → CadenceError (message contains \"CONTINUOUS\"). Contrast tests/valid/cadence/pure_topology.esm, where the SAME primitives over CONST mesh literals fold into the artifact and are allowed.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "aggregate",
      "cadence-partition",
      "value-invention",
      "invalid",
      "resolver"
    ]
  },
  "models": {
    "ContinuousRelationalNode": {
      "index_sets": {
        "faces": {
          "kind": "interval",
          "size": 4
        }
      },
      "variables": {
        "u": {
          "type": "state"
        },
        "edge_exists": {
          "type": "state"
        }
      },
      "equations": [
        {
          "_comment": "REJECTED by §5.7 guard 2: this distinct/value-invention node reads the state variable u in its Skolem key, so class(node) = CONTINUOUS. Relational work may not run on the per-step hot path; declare the leaves CONST (document literals) or DISCRETE (a `discrete` variable refreshed at events) instead.",
          "lhs": {
            "op": "index",
            "args": ["edge_exists", "e"]
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "distinct": true,
            "semiring": "bool_and_or",
            "output_idx": ["e"],
            "ranges": {
              "f": { "from": "faces" }
            },
            "key": {
              "op": "skolem",
              "args": [
                "edge",
                { "op": "index", "args": ["u", "f"] }
              ]
            },
            "expr": {
              "op": "true",
              "args": []
            }
          }
        },
        {
          "_comment": "An ordinary continuous decay so u is a well-formed state with an ODE alongside the (rejected) value-invention node above.",
          "lhs": {
            "op": "D",
            "args": ["u"],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": ["u"]
          }
        }
      ]
    }
  }
}
