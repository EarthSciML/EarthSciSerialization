{
  "esm": "0.1.0",
  "metadata": {
    "name": "DataLoaderUndefinedReference",
    "description": "Test case: coupling references undefined data loader variable",
    "authors": [
      "Test Suite"
    ]
  },
  "data_loaders": {
    "WeatherData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/weather/{date:%Y%m%d}.nc"
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": "n_lon",
            "spacing": "uniform"
          },
          "lat": {
            "n": "n_lat",
            "spacing": "uniform"
          }
        },
        "parameters": {
          "n_lon": {
            "description": "lon cell count, resolved from the source dataset at load time"
          },
          "n_lat": {
            "description": "lat cell count, resolved from the source dataset at load time"
          }
        }
      },
      "variables": {
        "T": {
          "file_variable": "T",
          "units": "K",
          "description": "Temperature"
        },
        "P": {
          "file_variable": "P",
          "units": "Pa",
          "description": "Pressure"
        }
      }
    }
  },
  "models": {
    "TestModel": {
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 1.0
        },
        "external_temp": {
          "type": "parameter",
          "units": "K",
          "default": 298.15
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -0.1,
              "x"
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "WeatherData.undefined_variable",
      "to": "TestModel.external_temp",
      "transform": "param_to_var",
      "description": "This should fail - variable not provided by loader"
    }
  ]
}
