{
  "esm": "0.1.0",
  "metadata": {
    "name": "Complete Error Coverage Test",
    "description": "Comprehensive test case covering all 11 required error codes from ESM Libraries Specification Section 3.4",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T18:00:00Z",
    "license": "CC0-1.0"
  },
  "models": {
    "BadModel": {
      "type": "ode",
      "variables": {
        "x": {
          "type": "state",
          "units": "kg",
          "description": "State variable x",
          "default": 1.0
        },
        "y": {
          "type": "state",
          "units": "kg",
          "description": "State variable y",
          "default": 0.0
        },
        "observed_without_expr": {
          "type": "observed",
          "units": "kg",
          "description": "Observed variable missing expression"
        }
      },
      "equations": [
        "dx/dt = undefined_rate + undefined_var"
      ],
      "continuous_events": [
        {
          "name": "bad_event",
          "condition": "undefined_condition_var > 0",
          "affects": [
            {
              "lhs": "nonexistent_var",
              "rhs": "0.0"
            }
          ]
        }
      ],
      "discrete_events": [
        {
          "name": "bad_discrete_event",
          "trigger": "t > 5.0",
          "discrete_parameters": [
            "undefined_discrete_param"
          ],
          "affects": [
            {
              "lhs": "x",
              "rhs": "1.0"
            }
          ]
        }
      ]
    }
  },
  "reaction_systems": {
    "BadReactions": {
      "species": {
        "A": {
          "units": "mol",
          "description": "Species A"
        }
      },
      "parameters": {},
      "reactions": [
        {
          "id": "bad_reaction",
          "substrates": null,
          "products": null,
          "rate": "missing_rate_param * A"
        },
        {
          "id": "undefined_species_reaction",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "UndefinedProduct",
              "stoichiometry": 1
            }
          ],
          "rate": "also_missing_param"
        }
      ]
    }
  },
  "data_loaders": {
    "TestDataLoader": {
      "kind": "static",
      "source": {
        "url_template": "file:///data/test_loader.nc"
      },
      "grid": {
        "family": "cartesian",
        "crs": {
          "projection": "longlat",
          "datum": "WGS84"
        },
        "description": "Native grid migrated from the loader's former 'spatial' block (RFC pure-io-data-loaders §4.1); the loader describes this grid but performs no reprojection or regridding.",
        "dimensions": [
          "lon",
          "lat"
        ],
        "extents": {
          "lon": {
            "n": "n_lon",
            "spacing": "uniform"
          },
          "lat": {
            "n": "n_lat",
            "spacing": "uniform"
          }
        },
        "parameters": {
          "n_lon": {
            "description": "lon cell count, resolved from the source dataset at load time"
          },
          "n_lat": {
            "description": "lat cell count, resolved from the source dataset at load time"
          }
        }
      },
      "variables": {
        "temperature": {
          "file_variable": "temperature",
          "units": "K",
          "description": "Temperature data"
        }
      },
      "metadata": {
        "tags": [
          "static"
        ]
      }
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "NonExistentSystem.var",
      "to": "BadModel.x"
    }
  ]
}
