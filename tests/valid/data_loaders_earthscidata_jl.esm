{
  "esm": "0.1.0",
  "metadata": {
    "name": "DataLoadersEarthSciDataJLCoverage",
    "description": "Expressiveness fixture: demonstrates the STAC-like DataLoader schema can express every data source currently implemented in EarthSciData.jl. Each loader documents the Julia source file + struct it corresponds to in its metadata.description. Hand-constructed from the EarthSciData.jl parameter footprint (no actual data fetched) — see task gt-dba Mayor amendment.",
    "authors": ["ESM Test Suite"],
    "created": "2026-04-14T00:00:00Z",
    "tags": ["data-loaders", "expressiveness", "earthscidata-jl-coverage"]
  },
  "data_loaders": {
    "ERA5PressureLevel": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/era5/era5_pl_{date:%Y}_{date:%m}.nc",
        "mirrors": [
          "https://cds.climate.copernicus.eu/api/v2/reanalysis-era5-pressure-levels/{date:%Y}/{date:%m}.nc"
        ]
      },
      "temporal": {
        "file_period": "P1M",
        "frequency": "PT1H",
        "time_variable": "valid_time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "longitude": "center",
          "latitude": "center",
          "pressure_level": "center"
        },
        "resolution": {
          "longitude": 0.25,
          "latitude": 0.25
        }
      },
      "variables": {
        "temperature": {
          "file_variable": "t",
          "units": "K",
          "description": "Air temperature on ERA5 pressure levels"
        },
        "u_component_of_wind": {
          "file_variable": "u",
          "units": "m/s",
          "description": "Eastward component of wind"
        },
        "v_component_of_wind": {
          "file_variable": "v",
          "units": "m/s",
          "description": "Northward component of wind"
        },
        "vertical_velocity": {
          "file_variable": "w",
          "units": "Pa/s",
          "description": "Vertical velocity in pressure coordinates"
        },
        "specific_humidity": {
          "file_variable": "q",
          "units": "kg/kg",
          "description": "Specific humidity"
        },
        "geopotential": {
          "file_variable": "z",
          "units": "m^2/s^2",
          "description": "Geopotential"
        },
        "ozone_mass_mixing_ratio": {
          "file_variable": "o3",
          "units": "kg/kg",
          "description": "Ozone mass mixing ratio"
        }
      },
      "reference": {
        "citation": "Hersbach et al., 2020 — ERA5 Global Reanalysis, Copernicus Climate Change Service (C3S)",
        "doi": "10.24381/cds.bd0915c6",
        "url": "https://cds.climate.copernicus.eu/",
        "notes": "EarthSciData.jl source: src/era5.jl — struct ERA5PressureLevelFileSet (lines 56-210), relpath (lines 213-217), variable short-name table ERA5_VARIABLES (lines 16-33). Native time/longitude orientation is normalized in loadslice!."
      },
      "metadata": {
        "tags": ["reanalysis", "meteorology", "pressure-levels", "cds"]
      }
    },

    "WRFRegional": {
      "kind": "grid",
      "source": {
        "url_template": "https://data.rda.ucar.edu/d340000/{date:%Y}{date:%m}/wrfout_hourly_d01_{date:%Y-%m-%d}_{date:%H:%M:%S}.nc"
      },
      "temporal": {
        "file_period": "PT1H",
        "frequency": "PT1H",
        "records_per_file": 1,
        "time_variable": "time"
      },
      "spatial": {
        "crs": "+proj=lcc +lat_1=30.0 +lat_2=60.0 +lat_0=40.0 +lon_0=-97.0 +x_0=0 +y_0=0 +a=6370000 +b=6370000 +to_meter=1",
        "grid_type": "lambert_conformal",
        "staggering": {
          "west_east": "center",
          "south_north": "center",
          "bottom_top": "center"
        }
      },
      "variables": {
        "T2": {
          "file_variable": "T2",
          "units": "K",
          "description": "2-meter air temperature"
        },
        "U10": {
          "file_variable": "U10",
          "units": "m/s",
          "description": "10-meter eastward wind"
        },
        "V10": {
          "file_variable": "V10",
          "units": "m/s",
          "description": "10-meter northward wind"
        },
        "PBLH": {
          "file_variable": "PBLH",
          "units": "m",
          "description": "Planetary boundary layer height"
        },
        "PSFC": {
          "file_variable": "PSFC",
          "units": "Pa",
          "description": "Surface pressure"
        }
      },
      "reference": {
        "citation": "Skamarock et al., 2019 — A Description of the Advanced Research WRF Model Version 4",
        "url": "https://rda.ucar.edu/datasets/d340000/",
        "notes": "EarthSciData.jl source: src/wrf.jl — struct WRFFileSet (lines 4-37), relpath (lines 39-45), projection decoded at runtime from MAP_PROJ/TRUELAT1/TRUELAT2/MOAD_CEN_LAT/STAND_LON (lines 85-92). Projection string here uses example CONUS parameters; real values come from file attributes."
      },
      "metadata": {
        "tags": ["reanalysis", "meteorology", "regional", "lambert-conformal"]
      }
    },

    "CEDSAnthroSO2": {
      "kind": "grid",
      "source": {
        "url_template": "https://esgf-node.ornl.gov/thredds/fileServer/user_pub_work/input4MIPs/CMIP7/CMIP/PNNL-JGCRI/CEDS-CMIP-2025-04-18/atmos/mon/{species}_em_anthro/gn/v20250421/{species}-em-anthro_input4MIPs_emissions_CMIP_CEDS-CMIP-2025-04-18_gn_{year_start}01-{year_end}12.nc"
      },
      "temporal": {
        "start": "1750-01-01T00:00:00Z",
        "end": "2023-12-31T23:59:59Z",
        "file_period": "P50Y",
        "frequency": "P1M",
        "time_variable": "time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.5,
          "lat": 0.5
        }
      },
      "variables": {
        "SO2_em_anthro": {
          "file_variable": "SO2_em_anthro",
          "units": "kg/m^2/s",
          "description": "Anthropogenic SO2 emission flux, summed across sectors (Agriculture, Energy, Industrial, Transportation, Residential/Commercial/Other, Solvents, Waste, International Shipping)"
        }
      },
      "reference": {
        "citation": "Hoesly et al., 2018 — Historical (1750-2014) anthropogenic emissions of reactive gases and aerosols from the Community Emissions Data System",
        "doi": "10.5194/gmd-11-369-2018",
        "url": "https://esgf-node.ornl.gov/",
        "notes": "EarthSciData.jl source: src/ceds.jl — struct CEDSFileSet (lines 59-158), relpath (lines 159-167), sector list CEDS_SECTORS (lines 4-13), species list CEDS_SPECIES (lines 16-18), file chunks CEDS_GN_CHUNKS (lines 21-28). Files are chunked 50-year blocks; per-species. The url_template uses a custom {species}/{year_start}/{year_end} substitution — runtime resolves these."
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "sector-based", "ceds-cmip"],
        "sectors": [
          "Agriculture",
          "Energy",
          "Industrial",
          "Transportation",
          "Residential, Commercial, Other",
          "Solvents production and application",
          "Waste",
          "International Shipping"
        ]
      }
    },

    "EDGARv81MonthlyNOx": {
      "kind": "grid",
      "source": {
        "url_template": "https://jeodpp.jrc.ec.europa.eu/ftp/jrc-opendata/EDGAR/datasets/v81_FT2022_AP_new/monthly/{species}/bkl_{sector}/v81_FT2022_AP_new_{species}_{sector}_{date:%Y}_monthly.nc"
      },
      "temporal": {
        "start": "2000-01-01T00:00:00Z",
        "end": "2022-12-31T23:59:59Z",
        "file_period": "P1Y",
        "frequency": "P1M",
        "time_variable": "time"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.1,
          "lat": 0.1
        }
      },
      "variables": {
        "emi_nox_ENE": {
          "file_variable": "emi_nox",
          "units": "kg/m^2/s",
          "description": "NOx emission flux from the ENE (Power Industry) sector"
        }
      },
      "reference": {
        "citation": "Crippa et al., 2023 — EDGAR v8.1 monthly air pollutant emissions",
        "url": "https://edgar.jrc.ec.europa.eu/dataset_ap81",
        "notes": "EarthSciData.jl source: src/edgar_v81_monthly.jl — struct EDGARv81MonthlyEmisFileSet (lines 91-130), relative path helper _edgar_zip_relpath (lines 13-15), substance list EDGAR_V81_SUBSTANCES (lines 3-5), temporal range constants EDGAR_V81_START_YEAR/EDGAR_V81_END_YEAR (lines 8-9), mirror EDGAR_V81_MIRROR (line 7). Distributed as per-(substance, sector) zip archives; schema-level url_template uses {species}/{sector} custom substitutions."
      },
      "metadata": {
        "tags": ["emissions", "anthropogenic", "sector-based", "edgar", "per-species", "monthly"]
      }
    },

    "USGS3DEPElevation": {
      "kind": "static",
      "source": {
        "url_template": "https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/exportImage?bbox={bbox_west},{bbox_south},{bbox_east},{bbox_north}&size={width},{height}&format=tiff&f=image&bboxSR=4326&imageSR=4326"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 9.2592592592e-05,
          "lat": 9.2592592592e-05
        }
      },
      "variables": {
        "elevation": {
          "file_variable": "elevation",
          "units": "m",
          "description": "Terrain elevation above sea level (native 1/3 arc-second, ~10m resolution)"
        }
      },
      "regridding": {
        "extrapolation": "clamp",
        "fill_value": -9999.0
      },
      "reference": {
        "citation": "U.S. Geological Survey — 3D Elevation Program (3DEP)",
        "url": "https://elevation.nationalmap.gov/",
        "notes": "EarthSciData.jl source: src/usgs3dep.jl — struct USGS3DEPFileSet (lines 21-27), constructor USGS3DEPFileSet(domaininfo; resolution=1/3) (lines 44-100+), mirror URL USGS3DEP_MIRROR (line 3). This is a time-invariant (kind=\"static\") dataset; the REST API returns GeoTIFF on demand. Schema-level url_template uses custom {bbox_*},{width},{height} substitutions computed from the requested domain."
      },
      "metadata": {
        "tags": ["static", "elevation", "terrain", "usgs", "rest-api"]
      }
    }
  },
  "models": {
    "ExpressivenessWitness": {
      "variables": {
        "x": {
          "type": "state",
          "units": "1",
          "default": 0.0,
          "description": "Placeholder state variable — this model exists only to satisfy the ESM schema requirement that at least one model or reaction_system be present."
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": ["x"],
            "wrt": "t"
          },
          "rhs": 0
        }
      ]
    }
  }
}
