{
  "esm": "0.4.0",
  "metadata": {
    "name": "ExpressionTemplatesArrhenius",
    "description": "Conformance fixture for the in-file AST templates mechanism (RFC docs/content/rfcs/ast-expression-templates.md, esm-giy). Declares an `arrhenius` expression template inside a single reaction_system and references it via `apply_expression_template` in three reaction rates. After parse-time expansion (Option A, RFC v2 §4), every reaction rate AST MUST be structurally identical to the inline form and the `expression_templates` block MUST be absent on emit.",
    "created": "2026-04-28T00:00:00Z"
  },
  "reaction_systems": {
    "ToyArrhenius": {
      "species": {
        "A": { "default": 1.0 },
        "B": { "default": 0.0 },
        "C": { "default": 0.0 }
      },
      "parameters": {
        "T": { "default": 300.0 },
        "num_density": { "default": 2.5e19 }
      },
      "expression_templates": {
        "arrhenius": {
          "params": ["A_pre", "Ea"],
          "body": {
            "op": "*",
            "args": [
              "A_pre",
              {
                "op": "exp",
                "args": [
                  { "op": "/", "args": [{ "op": "-", "args": ["Ea"] }, "T"] }
                ]
              },
              "num_density"
            ]
          }
        }
      },
      "reactions": [
        {
          "id": "R1",
          "substrates": [{ "species": "A", "stoichiometry": 1 }],
          "products":   [{ "species": "B", "stoichiometry": 1 }],
          "rate": {
            "op": "apply_expression_template",
            "args": [],
            "name": "arrhenius",
            "bindings": { "A_pre": 1.8e-12, "Ea": 1500 }
          }
        },
        {
          "id": "R2",
          "substrates": [{ "species": "B", "stoichiometry": 1 }],
          "products":   [{ "species": "C", "stoichiometry": 1 }],
          "rate": {
            "op": "apply_expression_template",
            "args": [],
            "name": "arrhenius",
            "bindings": { "A_pre": 3.0e-13, "Ea": 460 }
          }
        },
        {
          "id": "R3",
          "substrates": [{ "species": "A", "stoichiometry": 1 }],
          "products":   [{ "species": "C", "stoichiometry": 1 }],
          "rate": {
            "op": "apply_expression_template",
            "args": [],
            "name": "arrhenius",
            "bindings": { "A_pre": 4.5e-14, "Ea": 920 }
          }
        }
      ]
    }
  }
}
