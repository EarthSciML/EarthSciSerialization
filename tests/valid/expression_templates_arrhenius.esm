{
  "esm": "0.4.0",
  "metadata": {
    "name": "expression_templates_arrhenius_valid",
    "description": "Authoring-fixture demonstration of the v0.4.0 expression_templates / apply_expression_template mechanism (esm-spec §9.6 / docs/rfcs/ast-expression-templates.md, esm-giy). A 2-parameter `arrhenius` template factors three reactions whose rates share the same A·exp(-Ea/T)·num_density form. After load-time expansion, the canonical AST is the inline form (Option A round-trip); this file is the source-of-truth on disk.",
    "authors": ["esm-giy"]
  },
  "reaction_systems": {
    "chem": {
      "species": {
        "A": {"default": 1.0},
        "B": {"default": 0.5},
        "C": {"default": 0.0},
        "D": {"default": 0.0}
      },
      "parameters": {
        "T":          {"default": 298.15, "units": "K"},
        "num_density":{"default": 2.5e19, "units": "molec/cm^3"}
      },
      "expression_templates": {
        "arrhenius": {
          "description": "k = A · exp(-Ea / T) · num_density (canonical single-exp Arrhenius rate).",
          "params": ["A_pre", "Ea"],
          "body": {
            "op": "*",
            "args": [
              "A_pre",
              {"op": "exp", "args": [
                {"op": "/", "args": [{"op": "-", "args": ["Ea"]}, "T"]}
              ]},
              "num_density"
            ]
          }
        }
      },
      "reactions": [
        {
          "id": "R1",
          "substrates": [{"species": "A", "stoichiometry": 1}],
          "products":   [{"species": "B", "stoichiometry": 1}],
          "rate": {
            "op": "apply_expression_template", "args": [],
            "name": "arrhenius",
            "bindings": {"A_pre": 1.8e-12, "Ea": 1500}
          }
        },
        {
          "id": "R2",
          "substrates": [{"species": "B", "stoichiometry": 1}],
          "products":   [{"species": "C", "stoichiometry": 1}],
          "rate": {
            "op": "apply_expression_template", "args": [],
            "name": "arrhenius",
            "bindings": {"A_pre": 3.4e-13, "Ea": 800}
          }
        },
        {
          "id": "R3",
          "substrates": [{"species": "C", "stoichiometry": 1}],
          "products":   [{"species": "D", "stoichiometry": 1}],
          "rate": {
            "op": "apply_expression_template", "args": [],
            "name": "arrhenius",
            "bindings": {"A_pre": 6.1e-14, "Ea": 200}
          }
        }
      ]
    }
  }
}
