  "models": {
    "ReferenceTestModel": {
      "reference": { "notes": "Test model for reference types" },
      "variables": {
        "concentration": { "type": "state", "units": "mol/mol", "default": 1e-9 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["concentration"], "wrt": "t" },
          "rhs": { "op": "-", "args": [0.1, "concentration"] }
        }
      ]
    }
  }
