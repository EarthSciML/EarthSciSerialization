{
  "esm": "0.1.0",
  "metadata": {
    "name": "DataLoadersComprehensive",
    "description": "Comprehensive test fixtures for data loader types, validation, and configuration",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "data-loaders",
      "validation",
      "comprehensive"
    ]
  },
  "data_loaders": {
    "GEOSFP_MeteoData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/GEOSFP/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT3H",
        "file_period": "PT3H",
        "records_per_file": 1
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.3125,
          "lat": 0.25,
          "lev": 72
        }
      },
      "variables": {
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "Eastward wind component"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "Northward wind component"
        },
        "T": {
          "file_variable": "T",
          "units": "K",
          "description": "Air temperature"
        },
        "PBLH": {
          "file_variable": "PBLH",
          "units": "m",
          "description": "Planetary boundary layer height"
        },
        "P": {
          "file_variable": "P",
          "units": "Pa",
          "description": "Air pressure"
        }
      },
      "reference": {
        "citation": "Global Modeling and Assimilation Office (GMAO), NASA GSFC",
        "url": "https://gmao.gsfc.nasa.gov/GEOS_systems/",
        "doi": "10.5067/8D5L8QSF2Y6L"
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    },
    "NEI_Emissions": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/NEI2016/{date:%Y%m%d_%H%M}.nc"
      },
      "temporal": {
        "frequency": "PT1H",
        "file_period": "PT1H",
        "records_per_file": 1
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.1,
          "lat": 0.1
        }
      },
      "variables": {
        "emission_rate_NO": {
          "file_variable": "emission_rate_NO",
          "units": "kg/m^2/s",
          "description": "NO emission rate"
        },
        "emission_rate_CO": {
          "file_variable": "emission_rate_CO",
          "units": "kg/m^2/s",
          "description": "CO emission rate"
        },
        "emission_rate_SO2": {
          "file_variable": "emission_rate_SO2",
          "units": "kg/m^2/s",
          "description": "SO2 emission rate"
        }
      },
      "reference": {
        "citation": "US EPA, 2016 National Emissions Inventory",
        "url": "https://www.epa.gov/air-emissions-inventories/2016-national-emissions-inventory-nei-data",
        "notes": "Gridded annual emissions with temporal and spatial allocation"
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic"
        ]
      }
    },
    "ObservationalData": {
      "kind": "points",
      "source": {
        "url_template": "file:///data/EPA_AQS/{date:%Y%m%d}.csv"
      },
      "temporal": {
        "frequency": "PT1H",
        "file_period": "PT1H",
        "records_per_file": 1
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "observed_O3": {
          "file_variable": "observed_O3",
          "units": "ppb",
          "description": "Surface ozone concentration"
        },
        "observed_SO2": {
          "file_variable": "observed_SO2",
          "units": "ppb",
          "description": "Surface SO2 concentration"
        }
      },
      "reference": {
        "citation": "US EPA Air Quality System (AQS)",
        "url": "https://www.epa.gov/aqs"
      },
      "metadata": {
        "tags": [
          "observation",
          "point-data"
        ]
      }
    },
    "StaticFields": {
      "kind": "static",
      "source": {
        "url_template": "file:///data/LandUseCover.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        },
        "resolution": {
          "lon": 0.00833333,
          "lat": 0.00833333
        }
      },
      "variables": {
        "land_use_type": {
          "file_variable": "land_use_type",
          "units": "1",
          "description": "IGBP land use classification (1-17)"
        },
        "leaf_area_index": {
          "file_variable": "leaf_area_index",
          "units": "m^2/m^2",
          "description": "Leaf area index"
        }
      },
      "reference": {
        "citation": "Friedl, M., Sulla-Menashe, D. MODIS Collection 6 Land Cover (MCD12Q1)",
        "doi": "10.5067/MODIS/MCD12Q1.006"
      },
      "metadata": {
        "tags": [
          "static"
        ]
      }
    },
    "CallbackData": {
      "kind": "grid",
      "source": {
        "url_template": "callback://UserDefinedCallback"
      },
      "temporal": {
        "frequency": "PT30M",
        "file_period": "PT30M",
        "records_per_file": 1
      },
      "variables": {
        "custom_u": {
          "file_variable": "custom_u",
          "units": "m/s",
          "description": "Custom scaled eastward wind"
        },
        "custom_T": {
          "file_variable": "custom_T",
          "units": "K",
          "description": "Custom adjusted temperature"
        }
      },
      "metadata": {
        "tags": [
          "runtime-callback"
        ]
      }
    }
  },
  "models": {
    "SimpleChemistry": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 5e-08,
          "description": "Ozone concentration"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-08,
          "description": "NO concentration"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  -1e-05,
                  "O3"
                ]
              },
              "GEOSFP_MeteoData.u"
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "GEOSFP_MeteoData.u",
      "to": "SimpleChemistry.wind_u",
      "transform": "param_to_var",
      "description": "Map wind data to chemistry model"
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-01T12:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -125.0,
          "max": -66.0
        },
        "lat": {
          "min": 20.0,
          "max": 50.0
        }
      }
    }
  }
}
