{
  "esm": "0.1.0",
  "metadata": {
    "name": "UnitsDimensionalAnalysis",
    "description": "Test fixtures for dimensional analysis in physics and chemistry equations",
    "authors": [
      "Chris Tessum with Claude"
    ],
    "created": "2026-02-16T00:00:00Z",
    "tags": [
      "units",
      "dimensional_analysis",
      "physics",
      "chemistry",
      "validation"
    ]
  },
  "models": {
    "NewtonianMechanics": {
      "reference": {
        "notes": "Classical mechanics equations with proper dimensional analysis"
      },
      "variables": {
        "m": {
          "type": "parameter",
          "units": "kg",
          "default": 10.0,
          "description": "Mass"
        },
        "v": {
          "type": "state",
          "units": "m/s",
          "default": 5.0,
          "description": "Velocity"
        },
        "a": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Acceleration"
        },
        "t": {
          "type": "parameter",
          "units": "s",
          "default": 1.0,
          "description": "Time"
        },
        "x": {
          "type": "state",
          "units": "m",
          "default": 0.0,
          "description": "Position"
        },
        "F": {
          "type": "observed",
          "units": "N",
          "description": "Force from Newton's second law",
          "expression": {
            "op": "*",
            "args": [
              "m",
              "a"
            ]
          }
        },
        "p": {
          "type": "observed",
          "units": "kg*m/s",
          "description": "Momentum",
          "expression": {
            "op": "*",
            "args": [
              "m",
              "v"
            ]
          }
        },
        "E_kinetic": {
          "type": "observed",
          "units": "J",
          "description": "Kinetic energy",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  0.5,
                  "m"
                ]
              },
              {
                "op": "^",
                "args": [
                  "v",
                  2
                ]
              }
            ]
          }
        },
        "W": {
          "type": "observed",
          "units": "J",
          "description": "Work done",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "m",
                  "a"
                ]
              },
              "x"
            ]
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": "v"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "v"
            ],
            "wrt": "t"
          },
          "rhs": "a"
        }
      ],
      "tolerance": { "rel": 1e-10 },
      "tests": [
        {
          "id": "newton_observed_at_t0",
          "description": "At t=0 with m=10 kg, a=2 m/s^2, v=5 m/s, x=2 m: F = m*a = 20 N; p = m*v = 50 kg*m/s; E_kinetic = 0.5*m*v^2 = 125 J; W = m*a*x = 40 J. Exercises multiplication and v^2 via the ^ operator.",
          "initial_conditions": {
            "v": 5.0,
            "x": 2.0
          },
          "parameter_overrides": {
            "m": 10.0,
            "a": 2.0,
            "t": 1.0
          },
          "time_span": { "start": 0.0, "end": 0.0 },
          "assertions": [
            { "variable": "F",         "time": 0.0, "expected":  20.0 },
            { "variable": "p",         "time": 0.0, "expected":  50.0 },
            { "variable": "E_kinetic", "time": 0.0, "expected": 125.0 },
            { "variable": "W",         "time": 0.0, "expected":  40.0 }
          ]
        }
      ]
    },
    "Thermodynamics": {
      "reference": {
        "notes": "Thermodynamic equations with dimensional consistency"
      },
      "variables": {
        "n": {
          "type": "parameter",
          "units": "mol",
          "default": 1.0,
          "description": "Amount of substance"
        },
        "R": {
          "type": "parameter",
          "units": "J/(mol*K)",
          "default": 8.314,
          "description": "Gas constant"
        },
        "T": {
          "type": "state",
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "P": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure"
        },
        "V": {
          "type": "state",
          "units": "m^3",
          "default": 0.0247,
          "description": "Volume"
        },
        "Cv": {
          "type": "parameter",
          "units": "J/(mol*K)",
          "default": 20.8,
          "description": "Heat capacity at constant volume"
        },
        "U": {
          "type": "observed",
          "units": "J",
          "description": "Internal energy",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "n",
                  "Cv"
                ]
              },
              "T"
            ]
          }
        },
        "H": {
          "type": "observed",
          "units": "J",
          "description": "Enthalpy",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "n",
                      "Cv"
                    ]
                  },
                  "T"
                ]
              },
              {
                "op": "*",
                "args": [
                  "P",
                  "V"
                ]
              }
            ]
          }
        },
        "S": {
          "type": "observed",
          "units": "J/K",
          "description": "Entropy (simplified)",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "n",
                  "R"
                ]
              },
              {
                "op": "log",
                "args": [
                  "V"
                ]
              }
            ]
          }
        },
        "G": {
          "type": "observed",
          "units": "J",
          "description": "Gibbs free energy",
          "expression": {
            "op": "-",
            "args": [
              {
                "op": "+",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "n",
                          "Cv"
                        ]
                      },
                      "T"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "P",
                      "V"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "T",
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "n",
                          "R"
                        ]
                      },
                      {
                        "op": "log",
                        "args": [
                          "V"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "T"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              {
                "op": "-",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "P",
                          "V"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "n",
                          "R"
                        ]
                      }
                    ]
                  },
                  "T"
                ]
              },
              1.0
            ]
          }
        }
      ],
      "tolerance": { "rel": 1e-10 },
      "tests": [
        {
          "id": "thermo_observed_at_t0",
          "description": "At t=0 with n=1 mol, Cv=20.8 J/(mol*K), T=300 K, P=100000 Pa, V=0.025 m^3: U = n*Cv*T = 6240 J; H = U + P*V = 6240 + 2500 = 8740 J. Tests multiplication chains and addition with mixed-but-commensurate expression terms. S and G are excluded because log(V) is dimensionally ill-formed (separate dimensional bead).",
          "initial_conditions": {
            "T": 300.0,
            "P": 100000.0,
            "V": 0.025
          },
          "parameter_overrides": {
            "n": 1.0,
            "R": 8.314,
            "Cv": 20.8
          },
          "time_span": { "start": 0.0, "end": 0.0 },
          "assertions": [
            { "variable": "U", "time": 0.0, "expected": 6240.0 },
            { "variable": "H", "time": 0.0, "expected": 8740.0 }
          ]
        }
      ]
    },
    "ElectromagneticFields": {
      "reference": {
        "notes": "Electromagnetic equations with proper unit analysis"
      },
      "variables": {
        "q": {
          "type": "parameter",
          "units": "C",
          "default": 1.6e-19,
          "description": "Electric charge"
        },
        "E": {
          "type": "parameter",
          "units": "V/m",
          "default": 1000.0,
          "description": "Electric field strength"
        },
        "B": {
          "type": "parameter",
          "units": "T",
          "default": 0.001,
          "description": "Magnetic field strength"
        },
        "v": {
          "type": "parameter",
          "units": "m/s",
          "default": 100000.0,
          "description": "Particle velocity"
        },
        "m": {
          "type": "parameter",
          "units": "kg",
          "default": 9.11e-31,
          "description": "Particle mass"
        },
        "epsilon0": {
          "type": "parameter",
          "units": "F/m",
          "default": 8.854e-12,
          "description": "Permittivity of free space"
        },
        "c": {
          "type": "parameter",
          "units": "m/s",
          "default": 300000000.0,
          "description": "Speed of light"
        },
        "F_electric": {
          "type": "observed",
          "units": "N",
          "description": "Electric force",
          "expression": {
            "op": "*",
            "args": [
              "q",
              "E"
            ]
          }
        },
        "F_magnetic": {
          "type": "observed",
          "units": "N",
          "description": "Magnetic force",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "q",
                  "v"
                ]
              },
              "B"
            ]
          }
        },
        "energy_density": {
          "type": "observed",
          "units": "J/m^3",
          "description": "Electromagnetic energy density",
          "expression": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      0.5,
                      "epsilon0"
                    ]
                  },
                  {
                    "op": "^",
                    "args": [
                      "E",
                      2
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      0.5,
                      {
                        "op": "*",
                        "args": [
                          4e-07,
                          3.14159
                        ]
                      }
                    ]
                  },
                  {
                    "op": "^",
                    "args": [
                      "B",
                      2
                    ]
                  }
                ]
              }
            ]
          }
        },
        "cyclotron_freq": {
          "type": "observed",
          "units": "Hz",
          "description": "Cyclotron frequency",
          "expression": {
            "op": "/",
            "args": [
              {
                "op": "*",
                "args": [
                  "q",
                  "B"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      2.0,
                      3.14159
                    ]
                  },
                  "m"
                ]
              }
            ]
          }
        }
      },
      "equations": [],
      "tolerance": { "rel": 1e-10 },
      "tests": [
        {
          "id": "electromagnetism_observed_at_t0",
          "description": "At t=0 with q=2 C, E=5 V/m, B=3.14159 T, v=10 m/s, m=1 kg: F_electric = q*E = 10 N; F_magnetic = q*v*B = 62.8318 N; cyclotron_freq = q*B/(2*3.14159*m) = 1.0 Hz (since B=2*pi/2 and the denominator has hardcoded 3.14159). energy_density is excluded because the magnetic-permeability literal 4e-7*3.14159 produces a huge magnitude that stresses float precision — it is dimensionally verified by downstream unit checkers.",
          "parameter_overrides": {
            "q": 2.0,
            "E": 5.0,
            "B": 3.14159,
            "v": 10.0,
            "m": 1.0,
            "epsilon0": 1.0,
            "c": 300000000.0
          },
          "time_span": { "start": 0.0, "end": 0.0 },
          "assertions": [
            { "variable": "F_electric",     "time": 0.0, "expected": 10.0 },
            { "variable": "F_magnetic",     "time": 0.0, "expected": 62.8318 },
            { "variable": "cyclotron_freq", "time": 0.0, "expected":  1.0 }
          ]
        }
      ]
    },
    "FluidMechanics": {
      "reference": {
        "notes": "Fluid mechanics equations with dimensional consistency"
      },
      "domain": "fluid_1d",
      "variables": {
        "rho": {
          "type": "parameter",
          "units": "kg/m^3",
          "default": 1000.0,
          "description": "Fluid density"
        },
        "v": {
          "type": "state",
          "units": "m/s",
          "default": 2.0,
          "description": "Flow velocity"
        },
        "P": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure"
        },
        "h": {
          "type": "parameter",
          "units": "m",
          "default": 10.0,
          "description": "Height"
        },
        "g": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravitational acceleration"
        },
        "mu": {
          "type": "parameter",
          "units": "Pa*s",
          "default": 0.001,
          "description": "Dynamic viscosity"
        },
        "L": {
          "type": "parameter",
          "units": "m",
          "default": 1.0,
          "description": "Characteristic length"
        },
        "nu": {
          "type": "observed",
          "units": "m^2/s",
          "description": "Kinematic viscosity",
          "expression": {
            "op": "/",
            "args": [
              "mu",
              "rho"
            ]
          }
        },
        "Re": {
          "type": "observed",
          "units": "1",
          "description": "Reynolds number",
          "expression": {
            "op": "/",
            "args": [
              {
                "op": "*",
                "args": [
                  "v",
                  "L"
                ]
              },
              {
                "op": "/",
                "args": [
                  "mu",
                  "rho"
                ]
              }
            ]
          }
        },
        "dynamic_pressure": {
          "type": "observed",
          "units": "Pa",
          "description": "Dynamic pressure",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  0.5,
                  "rho"
                ]
              },
              {
                "op": "^",
                "args": [
                  "v",
                  2
                ]
              }
            ]
          }
        },
        "hydrostatic_pressure": {
          "type": "observed",
          "units": "Pa",
          "description": "Hydrostatic pressure",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "rho",
                  "g"
                ]
              },
              "h"
            ]
          }
        },
        "total_pressure": {
          "type": "observed",
          "units": "Pa",
          "description": "Total pressure (Bernoulli)",
          "expression": {
            "op": "+",
            "args": [
              "P",
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      0.5,
                      "rho"
                    ]
                  },
                  {
                    "op": "^",
                    "args": [
                      "v",
                      2
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "rho",
                      "g"
                    ]
                  },
                  "h"
                ]
              }
            ]
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "v"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "/",
            "args": [
              {
                "op": "-",
                "args": [
                  {
                    "op": "grad",
                    "args": [
                      "P"
                    ],
                    "dim": "x"
                  }
                ]
              },
              "rho"
            ]
          }
        }
      ],
      "tolerance": { "rel": 1e-10 },
      "tests": [
        {
          "id": "fluids_observed_at_t0",
          "description": "At t=0 with rho=1000, v=2, P=100000, h=10, g=10, mu=0.001, L=1: nu = mu/rho = 1e-6 m^2/s; Re = v*L/nu = 2e6; dynamic_pressure = 0.5*rho*v^2 = 2000 Pa; hydrostatic_pressure = rho*g*h = 100000 Pa; total_pressure = P + dyn + hydro = 202000 Pa. Exercises division, v^2, and sum of three commensurate terms.",
          "initial_conditions": {
            "v": 2.0,
            "P": 100000.0
          },
          "parameter_overrides": {
            "rho": 1000.0,
            "h": 10.0,
            "g": 10.0,
            "mu": 0.001,
            "L": 1.0
          },
          "time_span": { "start": 0.0, "end": 0.0 },
          "assertions": [
            { "variable": "nu",                   "time": 0.0, "expected":      1.0e-6 },
            { "variable": "Re",                   "time": 0.0, "expected":  2000000.0 },
            { "variable": "dynamic_pressure",     "time": 0.0, "expected":     2000.0 },
            { "variable": "hydrostatic_pressure", "time": 0.0, "expected":   100000.0 },
            { "variable": "total_pressure",       "time": 0.0, "expected":   202000.0 }
          ]
        }
      ]
    },
    "ChemicalKinetics": {
      "reference": {
        "notes": "Chemical kinetics with proper unit analysis"
      },
      "variables": {
        "k_unimolecular": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.01,
          "description": "Unimolecular rate constant"
        },
        "k_bimolecular": {
          "type": "parameter",
          "units": "m^3/(mol*s)",
          "default": 0.001,
          "description": "Bimolecular rate constant"
        },
        "k_trimolecular": {
          "type": "parameter",
          "units": "m^6/(mol^2*s)",
          "default": 1e-06,
          "description": "Trimolecular rate constant"
        },
        "A": {
          "type": "state",
          "units": "mol/m^3",
          "default": 1.0,
          "description": "Concentration of species A"
        },
        "B": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.5,
          "description": "Concentration of species B"
        },
        "C": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.1,
          "description": "Concentration of species C"
        },
        "Ea": {
          "type": "parameter",
          "units": "J/mol",
          "default": 50000.0,
          "description": "Activation energy"
        },
        "R": {
          "type": "parameter",
          "units": "J/(mol*K)",
          "default": 8.314,
          "description": "Gas constant"
        },
        "T": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "rate_unimol": {
          "type": "observed",
          "units": "mol/(m^3*s)",
          "description": "Unimolecular reaction rate",
          "expression": {
            "op": "*",
            "args": [
              "k_unimolecular",
              "A"
            ]
          }
        },
        "rate_bimol": {
          "type": "observed",
          "units": "mol/(m^3*s)",
          "description": "Bimolecular reaction rate",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_bimolecular",
                  "A"
                ]
              },
              "B"
            ]
          }
        },
        "rate_trimol": {
          "type": "observed",
          "units": "mol/(m^3*s)",
          "description": "Trimolecular reaction rate",
          "expression": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_trimolecular",
                  "A"
                ]
              },
              {
                "op": "*",
                "args": [
                  "B",
                  "C"
                ]
              }
            ]
          }
        },
        "arrhenius_rate": {
          "type": "observed",
          "units": "1/s",
          "description": "Arrhenius rate constant",
          "expression": {
            "op": "*",
            "args": [
              "k_unimolecular",
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "Ea"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "R",
                          "T"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "A"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_unimolecular",
                  "A"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "B"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "k_bimolecular",
                      "A"
                    ]
                  },
                  "B"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "C"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "*",
                "args": [
                  "k_bimolecular",
                  "A"
                ]
              },
              "B"
            ]
          }
        }
      ],
      "tolerance": { "rel": 1e-10 },
      "tests": [
        {
          "id": "kinetics_observed_at_t0",
