{
  "esm": "0.1.0",
  "metadata": {
    "name": "BasicInterpolationOperators",
    "description": "Basic interpolation operators: linear, cubic, and spline for data fusion and regridding",
    "authors": ["ESM Format Team"],
    "created": "2026-02-19T00:00:00Z",
    "tags": ["interpolation", "linear", "cubic", "spline"]
  },

  "operators": {
    "LinearInterpolationOperator": {
      "operator_id": "linear_interp_1d",
      "reference": {
        "citation": "Linear interpolation: piecewise linear approximation between data points",
        "notes": "Most basic form of interpolation, fast and robust for monotonic data"
      },
      "config": {
        "method": "linear",
        "extrapolation_mode": "constant",
        "bounds_error": false
      },
      "needed_vars": ["x_coords", "y_values", "x_new"],
      "modifies": ["y_interp"],
      "description": "Linear interpolation for 1D data with constant extrapolation"
    },

    "CubicInterpolationOperator": {
      "operator_id": "cubic_interp_1d",
      "reference": {
        "citation": "Cubic interpolation: third-order polynomial interpolation",
        "notes": "Higher-order interpolation providing smoother results than linear"
      },
      "config": {
        "method": "cubic",
        "boundary_condition": "natural",
        "extrapolation_mode": "linear"
      },
      "needed_vars": ["x_coords", "y_values", "x_new"],
      "modifies": ["y_interp"],
      "description": "Cubic polynomial interpolation with natural boundary conditions"
    },

    "SplineInterpolationOperator": {
      "operator_id": "spline_interp_1d",
      "reference": {
        "doi": "10.1137/0717021",
        "citation": "Carl de Boor (1978). A Practical Guide to Splines",
        "notes": "Spline interpolation provides smooth curves with continuous derivatives"
      },
      "config": {
        "spline_order": 3,
        "smoothing_factor": 0.0,
        "boundary_condition": "natural",
        "knot_selection": "uniform"
      },
      "needed_vars": ["x_coords", "y_values", "x_new"],
      "modifies": ["y_interp", "y_deriv"],
      "description": "B-spline interpolation with configurable order and smoothing"
    }
  },

  "models": {
    "SimpleDataModel": {
      "variables": {
        "data_value": {
          "type": "state",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Simple data value for interpolation testing"
        },
        "coordinate": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 0.0,
          "description": "Coordinate for interpolation"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["data_value"], "wrt": "t" },
          "rhs": { "op": "sin", "args": ["coordinate"] }
        }
      ]
    }
  },

  "coupling": [
    {
      "type": "operator_apply",
      "operator": "LinearInterpolationOperator",
      "description": "Apply linear interpolation for basic data regridding"
    }
  ],

  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T01:00:00Z"
    },
    "spatial": {
      "x": { "min": 0.0, "max": 10.0, "units": "m" }
    }
  },

  "solver": {
    "strategy": "strang_serial",
    "config": {
      "timestep": 10.0
    }
  }
}