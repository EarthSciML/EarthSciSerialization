{
  "esm": "0.6.0",
  "metadata": {
    "name": "pure_topology",
    "description": "M3 cadence-partition fixture (RFC semiring-faq-unified-ir §6.1 / §7.3; CONFORMANCE_SPEC.md §5.7; bead ess-my4.3.6): the PURE-TOPOLOGY case — all CONST, EMPTY hot tree. A mesh-edge enumeration (the relational operation einsum cannot do) deduplicates the unique undirected edges discovered from a document-literal face->vertex relation, names each by a canonical Skolem key, exposes the result as a kind:\"derived\" index set via `from_faq`, and `rank`s it to dense ids. Because the connectivity (`face_lo`, `face_hi`) are document literals (arrayed parameters), the ENTIRE topology partition classes CONST and folds into the artifact at compile time (inline provenance) — every expression node is CONST, the per-step CONTINUOUS `_Node` tree is EMPTY (the `edge_exists` / `edge_dense_id` outputs are assigned algebraically, not by D/dt, and the partition's observed-variable elimination folds them out of the hot path since their defining expressions are all-CONST), and the per-event DISCRETE handler is EMPTY. This is the partition's degenerate-but-important endpoint: a rule that is entirely setup work and contributes nothing to the hot path, the concrete mechanism by which an unstructured-mesh discretization drops its imperative edge/connectivity construction. (Were the mesh instead a `discrete` remesh-reloadable variable, the SAME nodes would class DISCRETE and move into the per-event handler — the partition is identical modulo the leaf seed; mixed_stencil.esm demonstrates that DISCRETE materialization.) Every expression node carries an `expect_cadence:\"const\"` assertion the partition pass checks against its derived class. Validates against the schema with no evaluator; the golden edge set + dense ids live in tests/conformance/cadence/manifest.json.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "cadence-partition",
      "pure-topology",
      "empty-hot-tree",
      "edge-enumeration",
      "value-invention",
      "const-fold",
      "conformance",
      "schema",
      "ess-my4.3.6"
    ]
  },
  "models": {
    "PureTopologyEdges": {
      "index_sets": {
        "faces": { "kind": "interval", "size": 2 },
        "local_edges": { "kind": "interval", "size": 3 },
        "edges": { "kind": "derived", "from_faq": "edge_set" }
      },
      "variables": {
        "face_lo": {
          "type": "parameter",
          "shape": ["faces", "local_edges"],
          "description": "Lower-endpoint vertex id of each face-local edge (mesh connectivity) — a document-literal arrayed parameter, CONST cadence."
        },
        "face_hi": {
          "type": "parameter",
          "shape": ["faces", "local_edges"],
          "description": "Upper-endpoint vertex id of each face-local edge (mesh connectivity) — a document-literal arrayed parameter, CONST cadence."
        },
        "edge_exists": {
          "type": "state",
          "shape": ["edges"],
          "description": "Materialized edge-membership over the derived `edges` set, assigned algebraically (not D/dt) from the CONST connectivity. Declared `state` so the model is a balanced system (one equation per unknown); the partition pass's observed-variable elimination (the structural_simplify analogue) then folds it out of the hot path entirely, because its defining expression is all-CONST — this is exactly why the hot tree is empty."
        },
        "edge_dense_id": {
          "type": "state",
          "shape": ["edges"],
          "description": "Dense integer ids over the derived `edges` set (the array-backend index), assigned algebraically from CONST inputs. Declared `state` for balance; CONST-folded out of the hot path by the partition."
        }
      },
      "equations": [
        {
          "_comment": "edge_set: the index-set-producing node referenced by index_sets.edges.from_faq. distinct:true under bool_and_or dedups the unique undirected edges; `key` mints a canonical Skolem term over the endpoint vertices; the `true` body marks existence. All inputs (face_lo/face_hi) are CONST -> the node is CONST and folds at compile (inline provenance). Output order is the §5.5 sorted order, never insertion order.",
          "lhs": {
            "op": "index",
            "args": ["edge_exists", "e"]
          },
          "rhs": {
            "op": "aggregate",
            "id": "edge_set",
            "args": [],
            "semiring": "bool_and_or",
            "distinct": true,
            "expect_cadence": "const",
            "output_idx": ["e"],
            "ranges": {
              "f": { "from": "faces" },
              "le": { "from": "local_edges" }
            },
            "key": {
              "op": "skolem",
              "expect_cadence": "const",
              "args": [
                "edge",
                {
                  "op": "index",
                  "args": ["face_lo", "f", "le"],
                  "expect_cadence": "const"
                },
                {
                  "op": "index",
                  "args": ["face_hi", "f", "le"],
                  "expect_cadence": "const"
                }
              ]
            },
            "filter": { "op": "true", "args": [] },
            "expr": { "op": "true", "args": [] }
          }
        },
        {
          "_comment": "rank: dense integer ids over the derived `edges` set, by position in the sorted distinct sequence (§5.5). All-CONST -> folds at compile. Empty hot tree: there is no continuous state and no D/dt equation, so nothing remains for the per-step RHS.",
          "lhs": {
            "op": "index",
            "args": ["edge_dense_id", "e"]
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "semiring": "sum_product",
            "expect_cadence": "const",
            "output_idx": ["e"],
            "ranges": { "e": { "from": "edges" } },
            "expr": {
              "op": "rank",
              "args": ["edges"],
              "expect_cadence": "const"
            }
          }
        }
      ]
    }
  }
}
