{
  "esm": "0.6.0",
  "metadata": {
    "name": "pure_pointwise",
    "description": "M3 cadence-partition fixture (RFC semiring-faq-unified-ir §6.1; CONFORMANCE_SPEC.md §5.7; bead ess-my4.3.6): the PURE-POINTWISE case — all CONTINUOUS, EMPTY per-event handler, EMPTY materialization set. A pointwise relaxation-plus-forcing RHS D(u[i])/dt = -u[i] + A*sin(omega*t). Every expression node classes CONTINUOUS: the state loads u[i] change every step, and CRUCIALLY the explicit continuous-`t` forcing sin(omega*t) is CONTINUOUS too — NOT discrete. This is the §6.1 subtlety the partition is named for: classifying by CADENCE (\"changes every step\") rather than by ROLE (\"the unknown we solve for\") keeps an analytic forcing out of DISCRETE, where it would silently go stale between events. The CONST scalar parameters `A` and `omega` feed CONTINUOUS parents and inline as literals (the pre-existing constant-fold) — a bare scalar constant is the degenerate zero-buffer case and is NOT a partition materialization point, so the materialization-point SET is empty, the per-event DISCRETE handler is empty, and the hot per-step `_Node` tree is the entire RHS (identical in shape to today's compiled output — performance for existing pointwise rules is unchanged). Every node carries an `expect_cadence:\"continuous\"` assertion the partition pass checks against its derived class. Validates against the schema with no evaluator.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "cadence-partition",
      "pure-pointwise",
      "continuous-forcing",
      "empty-handler",
      "no-materialization",
      "conformance",
      "schema",
      "ess-my4.3.6"
    ]
  },
  "models": {
    "PurePointwiseForcing": {
      "index_sets": {
        "cells": { "kind": "interval", "size": 4 }
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["cells"],
          "description": "Integrated state — CONTINUOUS cadence (changes every step)."
        },
        "A": {
          "type": "parameter",
          "default": 0.5,
          "description": "Forcing amplitude — CONST scalar. Inlines as a literal into the CONTINUOUS hot tree (pre-existing constant-fold); NOT a materialization point (no buffer)."
        },
        "omega": {
          "type": "parameter",
          "default": 6.283185307179586,
          "description": "Forcing angular frequency — CONST scalar. Inlines as a literal; NOT a materialization point."
        }
      },
      "equations": [
        {
          "_comment": "D(u[i])/dt = -u[i] + A*sin(omega*t). All nodes CONTINUOUS. omega*t is CONST*CONTINUOUS = CONTINUOUS: the analytic forcing recomputes every step and must NOT be classed DISCRETE (it is not piecewise-constant between events). No topology, no discrete fields -> empty materialization set, empty per-event handler, entire RHS is the hot tree.",
          "lhs": {
            "op": "index",
            "args": [
              { "op": "D", "args": ["u"], "wrt": "t" },
              "i"
            ]
          },
          "rhs": {
            "op": "+",
            "expect_cadence": "continuous",
            "args": [
              {
                "op": "-",
                "expect_cadence": "continuous",
                "args": [
                  { "op": "index", "args": ["u", "i"], "expect_cadence": "continuous" }
                ]
              },
              {
                "op": "*",
                "expect_cadence": "continuous",
                "args": [
                  "A",
                  {
                    "op": "sin",
                    "expect_cadence": "continuous",
                    "args": [
                      {
                        "op": "*",
                        "expect_cadence": "continuous",
                        "args": ["omega", "t"]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
