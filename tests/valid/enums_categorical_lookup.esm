{
  "esm": "0.3.0",
  "metadata": {
    "name": "WeselyCategoricalLookup",
    "description": "End-to-end demonstration of the v0.3.0 enums + index categorical-lookup pattern (esm-spec.md §9.3, §4.5). A Wesely-style canopy resistance r_c is read from a 4 (season) × 11 (land-use class) const table, indexed by enum-resolved integers. Replaces the v0.2.0 pattern that would have used a `call` op into a registered `wesely_r_c` handler.",
    "authors": ["EarthSciML"],
    "created": "2026-04-25T00:00:00Z",
    "tags": [
      "enums",
      "categorical-lookup",
      "wesely",
      "dry-deposition",
      "closed-function-registry"
    ],
    "references": [
      {
        "doi": "10.1016/0004-6981(89)90153-4",
        "citation": "Wesely, M.L., 1989. Parameterization of surface resistances to gaseous dry deposition in regional-scale numerical models. Atmospheric Environment 23(6), 1293-1304."
      }
    ]
  },
  "enums": {
    "season": {
      "winter": 1,
      "spring": 2,
      "summer": 3,
      "autumn": 4
    },
    "land_use_class": {
      "urban": 1,
      "agricultural": 2,
      "deciduous_forest": 3,
      "coniferous_forest": 4,
      "mixed_forest": 5,
      "shrubland": 6,
      "grassland": 7,
      "wetland": 8,
      "water": 9,
      "barren": 10,
      "snow_ice": 11
    }
  },
  "models": {
    "DryDep": {
      "variables": {
        "r_c": {
          "type": "observed",
          "units": "s/m",
          "description": "Canopy resistance for the (summer × deciduous_forest) site, looked up from the Wesely Table-2-style coefficient array.",
          "expression": {
            "op": "index",
            "args": [
              {
                "op": "const",
                "args": [],
                "value": [
                  [200.0, 150.0, 100.0, 100.0, 120.0, 250.0, 180.0, 90.0, 9999.0, 9999.0, 9999.0],
                  [200.0, 150.0, 100.0, 100.0, 120.0, 250.0, 180.0, 90.0, 9999.0, 9999.0, 9999.0],
                  [200.0, 100.0,  60.0,  60.0,  80.0, 200.0, 140.0, 80.0, 9999.0, 9999.0, 9999.0],
                  [200.0, 150.0, 100.0, 100.0, 120.0, 250.0, 180.0, 90.0, 9999.0, 9999.0, 9999.0]
                ]
              },
              { "op": "enum", "args": ["season", "summer"] },
              { "op": "enum", "args": ["land_use_class", "deciduous_forest"] }
            ]
          }
        },
        "vd_O3": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Effective deposition velocity, vd = 1 / r_c, integrated trivially as a state to give the round-trip path real semantics."
        }
      },
      "equations": [
        {
          "_comment": "Trivial deposition velocity from canopy resistance.",
          "lhs": { "op": "D", "args": ["vd_O3"], "wrt": "t" },
          "rhs": { "op": "/", "args": [1.0, "r_c"] }
        }
      ]
    }
  }
}
