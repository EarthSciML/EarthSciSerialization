{
  "esm": "0.1.0",
  "metadata": {
    "name": "CompleteMetadataExample",
    "description": "Comprehensive example demonstrating all ESM metadata fields and variations including extended references, funding information, validation details, and software requirements",
    "authors": [
      "Dr. Jane Smith <jane.smith@university.edu>",
      "Prof. Robert Chen",
      "Alex Johnson (ORCID: 0000-0000-0000-0000)",
      "Maria Rodriguez",
      "ESM Development Team"
    ],
    "license": "MIT",
    "created": "2024-01-15T10:30:00Z",
    "modified": "2024-02-14T16:45:30Z",
    "tags": [
      "atmospheric-chemistry",
      "ozone",
      "NOx",
      "photochemistry",
      "validation",
      "benchmark"
    ],
    "references": [
      {
        "doi": "10.1029/2023JD038742",
        "citation": "Smith, J. et al. (2023). Advanced ozone-NOx chemistry for Earth system models. Journal of Geophysical Research: Atmospheres, 128(12), e2023JD038742.",
        "notes": "Primary reference for chemical mechanism"
      },
      {
        "url": "https://acp.copernicus.org/articles/21/1809/2021/",
        "citation": "Chen, R. & Johnson, A. (2021). Photolysis rate calculations in complex atmospheric environments. Atmospheric Chemistry and Physics, 21, 1809-1825.",
        "notes": "Photolysis rate methodology"
      },
      {
        "citation": "Finlayson-Pitts, B. J., & Pitts Jr, J. N. (2000). Chemistry of the upper and lower atmosphere. Academic Press.",
        "notes": "Fundamental atmospheric chemistry principles"
      },
      {
        "citation": "Williams, M. (2020). Chemical kinetics database v2.1. National Center for Atmospheric Research Technical Note.",
        "notes": "Rate constant compilation"
      },
      {
        "doi": "10.5281/zenodo.7891234",
        "citation": "Atmospheric Chemistry Community (2023). Global atmospheric chemistry validation dataset v1.0. Zenodo.",
        "notes": "Validation data used for model evaluation"
      }
    ]
  },
  "reaction_systems": {
    "ComprehensiveOzoneChemistry": {
      "coupletype": "OzoneChemistryCoupler",
      "reference": {
        "notes": "Complete O3-NOx-HOx photochemical cycle with metadata demonstration",
        "doi": "10.1029/2023JD038742"
      },
      "species": {
        "O3": {
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone mixing ratio"
        },
        "NO": {
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide mixing ratio"
        },
        "NO2": {
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide mixing ratio"
        },
        "HO2": {
          "units": "mol/mol",
          "default": 1e-11,
          "description": "Hydroperoxyl radical mixing ratio"
        },
        "OH": {
          "units": "mol/mol",
          "default": 1e-12,
          "description": "Hydroxyl radical mixing ratio"
        }
      },
      "parameters": {
        "T": {
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "M": {
          "units": "molec/cm^3",
          "default": 2.46e+19,
          "description": "Air number density"
        },
        "j_NO2": {
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis rate coefficient"
        },
        "j_O3": {
          "units": "1/s",
          "default": 2e-05,
          "description": "O3 photolysis rate coefficient"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "NO_O3_reaction",
          "substrates": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              1.8e-12,
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      -1370,
                      "T"
                    ]
                  }
                ]
              },
              "M"
            ]
          },
          "reference": {
            "citation": "JPL 19-5"
          }
        },
        {
          "id": "R2",
          "name": "NO2_photolysis",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "rate": "j_NO2",
          "reference": {
            "citation": "TUV model calculations"
          }
        },
        {
          "id": "R3",
          "name": "HO2_NO_reaction",
          "substrates": [
            {
              "species": "HO2",
              "stoichiometry": 1
            },
            {
              "species": "NO",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "OH",
              "stoichiometry": 1
            },
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              8.1e-12,
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      270,
                      "T"
                    ]
                  }
                ]
              }
            ]
          },
          "reference": {
            "citation": "IUPAC 2021"
          }
        }
      ]
    }
  },
  "solver": {
    "strategy": "imex",
    "config": {
      "algorithm": "Rosenbrock23",
      "abstol": 1e-08,
      "reltol": 1e-06,
      "maxiters": 10000
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-02T00:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -130.0,
          "max": -100.0,
          "grid_spacing": 0.5,
          "units": "degrees"
        },
        "lat": {
          "min": 30.0,
          "max": 50.0,
          "grid_spacing": 0.5,
          "units": "degrees"
        },
        "lev": {
          "min": 1,
          "max": 10,
          "grid_spacing": 1,
          "units": "level"
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "boundary_conditions": [
        {
          "type": "dirichlet",
          "value": 4e-08,
          "dimensions": [
            "x"
          ]
        }
      ],
      "element_type": "Float64"
    }
  }
}
