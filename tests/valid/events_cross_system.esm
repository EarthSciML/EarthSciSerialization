{
  "esm": "0.1.0",
  "metadata": {
    "name": "EventsCrossSystemInteraction",
    "description": "Test fixture for cross-system events - Events spanning multiple coupled systems with inter-system dependencies",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "events",
      "cross_system",
      "coupling",
      "multi_system",
      "interactions"
    ]
  },
  "reaction_systems": {
    "AtmosphericChemistry": {
      "coupletype": "AtmosphericCoupler",
      "reference": {
        "notes": "Simplified atmospheric chemistry system"
      },
      "species": {
        "O3": {
          "units": "ppb",
          "default": 40.0,
          "description": "Ozone concentration"
        },
        "NO2": {
          "units": "ppb",
          "default": 20.0,
          "description": "Nitrogen dioxide concentration"
        },
        "VOC": {
          "units": "ppb",
          "default": 100.0,
          "description": "Volatile organic compounds"
        }
      },
      "parameters": {
        "k_photo": {
          "units": "1/min",
          "default": 0.01,
          "description": "Photolysis rate constant"
        },
        "k_formation": {
          "units": "ppb^-2/min",
          "default": 0.001,
          "description": "Ozone formation rate constant"
        },
        "emission_rate_NO2": {
          "units": "ppb/min",
          "default": 0.1,
          "description": "NO2 emission rate"
        },
        "emission_rate_VOC": {
          "units": "ppb/min",
          "default": 0.5,
          "description": "VOC emission rate"
        }
      },
      "reactions": [
        {
          "id": "R1_photo",
          "name": "NO2_photolysis",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "products": null,
          "rate": {
            "op": "*",
            "args": [
              "k_photo",
              "MeteorologicalSystem.solar_intensity"
            ]
          }
        },
        {
          "id": "R2_formation",
          "name": "O3_formation",
          "substrates": [
            {
              "species": "NO2",
              "stoichiometry": 1
            },
            {
              "species": "VOC",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "rate": "k_formation"
        }
      ]
    },
    "BiologicalSystem": {
      "coupletype": "BiologicalCoupler",
      "reference": {
        "notes": "Plant response to air quality"
      },
      "species": {
        "healthy_biomass": {
          "units": "g/m^2",
          "default": 1000.0,
          "description": "Healthy plant biomass"
        },
        "stressed_biomass": {
          "units": "g/m^2",
          "default": 0.0,
          "description": "Stress-damaged biomass"
        }
      },
      "parameters": {
        "growth_rate": {
          "units": "1/day",
          "default": 0.05,
          "description": "Plant growth rate"
        },
        "stress_threshold": {
          "units": "ppb",
          "default": 60.0,
          "description": "Ozone stress threshold"
        },
        "damage_rate": {
          "units": "1/day",
          "default": 0.1,
          "description": "Ozone damage rate"
        },
        "recovery_rate": {
          "units": "1/day",
          "default": 0.02,
          "description": "Plant recovery rate"
        }
      },
      "reactions": [
        {
          "id": "growth",
          "name": "plant_growth",
          "substrates": null,
          "products": [
            {
              "species": "healthy_biomass",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              "growth_rate",
              "MeteorologicalSystem.temperature_factor"
            ]
          }
        },
        {
          "id": "stress_damage",
          "name": "ozone_damage",
          "substrates": [
            {
              "species": "healthy_biomass",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "stressed_biomass",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "ifelse",
            "args": [
              {
                "op": ">",
                "args": [
                  "AtmosphericChemistry.O3",
                  "stress_threshold"
                ]
              },
              {
                "op": "*",
                "args": [
                  "damage_rate",
                  {
                    "op": "-",
                    "args": [
                      "AtmosphericChemistry.O3",
                      "stress_threshold"
                    ]
                  }
                ]
              },
              0.0
            ]
          }
        }
      ]
    }
  },
  "models": {
    "MeteorologicalSystem": {
      "reference": {
        "notes": "Weather system affecting chemistry and biology"
      },
      "variables": {
        "solar_intensity": {
          "type": "state",
          "units": "W/m^2",
          "default": 800.0,
          "description": "Solar radiation intensity"
        },
        "temperature": {
          "type": "state",
          "units": "\u00b0C",
          "default": 25.0,
          "description": "Air temperature"
        },
        "wind_speed": {
          "type": "state",
          "units": "m/s",
          "default": 3.0,
          "description": "Wind speed for mixing"
        },
        "temperature_factor": {
          "type": "observed",
          "units": "dimensionless",
          "description": "Temperature factor for biological processes",
          "expression": 0.0
        },
        "diurnal_amplitude": {
          "units": "W/m^2",
          "default": 600.0,
          "description": "Solar radiation amplitude",
          "type": "parameter"
        },
        "base_solar": {
          "units": "W/m^2",
          "default": 200.0,
          "description": "Base solar radiation",
          "type": "parameter"
        },
        "temp_amplitude": {
          "units": "\u00b0C",
          "default": 10.0,
          "description": "Diurnal temperature amplitude",
          "type": "parameter"
        },
        "base_temp": {
          "units": "\u00b0C",
          "default": 20.0,
          "description": "Base temperature",
          "type": "parameter"
        },
        "wind_variability": {
          "units": "m/s",
          "default": 1.0,
          "description": "Wind speed variability",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "solar_intensity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              0.1,
              {
                "op": "-",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      "base_solar",
                      {
                        "op": "*",
                        "args": [
                          "diurnal_amplitude",
                          {
                            "op": "cos",
                            "args": [
                              {
                                "op": "*",
                                "args": [
                                  0.26,
                                  "t"
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  "solar_intensity"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              0.2,
              {
                "op": "-",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      "base_temp",
                      {
                        "op": "*",
                        "args": [
                          "temp_amplitude",
                          {
                            "op": "cos",
                            "args": [
                              {
                                "op": "*",
                                "args": [
                                  0.26,
                                  {
                                    "op": "+",
                                    "args": [
                                      "t",
                                      6
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  "temperature"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "wind_speed"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              0.05,
              {
                "op": "*",
                "args": [
                  "wind_variability",
                  {
                    "op": "sin",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          0.1,
                          "t"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": "temperature_factor",
          "rhs": {
            "op": "exp",
            "args": [
              {
                "op": "/",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "temperature",
                      25
                    ]
                  },
                  15
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "BiologicalSystem"
      ]
    },
    {
      "type": "operator_compose",
      "systems": [
        "MeteorologicalSystem",
        "MeteorologicalSystem_transport"
      ]
    }
  ],
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "base_algorithm": "Tsit5",
      "event_detection": "root_finding",
      "event_tolerance": 1e-10,
      "adaptive": true,
      "coupling_method": "operator_splitting"
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-08T00:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 100.0,
          "grid_spacing": 10.0,
          "units": "km"
        },
        "y": {
          "min": 0.0,
          "max": 100.0,
          "grid_spacing": 10.0,
          "units": "km"
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {}
      },
      "boundary_conditions": [
        {
          "type": "periodic",
          "dimensions": [
            "x",
            "y"
          ]
        }
      ],
      "element_type": "Float64"
    }
  }
}
