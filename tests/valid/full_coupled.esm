{
  "esm": "0.2.0",
  "metadata": {
    "name": "FullCoupledSystem",
    "description": "Comprehensive ESM test exercising all sections: models, reaction_systems, data_loaders, operators, coupling (all 6 types), domain with spatial+temporal+ICs+BCs, and solver\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "Claude Test Generator"
    ],
    "created": "2026-02-16T16:00:00Z",
    "tags": [
      "comprehensive",
      "test",
      "all-sections",
      "migrated_from_v01"
    ],
    "license": "MIT"
  },
  "reaction_systems": {
    "AtmosphericChemistry": {
      "coupletype": "AtmChemCoupler",
      "reference": {
        "notes": "Simplified atmospheric chemistry"
      },
      "species": {
        "O3": {
          "units": "mol/mol",
          "default": 4e-08,
          "description": "Ozone"
        },
        "NO": {
          "units": "mol/mol",
          "default": 1e-10,
          "description": "Nitric oxide"
        },
        "NO2": {
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Nitrogen dioxide"
        },
        "OH": {
          "units": "mol/mol",
          "default": 5e-11,
          "description": "Hydroxyl radical"
        }
      },
      "parameters": {
        "T": {
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "M": {
          "units": "molec/cm^3",
          "default": 2.46e+19,
          "description": "Air density"
        },
        "jNO2": {
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "NO_O3_reaction",
          "substrates": [
            {
              "species": "NO",
              "stoichiometry": 1
            },
            {
              "species": "O3",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "NO2",
              "stoichiometry": 1
            }
          ],
          "rate": {
            "op": "*",
            "args": [
              1.8e-12,
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      -1370,
                      "T"
                    ]
                  }
                ]
              },
              "M"
            ]
          }
        }
      ]
    }
  },
  "models": {
    "Transport": {
      "reference": {
        "notes": "3D transport model"
      },
      "domain": "default",
      "variables": {
        "u": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Eastward wind"
        },
        "v": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Northward wind"
        },
        "w": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Vertical wind"
        },
        "K_h": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0,
          "description": "Horizontal diffusion"
        },
        "K_v": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 10.0,
          "description": "Vertical diffusion"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "lon"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "lat"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "w"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "u"
                    ],
                    "dim": "lev"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "K_h",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ],
                    "dim": "lon"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "K_v",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ],
                    "dim": "lev"
                  }
                ]
              }
            ]
          }
        }
      ],
      "continuous_events": [
        {
          "name": "concentration_limit",
          "conditions": [
            {
              "op": "-",
              "args": [
                "u",
                0.001
              ]
            }
          ],
          "affects": [
            {
              "lhs": "_var",
              "rhs": 0.001
            }
          ],
          "affect_neg": [
            {
              "lhs": "_var",
              "rhs": {
                "op": "max",
                "args": [
                  0.0,
                  {
                    "op": "Pre",
                    "args": [
                      "u"
                    ]
                  }
                ]
              }
            }
          ],
          "root_find": "all"
        }
      ],
      "discrete_events": [
        {
          "name": "hourly_reset",
          "trigger": {
            "type": "periodic",
            "interval": 3600.0
          },
          "discrete_parameters": [
            "K_h"
          ],
          "functional_affect": {
            "handler_id": "hourly_diffusion_update",
            "read_vars": [
              "_var"
            ],
            "read_params": [
              "K_h"
            ],
            "modified_params": [
              "K_h"
            ],
            "config": {
              "factor": 1.1
            }
          }
        },
        {
          "name": "preset_events",
          "trigger": {
            "type": "preset_times",
            "times": [
              86400,
              172800,
              259200
            ]
          },
          "affects": [
            {
              "lhs": "K_v",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "Pre",
                    "args": [
                      "K_v"
                    ]
                  },
                  0.9
                ]
              }
            }
          ],
          "discrete_parameters": [
            "K_v"
          ]
        }
      ]
    }
  },
  "data_loaders": {
    "MeteoData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/GEOSFP/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "u": {
          "file_variable": "u",
          "units": "m/s",
          "description": "Eastward wind"
        },
        "v": {
          "file_variable": "v",
          "units": "m/s",
          "description": "Northward wind"
        },
        "w": {
          "file_variable": "w",
          "units": "m/s",
          "description": "Vertical wind"
        },
        "T": {
          "file_variable": "T",
          "units": "K",
          "description": "Temperature"
        },
        "P": {
          "file_variable": "P",
          "units": "Pa",
          "description": "Pressure"
        }
      },
      "metadata": {
        "tags": [
          "meteorology",
          "reanalysis"
        ]
      }
    },
    "EmissionsData": {
      "kind": "grid",
      "source": {
        "url_template": "file:///data/EDGAR_v5/{date:%Y%m%d_%H%M}.nc"
      },
      "spatial": {
        "crs": "EPSG:4326",
        "grid_type": "latlon",
        "staggering": {
          "lon": "center",
          "lat": "center"
        }
      },
      "variables": {
        "NOx_emissions": {
          "file_variable": "NOx_emissions",
          "units": "kg/m^2/s",
          "description": "NOx emissions"
        }
      },
      "metadata": {
        "tags": [
          "emissions",
          "anthropogenic"
        ]
      }
    }
  },
  "operators": {
    "SpatialInterpolator": {
      "operator_id": "bilinear_interp",
      "needed_vars": [
        "u",
        "v",
        "T"
      ],
      "config": {
        "method": "bilinear",
        "extrapolation": "nearest"
      },
      "reference": {
        "notes": "Spatial interpolation operator"
      }
    },
    "UnitConverter": {
      "operator_id": "unit_conversion",
      "needed_vars": [
        "NOx_emissions"
      ],
      "config": {
        "from": "kg/m^2/s",
        "to": "mol/mol/s",
        "molecular_weight": 46.0
      },
      "reference": {
        "notes": "NOx unit conversion"
      }
    }
  },
  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "Transport"
      ]
    },
    {
      "type": "variable_map",
      "from": "MeteoData.T",
      "to": "AtmosphericChemistry.T",
      "transform": "param_to_var"
    },
    {
      "type": "variable_map",
      "from": "MeteoData.u",
      "to": "Transport.u",
      "transform": "param_to_var"
    },
    {
      "type": "variable_map",
      "from": "MeteoData.v",
      "to": "Transport.v",
      "transform": "param_to_var"
    },
    {
      "type": "operator_apply",
      "operator": "UnitConverter"
    },
    {
      "type": "callback",
      "callback_id": "apply_emissions"
    }
  ],
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-08T00:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -125.0,
          "max": -110.0,
          "grid_spacing": 0.25,
          "units": "m"
        },
        "lat": {
          "min": 32.0,
          "max": 42.0,
          "grid_spacing": 0.25,
          "units": "m"
        },
        "lev": {
          "min": 1,
          "max": 10,
          "grid_spacing": 1,
          "units": "m"
        }
      },
      "coordinate_transforms": [
        {
          "id": "lonlat_to_meters",
          "dimensions": [
            "lon",
            "lat"
          ]
        },
        {
          "id": "sigma_to_pressure",
          "dimensions": [
            "lev"
          ]
        }
      ],
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "O3": 4e-08,
          "NO": 1e-10,
          "NO2": 1e-09
        }
      },
      "element_type": "Float64"
    }
  }
}
