{
  "esm": "0.6.0",
  "metadata": {
    "name": "expression_ignition_front_1d",
    "description": "Cross-binding conformance golden for the `expression` initial-condition type (bead ess-gjn, epic campfire-e2e ea-6sh). The domain declares a 1-D spatial grid x in [0,1] at grid_spacing 0.25 (5 nodes) and an `expression` initial condition: u's initial field is the ignition-front profile psi(x) = 0.5 * (1 + tanh((x - 0.3) / 0.15)), the EXISTING expression AST evaluated at every grid node at t=0 (no new primitive). The state u[i] is method-of-lines discretized with trivial dynamics D(u[i])/dt = 0, so u holds at its IC and the assertions isolate the expression-IC evaluation: u[i](t) == psi(x_i) for x_i = 0, 0.25, 0.5, 0.75, 1.0. The front is asymmetric, so an axis-reversed seeding would fail. Python evaluates this end-to-end; Julia and Rust load + validate it as the shared contract for their (deferred) expression-IC evaluation.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.slit"
    ],
    "tags": [
      "initial-conditions",
      "expression",
      "pde",
      "ignition-front",
      "conformance",
      "campfire-e2e",
      "ess-gjn"
    ]
  },
  "models": {
    "IgnitionFront1D": {
      "tolerance": {
        "rel": 1e-6,
        "abs": 1e-9
      },
      "domain": "line",
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i"],
          "units": "1",
          "description": "Ignition-progress field psi(x); held constant (D(u)/dt = 0) so the test isolates the expression initial condition."
        }
      },
      "equations": [
        {
          "_comment": "D(u[i])/dt = 0 over i in [1,5]; u[i] holds at its expression IC psi(x_i).",
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "expr": {
              "op": "D",
              "args": [{ "op": "index", "args": ["u", "i"] }],
              "wrt": "t"
            },
            "ranges": { "i": [1, 5] }
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": ["i"],
            "ranges": { "i": [1, 5] },
            "expr": 0
          }
        }
      ],
      "tests": [
        {
          "id": "ignition_front_ic",
          "description": "psi(x) = 0.5*(1 + tanh((x - 0.3)/0.15)) seeded from the domain expression IC at x = [0, 0.25, 0.5, 0.75, 1.0]; D(u)/dt = 0 holds it constant, asserted at t=0 (the IC itself) and at t=1.",
          "time_span": { "start": 0.0, "end": 1.0 },
          "assertions": [
            { "variable": "u[1]", "time": 0.0, "expected": 0.01798620996209155 },
            { "variable": "u[2]", "time": 0.0, "expected": 0.3392436312341829 },
            { "variable": "u[3]", "time": 0.0, "expected": 0.935030830871336 },
            { "variable": "u[4]", "time": 0.0, "expected": 0.9975273768433652 },
            { "variable": "u[5]", "time": 0.0, "expected": 0.999911580829981 },
            { "variable": "u[3]", "time": 1.0, "expected": 0.935030830871336 }
          ]
        }
      ]
    }
  },
  "domains": {
    "line": {
      "initial_conditions": {
        "type": "expression",
        "values": {
          "u": {
            "op": "*",
            "args": [
              0.5,
              {
                "op": "+",
                "args": [
                  1,
                  {
                    "op": "tanh",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          { "op": "-", "args": ["x", 0.3] },
                          0.15
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }
}
