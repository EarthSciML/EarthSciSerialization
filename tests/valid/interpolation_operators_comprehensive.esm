{
  "esm": "0.1.0",
  "metadata": {
    "name": "InterpolationOperatorsComprehensive",
    "description": "Comprehensive test fixtures for interpolation operators supporting various interpolation methods, grid remapping, and coordinate transformations",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-19T00:00:00Z",
    "tags": ["interpolation", "operators", "regridding", "data_fusion"]
  },

  "operators": {
    "LinearInterpolation": {
      "operator_id": "LinearInterp1D",
      "reference": {
        "citation": "Linear interpolation using piecewise linear functions",
        "notes": "Standard linear interpolation between adjacent data points",
        "url": "https://en.wikipedia.org/wiki/Linear_interpolation"
      },
      "config": {
        "method": "linear",
        "extrapolation": "constant",
        "fill_value": "nan",
        "bounds_error": false
      },
      "needed_vars": ["source_coordinates", "source_values", "target_coordinates"],
      "modifies": ["interpolated_values"],
      "description": "1D linear interpolation for temporal or spatial data",
      "temporal_resolution": "PT1S",
      "spatial_resolution": { "adaptive": true }
    },

    "CubicSplineInterpolation": {
      "operator_id": "CubicSpline1D",
      "reference": {
        "doi": "10.1137/0717021",
        "citation": "de Boor, C. (1978). A Practical Guide to Splines",
        "notes": "Cubic spline interpolation with natural boundary conditions"
      },
      "config": {
        "method": "cubic_spline",
        "boundary_conditions": "natural",
        "extrapolation": "linear",
        "smoothing_factor": 0.0,
        "derivative_order": 0
      },
      "needed_vars": ["source_coordinates", "source_values", "target_coordinates"],
      "modifies": ["interpolated_values", "interpolated_derivatives"],
      "description": "Cubic spline interpolation with smooth derivatives",
      "temporal_resolution": "PT1S",
      "spatial_resolution": { "adaptive": true }
    },

    "BSplineInterpolation": {
      "operator_id": "BSplineND",
      "reference": {
        "doi": "10.1137/0717021",
        "citation": "de Boor, C. (1978). A Practical Guide to Splines",
        "notes": "Multi-dimensional B-spline interpolation with configurable order"
      },
      "config": {
        "spline_order": 3,
        "knot_spacing": "uniform",
        "extrapolation": "constant",
        "boundary_conditions": "clamped",
        "smoothing_parameter": 0.0
      },
      "needed_vars": ["source_coordinates", "source_values", "target_coordinates"],
      "modifies": ["interpolated_values"],
      "description": "Multi-dimensional B-spline interpolation for smooth regridding",
      "temporal_resolution": "PT1S",
      "spatial_resolution": { "lon": 0.001, "lat": 0.001, "lev": 1.0 }
    },

    "BilinearGridInterpolation": {
      "operator_id": "BilinearGrid2D",
      "reference": {
        "citation": "Bilinear interpolation on regular 2D grids",
        "notes": "Fast bilinear interpolation for regular latitude-longitude grids",
        "url": "https://en.wikipedia.org/wiki/Bilinear_interpolation"
      },
      "config": {
        "method": "bilinear",
        "grid_type": "regular",
        "coordinate_system": "geographic",
        "wrap_longitude": true,
        "fill_value": "nan"
      },
      "needed_vars": ["source_lon", "source_lat", "source_values", "target_lon", "target_lat"],
      "modifies": ["interpolated_values"],
      "description": "Bilinear interpolation for 2D geographic grids",
      "temporal_resolution": "PT5M",
      "spatial_resolution": { "lon": 0.01, "lat": 0.01 }
    },

    "TrilinearGridInterpolation": {
      "operator_id": "TrilinearGrid3D",
      "reference": {
        "citation": "Trilinear interpolation on regular 3D grids",
        "notes": "3D interpolation for atmospheric and oceanic data with vertical levels"
      },
      "config": {
        "method": "trilinear",
        "grid_type": "regular",
        "coordinate_system": "geographic_pressure",
        "vertical_coordinate": "pressure",
        "wrap_longitude": true,
        "extrapolation_below": "constant",
        "extrapolation_above": "constant"
      },
      "needed_vars": ["source_lon", "source_lat", "source_lev", "source_values", "target_lon", "target_lat", "target_lev"],
      "modifies": ["interpolated_values"],
      "description": "Trilinear interpolation for 3D atmospheric/oceanic data",
      "temporal_resolution": "PT1H",
      "spatial_resolution": { "lon": 0.25, "lat": 0.25, "lev": 25.0 }
    },

    "NearestNeighborInterpolation": {
      "operator_id": "NearestNeighbor",
      "reference": {
        "citation": "Nearest neighbor interpolation",
        "notes": "Simple nearest neighbor lookup for categorical or discrete data"
      },
      "config": {
        "method": "nearest",
        "distance_metric": "euclidean",
        "max_distance": null,
        "fill_value": "nan"
      },
      "needed_vars": ["source_coordinates", "source_values", "target_coordinates"],
      "modifies": ["interpolated_values"],
      "description": "Nearest neighbor interpolation for categorical data",
      "temporal_resolution": "PT1S",
      "spatial_resolution": { "adaptive": true }
    },

    "RadialBasisFunctionInterpolation": {
      "operator_id": "RBFInterp",
      "reference": {
        "doi": "10.1137/0713069",
        "citation": "Hardy, R. L. (1971). Multiquadric equations of topography and other irregular surfaces",
        "notes": "Radial basis function interpolation for irregular grids"
      },
      "config": {
        "basis_function": "multiquadric",
        "shape_parameter": 1.0,
        "smoothing": 0.0,
        "polynomial_degree": -1,
        "max_points": 1000
      },
      "needed_vars": ["source_coordinates", "source_values", "target_coordinates"],
      "modifies": ["interpolated_values"],
      "description": "Radial basis function interpolation for irregular data",
      "temporal_resolution": "PT10M",
      "spatial_resolution": { "adaptive": true }
    },

    "ConservativeRemapping": {
      "operator_id": "ConservativeRemap",
      "reference": {
        "doi": "10.1175/1520-0493(1999)127<2204:FASOCR>2.0.CO;2",
        "citation": "Jones, P. W. (1999). First- and second-order conservative remapping schemes",
        "notes": "Conservative remapping that preserves integrals over grid cells"
      },
      "config": {
        "order": 1,
        "normalization": "fracarea",
        "monotonic": true,
        "positive_definite": false,
        "search_radius": 5
      },
      "needed_vars": ["source_grid", "source_areas", "source_values", "target_grid", "target_areas"],
      "modifies": ["interpolated_values", "remapping_weights"],
      "description": "Conservative remapping for flux quantities and climate data",
      "temporal_resolution": "PT1H",
      "spatial_resolution": { "lon": 1.0, "lat": 1.0 }
    },

    "TemporalInterpolation": {
      "operator_id": "TimeInterp",
      "reference": {
        "citation": "Temporal interpolation methods for time series data",
        "notes": "Various temporal interpolation methods including seasonal awareness"
      },
      "config": {
        "method": "linear",
        "time_units": "hours since 1900-01-01",
        "seasonal_adjustment": false,
        "leap_year_handling": "proportional",
        "missing_data_threshold": 0.1
      },
      "needed_vars": ["source_time", "source_values", "target_time"],
      "modifies": ["interpolated_values", "interpolation_quality"],
      "description": "Temporal interpolation with calendar awareness",
      "temporal_resolution": "PT1M"
    },

    "CoordinateTransformInterpolation": {
      "operator_id": "CoordTransformInterp",
      "reference": {
        "citation": "Coordinate transformation with interpolation",
        "notes": "Interpolation combined with coordinate system transformations"
      },
      "config": {
        "source_crs": "EPSG:4326",
        "target_crs": "EPSG:3857",
        "interpolation_method": "bilinear",
        "transform_method": "proj4",
        "resampling": "bilinear"
      },
      "needed_vars": ["source_x", "source_y", "source_values", "target_x", "target_y"],
      "modifies": ["interpolated_values", "transformed_coordinates"],
      "description": "Interpolation with coordinate reference system transformation",
      "temporal_resolution": "PT15M",
      "spatial_resolution": { "x": 1000.0, "y": 1000.0 }
    }
  },

  "models": {
    "InterpolationTestModel": {
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 298.15,
          "description": "Temperature field for interpolation testing"
        },
        "pressure": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Pressure field for interpolation testing"
        },
        "humidity": {
          "type": "parameter",
          "units": "kg/kg",
          "default": 0.01,
          "description": "Humidity field for interpolation testing"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["temperature"], "wrt": "t" },
          "rhs": { "op": "*", "args": [-0.001, "temperature"] }
        },
        {
          "lhs": { "op": "D", "args": ["pressure"], "wrt": "t" },
          "rhs": { "op": "*", "args": [0.0001, "pressure"] }
        }
      ]
    }
  },

  "coupling": [
    {
      "type": "operator_apply",
      "operator": "LinearInterpolation",
      "description": "Apply linear interpolation for time series data"
    },
    {
      "type": "operator_apply",
      "operator": "BilinearGridInterpolation",
      "description": "Apply bilinear grid interpolation for spatial regridding"
    },
    {
      "type": "operator_apply",
      "operator": "CubicSplineInterpolation",
      "description": "Apply cubic spline interpolation for smooth temporal evolution"
    },
    {
      "type": "operator_apply",
      "operator": "ConservativeRemapping",
      "description": "Apply conservative remapping for flux conservation"
    }
  ],

  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-02T00:00:00Z"
    },
    "spatial": {
      "lon": { "min": -180.0, "max": 180.0, "units": "degrees_east" },
      "lat": { "min": -90.0, "max": 90.0, "units": "degrees_north" },
      "lev": { "min": 0.0, "max": 100000.0, "units": "Pa" }
    },
    "coordinate_transforms": [
      {
        "id": "geographic_to_cartesian",
        "description": "Transform from geographic to cartesian coordinates",
        "dimensions": ["lon", "lat", "lev"]
      }
    ]
  },

  "solver": {
    "strategy": "strang_threads",
    "config": {
      "timestep": 60.0,
      "threads": 4,
      "stiff_kwargs": {
        "abstol": 1e-8,
        "reltol": 1e-6
      }
    }
  }
}