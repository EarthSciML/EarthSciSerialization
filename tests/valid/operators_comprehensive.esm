{
  "esm": "0.1.0",
  "metadata": {
    "name": "OperatorsComprehensive",
    "description": "Comprehensive test fixtures for operator types, validation, and configuration",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "operators",
      "validation",
      "comprehensive"
    ]
  },
  "operators": {
    "DryDepGrid": {
      "operator_id": "WesleyDryDep",
      "reference": {
        "doi": "10.1016/0004-6981(89)90153-4",
        "citation": "Wesely, 1989. Parameterization of surface resistances to gaseous dry deposition in regional-scale numerical models.",
        "notes": "Resistance-based model: r_total = r_a + r_b + r_c",
        "url": "https://doi.org/10.1016/0004-6981(89)90153-4"
      },
      "config": {
        "season": "summer",
        "land_use_categories": 11,
        "surface_roughness": 0.1,
        "deposition_velocity_min": 0.001,
        "deposition_velocity_max": 10.0,
        "temporal_resolution": "PT1H",
        "spatial_resolution": {
          "lon": 0.25,
          "lat": 0.25
        }
      },
      "needed_vars": [
        "O3",
        "NO2",
        "SO2",
        "T",
        "u_star",
        "LAI",
        "surface_pressure"
      ],
      "modifies": [
        "O3",
        "NO2",
        "SO2"
      ],
      "description": "First-order dry deposition loss based on surface resistance parameterization"
    },
    "WetScavenging": {
      "operator_id": "BelowCloudScav",
      "reference": {
        "doi": "10.1029/2001JD001480",
        "citation": "Mari et al., 2000. A kinetic approach to study the redistribution of trace gases in convective clouds",
        "notes": "Below-cloud washout parameterization for soluble species"
      },
      "config": {
        "scavenging_efficiency": 0.8,
        "rain_threshold": 0.1,
        "temperature_dependence": true,
        "temporal_resolution": "PT30M"
      },
      "needed_vars": [
        "precip_rate",
        "cloud_fraction",
        "T",
        "P"
      ],
      "modifies": [
        "H2O2",
        "CH2O",
        "HNO3",
        "SO2",
        "NH3"
      ],
      "description": "Below-cloud washout of soluble species"
    },
    "AdvectionOperator": {
      "operator_id": "MPDATA_3rdOrder",
      "reference": {
        "doi": "10.1006/jcph.1998.6119",
        "citation": "Smolarkiewicz & Szmelter, 1998. A multidimensional positive definite advection transport algorithm",
        "notes": "Third-order MPDATA scheme with FCT limiter"
      },
      "config": {
        "order": 3,
        "flux_corrected_transport": true,
        "boundary_conditions": "periodic",
        "courant_limit": 0.8,
        "temporal_resolution": "PT5M",
        "spatial_resolution": {
          "lon": 0.1,
          "lat": 0.1,
          "lev": 500.0
        }
      },
      "needed_vars": [
        "u",
        "v",
        "w",
        "air_density"
      ],
      "modifies": [
        "O3",
        "NO",
        "NO2",
        "CO",
        "CH4",
        "SO2"
      ],
      "description": "3D advection transport using MPDATA scheme"
    },
    "DiffusionOperator": {
      "operator_id": "TurbulentMixing",
      "reference": {
        "citation": "Smagorinsky turbulent diffusion with stability correction",
        "notes": "Vertical and horizontal turbulent mixing"
      },
      "config": {
        "horizontal_diffusivity": 1000.0,
        "vertical_diffusivity_min": 1.0,
        "vertical_diffusivity_max": 1000.0,
        "richardson_number_critical": 0.25,
        "stability_correction": true,
        "temporal_resolution": "PT1M"
      },
      "needed_vars": [
        "u",
        "v",
        "T",
        "P",
        "surface_roughness",
        "mixing_height"
      ],
      "modifies": [
        "O3",
        "NO",
        "NO2",
        "CO",
        "u",
        "v",
        "T"
      ],
      "description": "Turbulent mixing in horizontal and vertical directions"
    },
    "PhotolysisRates": {
      "operator_id": "TUV_Photolysis",
      "reference": {
        "doi": "10.1029/98JD02796",
        "citation": "Madronich & Flocke, 1999. The role of solar radiation in atmospheric chemistry",
        "url": "https://www2.acd.ucar.edu/modeling/tropospheric-ultraviolet-and-visible-tuv-radiation-model"
      },
      "config": {
        "wavelength_bins": 150,
        "altitude_layers": 80,
        "ozone_column": 300.0,
        "aerosol_optical_depth": 0.2,
        "surface_albedo": 0.1,
        "temporal_resolution": "PT15M"
      },
      "needed_vars": [
        "solar_zenith_angle",
        "O3_column",
        "cloud_optical_depth",
        "T",
        "P"
      ],
      "modifies": [
        "j_NO2",
        "j_O3",
        "j_HCHO",
        "j_H2O2"
      ],
      "description": "Photolysis rate calculations using TUV radiative transfer model"
    },
    "EmissionProcessor": {
      "operator_id": "EmissionInjection",
      "reference": {
        "citation": "Emission injection with temporal and vertical allocation",
        "notes": "Processes emission inventories and injects into model grid"
      },
      "config": {
        "injection_height": "mixed_layer",
        "temporal_profile": "diurnal",
        "weekday_weekend_scaling": true,
        "holiday_scaling": true,
        "temporal_resolution": "PT1H"
      },
      "needed_vars": [
        "mixing_height",
        "surface_pressure",
        "hour_of_day",
        "day_of_week"
      ],
      "modifies": [
        "NO",
        "CO",
        "SO2",
        "NH3",
        "VOC_emissions"
      ],
      "description": "Emission injection with temporal and vertical allocation"
    }
  },
  "models": {
    "AtmosphericChemistry": {
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 5e-08,
          "description": "Ozone concentration"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-08,
          "description": "NO concentration"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 2e-08,
          "description": "NO2 concentration"
        },
        "T": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Temperature"
        },
        "u": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Eastward wind"
        },
        "v": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Northward wind"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "O3"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              -1e-05,
              "O3"
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "NO"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              1e-06,
              "NO2"
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "operator_apply",
      "operator": "DryDepGrid",
      "description": "Apply dry deposition to chemical species"
    },
    {
      "type": "operator_apply",
      "operator": "WetScavenging",
      "description": "Apply wet scavenging to soluble species"
    },
    {
      "type": "operator_apply",
      "operator": "AdvectionOperator",
      "description": "Apply 3D advection transport"
    },
    {
      "type": "operator_compose",
      "systems": [
        "AtmosphericChemistry",
        "DiffusionOperator"
      ],
      "description": "Compose chemistry with turbulent mixing"
    }
  ],
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "timestep": 60.0,
      "rtol": 1e-06,
      "atol": 1e-08
    }
  },
  "domains": {
    "default": {
      "temporal": {
        "start": "2024-07-01T00:00:00Z",
        "end": "2024-07-01T06:00:00Z"
      },
      "spatial": {
        "lon": {
          "min": -125.0,
          "max": -66.0
        },
        "lat": {
          "min": 20.0,
          "max": 50.0
        },
        "lev": {
          "min": 0,
          "max": 20000
        }
      }
    }
  }
}
