  "coupling": [
    {
      "type": "operator_compose",
      "systems": [
        "FluidDynamics",
        "WaveEquation"
      ]
    },
    {
      "type": "variable_map",
      "from": "WindField.wind_u",
      "to": "FluidDynamics.f_x",
      "transform": "multiplicative"
    },
    {
      "type": "variable_map",
      "from": "WindField.wind_v",
      "to": "FluidDynamics.f_y",
