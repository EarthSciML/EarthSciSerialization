{
  "esm": "0.1.0",
  "metadata": {
    "name": "TestsAndExamplesComprehensive",
    "description": "Worked fixture exercising the full surface area of the inline tests and examples features: model-level tolerance, per-test and per-assertion tolerance overrides, initial_condition and parameter overrides, multi-dimension Cartesian parameter sweeps, and all three plot types (line, scatter, heatmap) including a heatmap over a sweep with a reduced z value.",
    "authors": [
      "ESM Format Contributors"
    ],
    "created": "2026-04-14T00:00:00Z",
    "tags": [
      "tests",
      "examples",
      "parameter-sweep",
      "heatmap",
      "fixture"
    ]
  },
  "models": {
    "LogisticGrowth": {
      "reference": {
        "notes": "Single-variable logistic growth: dN/dt = r*N*(1 - N/K). Closed-form solution N(t) = K / (1 + ((K - N0)/N0) * exp(-r*t))."
      },
      "variables": {
        "N": {
          "type": "state",
          "units": "1",
          "default": 1.0,
          "description": "Population"
        },
        "r": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.5,
          "description": "Intrinsic growth rate"
        },
        "K": {
          "type": "parameter",
          "units": "1",
          "default": 100.0,
          "description": "Carrying capacity"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["N"], "wrt": "t" },
          "rhs": {
            "op": "*",
            "args": [
              "r",
              "N",
              {
                "op": "-",
                "args": [
                  1,
                  { "op": "/", "args": ["N", "K"] }
                ]
              }
            ]
          }
        }
      ],
      "tolerance": {
        "rel": 1e-06
      },
      "tests": [
        {
          "id": "closed_form_trajectory",
          "description": "Compare the numerical solution against the closed-form logistic solution N(t) = K / (1 + ((K - N0)/N0) * exp(-r*t)) with N0=1, r=0.5, K=100 at several points on the sigmoid.",
          "initial_conditions": {
            "N": 1.0
          },
          "parameter_overrides": {
            "r": 0.5,
            "K": 100.0
          },
          "time_span": {
            "start": 0.0,
            "end": 30.0
          },
          "tolerance": {
            "rel": 1e-05
          },
          "assertions": [
            { "variable": "N", "time":  0.0, "expected":  1.0 },
            { "variable": "N", "time":  5.0, "expected": 10.957205155884768 },
            { "variable": "N", "time": 10.0, "expected": 59.985960181303476 },
            { "variable": "N", "time": 15.0, "expected": 94.80871535685075,
              "tolerance": { "abs": 1e-04 } },
            { "variable": "N", "time": 30.0, "expected": 99.99697165873832,
              "tolerance": { "abs": 1e-04, "rel": 1e-08 } }
          ]
        },
        {
          "id": "high_initial_overshoot_settles",
          "description": "Starting above carrying capacity (N0 = 150 with K = 100), the population should decay monotonically to K. We only pin the final value — tolerance is taken from the model-level default.",
          "initial_conditions": {
            "N": 150.0
          },
          "parameter_overrides": {
            "r": 0.5,
            "K": 100.0
          },
          "time_span": {
            "start": 0.0,
            "end": 30.0
          },
          "assertions": [
            { "variable": "N", "time":  0.0, "expected": 150.0 },
            { "variable": "N", "time": 30.0, "expected": 100.0,
              "tolerance": { "abs": 1e-03 } }
          ]
        }
      ],
      "examples": [
        {
          "id": "single_run",
          "description": "A single default run illustrating the classic sigmoid approach to carrying capacity.",
          "initial_state": {
            "type": "constant",
            "value": 1.0
          },
          "parameters": {
            "r": 0.5,
            "K": 100.0
          },
          "time_span": {
            "start": 0.0,
            "end": 30.0
          },
          "plots": [
            {
              "id": "population_vs_time",
              "type": "line",
              "description": "Population size versus time, showing sigmoidal growth.",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "N", "label": "population" }
            },
            {
              "id": "population_scatter",
              "type": "scatter",
              "description": "Same trajectory as a scatter plot, useful when the data is sparse.",
              "x": { "variable": "t" },
              "y": { "variable": "N" }
            }
          ]
        },
        {
          "id": "rK_heatmap_sweep",
          "description": "A 2-D Cartesian sweep over r and K, plotting the final population on a heatmap and illustrating both scale types (linear in r, logarithmic in K). Because N(final) -> K for any r>0 when the run is long enough, this sweep mostly visualizes the convergence-to-carrying-capacity surface.",
          "initial_state": {
            "type": "constant",
            "value": 1.0
          },
          "time_span": {
            "start": 0.0,
            "end": 50.0
          },
          "parameter_sweep": {
            "type": "cartesian",
            "dimensions": [
              {
                "parameter": "r",
                "range": { "start": 0.1, "stop": 1.0, "count": 10, "scale": "linear" }
              },
              {
                "parameter": "K",
                "range": { "start": 10.0, "stop": 1000.0, "count": 5, "scale": "log" }
              }
            ]
          },
          "plots": [
            {
              "id": "final_N_heatmap",
              "type": "heatmap",
              "description": "Final population as a function of r (x) and K (y). Uses reduce=final so the value is independent of the exact time grid.",
              "x": { "variable": "r", "label": "growth rate r (1/s)" },
              "y": { "variable": "K", "label": "carrying capacity K" },
              "value": { "variable": "N", "reduce": "final" }
            },
            {
              "id": "max_N_heatmap",
              "type": "heatmap",
              "description": "Same sweep, but coloring by the maximum N observed during the run. Equivalent to the final run for monotone trajectories, but distinguishes overshoot for oscillatory models.",
              "x": { "variable": "r" },
              "y": { "variable": "K" },
              "value": { "variable": "N", "reduce": "max" }
            },
            {
              "id": "N_at_fixed_time_heatmap",
              "type": "heatmap",
              "description": "Population at t=10 across the sweep, using at_time instead of reduce.",
              "x": { "variable": "r" },
              "y": { "variable": "K" },
              "value": { "variable": "N", "at_time": 10.0 }
            }
          ]
        },
        {
          "id": "enumerated_r_sweep",
          "description": "A 1-D sweep over an enumerated set of r values, illustrating the values form of sweep dimensions (as opposed to generated ranges).",
          "initial_state": {
            "type": "per_variable",
            "values": {
              "N": 1.0
            }
          },
          "parameters": {
            "K": 100.0
          },
          "time_span": {
            "start": 0.0,
            "end": 30.0
          },
          "parameter_sweep": {
            "type": "cartesian",
            "dimensions": [
              {
                "parameter": "r",
                "values": [0.1, 0.25, 0.5, 0.75, 1.0, 1.5, 2.0]
              }
            ]
          },
          "plots": [
            {
              "id": "trajectories_overlay",
              "type": "line",
              "description": "Population trajectories for each r in the sweep, overlaid on one axis.",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "N", "label": "population" }
            }
          ]
        }
      ]
    }
  },
  "reaction_systems": {
    "SimpleDecay": {
      "reference": {
        "notes": "A -> B reaction system used to demonstrate that tests/examples have identical shape on ReactionSystem as on Model."
      },
      "species": {
        "A": { "units": "mol/L", "default": 1.0 },
        "B": { "units": "mol/L", "default": 0.0 }
      },
      "parameters": {
        "k": { "units": "1/s", "default": 0.1, "description": "First-order rate constant" }
      },
      "reactions": [
        {
          "id": "R1",
          "name": "A_to_B",
          "substrates": [ { "species": "A", "stoichiometry": 1 } ],
          "products":   [ { "species": "B", "stoichiometry": 1 } ],
          "rate": "k"
        }
      ],
      "tolerance": {
        "rel": 1e-06
      },
      "tests": [
        {
          "id": "exponential_decay",
          "description": "A decays exponentially: A(t) = A0 * exp(-k*t), B(t) = A0 - A(t).",
          "initial_conditions": {
            "A": 1.0,
            "B": 0.0
          },
          "parameter_overrides": {
            "k": 0.1
          },
          "time_span": {
            "start": 0.0,
            "end": 50.0
          },
          "assertions": [
            { "variable": "A", "time":  0.0, "expected": 1.0 },
            { "variable": "A", "time": 10.0, "expected": 0.36787944117144233 },
            { "variable": "A", "time": 50.0, "expected": 0.006737946999085467,
              "tolerance": { "abs": 1e-08 } },
            { "variable": "B", "time": 50.0, "expected": 0.9932620530009145,
              "tolerance": { "abs": 1e-08 } }
          ]
        }
      ],
      "examples": [
        {
          "id": "decay_trace",
          "description": "Plot A and B vs time for a single default run.",
          "initial_state": {
            "type": "per_variable",
            "values": { "A": 1.0, "B": 0.0 }
          },
          "parameters": { "k": 0.1 },
          "time_span": { "start": 0.0, "end": 50.0 },
          "plots": [
            {
              "id": "ab_vs_time",
              "type": "line",
              "x": { "variable": "t", "label": "time (s)" },
              "y": { "variable": "A", "label": "concentration (mol/L)" },
              "series": [
                { "name": "A", "variable": "A" },
                { "name": "B", "variable": "B" }
              ]
            }
          ]
        }
      ]
    }
  }
}
