{
  "esm": "0.1.0",
  "metadata": {
    "name": "BoundaryInitialConditions",
    "description": "Comprehensive test of boundary condition types (Dirichlet, Neumann, Robin, periodic) and initial condition specifications",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-17T00:00:00Z",
    "tags": ["boundary-conditions", "initial-conditions", "domain-setup"],
    "references": [
      {
        "citation": "Boundary and initial condition test fixture for numerical PDE solvers",
        "notes": "Tests all boundary condition types supported in ESM schema and various initial condition patterns"
      }
    ]
  },

  "models": {
    "AdvectionDiffusionSystem": {
      "reference": { "notes": "Multi-species system testing different boundary conditions" },
      "variables": {
        "concentration_A": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species A with Dirichlet boundaries"
        },
        "concentration_B": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species B with Neumann boundaries"
        },
        "concentration_C": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species C with Robin boundaries"
        },
        "concentration_D": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species D with periodic boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        },
        "advection_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 2.0,
          "description": "Advection velocity"
        },
        "robin_alpha": {
          "type": "parameter",
          "units": "1/m",
          "default": 0.1,
          "description": "Robin BC coefficient α"
        },
        "robin_beta": {
          "type": "parameter",
          "units": "m^2/s/m",
          "default": 50.0,
          "description": "Robin BC coefficient β"
        },
        "robin_gamma": {
          "type": "parameter",
          "units": "mol/m^3/s/m",
          "default": 1.0,
          "description": "Robin BC RHS γ"
        }
      },
      "equations": [
        {
          "_comment": "Advection-diffusion for species A (Dirichlet BCs)",
          "lhs": {"op": "D", "args": ["concentration_A"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["advection_velocity"]},
                  {"op": "grad", "args": ["concentration_A"], "dim": "x"}
                ]
              },
              {
                "op": "*",
                "args": ["diffusivity", {"op": "laplacian", "args": ["concentration_A"]}]
              }
            ]
          }
        },
        {
          "_comment": "Advection-diffusion for species B (Neumann BCs)",
          "lhs": {"op": "D", "args": ["concentration_B"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["advection_velocity"]},
                  {"op": "grad", "args": ["concentration_B"], "dim": "x"}
                ]
              },
              {
                "op": "*",
                "args": ["diffusivity", {"op": "laplacian", "args": ["concentration_B"]}]
              }
            ]
          }
        },
        {
          "_comment": "Advection-diffusion for species C (Robin BCs)",
          "lhs": {"op": "D", "args": ["concentration_C"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["advection_velocity"]},
                  {"op": "grad", "args": ["concentration_C"], "dim": "x"}
                ]
              },
              {
                "op": "*",
                "args": ["diffusivity", {"op": "laplacian", "args": ["concentration_C"]}]
              }
            ]
          }
        },
        {
          "_comment": "Advection-diffusion for species D (periodic BCs)",
          "lhs": {"op": "D", "args": ["concentration_D"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["advection_velocity"]},
                  {"op": "grad", "args": ["concentration_D"], "dim": "x"}
                ]
              },
              {
                "op": "*",
                "args": ["diffusivity", {"op": "laplacian", "args": ["concentration_D"]}]
              }
            ]
          }
        }
      ]
    }
  },

  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T06:00:00Z",
      "_comment": "6-hour simulation for boundary condition testing"
    },
    "spatial": {
      "x": {
        "min": 0.0,
        "max": 10000.0,
        "units": "meters",
        "grid_spacing": 100.0,
        "_comment": "10 km domain with 100 m resolution (101 points)"
      },
      "y": {
        "min": 0.0,
        "max": 5000.0,
        "units": "meters",
        "grid_spacing": 100.0,
        "_comment": "5 km domain with 100 m resolution (51 points)"
      }
    },
    "initial_conditions": {
      "type": "per_variable",
      "values": {
        "concentration_A": 0.0,
        "concentration_B": 0.0,
        "concentration_C": 0.0,
        "concentration_D": 0.0
      },
      "_spatial_patterns": {
        "concentration_A": {
          "type": "gaussian",
          "center": [5000.0, 2500.0],
          "sigma": [1000.0, 500.0],
          "amplitude": 10.0,
          "_comment": "Gaussian plume centered in domain"
        },
        "concentration_B": {
          "type": "linear",
          "gradient": [0.001, 0.0],
          "intercept": 0.0,
          "_comment": "Linear increase from west to east"
        },
        "concentration_C": {
          "type": "sinusoidal",
          "wavelength": [2000.0, 1000.0],
          "amplitude": 5.0,
          "phase": [0.0, 1.5708],
          "_comment": "Sinusoidal pattern with 2 km x-wavelength, 1 km y-wavelength"
        },
        "concentration_D": {
          "type": "step",
          "transition": 5000.0,
          "value_left": 2.0,
          "value_right": 8.0,
          "transition_width": 200.0,
          "_comment": "Step function at x=5km with smooth transition"
        }
      }
    },
    "boundary_conditions": [
      {
        "_comment": "Dirichlet (constant value) boundary conditions for species A",
        "type": "constant",
        "dimensions": ["x", "y"],
        "applies_to": ["concentration_A"],
        "boundaries": {
          "x_min": 5.0,
          "x_max": 1.0,
          "y_min": 2.0,
          "y_max": 0.5
        },
        "description": "Fixed concentrations: west=5, east=1, south=2, north=0.5"
      },
      {
        "_comment": "Neumann (zero gradient) boundary conditions for species B",
        "type": "zero_gradient",
        "dimensions": ["x", "y"],
        "applies_to": ["concentration_B"],
        "description": "∂C/∂n = 0 at all boundaries"
      },
      {
        "_comment": "Robin boundary conditions for species C: αu + β∂u/∂n = γ",
        "type": "robin",
        "dimensions": ["x", "y"],
        "applies_to": ["concentration_C"],
        "robin_alpha": 0.1,
        "robin_beta": 50.0,
        "robin_gamma": 1.0,
        "description": "Mixed BC: 0.1*C + 50.0*∂C/∂n = 1.0"
      },
      {
        "_comment": "Periodic boundary conditions for species D",
        "type": "periodic",
        "dimensions": ["x"],
        "applies_to": ["concentration_D"],
        "description": "C(x=0) = C(x=10000) with continuous derivatives"
      },
      {
        "_comment": "Zero gradient in y-direction for periodic species",
        "type": "zero_gradient",
        "dimensions": ["y"],
        "applies_to": ["concentration_D"],
        "description": "∂C/∂y = 0 at y boundaries for periodic species"
      },
      {
        "_comment": "Mixed boundary types for demonstration",
        "type": "mixed",
        "applies_to": ["concentration_A"],
        "conditions": [
          {
            "boundary": "west",
            "type": "dirichlet",
            "value": 10.0,
            "description": "High concentration source at western boundary"
          },
          {
            "boundary": "east",
            "type": "neumann",
            "flux": 0.0,
            "description": "No flux through eastern boundary"
          },
          {
            "boundary": "south",
            "type": "robin",
            "alpha": 0.05,
            "beta": 25.0,
            "gamma": 0.5,
            "description": "Mixed BC at southern boundary"
          },
          {
            "boundary": "north",
            "type": "dirichlet",
            "value": 0.0,
            "description": "Zero concentration at northern boundary"
          }
        ]
      }
    ],
    "element_type": "Float64",
    "array_type": "Array"
  },

  "solver": {
    "strategy": "imex",
    "config": {
      "stiff_algorithm": "QNDF",
      "nonstiff_algorithm": "Vern7",
      "timestep": 10.0,
      "stiff_kwargs": {
        "abstol": 1e-9,
        "reltol": 1e-6
      },
      "nonstiff_kwargs": {
        "abstol": 1e-8,
        "reltol": 1e-5
      },
      "_comment": "IMEX solver for stiff diffusion and non-stiff advection"
    }
  },

  "_test_expectations": {
    "boundary_condition_implementation": {
      "dirichlet_species": "concentration_A",
      "neumann_species": "concentration_B",
      "robin_species": "concentration_C",
      "periodic_species": "concentration_D"
    },
    "initial_condition_patterns": {
      "gaussian_peak_location": [5000.0, 2500.0],
      "linear_gradient_direction": "west_to_east",
      "sinusoidal_wavelengths": [2000.0, 1000.0],
      "step_transition_location": 5000.0
    },
    "boundary_values": {
      "dirichlet_west": 5.0,
      "dirichlet_east": 1.0,
      "dirichlet_south": 2.0,
      "dirichlet_north": 0.5,
      "robin_coefficients": [0.1, 50.0, 1.0],
      "neumann_flux": 0.0
    },
    "solver_configuration": {
      "expected_strategy": "imex",
      "stiff_component": "diffusion",
      "nonstiff_component": "advection",
      "expected_timestep": 10.0
    },
    "conservation_properties": {
      "periodic_mass_conservation": true,
      "neumann_boundary_flux": 0.0,
      "dirichlet_boundary_fixed": true,
      "robin_boundary_mixed": true
    }
  }
}