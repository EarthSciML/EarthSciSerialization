{
  "esm": "0.1.0",
  "metadata": {
    "name": "BoundaryInitialConditions",
    "description": "Comprehensive test of boundary condition types (Dirichlet, Neumann, Robin, periodic) and initial condition specifications",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "boundary-conditions",
      "initial-conditions",
      "domain-setup"
    ],
    "references": [
      {
        "citation": "Boundary and initial condition test fixture for numerical PDE solvers",
        "notes": "Tests all boundary condition types supported in ESM schema and various initial condition patterns"
      }
    ]
  },
  "models": {
    "AdvectionDiffusionSystem": {
      "reference": {
        "notes": "Multi-species system testing different boundary conditions"
      },
      "variables": {
        "concentration_A": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species A with Dirichlet boundaries"
        },
        "concentration_B": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species B with Neumann boundaries"
        },
        "concentration_C": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species C with Robin boundaries"
        },
        "concentration_D": {
          "type": "state",
          "units": "mol/m^3",
          "default": 0.0,
          "description": "Species D with periodic boundaries"
        },
        "diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 50.0,
          "description": "Molecular diffusivity"
        },
        "advection_velocity": {
          "type": "parameter",
          "units": "m/s",
          "default": 2.0,
          "description": "Advection velocity"
        },
        "robin_alpha": {
          "type": "parameter",
          "units": "1/m",
          "default": 0.1,
          "description": "Robin BC coefficient \u03b1"
        },
        "robin_beta": {
          "type": "parameter",
          "units": "m^2/s/m",
          "default": 50.0,
          "description": "Robin BC coefficient \u03b2"
        },
        "robin_gamma": {
          "type": "parameter",
          "units": "mol/m^3/s/m",
          "default": 1.0,
          "description": "Robin BC RHS \u03b3"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration_A"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "advection_velocity"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "concentration_A"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "concentration_A"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration_B"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "advection_velocity"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "concentration_B"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "concentration_B"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration_C"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "advection_velocity"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "concentration_C"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "concentration_C"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "concentration_D"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "advection_velocity"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "concentration_D"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "concentration_D"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T06:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 10000.0,
          "units": "meters",
          "grid_spacing": 100.0
        },
        "y": {
          "min": 0.0,
          "max": 5000.0,
          "units": "meters",
          "grid_spacing": 100.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "concentration_A": 0.0,
          "concentration_B": 0.0,
          "concentration_C": 0.0,
          "concentration_D": 0.0
        }
      },
      "boundary_conditions": [
        {
          "type": "constant",
          "dimensions": [
            "x",
            "y"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "x",
            "y"
          ]
        },
        {
          "type": "robin",
          "dimensions": [
            "x",
            "y"
          ],
          "robin_alpha": 0.1,
          "robin_beta": 50.0,
          "robin_gamma": 1.0
        },
        {
          "type": "periodic",
          "dimensions": [
            "x"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "y"
          ]
        },
        {
          "type": "robin",
          "dimensions": [
            "x"
          ]
        }
      ],
      "element_type": "Float64",
      "array_type": "Array"
    }
  }
}
