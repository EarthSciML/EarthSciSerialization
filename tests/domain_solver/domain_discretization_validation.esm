{
  "esm": "0.1.0",
  "metadata": {
    "name": "DomainDiscretizationValidation",
    "description": "Validation test for proper domain discretization ensuring consistent grid setup, boundary condition application, and simulation-ready configuration",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "domain-discretization",
      "grid-validation",
      "simulation-setup"
    ],
    "references": [
      {
        "citation": "Domain discretization validation test fixture for simulation-capable libraries",
        "notes": "Ensures proper interpretation of domain specifications for numerical simulation setup"
      }
    ]
  },
  "models": {
    "ValidationSystem": {
      "reference": {
        "notes": "Multi-physics system for domain discretization validation"
      },
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 288.15,
          "description": "Air temperature for heat transfer validation"
        },
        "pressure": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Air pressure for compressible flow validation"
        },
        "velocity_u": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Eastward velocity component"
        },
        "velocity_v": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Northward velocity component"
        },
        "scalar_tracer": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Passive scalar for transport validation"
        },
        "thermal_diffusivity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 2e-05,
          "description": "Thermal diffusivity of air"
        },
        "kinematic_viscosity": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 1.5e-05,
          "description": "Kinematic viscosity of air"
        },
        "coriolis_parameter": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.0001,
          "description": "Coriolis parameter (f = 2\u03a9 sin \u03c6)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "temperature"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "temperature"
                    ],
                    "dim": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "thermal_diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "temperature"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity_u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "velocity_u"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "velocity_u"
                    ],
                    "dim": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "coriolis_parameter",
                  "velocity_v"
                ]
              },
              {
                "op": "*",
                "args": [
                  "kinematic_viscosity",
                  {
                    "op": "laplacian",
                    "args": [
                      "velocity_u"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity_v"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "velocity_v"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "velocity_v"
                    ],
                    "dim": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "coriolis_parameter"
                    ]
                  },
                  "velocity_u"
                ]
              },
              {
                "op": "*",
                "args": [
                  "kinematic_viscosity",
                  {
                    "op": "laplacian",
                    "args": [
                      "velocity_v"
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "scalar_tracer"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_u"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "scalar_tracer"
                    ],
                    "dim": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "velocity_v"
                    ]
                  },
                  {
                    "op": "grad",
                    "args": [
                      "scalar_tracer"
                    ],
                    "dim": "y"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "threads": 4,
      "stiff_algorithm": "QNDF",
      "nonstiff_algorithm": "Vern7",
      "timestep": 60.0,
      "stiff_kwargs": {
        "abstol": 1e-10,
        "reltol": 1e-07,
        "maxiters": 1000
      },
      "nonstiff_kwargs": {
        "abstol": 1e-08,
        "reltol": 1e-05
      },
      "adaptive_timestepping": {
        "enabled": true,
        "min_timestep": 1.0,
        "max_timestep": 300.0,
        "safety_factor": 0.9
      }
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-03-15T00:00:00Z",
        "end": "2024-03-15T12:00:00Z",
        "reference_time": "2024-03-15T00:00:00Z"
      },
      "spatial": {
        "x": {
          "min": -50000.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 2000.0
        },
        "y": {
          "min": -25000.0,
          "max": 25000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "z": {
          "min": 0.0,
          "max": 10000.0,
          "units": "meters",
          "grid_spacing": 200.0
        },
        "lon": {
          "min": -123.5,
          "max": -121.5,
          "units": "degrees",
          "grid_spacing": 0.02
        },
        "lat": {
          "min": 46.0,
          "max": 48.0,
          "units": "degrees",
          "grid_spacing": 0.02
        }
      },
      "coordinate_transforms": [
        {
          "id": "cartesian_grid_alignment",
          "description": "Ensure Cartesian x,y,z grid alignment with physical coordinates",
          "dimensions": [
            "x",
            "y",
            "z"
          ]
        },
        {
          "id": "geographic_projection",
          "description": "Project lon,lat to Cartesian for finite difference methods",
          "dimensions": [
            "lon",
            "lat"
          ]
        },
        {
          "id": "vertical_coordinate_mapping",
          "description": "Map geometric height to model levels if needed",
          "dimensions": [
            "z"
          ]
        }
      ],
      "spatial_ref": "EPSG:4326",
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "temperature": 288.15,
          "pressure": 101325.0,
          "velocity_u": 0.0,
          "velocity_v": 0.0,
          "scalar_tracer": 1e-06
        }
      },
      "boundary_conditions": [
        {
          "type": "constant",
          "dimensions": [
            "x",
            "y"
          ]
        },
        {
          "type": "constant",
          "dimensions": [
            "x",
            "y"
          ],
          "value": 0.0
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "z"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "x",
            "y",
            "z"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "x",
            "y"
          ]
        },
        {
          "type": "periodic",
          "dimensions": [
            "lon"
          ]
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "lat"
          ]
        }
      ],
      "element_type": "Float64",
      "array_type": "Array"
    }
  }
}
