{
  "esm": "0.1.0",
  "metadata": {
    "name": "SolverStrategyConfigurations",
    "description": "Comprehensive test of all solver strategies (strang_threads, strang_serial, imex) with various algorithm combinations and configuration options",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "solver-strategies",
      "time-integration",
      "numerical-methods"
    ],
    "references": [
      {
        "citation": "Solver strategy test fixture for time integration algorithms",
        "notes": "Tests Strang splitting (serial/threaded) and IMEX methods with different ODE solvers and error tolerances"
      }
    ]
  },
  "reaction_systems": {
    "StiffChemistry": {
      "reference": {
        "notes": "Stiff chemical system requiring robust time integration"
      },
      "species": {
        "A": {
          "units": "mol/mol",
          "default": 0.001,
          "description": "Fast-reacting species A"
        },
        "B": {
          "units": "mol/mol",
          "default": 1e-06,
          "description": "Intermediate species B"
        },
        "C": {
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Product species C"
        }
      },
      "parameters": {
        "k1_fast": {
          "units": "1/s",
          "default": 1000.0,
          "description": "Fast reaction rate"
        },
        "k2_medium": {
          "units": "1/s",
          "default": 10.0,
          "description": "Medium reaction rate"
        },
        "k3_slow": {
          "units": "1/s",
          "default": 0.1,
          "description": "Slow reaction rate"
        }
      },
      "reactions": [
        {
          "id": "R1_fast",
          "name": "A_to_B_fast",
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "rate": "k1_fast"
        },
        {
          "id": "R2_medium",
          "name": "B_to_C_medium",
          "substrates": [
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            }
          ],
          "rate": "k2_medium"
        },
        {
          "id": "R3_slow",
          "name": "C_to_A_slow",
          "substrates": [
            {
              "species": "C",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "A",
              "stoichiometry": 1
            }
          ],
          "rate": "k3_slow"
        }
      ]
    }
  },
  "models": {
    "NonStiffTransport": {
      "reference": {
        "notes": "Non-stiff transport processes suitable for explicit methods"
      },
      "variables": {
        "wind_u": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Eastward wind velocity"
        },
        "wind_v": {
          "type": "parameter",
          "units": "m/s",
          "default": 2.0,
          "description": "Northward wind velocity"
        },
        "diffusivity_h": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0,
          "description": "Horizontal diffusivity (non-stiff)"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "u"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "+",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "wind_u"
                        ]
                      },
                      {
                        "op": "grad",
                        "args": [
                          "u"
                        ],
                        "dim": "x"
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "wind_v"
                        ]
                      },
                      {
                        "op": "grad",
                        "args": [
                          "u"
                        ],
                        "dim": "y"
                      }
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity_h",
                  {
                    "op": "laplacian",
                    "args": [
                      "u"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "threads": 6,
      "stiff_algorithm": "QNDF",
      "nonstiff_algorithm": "Vern7",
      "timestep": 1.0,
      "stiff_kwargs": {
        "abstol": 1e-12,
        "reltol": 1e-09,
        "maxiters": 10000,
        "dtmax": 0.1
      },
      "nonstiff_kwargs": {
        "abstol": 1e-08,
        "reltol": 1e-05,
        "dtmax": 1.0
      },
      "map_algorithm": "threads",
      "operator_splitting": {
        "chemistry_timestep": 0.1,
        "transport_timestep": 1.0
      },
      "load_balancing": {
        "enabled": true,
        "chunk_size": 50,
        "dynamic_scheduling": true
      },
      "adaptive_timestepping": {
        "enabled": true,
        "min_timestep": 1e-06,
        "max_timestep": 10.0,
        "safety_factor": 0.8,
        "error_estimator": "embedded"
      },
      "performance_monitoring": {
        "enabled": true,
        "log_frequency": 100,
        "track_metrics": [
          "walltime",
          "iterations",
          "rejections",
          "function_evaluations"
        ]
      }
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T01:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 10000.0,
          "units": "meters",
          "grid_spacing": 500.0
        },
        "y": {
          "min": 0.0,
          "max": 5000.0,
          "units": "meters",
          "grid_spacing": 500.0
        }
      },
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "A": 0.001,
          "B": 1e-06,
          "C": 1e-09
        }
      },
      "boundary_conditions": [
        {
          "type": "periodic",
          "dimensions": [
            "x",
            "y"
          ]
        }
      ],
      "element_type": "Float64"
    }
  }
}
