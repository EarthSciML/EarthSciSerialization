{
  "esm": "0.1.0",
  "metadata": {
    "name": "SpatialGridDefinitions",
    "description": "Test various spatial grid definitions including 1D, 2D, and 3D grids with different coordinate systems and grid spacing",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "spatial-grid",
      "coordinate-systems",
      "grid-discretization"
    ],
    "references": [
      {
        "citation": "Comprehensive spatial grid test fixture for atmospheric and earth system modeling",
        "notes": "Tests Cartesian, geographic, and hybrid coordinate systems with various grid resolutions"
      }
    ]
  },
  "models": {
    "DiffusionModel": {
      "reference": {
        "notes": "Multi-dimensional diffusion for spatial grid testing"
      },
      "variables": {
        "scalar_field": {
          "type": "state",
          "units": "kg/m^3",
          "default": 1.0,
          "description": "Scalar quantity for diffusion testing"
        },
        "diffusivity_x": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0,
          "description": "X-direction diffusivity"
        },
        "diffusivity_y": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 100.0,
          "description": "Y-direction diffusivity"
        },
        "diffusivity_z": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 10.0,
          "description": "Z-direction (vertical) diffusivity"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "scalar_field"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "diffusivity_x",
                  {
                    "op": "D",
                    "args": [
                      {
                        "op": "grad",
                        "args": [
                          "scalar_field"
                        ],
                        "dim": "x"
                      }
                    ],
                    "wrt": "x"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity_y",
                  {
                    "op": "D",
                    "args": [
                      {
                        "op": "grad",
                        "args": [
                          "scalar_field"
                        ],
                        "dim": "y"
                      }
                    ],
                    "wrt": "y"
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  "diffusivity_z",
                  {
                    "op": "D",
                    "args": [
                      {
                        "op": "grad",
                        "args": [
                          "scalar_field"
                        ],
                        "dim": "z"
                      }
                    ],
                    "wrt": "z"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "solver": {
    "strategy": "strang_serial",
    "config": {
      "stiff_algorithm": "Rodas4",
      "timestep": 600.0,
      "stiff_kwargs": {
        "abstol": 1e-08,
        "reltol": 1e-05
      }
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-01-01T00:00:00Z",
        "end": "2024-01-01T12:00:00Z"
      },
      "spatial": {
        "x": {
          "min": 0.0,
          "max": 100000.0,
          "units": "meters",
          "grid_spacing": 1000.0
        },
        "y": {
          "min": -50000.0,
          "max": 50000.0,
          "units": "meters",
          "grid_spacing": 2500.0
        },
        "z": {
          "min": 0.0,
          "max": 5000.0,
          "units": "meters",
          "grid_spacing": 100.0
        },
        "lon": {
          "min": -125.0,
          "max": -115.0,
          "units": "degrees",
          "grid_spacing": 0.1
        },
        "lat": {
          "min": 40.0,
          "max": 50.0,
          "units": "degrees",
          "grid_spacing": 0.1
        },
        "lev": {
          "min": 1000.0,
          "max": 100.0,
          "units": "hPa",
          "grid_spacing": 50.0
        }
      },
      "coordinate_transforms": [
        {
          "id": "cartesian_to_geographic",
          "description": "Transform Cartesian x,y,z to lon,lat,lev",
          "dimensions": [
            "x",
            "y",
            "z"
          ]
        },
        {
          "id": "pressure_to_height",
          "description": "Convert pressure levels to geometric height",
          "dimensions": [
            "lev"
          ]
        },
        {
          "id": "lonlat_to_cartesian_projection",
          "description": "Project lon,lat to Cartesian for numerical methods",
          "dimensions": [
            "lon",
            "lat"
          ]
        }
      ],
      "spatial_ref": "WGS84",
      "initial_conditions": {
        "type": "per_variable",
        "values": {
          "scalar_field": 1.0
        }
      },
      "boundary_conditions": [
        {
          "type": "zero_gradient",
          "dimensions": [
            "x",
            "y",
            "z"
          ]
        },
        {
          "type": "periodic",
          "dimensions": [
            "lon"
          ]
        },
        {
          "type": "constant",
          "dimensions": [
            "lat"
          ],
          "value": 0.5
        },
        {
          "type": "zero_gradient",
          "dimensions": [
            "lev"
          ]
        }
      ],
      "element_type": "Float64",
      "array_type": "Array"
    }
  }
}
