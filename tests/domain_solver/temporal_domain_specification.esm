{
  "esm": "0.1.0",
  "metadata": {
    "name": "TemporalDomainSpecification",
    "description": "Test comprehensive temporal domain specifications with various date-time formats and reference times",
    "authors": [
      "ESM Test Suite"
    ],
    "created": "2026-02-17T00:00:00Z",
    "tags": [
      "temporal-domain",
      "date-time",
      "simulation-time"
    ],
    "references": [
      {
        "citation": "Test fixture for temporal domain specification validation",
        "notes": "Validates proper parsing and interpretation of ISO 8601 timestamps and simulation time ranges"
      }
    ]
  },
  "models": {
    "SimpleTracer": {
      "reference": {
        "notes": "Minimal tracer for temporal domain testing"
      },
      "variables": {
        "tracer_concentration": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-09,
          "description": "Simple atmospheric tracer"
        },
        "decay_constant": {
          "type": "parameter",
          "units": "1/s",
          "default": 1e-05,
          "description": "First-order decay rate"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "tracer_concentration"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "-",
                "args": [
                  "decay_constant"
                ]
              },
              "tracer_concentration"
            ]
          }
        }
      ]
    }
  },
  "solver": {
    "strategy": "strang_serial",
    "config": {
      "stiff_algorithm": "Rosenbrock23",
      "timestep": 300.0,
      "stiff_kwargs": {
        "abstol": 1e-09,
        "reltol": 1e-06
      }
    }
  },
  "domains": {
    "default": {
      "independent_variable": "t",
      "temporal": {
        "start": "2024-06-15T12:00:00Z",
        "end": "2024-06-18T18:30:00Z",
        "reference_time": "2024-06-15T00:00:00Z"
      },
      "initial_conditions": {
        "type": "constant",
        "value": 1e-09
      },
      "element_type": "Float64",
      "array_type": "Array"
    }
  }
}
