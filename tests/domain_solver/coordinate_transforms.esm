{
  "esm": "0.1.0",
  "metadata": {
    "name": "CoordinateTransforms",
    "description": "Test various coordinate transformation specifications for projecting between different spatial coordinate systems",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-17T00:00:00Z",
    "tags": ["coordinate-transforms", "projections", "spatial-mapping"],
    "references": [
      {
        "citation": "Coordinate transformation test fixture for earth system modeling",
        "notes": "Tests geographic-to-cartesian, pressure-to-height, and custom coordinate mappings"
      }
    ]
  },

  "models": {
    "GlobalTransport": {
      "reference": { "notes": "Global atmospheric transport requiring multiple coordinate transforms" },
      "variables": {
        "co2_mixing_ratio": {
          "type": "state",
          "units": "ppm",
          "default": 420.0,
          "description": "Carbon dioxide mixing ratio"
        },
        "ch4_mixing_ratio": {
          "type": "state",
          "units": "ppb",
          "default": 1900.0,
          "description": "Methane mixing ratio"
        },
        "zonal_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 10.0,
          "description": "Eastward wind component"
        },
        "meridional_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 0.0,
          "description": "Northward wind component"
        },
        "vertical_wind": {
          "type": "parameter",
          "units": "Pa/s",
          "default": 0.0,
          "description": "Vertical velocity in pressure coordinates"
        }
      },
      "equations": [
        {
          "_comment": "CO2 transport in spherical coordinates",
          "lhs": {"op": "D", "args": ["co2_mixing_ratio"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["zonal_wind"]},
                  {"op": "grad", "args": ["co2_mixing_ratio"], "dim": "lon"}
                ]
              },
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["meridional_wind"]},
                  {"op": "grad", "args": ["co2_mixing_ratio"], "dim": "lat"}
                ]
              },
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["vertical_wind"]},
                  {"op": "grad", "args": ["co2_mixing_ratio"], "dim": "lev"}
                ]
              }
            ]
          }
        },
        {
          "_comment": "CH4 transport with same dynamics",
          "lhs": {"op": "D", "args": ["ch4_mixing_ratio"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["zonal_wind"]},
                  {"op": "grad", "args": ["ch4_mixing_ratio"], "dim": "lon"}
                ]
              },
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["meridional_wind"]},
                  {"op": "grad", "args": ["ch4_mixing_ratio"], "dim": "lat"}
                ]
              },
              {
                "op": "*",
                "args": [
                  {"op": "-", "args": ["vertical_wind"]},
                  {"op": "grad", "args": ["ch4_mixing_ratio"], "dim": "lev"}
                ]
              }
            ]
          }
        }
      ]
    }
  },

  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-08T00:00:00Z",
      "_comment": "One week simulation for global transport"
    },
    "spatial": {
      "lon": {
        "min": -180.0,
        "max": 180.0,
        "units": "degrees",
        "grid_spacing": 2.5,
        "_comment": "Global longitude with 2.5° resolution (144 points)"
      },
      "lat": {
        "min": -90.0,
        "max": 90.0,
        "units": "degrees",
        "grid_spacing": 2.0,
        "_comment": "Global latitude with 2° resolution (90 points)"
      },
      "lev": {
        "min": 1000.0,
        "max": 10.0,
        "units": "hPa",
        "grid_spacing": 50.0,
        "_comment": "Pressure levels from surface to stratosphere (20 levels)"
      },
      "x_proj": {
        "min": -20037508.34,
        "max": 20037508.34,
        "units": "meters",
        "grid_spacing": 250000.0,
        "_comment": "Web Mercator projection x-coordinate (160 points)"
      },
      "y_proj": {
        "min": -15496570.74,
        "max": 18764656.23,
        "units": "meters",
        "grid_spacing": 250000.0,
        "_comment": "Web Mercator projection y-coordinate (137 points)"
      },
      "z_height": {
        "min": 0.0,
        "max": 30000.0,
        "units": "meters",
        "grid_spacing": 1000.0,
        "_comment": "Geometric height levels (31 points)"
      }
    },
    "coordinate_transforms": [
      {
        "id": "lonlat_to_mercator",
        "description": "Web Mercator projection from geographic to projected coordinates",
        "dimensions": ["lon", "lat"],
        "_transform_type": "projection",
        "_proj_string": "+proj=merc +a=6378137 +b=6378137 +lat_ts=0.0 +lon_0=0.0 +x_0=0.0 +y_0=0 +k=1.0 +units=m +nadgrids=@null +wktext +no_defs"
      },
      {
        "id": "pressure_to_height_standard",
        "description": "Standard atmosphere pressure-to-height conversion",
        "dimensions": ["lev"],
        "_transform_type": "vertical",
        "_formula": "z = -H * ln(p/p0) where H=7400m, p0=1013.25hPa"
      },
      {
        "id": "mercator_to_lonlat",
        "description": "Inverse Web Mercator projection",
        "dimensions": ["x_proj", "y_proj"],
        "_transform_type": "inverse_projection",
        "_inverse_of": "lonlat_to_mercator"
      },
      {
        "id": "height_to_pressure_standard",
        "description": "Standard atmosphere height-to-pressure conversion",
        "dimensions": ["z_height"],
        "_transform_type": "vertical",
        "_formula": "p = p0 * exp(-z/H) where H=7400m, p0=1013.25hPa",
        "_inverse_of": "pressure_to_height_standard"
      },
      {
        "id": "spherical_to_cartesian",
        "description": "Spherical Earth to 3D Cartesian coordinates",
        "dimensions": ["lon", "lat", "z_height"],
        "_transform_type": "3d_mapping",
        "_earth_radius": 6371000.0
      },
      {
        "id": "cartesian_to_spherical",
        "description": "3D Cartesian to spherical Earth coordinates",
        "dimensions": ["x_cart", "y_cart", "z_cart"],
        "_transform_type": "3d_mapping",
        "_inverse_of": "spherical_to_cartesian"
      }
    ],
    "spatial_ref": "EPSG:4326",
    "initial_conditions": {
      "type": "per_variable",
      "values": {
        "co2_mixing_ratio": 420.0,
        "ch4_mixing_ratio": 1900.0
      },
      "_comment": "Spatially uniform initial conditions"
    },
    "boundary_conditions": [
      {
        "type": "periodic",
        "dimensions": ["lon"],
        "_comment": "Periodic in longitude for global domain"
      },
      {
        "type": "zero_gradient",
        "dimensions": ["lat"],
        "_comment": "No flux through poles"
      },
      {
        "type": "constant",
        "dimensions": ["lev"],
        "value": 0.0,
        "_comment": "Fixed concentrations at pressure boundaries"
      },
      {
        "type": "periodic",
        "dimensions": ["x_proj"],
        "_comment": "Periodic in projected x (equivalent to lon periodicity)"
      },
      {
        "type": "zero_gradient",
        "dimensions": ["y_proj"],
        "_comment": "No flux in projected y boundaries"
      },
      {
        "type": "zero_gradient",
        "dimensions": ["z_height"],
        "_comment": "No flux through geometric height boundaries"
      }
    ],
    "element_type": "Float32",
    "array_type": "Array"
  },

  "solver": {
    "strategy": "strang_threads",
    "config": {
      "threads": 4,
      "stiff_algorithm": "QNDF",
      "timestep": 3600.0,
      "stiff_kwargs": {
        "abstol": 1e-6,
        "reltol": 1e-4
      },
      "_comment": "1-hour timesteps suitable for global transport"
    }
  },

  "_test_expectations": {
    "coordinate_system_mapping": {
      "geographic_to_mercator": {
        "lon_0_maps_to_x": 0.0,
        "lat_0_maps_to_y": 0.0,
        "lon_180_maps_to_x": 20037508.34,
        "lat_85_maps_to_y_approx": 19929239.11
      },
      "pressure_to_height": {
        "p_1000hPa_maps_to_z": 0.0,
        "p_500hPa_maps_to_z_approx": 5574.0,
        "p_100hPa_maps_to_z_approx": 16093.0,
        "p_10hPa_maps_to_z_approx": 31055.0
      }
    },
    "grid_compatibility": {
      "consistent_lon_x_proj": true,
      "consistent_lat_y_proj": true,
      "consistent_lev_z_height": true,
      "boundary_condition_alignment": true
    },
    "transform_chains": [
      "lon,lat -> x_proj,y_proj -> lon,lat (roundtrip)",
      "lev -> z_height -> lev (roundtrip)",
      "lon,lat,z_height -> x_cart,y_cart,z_cart -> lon,lat,z_height (roundtrip)"
    ],
    "numerical_accuracy": {
      "projection_roundtrip_tolerance": 1e-10,
      "vertical_roundtrip_tolerance": 1e-8,
      "spherical_roundtrip_tolerance": 1e-12
    }
  }
}